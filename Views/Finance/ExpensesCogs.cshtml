@{
    ViewData["Title"] = "COGS Expense";
    Layout = "_AdminLayout";
}

<div class="space-y-8">
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
        <div>
            <div class="flex flex-wrap items-center gap-2 mb-2">
                <span id="fo-name" class="px-3 py-1 bg-emerald-100 text-emerald-700 font-black text-[10px] uppercase tracking-widest rounded-full">Finance Officer: Loading...</span>
                <span id="branch-name" class="px-3 py-1 bg-blue-100 text-blue-700 font-black text-[10px] uppercase tracking-widest rounded-full">Branch: Loading...</span>
                <span id="month-label" class="px-3 py-1 bg-slate-100 text-slate-700 font-black text-[10px] uppercase tracking-widest rounded-full">Month: --</span>
            </div>
            <h2 class="text-3xl font-black text-slate-900 tracking-tight">Expense Entry: COGS</h2>
            <p class="text-xs text-slate-400 font-bold uppercase tracking-widest mt-1">Capture imported cost and convert to PHP automatically</p>
        </div>
        <div class="flex items-center gap-3">
            <a href="/finance/dashboard" class="px-4 py-2 bg-slate-100 text-slate-700 text-xs font-bold rounded-xl hover:bg-slate-200 transition-all">Back to Dashboard</a>
            <a href="/finance/expenses/rent" class="px-4 py-2 bg-slate-900 text-white text-xs font-bold rounded-xl hover:bg-slate-800 transition-all">Next: Rent</a>
        </div>
    </div>

    <div id="locked-banner" class="hidden p-4 rounded-2xl border border-amber-200 bg-amber-50 text-amber-800">
        <p class="text-sm font-bold">This month is already submitted and locked.</p>
        <p class="text-xs mt-1">Go to <a href="/finance/edit-submission" class="underline font-black">Edit Submitted Data</a> if editing is allowed.</p>
    </div>

    <div class="grid grid-cols-1 xl:grid-cols-12 gap-8">
        <div class="xl:col-span-8">
            <div class="bg-white rounded-[2.5rem] shadow-sm border border-slate-100 overflow-hidden">
                <div class="p-8 border-b border-slate-100 flex items-center justify-between bg-slate-50/50">
                    <div>
                        <h3 class="text-xl font-black text-slate-900">Procurement Settlement Log</h3>
                        <p class="text-xs text-slate-500 mt-1">Record and convert multiple supplier invoices</p>
                    </div>
                    <button onclick="addRow()" type="button" class="px-4 py-2 bg-blue-600 text-white text-[10px] font-black uppercase tracking-widest rounded-xl hover:bg-blue-700 transition-all flex items-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                        Add Supplier
                    </button>
                </div>

                <div class="overflow-x-auto">
                    <table class="w-full">
                        <thead class="bg-slate-50">
                            <tr>
                                <th class="px-6 py-4 text-left text-[10px] font-black text-slate-500 uppercase tracking-widest">Supplier / Invoice</th>
                                <th class="px-6 py-4 text-left text-[10px] font-black text-slate-500 uppercase tracking-widest w-32">Original</th>
                                <th class="px-6 py-4 text-left text-[10px] font-black text-slate-500 uppercase tracking-widest w-32">Currency</th>
                                <th class="px-6 py-4 text-right text-[10px] font-black text-slate-500 uppercase tracking-widest">Converted (PHP)</th>
                                <th class="px-6 py-4 text-center text-[10px] font-black text-slate-500 uppercase tracking-widest w-20"></th>
                            </tr>
                        </thead>
                        <tbody id="cogs-rows" class="divide-y divide-slate-100">
                            <!-- Rows injected by JS -->
                        </tbody>
                        <tfoot>
                            <tr class="bg-slate-900">
                                <td colspan="3" class="px-6 py-4 text-right text-[10px] font-black text-white uppercase tracking-widest">Total Monthly COGS</td>
                                <td id="total-cogs-display" class="px-6 py-4 text-right text-sm font-black text-white">₱0.00</td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>

                <div class="p-8 bg-slate-50/50 border-t border-slate-100">
                    <button id="save-btn" onclick="saveProcurementLog()" class="w-full py-4 bg-blue-600 text-white font-black rounded-[1.5rem] hover:bg-blue-700 transition-all shadow-lg shadow-blue-100">
                        Commit Procurement Log to Cloud
                    </button>
                </div>
            </div>
        </div>

        <div class="xl:col-span-4 space-y-6">
            <div class="bg-white rounded-3xl shadow-sm border border-slate-100 p-6">
                <h3 class="text-base font-black text-slate-900">EDSS Insight</h3>
                <p class="text-xs text-slate-500 mt-1">Real-time procurement analysis</p>
                <div class="mt-6 space-y-4">
                    <div class="p-4 bg-blue-50 rounded-2xl border border-blue-100">
                        <p class="text-[10px] font-black text-blue-700 uppercase tracking-widest mb-1">Exchange Rate Engine</p>
                        <p class="text-xs text-blue-800 font-medium leading-relaxed">System automatically pulls live rates for non-PHP entries to simulate international supplier settlement.</p>
                    </div>
                    <div id="fx-warning" class="hidden p-4 bg-amber-50 rounded-2xl border border-amber-100">
                        <p class="text-[10px] font-black text-amber-700 uppercase tracking-widest mb-1">Currency Risk Alert</p>
                        <p class="text-xs text-amber-800 font-medium leading-relaxed">High percentage of USD procurement detected. Business is exposed to PHP devaluation risk.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="toast" class="fixed bottom-6 right-6 z-50 transform translate-y-20 opacity-0 transition-all duration-300">
    <div class="bg-emerald-600 text-white px-6 py-4 rounded-xl shadow-lg flex items-center gap-3">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
        <span id="toast-text" class="font-bold text-sm">Saved.</span>
    </div>
</div>

@section Scripts {
    <script src="~/js/finance-flow.js" asp-append-version="true"></script>
    <script>
        let monthKey = null;
        let cogsRows = [];

        document.addEventListener('DOMContentLoaded', async function () {
            const flow = window.CoretexFinanceFlow;
            monthKey = flow.getCurrentMonthKey();
            const context = flow.getContext();

            document.getElementById('fo-name').textContent = `Finance Officer: ${context.financeOfficer.name}`;
            document.getElementById('branch-name').textContent = `Branch: ${context.branch.name}`;
            document.getElementById('month-label').textContent = `Month: ${flow.formatMonthLabel(monthKey)}`;

            const locked = flow.isMonthLocked(monthKey, context.branch.id);
            if (locked) {
                document.getElementById('save-btn').disabled = true;
                document.getElementById('save-btn').classList.add('opacity-60', 'cursor-not-allowed');
            }

            await loadSavedData();
            if (cogsRows.length === 0) addRow();
        });

        function addRow(data = null) {
            const rowId = Date.now() + Math.random();
            const row = {
                id: rowId,
                description: data?.description || '',
                amount: data?.amount || 0,
                currency: data?.currency || 'PHP',
                rate: data?.rate || 1,
                converted: data?.converted || 0
            };
            cogsRows.push(row);
            renderRows();
        }

        function removeRow(id) {
            cogsRows = cogsRows.filter(r => r.id !== id);
            renderRows();
            calculateTotal();
        }

        function updateRow(id, field, value) {
            const row = cogsRows.find(r => r.id === id);
            if (row) {
                row[field] = value;
                if (field === 'amount' || field === 'currency') {
                    if (row.currency === 'PHP') {
                        row.rate = 1;
                        row.converted = Number(row.amount);
                    } else {
                        refreshRowConversion(id);
                    }
                }
                calculateTotal();
            }
        }

        async function refreshRowConversion(id) {
            const flow = window.CoretexFinanceFlow;
            const row = cogsRows.find(r => r.id === id);
            if (!row || row.currency === 'PHP') return;

            const btn = document.getElementById(`btn-rate-${id}`);
            if (btn) btn.classList.add('animate-spin');

            try {
                const result = await flow.fetchExchangeRate(row.currency);
                row.rate = result.rate;
                row.converted = Number(row.amount) * result.rate;
                renderRows();
                calculateTotal();
            } finally {
                if (btn) btn.classList.remove('animate-spin');
            }
        }

        function renderRows() {
            const flow = window.CoretexFinanceFlow;
            const tbody = document.getElementById('cogs-rows');
            tbody.innerHTML = cogsRows.map(row => `
                <tr class="group hover:bg-slate-50 transition-all">
                    <td class="px-6 py-4">
                        <input type="text" value="${row.description}" onchange="updateRow(${row.id}, 'description', this.value)" 
                            placeholder="Supplier / Invoice #" class="w-full bg-transparent border-b border-transparent focus:border-blue-300 outline-none text-sm font-bold text-slate-800" />
                    </td>
                    <td class="px-6 py-4">
                        <input type="number" step="0.01" value="${row.amount || ''}" oninput="updateRow(${row.id}, 'amount', this.value)" 
                            class="w-full bg-slate-50 border border-slate-100 rounded-lg px-2 py-1 text-sm font-black text-slate-900 focus:border-blue-400 outline-none" />
                    </td>
                    <td class="px-6 py-4">
                        <div class="flex items-center gap-2">
                            <select onchange="updateRow(${row.id}, 'currency', this.value)" class="bg-white border border-slate-200 rounded-lg text-[10px] font-black px-2 py-1 outline-none">
                                <option value="PHP" ${row.currency === 'PHP' ? 'selected' : ''}>PHP</option>
                                <option value="USD" ${row.currency === 'USD' ? 'selected' : ''}>USD</option>
                                <option value="CNY" ${row.currency === 'CNY' ? 'selected' : ''}>CNY</option>
                                <option value="EUR" ${row.currency === 'EUR' ? 'selected' : ''}>EUR</option>
                            </select>
                            ${row.currency !== 'PHP' ? `
                                <button id="btn-rate-${row.id}" onclick="refreshRowConversion(${row.id})" class="text-blue-500 hover:text-blue-700 transition-colors">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                                </button>
                            ` : ''}
                        </div>
                        ${row.currency !== 'PHP' ? `<p class="text-[9px] text-slate-400 font-bold mt-1">Rate: ${row.rate.toFixed(4)}</p>` : ''}
                    </td>
                    <td class="px-6 py-4 text-right">
                        <span class="text-sm font-black text-slate-900">${flow.formatCurrency(row.converted)}</span>
                    </td>
                    <td class="px-6 py-4 text-center">
                        <button onclick="removeRow(${row.id})" class="text-slate-300 hover:text-rose-500 transition-colors opacity-0 group-hover:opacity-100">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                        </button>
                    </td>
                </tr>
            `).join('');
        }

        function calculateTotal() {
            const flow = window.CoretexFinanceFlow;
            const total = cogsRows.reduce((sum, r) => sum + r.converted, 0);
            document.getElementById('total-cogs-display').textContent = flow.formatCurrency(total);
            
            const usdTotal = cogsRows.filter(r => r.currency === 'USD').reduce((sum, r) => sum + r.converted, 0);
            const warning = document.getElementById('fx-warning');
            if (usdTotal > (total * 0.5) && total > 0) {
                warning.classList.remove('hidden');
            } else {
                warning.classList.add('hidden');
            }
        }

        async function loadSavedData() {
            const flow = window.CoretexFinanceFlow;
            const context = flow.getContext();
            const record = flow.getExpenseRecord(monthKey, 'cogs', context.branch.id);
            
            if (record && record.details) {
                cogsRows = record.details.map(d => ({
                    id: Date.now() + Math.random(),
                    description: d.description,
                    amount: d.originalAmount,
                    currency: d.currency,
                    rate: d.exchangeRate,
                    converted: d.amountPHP
                }));
                renderRows();
                calculateTotal();
            }
        }

        async function saveProcurementLog() {
            const flow = window.CoretexFinanceFlow;
            const total = cogsRows.reduce((sum, r) => sum + r.converted, 0);

            if (total <= 0) {
                alert('Please add at least one supplier invoice with an amount.');
                return;
            }

            const btn = document.getElementById('save-btn');
            btn.disabled = true;
            btn.textContent = 'Syncing...';

            try {
                const details = cogsRows.map(r => ({
                    description: r.description,
                    originalAmount: Number(r.amount),
                    currency: r.currency,
                    exchangeRate: r.rate,
                    amountPHP: r.converted
                }));

                await flow.saveExpense('cogs', {
                    amountPHP: total,
                    details: details,
                    description: `Total of ${cogsRows.length} procurement settlements.`,
                    notes: `Currencies used: ${[...new Set(cogsRows.map(r => r.currency))].join(', ')}`
                }, { monthKey });

                showToast('Procurement log synced successfully.');
            } catch (error) {
                alert(error.message || 'Unable to sync procurement log.');
            } finally {
                btn.disabled = false;
                btn.textContent = 'Commit Procurement Log to Cloud';
            }
        }

        function showToast(message) {
            const toast = document.getElementById('toast');
            document.getElementById('toast-text').textContent = message;
            toast.classList.remove('translate-y-20', 'opacity-0');
            setTimeout(function () {
                toast.classList.add('translate-y-20', 'opacity-0');
            }, 2600);
        }
    </script>
}
