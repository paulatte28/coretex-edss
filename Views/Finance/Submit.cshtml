@{
    ViewData["Title"] = "Confirm and Submit";
    Layout = "_AdminLayout";
}

<div class="space-y-8">
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
        <div>
            <div class="flex flex-wrap items-center gap-2 mb-2">
                <span id="fo-name" class="px-3 py-1 bg-emerald-100 text-emerald-700 font-black text-[10px] uppercase tracking-widest rounded-full">Finance Officer: Loading...</span>
                <span id="branch-name" class="px-3 py-1 bg-blue-100 text-blue-700 font-black text-[10px] uppercase tracking-widest rounded-full">Branch: Loading...</span>
                <span id="month-label" class="px-3 py-1 bg-slate-100 text-slate-700 font-black text-[10px] uppercase tracking-widest rounded-full">Month: --</span>
            </div>
            <h2 class="text-3xl font-black text-slate-900 tracking-tight">Confirm and Submit</h2>
            <p class="text-xs text-slate-400 font-bold uppercase tracking-widest mt-1">Final validation before EDSS processing</p>
        </div>
        <div class="flex items-center gap-3">
            <a href="/finance/review" class="px-4 py-2 bg-slate-100 text-slate-700 text-xs font-bold rounded-xl hover:bg-slate-200 transition-all">Back to Review</a>
            <a href="/finance/submissions" class="px-4 py-2 bg-slate-900 text-white text-xs font-bold rounded-xl hover:bg-slate-800 transition-all">Submission History</a>
        </div>
    </div>

    <div id="already-submitted" class="hidden p-4 rounded-2xl border border-blue-200 bg-blue-50 text-blue-800">
        <p class="text-sm font-bold">This month has already been submitted.</p>
        <p id="submitted-meta" class="text-xs mt-1">Submitted on -</p>
    </div>

    <div class="bg-white rounded-3xl shadow-sm border border-slate-100 overflow-hidden">
        <div class="p-6 border-b border-slate-100">
            <h3 class="text-lg font-black text-slate-900">Pre-Submission Review Table</h3>
            <p class="text-xs text-slate-500 mt-1">Verify totals before locking monthly data</p>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead class="bg-slate-50">
                    <tr>
                        <th class="px-6 py-4 text-left text-[10px] font-black text-slate-500 uppercase tracking-widest">Metric</th>
                        <th class="px-6 py-4 text-right text-[10px] font-black text-slate-500 uppercase tracking-widest">Value</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    <tr>
                        <td class="px-6 py-4 text-sm font-semibold text-slate-900">Total POS Transactions</td>
                        <td id="row-total-tx" class="px-6 py-4 text-sm font-black text-slate-900 text-right">0</td>
                    </tr>
                    <tr>
                        <td class="px-6 py-4 text-sm font-semibold text-slate-900">Total Revenue</td>
                        <td id="row-total-revenue" class="px-6 py-4 text-sm font-black text-slate-900 text-right">P0.00</td>
                    </tr>
                    <tr>
                        <td class="px-6 py-4 text-sm font-semibold text-slate-900">COGS</td>
                        <td id="row-cogs" class="px-6 py-4 text-sm font-black text-slate-900 text-right">P0.00</td>
                    </tr>
                    <tr>
                        <td class="px-6 py-4 text-sm font-semibold text-slate-900">Rent</td>
                        <td id="row-rent" class="px-6 py-4 text-sm font-black text-slate-900 text-right">P0.00</td>
                    </tr>
                    <tr>
                        <td class="px-6 py-4 text-sm font-semibold text-slate-900">Salaries</td>
                        <td id="row-salaries" class="px-6 py-4 text-sm font-black text-slate-900 text-right">P0.00</td>
                    </tr>
                    <tr>
                        <td class="px-6 py-4 text-sm font-semibold text-slate-900">Utilities</td>
                        <td id="row-utilities" class="px-6 py-4 text-sm font-black text-slate-900 text-right">P0.00</td>
                    </tr>
                    <tr>
                        <td class="px-6 py-4 text-sm font-semibold text-slate-900">Total Expenses</td>
                        <td id="row-total-expenses" class="px-6 py-4 text-sm font-black text-slate-900 text-right">P0.00</td>
                    </tr>
                </tbody>
                <tfoot>
                    <tr class="bg-slate-900">
                        <td class="px-6 py-4 text-right text-xs font-black text-white uppercase tracking-widest">Net Profit</td>
                        <td id="row-net-profit" class="px-6 py-4 text-right text-sm font-black text-white">P0.00</td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>

    <div class="bg-white rounded-3xl shadow-sm border border-slate-100 p-6 space-y-4">
        <h3 class="text-base font-black text-slate-900">Submission Checklist</h3>
        <label class="flex items-start gap-3">
            <input id="check-1" type="checkbox" class="mt-0.5" />
            <span class="text-sm text-slate-700">I confirm all branch sales from POS are complete for this month.</span>
        </label>
        <label class="flex items-start gap-3">
            <input id="check-2" type="checkbox" class="mt-0.5" />
            <span class="text-sm text-slate-700">I confirm all expenses were reviewed and encoded correctly.</span>
        </label>
        <label class="flex items-start gap-3">
            <input id="check-3" type="checkbox" class="mt-0.5" />
            <span class="text-sm text-slate-700">I understand submission locks the month and changes require edit authorization.</span>
        </label>

        <button id="submit-btn" onclick="openConfirmModal()" class="w-full py-3.5 bg-emerald-600 text-white font-black rounded-xl hover:bg-emerald-700 transition-all disabled:opacity-60 disabled:cursor-not-allowed" disabled>
            Submit Monthly Data
        </button>
    </div>

    <div id="success-panel" class="hidden bg-emerald-50 border border-emerald-200 rounded-3xl p-8">
        <p id="success-main" class="text-lg font-black text-emerald-800">Data submitted successfully.</p>
        <p class="text-sm text-emerald-700 mt-2">The CEO dashboard has been updated with the latest analytics.</p>
        <p id="success-extra" class="text-xs text-emerald-700 mt-2"></p>
        <div class="mt-4 flex flex-wrap gap-3">
            <a href="/finance/submissions" class="px-4 py-2 bg-emerald-700 text-white text-xs font-bold rounded-xl hover:bg-emerald-800 transition-all">Go to Submission History</a>
            <a href="/finance/dashboard" class="px-4 py-2 bg-white text-emerald-700 text-xs font-bold rounded-xl border border-emerald-300 hover:bg-emerald-100 transition-all">Back to Dashboard</a>
        </div>
    </div>
</div>

<div id="confirm-modal" class="fixed inset-0 bg-black/50 backdrop-blur-sm z-50 hidden items-center justify-center">
    <div class="bg-white rounded-3xl shadow-2xl w-full max-w-lg mx-4 overflow-hidden">
        <div class="p-6 border-b border-slate-100">
            <h3 class="text-xl font-black text-slate-900">Confirm Submission</h3>
            <p id="confirm-message" class="text-sm text-slate-600 mt-2">Submit data for this month?</p>
        </div>
        <div class="p-6 flex items-center gap-3">
            <button onclick="closeConfirmModal()" class="flex-1 px-6 py-3 bg-slate-100 text-slate-700 font-bold rounded-xl hover:bg-slate-200 transition-colors">Cancel</button>
            <button id="confirm-btn" onclick="confirmSubmission()" class="flex-1 px-6 py-3 bg-emerald-600 text-white font-bold rounded-xl hover:bg-emerald-700 transition-colors">Confirm</button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/finance-flow.js" asp-append-version="true"></script>
    <script>
        let monthKey = null;
        let context = null;

        document.addEventListener('DOMContentLoaded', function () {
            const flow = window.CoretexFinanceFlow;
            monthKey = flow.getCurrentMonthKey();
            context = flow.getContext();

            document.getElementById('fo-name').textContent = `Finance Officer: ${context.financeOfficer.name}`;
            document.getElementById('branch-name').textContent = `Branch: ${context.branch.name}`;
            document.getElementById('month-label').textContent = `Month: ${flow.formatMonthLabel(monthKey)}`;
            document.getElementById('confirm-message').textContent = `Submit data for ${flow.formatMonthLabel(monthKey)}? This will trigger EDSS processing.`;

            renderSnapshot();
            bindChecklist();
            checkExistingSubmission();
        });

        function renderSnapshot() {
            const flow = window.CoretexFinanceFlow;
            const snapshot = flow.getSnapshot(monthKey, context.branch.id);

            document.getElementById('row-total-tx').textContent = String(snapshot.totalTransactions);
            document.getElementById('row-total-revenue').textContent = flow.formatCurrency(snapshot.totalRevenue);
            document.getElementById('row-cogs').textContent = flow.formatCurrency(snapshot.expenses.cogs);
            document.getElementById('row-rent').textContent = flow.formatCurrency(snapshot.expenses.rent);
            document.getElementById('row-salaries').textContent = flow.formatCurrency(snapshot.expenses.salaries);
            document.getElementById('row-utilities').textContent = flow.formatCurrency(snapshot.expenses.utilities);
            document.getElementById('row-total-expenses').textContent = flow.formatCurrency(snapshot.expenses.total);
            document.getElementById('row-net-profit').textContent = flow.formatCurrency(snapshot.netProfit);
        }

        function bindChecklist() {
            ['check-1', 'check-2', 'check-3'].forEach(id => {
                document.getElementById(id).addEventListener('change', updateSubmitState);
            });
        }

        function updateSubmitState() {
            const allChecked = document.getElementById('check-1').checked
                && document.getElementById('check-2').checked
                && document.getElementById('check-3').checked;

            document.getElementById('submit-btn').disabled = !allChecked;
        }

        function checkExistingSubmission() {
            const flow = window.CoretexFinanceFlow;
            const existing = flow.getSubmission(monthKey, context.branch.id);
            if (!existing) return;

            document.getElementById('already-submitted').classList.remove('hidden');
            document.getElementById('submitted-meta').textContent = `Submitted on ${flow.formatDateTime(existing.submittedAt)} | Status: ${existing.status || 'Submitted'}`;
        }

        function openConfirmModal() {
            const modal = document.getElementById('confirm-modal');
            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }

        function closeConfirmModal() {
            const modal = document.getElementById('confirm-modal');
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        }

        async function confirmSubmission() {
            const flow = window.CoretexFinanceFlow;
            const button = document.getElementById('confirm-btn');
            button.disabled = true;

            try {
                const result = await flow.submitMonth(monthKey);

                document.getElementById('success-panel').classList.remove('hidden');
                document.getElementById('success-main').textContent = `✅ Data submitted successfully for ${result.monthLabel}.`;

                let extra = 'Data locked for this month.';
                if (result.breaches && result.breaches.length > 0) {
                    extra = `KPI threshold breach detected. Twilio SMS alert to CEO triggered (simulated).`;
                }
                document.getElementById('success-extra').textContent = extra;

                closeConfirmModal();
                checkExistingSubmission();
            } catch (error) {
                alert(error.message || 'Unable to submit monthly data.');
            } finally {
                button.disabled = false;
            }
        }
    </script>
}
