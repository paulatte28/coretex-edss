@{
    ViewData["Title"] = "Rent Expense";
    Layout = "_AdminLayout";
}

<div class="space-y-8">
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
        <div>
            <div class="flex flex-wrap items-center gap-2 mb-2">
                <span id="fo-name" class="px-3 py-1 bg-emerald-100 text-emerald-700 font-black text-[10px] uppercase tracking-widest rounded-full">Finance Officer: Loading...</span>
                <span id="branch-name" class="px-3 py-1 bg-blue-100 text-blue-700 font-black text-[10px] uppercase tracking-widest rounded-full">Branch: Loading...</span>
                <span id="month-label" class="px-3 py-1 bg-slate-100 text-slate-700 font-black text-[10px] uppercase tracking-widest rounded-full">Month: --</span>
            </div>
            <h2 class="text-3xl font-black text-slate-900 tracking-tight">Expense Entry: Rent</h2>
            <p class="text-xs text-slate-400 font-bold uppercase tracking-widest mt-1">Record branch rental amount for the month</p>
        </div>
        <div class="flex items-center gap-3">
            <a href="/finance/expenses/cogs" class="px-4 py-2 bg-slate-100 text-slate-700 text-xs font-bold rounded-xl hover:bg-slate-200 transition-all">Back: COGS</a>
            <a href="/finance/expenses/salaries" class="px-4 py-2 bg-slate-900 text-white text-xs font-bold rounded-xl hover:bg-slate-800 transition-all">Next: Salaries</a>
        </div>
    </div>

    <div id="locked-banner" class="hidden p-4 rounded-2xl border border-amber-200 bg-amber-50 text-amber-800">
        <p class="text-sm font-bold">This month is already submitted and locked.</p>
        <p class="text-xs mt-1">Go to <a href="/finance/edit-submission" class="underline font-black">Edit Submitted Data</a> if editing is allowed.</p>
    </div>

    <div class="grid grid-cols-1 xl:grid-cols-12 gap-8">
        <div class="xl:col-span-8">
            <div class="bg-white rounded-3xl shadow-sm border border-slate-100 overflow-hidden">
                <div class="p-8 border-b border-slate-100 flex items-center justify-between">
                    <div>
                        <h3 class="text-xl font-black text-slate-900">Lease & Facility Settlement</h3>
                        <p class="text-xs text-slate-500 mt-1">Record monthly branch rental and facility obligations</p>
                    </div>
                    <div class="px-3 py-1 bg-amber-50 text-amber-600 rounded-full border border-amber-100">
                        <span class="text-[9px] font-black uppercase tracking-widest">Fixed Overhead</span>
                    </div>
                </div>

                <form id="rent-form" class="p-8 space-y-8" autocomplete="off">
                    <div class="space-y-3">
                        <label for="rent-amount" class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">Monthly Rental Amount (PHP)</label>
                        <div class="relative">
                            <span class="absolute left-6 top-1/2 -translate-y-1/2 text-2xl font-black text-slate-300">₱</span>
                            <input id="rent-amount" type="number" min="0.01" step="0.01" required class="w-full bg-slate-50 border-2 border-slate-100 rounded-2xl py-5 pl-12 pr-6 text-2xl font-black text-slate-900 focus:border-amber-500 focus:bg-white outline-none transition-all" placeholder="0.00" />
                        </div>
                    </div>

                    <div class="space-y-3">
                        <label for="rent-notes" class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">Lease Remarks & Period</label>
                        <textarea id="rent-notes" rows="3" maxlength="250" class="w-full bg-slate-50 border-2 border-slate-100 rounded-2xl py-4 px-6 text-sm font-bold focus:border-amber-500 focus:bg-white outline-none transition-all resize-none" placeholder="e.g. Month 12 of 24-Month Lease Agreement - SM North Annex"></textarea>
                    </div>

                    <div class="bg-slate-900 rounded-[2rem] p-8 text-white relative overflow-hidden group">
                        <div class="absolute -right-4 -top-4 w-24 h-24 bg-white/5 rounded-full blur-2xl group-hover:bg-white/10 transition-all"></div>
                        <div class="relative flex items-center justify-between">
                            <div>
                                <p class="text-[10px] font-black text-amber-400 uppercase tracking-[0.2em] mb-1">Audit Status</p>
                                <h4 class="text-xs font-bold text-slate-300 italic">"Rent is a Fixed Monthly Operating Expense"</h4>
                            </div>
                            <div class="text-right">
                                <p id="converted-amount" class="text-4xl font-black tracking-tighter text-amber-400">₱0.00</p>
                                <p class="text-[9px] font-black text-slate-500 uppercase tracking-widest mt-1">Recorded to Branch Ledger</p>
                            </div>
                        </div>
                    </div>

                    <button id="save-btn" type="submit" class="w-full py-5 bg-amber-600 text-white font-black rounded-2xl hover:bg-amber-700 shadow-xl shadow-amber-600/20 transition-all flex items-center justify-center space-x-3 group">
                        <svg class="w-5 h-5 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4" /></svg>
                        <span class="uppercase tracking-widest text-xs">Commit Lease Record</span>
                    </button>
                </form>
            </div>
        </div>

        <div class="xl:col-span-4">
            <div class="bg-white rounded-3xl shadow-sm border border-slate-100 overflow-hidden">
                <div class="p-6 border-b border-slate-100">
                    <h3 class="text-base font-black text-slate-900">Saved Rent Value</h3>
                    <p class="text-xs text-slate-500 mt-1">Current month value</p>
                </div>
                <div class="p-6 space-y-4">
                    <div class="p-5 bg-slate-50 rounded-2xl">
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Monthly Rent Amount</p>
                        <p id="saved-converted" class="text-2xl font-black text-slate-900">₱0.00</p>
                    </div>
                    <div class="p-5 bg-slate-50 rounded-2xl">
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Lease Remarks</p>
                        <p id="saved-notes" class="text-xs font-bold text-slate-600 mt-1 leading-relaxed">No notes saved.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="toast" class="fixed bottom-6 right-6 z-50 transform translate-y-20 opacity-0 transition-all duration-300">
    <div class="bg-emerald-600 text-white px-6 py-4 rounded-xl shadow-lg flex items-center gap-3">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
        <span id="toast-text" class="font-bold text-sm">Saved.</span>
    </div>
</div>

@section Scripts {
    <script src="~/js/finance-flow.js" asp-append-version="true"></script>
    <script>
        let monthKey = null;
        let currentRate = 1;

        document.addEventListener('DOMContentLoaded', async function () {
            const flow = window.CoretexFinanceFlow;
            monthKey = flow.getCurrentMonthKey();
            const context = flow.getContext();

            document.getElementById('fo-name').textContent = `Finance Officer: ${context.financeOfficer.name}`;
            document.getElementById('branch-name').textContent = `Branch: ${context.branch.name}`;
            document.getElementById('month-label').textContent = `Month: ${flow.formatMonthLabel(monthKey)}`;

            if (flow.isMonthLocked(monthKey, context.branch.id)) {
                document.getElementById('locked-banner').classList.remove('hidden');
                document.getElementById('save-btn').disabled = true;
                document.getElementById('save-btn').classList.add('opacity-60', 'cursor-not-allowed');
            }

            document.getElementById('rent-amount').addEventListener('input', refreshConversion);
            document.getElementById('rent-form').addEventListener('submit', async (e) => await saveExpense(e));

            await loadSavedData();
            await refreshConversion();
        });

        async function loadSavedData() {
            const flow = window.CoretexFinanceFlow;
            const context = flow.getContext();
            const record = flow.getExpenseRecord(monthKey, 'rent', context.branch.id);
            if (!record) return;

            document.getElementById('rent-amount').value = Number(record.originalAmount || 0).toFixed(2);
            document.getElementById('rent-notes').value = record.notes || '';

            currentRate = 1;
            document.getElementById('saved-converted').textContent = flow.formatCurrency(record.amountPHP || 0);
            document.getElementById('saved-notes').textContent = record.notes || 'No notes saved.';
        }

        async function refreshConversion() {
            const flow = window.CoretexFinanceFlow;
            const amount = Number(document.getElementById('rent-amount').value || 0);

            currentRate = 1;
            document.getElementById('converted-amount').textContent = flow.formatCurrency(amount * currentRate);
        }

        async function saveExpense(event) {
            event.preventDefault();

            const flow = window.CoretexFinanceFlow;
            const amount = Number(document.getElementById('rent-amount').value || 0);
            const currency = 'PHP';
            const notes = document.getElementById('rent-notes').value.trim();

            if (amount <= 0) {
                alert('Amount is required and must be greater than 0.');
                return;
            }

            try {
                const saved = await flow.saveExpense('rent', {
                    amount: amount,
                    originalAmount: amount,
                    currency: currency,
                    exchangeRate: currentRate,
                    amountPHP: amount * currentRate,
                    notes: notes,
                    description: notes
                }, {
                    monthKey
                });

                document.getElementById('saved-converted').textContent = flow.formatCurrency(saved.record.amountPHP);
                document.getElementById('saved-notes').textContent = saved.record.notes || 'No notes saved.';

                showToast('Rent expense saved successfully.');
            } catch (error) {
                alert(error.message || 'Unable to save rent expense.');
            }
        }

        function showToast(message) {
            const toast = document.getElementById('toast');
            document.getElementById('toast-text').textContent = message;
            toast.classList.remove('translate-y-20', 'opacity-0');
            setTimeout(function () {
                toast.classList.add('translate-y-20', 'opacity-0');
            }, 2600);
        }
    </script>
}
