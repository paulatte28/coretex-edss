@{
    ViewData["Title"] = "Finance Dashboard";
    Layout = "_AdminLayout";
}

<div class="space-y-8">
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
        <div>
            <div class="flex flex-wrap items-center gap-2 mb-2">
                <span id="fo-name" class="px-3 py-1 bg-emerald-100 text-emerald-700 font-black text-[10px] uppercase tracking-widest rounded-full">Finance Officer: Loading...</span>
                <span id="branch-name" class="px-3 py-1 bg-blue-100 text-blue-700 font-black text-[10px] uppercase tracking-widest rounded-full">Branch: Loading...</span>
                <span id="month-label" class="px-3 py-1 bg-slate-100 text-slate-700 font-black text-[10px] uppercase tracking-widest rounded-full">Month: --</span>
            </div>
            <h2 class="text-3xl font-black text-slate-900 tracking-tight">Finance Officer Dashboard</h2>
            <p class="text-xs text-slate-400 font-bold uppercase tracking-widest mt-1">Monthly finance operations and submission workflow</p>
        </div>
        <div class="flex items-center gap-3">
            <a href="/finance/review" class="px-4 py-2 bg-slate-100 text-slate-700 text-xs font-bold rounded-xl hover:bg-slate-200 transition-all">Review Data</a>
            <a href="/finance/submissions" class="px-4 py-2 bg-slate-900 text-white text-xs font-bold rounded-xl hover:bg-slate-800 transition-all">View Submission History</a>
        </div>
    </div>

    <!-- EXECUTIVE KPI RIBBON (Static for Demo Stability) -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        <div class="bg-white rounded-3xl p-6 shadow-sm border border-slate-100 flex flex-col justify-between">
            <div>
                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Gross Revenue</p>
                <h3 id="card-total-sales" class="text-2xl font-black text-slate-900">₱0.00</h3>
            </div>
            <p id="card-tx-count" class="text-[10px] text-emerald-500 font-bold mt-4 uppercase">Verified Transactions</p>
        </div>
        <div class="bg-white rounded-3xl p-6 shadow-sm border border-slate-100 flex flex-col justify-between">
            <div>
                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Total Overheads</p>
                <h3 id="card-total-expenses" class="text-2xl font-black text-rose-600">₱0.00</h3>
            </div>
            <p class="text-[10px] text-slate-400 font-bold mt-4 uppercase">Rent, Salaries, Utilities</p>
        </div>
        <div class="bg-white rounded-3xl p-6 shadow-sm border border-slate-100 flex flex-col justify-between">
            <div>
                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Net Operating Profit</p>
                <h3 id="snapshot-net" class="text-2xl font-black text-emerald-600">₱0.00</h3>
            </div>
            <div class="w-full bg-slate-100 h-1 rounded-full mt-4 overflow-hidden">
                <div id="profit-margin-bar" class="bg-emerald-500 h-full transition-all" style="width: 0%"></div>
            </div>
        </div>
        <div class="bg-white rounded-3xl p-6 shadow-sm border border-slate-100 flex flex-col justify-between">
            <div>
                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Submission Health</p>
                <h3 id="card-submission-status" class="text-xl font-black text-slate-900">Checking...</h3>
            </div>
            <p id="card-submission-meta" class="text-[10px] text-amber-600 font-bold mt-4 uppercase">Awaiting Sync</p>
        </div>
    </div>

    <div id="lock-banner" class="hidden p-4 rounded-2xl border border-indigo-100 bg-indigo-50/50 text-indigo-900 backdrop-blur-sm">
        <div class="flex items-center space-x-3">
            <svg class="w-5 h-5 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
            <div>
                <p class="text-xs font-black uppercase tracking-widest">Repository Locked</p>
                <p class="text-[10px] font-medium opacity-70">This month's data has been committed to the Executive Cloud. Edits require Admin authorization.</p>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 xl:grid-cols-12 gap-8">
        <div class="xl:col-span-8 bg-white rounded-3xl shadow-sm border border-slate-100 overflow-hidden">
            <div class="p-8 border-b border-slate-100 flex items-center justify-between">
                <div>
                    <h3 class="text-xl font-black text-slate-900">Monthly Closing Workflow</h3>
                    <p class="text-xs text-slate-500 mt-1">Systematic expense logging and cloud synchronization</p>
                </div>
                <div class="px-4 py-2 bg-slate-50 rounded-xl border border-slate-100">
                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest text-center">Process Status</p>
                    <p id="workflow-status" class="text-xs font-black text-indigo-600 text-center">Active Phase</p>
                </div>
            </div>
            <div class="p-8 space-y-6">
                <!-- STEP 1 & 2: OPERATIONS -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <a href="/finance/expenses/cogs" class="group p-6 rounded-2xl border border-slate-100 bg-slate-50/50 hover:bg-white hover:border-indigo-500 hover:shadow-xl transition-all">
                        <div class="flex items-center justify-between mb-4">
                            <span class="text-[10px] font-black px-2 py-1 bg-indigo-100 text-indigo-600 rounded-lg">STEP 01</span>
                            <div class="w-8 h-8 bg-white rounded-full flex items-center justify-center text-slate-300 group-hover:text-indigo-500 transition-colors">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                            </div>
                        </div>
                        <h4 class="font-black text-slate-900">Inventory COGS</h4>
                        <p class="text-xs text-slate-500 mt-1">Convert international supplier costs to PHP</p>
                    </a>
                    <a href="/finance/expenses/rent" class="group p-6 rounded-2xl border border-slate-100 bg-slate-50/50 hover:bg-white hover:border-indigo-500 hover:shadow-xl transition-all">
                        <div class="flex items-center justify-between mb-4">
                            <span class="text-[10px] font-black px-2 py-1 bg-indigo-100 text-indigo-600 rounded-lg">STEP 02</span>
                            <div class="w-8 h-8 bg-white rounded-full flex items-center justify-center text-slate-300 group-hover:text-indigo-500 transition-colors">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
                            </div>
                        </div>
                        <h4 class="font-black text-slate-900">Branch Rent</h4>
                        <p class="text-xs text-slate-500 mt-1">Log monthly facility and lease obligations</p>
                    </a>
                </div>

                <!-- STEP 3 & 4: OVERHEADS -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <a href="/finance/expenses/salaries" class="group p-6 rounded-2xl border border-slate-100 bg-slate-50/50 hover:bg-white hover:border-indigo-500 hover:shadow-xl transition-all">
                        <div class="flex items-center justify-between mb-4">
                            <span class="text-[10px] font-black px-2 py-1 bg-indigo-100 text-indigo-600 rounded-lg">STEP 03</span>
                            <div class="w-8 h-8 bg-white rounded-full flex items-center justify-center text-slate-300 group-hover:text-indigo-500 transition-colors">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
                            </div>
                        </div>
                        <h4 class="font-black text-slate-900">Personnel Payroll</h4>
                        <p class="text-xs text-slate-500 mt-1">Finalize branch salary and benefit distributions</p>
                    </a>
                    <a href="/finance/expenses/utilities" class="group p-6 rounded-2xl border border-slate-100 bg-slate-50/50 hover:bg-white hover:border-indigo-500 hover:shadow-xl transition-all">
                        <div class="flex items-center justify-between mb-4">
                            <span class="text-[10px] font-black px-2 py-1 bg-indigo-100 text-indigo-600 rounded-lg">STEP 04</span>
                            <div class="w-8 h-8 bg-white rounded-full flex items-center justify-center text-slate-300 group-hover:text-indigo-500 transition-colors">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                            </div>
                        </div>
                        <h4 class="font-black text-slate-900">Utility Payables</h4>
                        <p class="text-xs text-slate-500 mt-1">Electricity, water, and connectivity costs</p>
                    </a>
                </div>

                <!-- STEP 5 & 6: FINALIZATION -->
                <div class="pt-4 flex flex-col md:flex-row gap-4">
                    <a href="/finance/review" class="flex-1 group p-6 rounded-2xl border-2 border-dashed border-slate-200 hover:border-emerald-500 hover:bg-emerald-50/30 transition-all text-center">
                        <span class="text-[10px] font-black text-emerald-600 uppercase tracking-widest">Phase: Validation</span>
                        <h4 class="font-black text-slate-900 mt-1">Review Monthly Audit</h4>
                    </a>
                    <a href="/finance/submit" class="flex-1 group p-6 rounded-2xl bg-slate-900 hover:bg-indigo-600 shadow-xl shadow-slate-900/10 transition-all text-center">
                        <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Phase: Commitment</span>
                        <h4 class="font-black text-white mt-1">Sync to Executive Cloud</h4>
                    </a>
                </div>
            </div>
        </div>

        <div class="xl:col-span-4 space-y-6">
            <div class="bg-white rounded-3xl shadow-sm border border-slate-100 overflow-hidden">
                <div class="p-6 border-b border-slate-100">
                    <h3 class="text-base font-black text-slate-900">Current Month Snapshot</h3>
                </div>
                <div class="p-6 space-y-4">
                    <div class="p-4 bg-slate-50 rounded-xl flex items-center justify-between">
                        <span class="text-xs font-bold text-slate-600">Top Product</span>
                        <span id="snapshot-top-product" class="text-sm font-black text-slate-900">-</span>
                    </div>
                    <div class="p-4 bg-slate-50 rounded-xl flex items-center justify-between">
                        <span class="text-xs font-bold text-slate-600">Top Product Qty</span>
                        <span id="snapshot-top-qty" class="text-sm font-black text-slate-900">0</span>
                    </div>
                    <div class="p-4 bg-slate-50 rounded-xl flex items-center justify-between">
                        <span class="text-xs font-bold text-slate-600">Net Profit</span>
                        <span id="snapshot-net" class="text-sm font-black text-slate-900">P0.00</span>
                    </div>
                </div>
            </div>

            <div class="bg-white rounded-3xl shadow-sm border border-slate-100 p-6">
                <h3 class="text-base font-black text-slate-900">More Actions</h3>
                <div class="mt-4 space-y-2">
                    <a href="/finance/edit-submission" class="block w-full px-4 py-3 bg-slate-100 text-slate-700 text-xs font-bold rounded-xl hover:bg-slate-200 transition-all text-center">Edit Submitted Data</a>
                    <a href="/finance/submissions" class="block w-full px-4 py-3 bg-slate-900 text-white text-xs font-bold rounded-xl hover:bg-slate-800 transition-all text-center">Submission History</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/finance-flow.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', async function () {
            const flow = window.CoretexFinanceFlow;
            const monthKey = flow.getCurrentMonthKey();
            const dashboard = await flow.getDashboardData(monthKey);

            document.getElementById('fo-name').textContent = `Finance Officer: ${dashboard.context.financeOfficer.name}`;
            document.getElementById('branch-name').textContent = `Branch: ${dashboard.context.branch.name}`;
            document.getElementById('month-label').textContent = `Month: ${flow.formatMonthLabel(monthKey)}`;

            document.getElementById('card-total-sales').textContent = flow.formatCurrency(dashboard.snapshot.totalRevenue);
            document.getElementById('card-tx-count').textContent = `${dashboard.snapshot.totalTransactions} transactions`;
            document.getElementById('card-total-expenses').textContent = flow.formatCurrency(dashboard.snapshot.expenses.total);
            document.getElementById('card-submission-status').textContent = dashboard.submissionStatus;

            if (dashboard.submission) {
                document.getElementById('card-submission-meta').textContent = `Status: ${dashboard.submission.status || 'Submitted'}`;
                document.getElementById('lock-banner').classList.remove('hidden');
            }

            document.getElementById('snapshot-top-product').textContent = dashboard.snapshot.topProduct || '-';
            document.getElementById('snapshot-top-qty').textContent = Number(dashboard.snapshot.topProductQty || 0).toString();
            document.getElementById('snapshot-net').textContent = flow.formatCurrency(dashboard.snapshot.netProfit);

            // Update Profit Margin Bar
            const revenue = dashboard.snapshot.totalRevenue || 1;
            const net = dashboard.snapshot.netProfit;
            const margin = Math.max(0, Math.min(100, (net / revenue) * 100));
            document.getElementById('profit-margin-bar').style.width = `${margin}%`;

            if (dashboard.snapshot.netProfit < 0) {
                document.getElementById('profit-margin-bar').classList.replace('bg-emerald-500', 'bg-rose-500');
                document.getElementById('snapshot-net').classList.replace('text-emerald-600', 'text-rose-600');
            }

            // Update Workflow Status
            const expenseCount = Object.values(dashboard.snapshot.expenses).filter(v => typeof v === 'number' && v > 0).length;
            if (dashboard.submission) {
                document.getElementById('workflow-status').textContent = 'SYNCED';
                document.getElementById('workflow-status').classList.replace('text-indigo-600', 'text-emerald-600');
            } else if (expenseCount > 2) {
                document.getElementById('workflow-status').textContent = 'REVIEW READY';
            }
        });
    </script>
}
