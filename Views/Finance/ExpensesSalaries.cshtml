@{
    ViewData["Title"] = "Salaries Expense";
    Layout = "_AdminLayout";
}

<div class="space-y-8">
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
        <div>
            <div class="flex flex-wrap items-center gap-2 mb-2">
                <span id="fo-name" class="px-3 py-1 bg-emerald-100 text-emerald-700 font-black text-[10px] uppercase tracking-widest rounded-full">Finance Officer: Loading...</span>
                <span id="branch-name" class="px-3 py-1 bg-blue-100 text-blue-700 font-black text-[10px] uppercase tracking-widest rounded-full">Branch: Loading...</span>
                <span id="month-label" class="px-3 py-1 bg-slate-100 text-slate-700 font-black text-[10px] uppercase tracking-widest rounded-full">Month: --</span>
            </div>
            <h2 class="text-3xl font-black text-slate-900 tracking-tight">Expense Entry: Salaries</h2>
            <p class="text-xs text-slate-400 font-bold uppercase tracking-widest mt-1">Record payroll and compensation totals for the month</p>
        </div>
        <div class="flex items-center gap-3">
            <a href="/finance/expenses/rent" class="px-4 py-2 bg-slate-100 text-slate-700 text-xs font-bold rounded-xl hover:bg-slate-200 transition-all">Back: Rent</a>
            <a href="/finance/expenses/utilities" class="px-4 py-2 bg-slate-900 text-white text-xs font-bold rounded-xl hover:bg-slate-800 transition-all">Next: Utilities</a>
        </div>
    </div>

    <div id="locked-banner" class="hidden p-4 rounded-2xl border border-amber-200 bg-amber-50 text-amber-800">
        <p class="text-sm font-bold">This month is already submitted and locked.</p>
        <p class="text-xs mt-1">Go to <a href="/finance/edit-submission" class="underline font-black">Edit Submitted Data</a> if editing is allowed.</p>
    </div>

    <div class="grid grid-cols-1 xl:grid-cols-12 gap-8">
        <div class="xl:col-span-8">
            <div class="bg-white rounded-3xl shadow-sm border border-slate-100 overflow-hidden">
                <div class="p-8 border-b border-slate-100 flex items-center justify-between">
                    <div>
                        <h3 class="text-xl font-black text-slate-900">Salaries & Compensation</h3>
                        <p class="text-xs text-slate-500 mt-1">Audit-grade monthly payroll logging</p>
                    </div>
                    <div class="flex items-center space-x-2 px-3 py-1 bg-emerald-50 text-emerald-600 rounded-full border border-emerald-100">
                        <div class="w-2 h-2 bg-emerald-500 rounded-full animate-pulse"></div>
                        <span class="text-[9px] font-black uppercase tracking-widest">Live Currency Link</span>
                    </div>
                </div>

                <form id="salaries-form" class="p-8 space-y-8" autocomplete="off">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                        <div class="space-y-3">
                            <label for="salaries-amount" class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">Payroll Amount</label>
                            <div class="relative">
                                <input id="salaries-amount" type="number" min="0.01" step="0.01" required class="w-full bg-slate-50 border-2 border-slate-100 rounded-2xl py-5 px-6 text-2xl font-black text-slate-900 focus:border-indigo-500 focus:bg-white outline-none transition-all" placeholder="0.00" />
                            </div>
                        </div>
                        <div class="space-y-3">
                            <label for="salaries-currency" class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">Settlement Currency</label>
                            <select id="salaries-currency" class="w-full bg-slate-50 border-2 border-slate-100 rounded-2xl py-5 px-6 text-lg font-black text-slate-900 focus:border-indigo-500 focus:bg-white outline-none transition-all appearance-none">
                                <option value="PHP">🇵🇭 Philippine Peso (PHP)</option>
                                <option value="USD">🇺🇸 US Dollar (USD)</option>
                                <option value="CNY">🇨🇳 Chinese Yuan (CNY)</option>
                                <option value="EUR">🇪🇺 Euro (EUR)</option>
                            </select>
                        </div>
                    </div>

                    <div class="space-y-3">
                        <label for="salaries-notes" class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">Audit Remarks</label>
                        <textarea id="salaries-notes" rows="3" maxlength="250" class="w-full bg-slate-50 border-2 border-slate-100 rounded-2xl py-4 px-6 text-sm font-bold focus:border-indigo-500 focus:bg-white outline-none transition-all resize-none" placeholder="e.g. Total branch salaries for Q3 Month 1..."></textarea>
                    </div>

                    <div class="bg-slate-900 rounded-[2rem] p-8 text-white relative overflow-hidden group">
                        <div class="absolute -right-4 -top-4 w-24 h-24 bg-white/5 rounded-full blur-2xl group-hover:bg-white/10 transition-all"></div>
                        <div class="relative flex flex-col md:flex-row md:items-center justify-between gap-6">
                            <div>
                                <p id="conversion-text" class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] mb-1">Exchange Basis: 1 PHP = P1.00</p>
                                <h4 class="text-xs font-bold text-slate-300">Net Conversion Applied to Repository</h4>
                            </div>
                            <div class="text-right">
                                <p id="converted-amount" class="text-4xl font-black tracking-tighter text-emerald-400">₱0.00</p>
                                <p class="text-[9px] font-black text-slate-500 uppercase tracking-widest mt-1">Converted to Local HQ Currency</p>
                            </div>
                        </div>
                    </div>

                    <button id="save-btn" type="submit" class="w-full py-5 bg-indigo-600 text-white font-black rounded-2xl hover:bg-indigo-700 shadow-xl shadow-indigo-600/20 transition-all flex items-center justify-center space-x-3 group">
                        <svg class="w-5 h-5 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4" /></svg>
                        <span class="uppercase tracking-widest text-xs">Commit Salary Record</span>
                    </button>
                </form>
            </div>
        </div>

        <div class="xl:col-span-4">
            <div class="bg-white rounded-3xl shadow-sm border border-slate-100 overflow-hidden">
                <div class="p-6 border-b border-slate-100">
                    <h3 class="text-base font-black text-slate-900">Saved Salaries Value</h3>
                    <p class="text-xs text-slate-500 mt-1">Current month value</p>
                </div>
                <div class="p-6 space-y-3">
                    <div class="p-4 bg-slate-50 rounded-xl flex items-center justify-between">
                        <span class="text-xs font-bold text-slate-600">Original</span>
                        <span id="saved-original" class="text-sm font-black text-slate-900">-</span>
                    </div>
                    <div class="p-4 bg-slate-50 rounded-xl flex items-center justify-between">
                        <span class="text-xs font-bold text-slate-600">Converted (PHP)</span>
                        <span id="saved-converted" class="text-sm font-black text-slate-900">P0.00</span>
                    </div>
                    <div class="p-4 bg-slate-50 rounded-xl">
                        <p class="text-xs font-bold text-slate-600">Notes</p>
                        <p id="saved-notes" class="text-xs text-slate-800 mt-1">No notes saved.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="toast" class="fixed bottom-6 right-6 z-50 transform translate-y-20 opacity-0 transition-all duration-300">
    <div class="bg-emerald-600 text-white px-6 py-4 rounded-xl shadow-lg flex items-center gap-3">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
        <span id="toast-text" class="font-bold text-sm">Saved.</span>
    </div>
</div>

@section Scripts {
    <script src="~/js/finance-flow.js" asp-append-version="true"></script>
    <script>
        let monthKey = null;
        let currentRate = 1;

        document.addEventListener('DOMContentLoaded', async function () {
            const flow = window.CoretexFinanceFlow;
            monthKey = flow.getCurrentMonthKey();
            const context = flow.getContext();

            document.getElementById('fo-name').textContent = `Finance Officer: ${context.financeOfficer.name}`;
            document.getElementById('branch-name').textContent = `Branch: ${context.branch.name}`;
            document.getElementById('month-label').textContent = `Month: ${flow.formatMonthLabel(monthKey)}`;

            if (flow.isMonthLocked(monthKey, context.branch.id)) {
                document.getElementById('locked-banner').classList.remove('hidden');
                document.getElementById('save-btn').disabled = true;
                document.getElementById('save-btn').classList.add('opacity-60', 'cursor-not-allowed');
            }

            document.getElementById('salaries-currency').addEventListener('change', refreshConversion);
            document.getElementById('salaries-amount').addEventListener('input', refreshConversion);
            document.getElementById('salaries-form').addEventListener('submit', async (e) => await saveExpense(e));

            await loadSavedData();
            await refreshConversion();
        });

        async function loadSavedData() {
            const flow = window.CoretexFinanceFlow;
            const context = flow.getContext();
            const record = flow.getExpenseRecord(monthKey, 'salaries', context.branch.id);
            if (!record) return;

            document.getElementById('salaries-amount').value = Number(record.originalAmount || 0).toFixed(2);
            document.getElementById('salaries-currency').value = record.currency || 'PHP';
            document.getElementById('salaries-notes').value = record.notes || '';

            currentRate = Number(record.exchangeRate || 1);
            document.getElementById('saved-original').textContent = `${record.currency || 'PHP'} ${Number(record.originalAmount || 0).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
            document.getElementById('saved-converted').textContent = flow.formatCurrency(record.amountPHP || 0);
            document.getElementById('saved-notes').textContent = record.notes || 'No notes saved.';
        }

        async function refreshConversion() {
            const flow = window.CoretexFinanceFlow;
            const currency = document.getElementById('salaries-currency').value;
            const amount = Number(document.getElementById('salaries-amount').value || 0);

            const result = await flow.fetchExchangeRate(currency);
            currentRate = Number(result.rate || 1);

            document.getElementById('conversion-text').textContent = `Exchange Basis: 1 ${currency} = ${flow.formatCurrency(currentRate)}`;
            document.getElementById('converted-amount').textContent = flow.formatCurrency(amount * currentRate);
        }

        async function saveExpense(event) {
            event.preventDefault();

            const flow = window.CoretexFinanceFlow;
            const amount = Number(document.getElementById('salaries-amount').value || 0);
            const currency = document.getElementById('salaries-currency').value;
            const notes = document.getElementById('salaries-notes').value.trim();

            if (amount <= 0) {
                alert('Amount is required and must be greater than 0.');
                return;
            }

            try {
                const saved = await flow.saveExpense('salaries', {
                    amount: amount,
                    originalAmount: amount,
                    currency: currency,
                    exchangeRate: currentRate,
                    amountPHP: amount * currentRate,
                    notes: notes,
                    description: notes
                }, {
                    monthKey
                });

                document.getElementById('saved-original').textContent = `${saved.record.currency} ${Number(saved.record.originalAmount).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
                document.getElementById('saved-converted').textContent = flow.formatCurrency(saved.record.amountPHP);
                document.getElementById('saved-notes').textContent = saved.record.notes || 'No notes saved.';

                showToast('Salaries expense saved successfully.');
            } catch (error) {
                alert(error.message || 'Unable to save salaries expense.');
            }
        }

        function showToast(message) {
            const toast = document.getElementById('toast');
            document.getElementById('toast-text').textContent = message;
            toast.classList.remove('translate-y-20', 'opacity-0');
            setTimeout(function () {
                toast.classList.add('translate-y-20', 'opacity-0');
            }, 2600);
        }
    </script>
}
