@{
    ViewData["Title"] = "Coretex | Decision Intelligence for Electronics Manufacturers";
}

<div class="relative overflow-hidden min-h-screen flex items-center justify-center bg-white px-6">
    <!-- Background Accents -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-7xl h-full pointer-events-none">
        <div class="absolute -top-32 -left-32 w-96 h-96 bg-blue-50 rounded-full blur-3xl opacity-50"></div>
        <div class="absolute top-1/2 -right-32 w-96 h-96 bg-slate-50 rounded-full blur-3xl opacity-50"></div>
    </div>

    <div class="relative z-10 max-w-4xl text-center space-y-10">
        <!-- Badge -->
        <div class="inline-flex items-center space-x-2 px-4 py-2 bg-slate-50 rounded-full border border-slate-100 animate-in fade-in slide-in-from-bottom-2 duration-700">
            <span class="relative flex h-2 w-2">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-blue-500"></span>
            </span>
            <span class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-500">Now Powering 2,500+ Manufacturers</span>
        </div>

        <!-- Main Title -->
        <h1 class="text-6xl md:text-8xl font-black text-slate-900 tracking-tighter leading-[0.9] animate-in fade-in slide-in-from-bottom-4 duration-700 delay-100">
            Scale Your <br/>
            <span class="text-blue-600">Decision Intelligence.</span>
        </h1>

        <!-- Subtitle -->
        <p class="max-w-2xl mx-auto text-lg md:text-xl text-slate-500 font-medium leading-relaxed animate-in fade-in slide-in-from-bottom-4 duration-700 delay-200">
            The next-generation EDSS platform built specifically for electronics manufacturers. Unified analytics, AI forecasting, and multi-tenant management—all in one place.
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-col md:flex-row items-center justify-center space-y-4 md:space-y-0 md:space-x-6 animate-in fade-in slide-in-from-bottom-4 duration-700 delay-300">
            <a href="/Home/Onboarding" class="px-10 py-5 bg-slate-900 text-white font-black rounded-2xl hover:bg-slate-800 transition-all shadow-2xl shadow-slate-900/20 flex items-center space-x-3 group">
                <span>Start Free Onboarding</span>
                <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
            </a>
            <a href="/Dashboard" class="px-10 py-5 bg-white text-slate-600 font-bold rounded-2xl border border-slate-200 hover:bg-slate-50 transition-all">
                Access Portal
            </a>
        </div>

        <!-- Social Proof -->
        <div class="pt-16 grid grid-cols-2 md:grid-cols-4 gap-8 opacity-30 animate-in fade-in duration-1000 delay-500">
            <div class="flex items-center justify-center space-x-2 grayscale font-black text-xl italic">NEXUS</div>
            <div class="flex items-center justify-center space-x-2 grayscale font-black text-xl">QUANTUM</div>
            <div class="flex items-center justify-center space-x-2 grayscale font-black text-xl italic">VERTEX</div>
            <div class="flex items-center justify-center space-x-2 grayscale font-black text-xl uppercase tracking-widest">Helix</div>
        </div>
    </div>
</div>

<style>
    @@keyframes fade-in { from { opacity: 0; } to { opacity: 1; } }
    @@keyframes slide-in-from-bottom-2 { from { transform: translateY(0.5rem); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
    @@keyframes slide-in-from-bottom-4 { from { transform: translateY(1rem); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
    
    .animate-in { animation: 0.5s ease-out forwards; }
    .fade-in { animation-name: fade-in; }
    .slide-in-from-bottom-2 { animation-name: slide-in-from-bottom-2; }
    .slide-in-from-bottom-4 { animation-name: slide-in-from-bottom-4; }
    .delay-100 { animation-delay: 0.1s; }
    .delay-200 { animation-delay: 0.2s; }
    .delay-300 { animation-delay: 0.3s; }
    .delay-500 { animation-delay: 0.5s; }
</style>
