@{
    ViewData["Title"] = "CORETEX EDSS | Executive Decision Support System";
}

<div class="relative min-h-[80vh] flex flex-col items-center justify-center px-6 overflow-hidden">
    <!-- Abstract Shapes -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-6xl h-full -z-10 opacity-40">
        <div class="absolute top-0 left-0 w-96 h-96 bg-blue-400/20 blur-[120px] rounded-full animate-pulse"></div>
        <div class="absolute bottom-0 right-0 w-96 h-96 bg-emerald-400/20 blur-[120px] rounded-full animate-pulse" style="animation-delay: 2s"></div>
    </div>

    <div class="max-w-5xl w-full text-center space-y-12 relative z-10">
        <!-- Brand Badge -->
        <div class="inline-flex items-center space-x-3 px-5 py-2 bg-white/50 backdrop-blur-md border border-white/50 rounded-full shadow-sm animate-in fade-in slide-in-from-bottom-2 duration-700">
            <span class="flex h-2 w-2 rounded-full bg-emerald-500 shadow-[0_0_10px_rgba(16,185,129,0.5)]"></span>
            <span class="text-[10px] font-black uppercase tracking-[0.3em] text-slate-500">Coretech Electronics</span>
        </div>

        <!-- Main Headline -->
        <h1 class="text-6xl md:text-9xl font-black text-slate-900 tracking-[-0.05em] leading-[0.85] animate-in fade-in slide-in-from-bottom-6 duration-1000">
            CORETEX <br/>
            <span class="bg-clip-text text-transparent bg-gradient-to-r from-blue-600 via-emerald-500 to-blue-600 bg-[length:200%_auto] animate-text-gradient">EDSS</span>
        </h1>

        <!-- Subtitle -->
        <p class="max-w-2xl mx-auto text-lg md:text-xl text-slate-500 font-semibold leading-relaxed animate-in fade-in slide-in-from-bottom-6 duration-1000 delay-200">
            Executive Decision Support System for Coretech Electronics. Real-time KPIs, predictive analytics, and intelligent reporting across all branches.
        </p>

        <!-- Login CTAs -->
        <div class="flex flex-col sm:flex-row items-center justify-center space-y-4 sm:space-y-0 sm:space-x-8 pt-6 animate-in fade-in slide-in-from-bottom-8 duration-1000 delay-300">
            <a href="/Home/Login" class="group relative px-12 py-6 bg-slate-900 text-white font-black rounded-2xl hover:scale-[1.02] active:scale-95 transition-all shadow-[0_20px_50px_rgba(15,23,42,0.2)] flex items-center space-x-4">
                <svg class="w-5 h-5 relative z-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"/></svg>
                <span class="relative z-10">Sign In</span>
                <div class="absolute inset-0 bg-gradient-to-r from-blue-600 to-emerald-600 opacity-0 group-hover:opacity-100 rounded-2xl transition-opacity duration-500"></div>
            </a>
            
            <a href="/Dashboard" class="px-12 py-6 bg-white/80 backdrop-blur-md text-slate-600 font-black rounded-2xl border border-white hover:bg-white hover:text-slate-900 hover:shadow-xl hover:shadow-slate-200/50 transition-all active:scale-95">
                Executive Dashboard
            </a>
        </div>

        <!-- Role Info -->
        <div class="pt-8 animate-in fade-in duration-1000 delay-500">
            <p class="text-xs text-slate-400 uppercase tracking-widest mb-4">Access for authorized personnel only</p>
            <div class="flex flex-wrap justify-center gap-4">
                <span class="px-4 py-2 bg-blue-50 text-blue-600 rounded-xl text-xs font-bold">System Admin</span>
                <span class="px-4 py-2 bg-emerald-50 text-emerald-600 rounded-xl text-xs font-bold">Business Owner / CEO</span>
                <span class="px-4 py-2 bg-purple-50 text-purple-600 rounded-xl text-xs font-bold">Finance Officers</span>
            </div>
        </div>
    </div>

    <!-- Stats / Features Section -->
    <div class="mt-24 grid grid-cols-2 md:grid-cols-4 gap-x-16 gap-y-8 animate-in fade-in duration-1000 delay-500">
        <div class="text-center">
            <div class="w-12 h-12 mx-auto mb-3 bg-blue-100 rounded-xl flex items-center justify-center">
                <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
            </div>
            <p class="text-sm font-black text-slate-900">KPI Dashboard</p>
            <p class="text-[10px] text-slate-400 uppercase tracking-widest">Real-time Metrics</p>
        </div>
        <div class="text-center">
            <div class="w-12 h-12 mx-auto mb-3 bg-emerald-100 rounded-xl flex items-center justify-center">
                <svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
            </div>
            <p class="text-sm font-black text-slate-900">Trend Analysis</p>
            <p class="text-[10px] text-slate-400 uppercase tracking-widest">Predictive Insights</p>
        </div>
        <div class="text-center">
            <div class="w-12 h-12 mx-auto mb-3 bg-amber-100 rounded-xl flex items-center justify-center">
                <svg class="w-6 h-6 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
            </div>
            <p class="text-sm font-black text-slate-900">Risk Alerts</p>
            <p class="text-[10px] text-slate-400 uppercase tracking-widest">SMS via Twilio</p>
        </div>
        <div class="text-center">
            <div class="w-12 h-12 mx-auto mb-3 bg-purple-100 rounded-xl flex items-center justify-center">
                <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            </div>
            <p class="text-sm font-black text-slate-900">Auto Reports</p>
            <p class="text-[10px] text-slate-400 uppercase tracking-widest">PDF via SendGrid</p>
        </div>
    </div>
</div>

<style>
    @@keyframes text-gradient {
        0% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
        100% { background-position: 0% 50%; }
    }
    .animate-text-gradient {
        animation: text-gradient 6s ease infinite;
    }

    @@keyframes fade-in { from { opacity: 0; } to { opacity: 1; } }
    @@keyframes slide-in-from-bottom-2 { from { transform: translateY(10px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
    @@keyframes slide-in-from-bottom-6 { from { transform: translateY(30px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
    @@keyframes slide-in-from-bottom-8 { from { transform: translateY(40px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }

    .animate-in { animation: 1s ease-out forwards; }
    .fade-in { animation-name: fade-in; }
    .slide-in-from-bottom-2 { animation-name: slide-in-from-bottom-2; }
    .slide-in-from-bottom-6 { animation-name: slide-in-from-bottom-6; }
    .slide-in-from-bottom-8 { animation-name: slide-in-from-bottom-8; }
    .delay-200 { animation-delay: 0.2s; }
    .delay-300 { animation-delay: 0.3s; }
    .delay-500 { animation-delay: 0.5s; }
</style>
