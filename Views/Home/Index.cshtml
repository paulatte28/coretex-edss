@{
    ViewData["Title"] = "CORETEX EDSS | Executive Decision Support System";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .bg-image {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            z-index: -2;
            background-image: url('https://images.unsplash.com/photo-1551434678-e076c223a692?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80');
            background-size: cover;
            background-position: center;
        }
        .bg-overlay {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            z-index: -1;
            background: linear-gradient(135deg, rgba(0,26,77,0.92) 0%, rgba(0,77,71,0.88) 100%);
        }
        .glass-card {
            background: rgba(255,255,255,0.08);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255,255,255,0.15);
        }
        @@keyframes fade-in { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
        @@keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-10px); } }
        .animate-fade-in { animation: fade-in 0.8s ease-out forwards; }
        .animate-float { animation: float 6s ease-in-out infinite; }
        .delay-100 { animation-delay: 0.1s; opacity: 0; }
        .delay-200 { animation-delay: 0.2s; opacity: 0; }
        .delay-300 { animation-delay: 0.3s; opacity: 0; }
        .delay-400 { animation-delay: 0.4s; opacity: 0; }
        .delay-500 { animation-delay: 0.5s; opacity: 0; }
    </style>
</head>
<body class="min-h-screen">
    <div class="bg-image"></div>
    <div class="bg-overlay"></div>

    <!-- Navigation -->
    <nav class="fixed top-0 left-0 right-0 z-50 px-6 py-4">
        <div class="max-w-7xl mx-auto flex items-center justify-between">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-white/10 backdrop-blur-md rounded-xl flex items-center justify-center border border-white/20">
                    <span class="text-white font-black text-lg">C</span>
                </div>
                <span class="text-white font-bold text-lg hidden sm:block">CORETEX</span>
            </div>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <form asp-controller="Home" asp-action="Logout" method="post" class="inline">
                    <button type="submit" class="px-5 py-2.5 bg-white/10 backdrop-blur-md text-white border border-white/20 text-sm font-semibold rounded-lg hover:bg-white/20 transition-all shadow-lg">
                        Sign Out
                    </button>
                </form>
            }
            else
            {
                <a href="/Home/Login" class="px-5 py-2.5 bg-white text-slate-800 text-sm font-semibold rounded-lg hover:bg-white/90 transition-all shadow-lg">
                    Sign In
                </a>
            }
        </div>
    </nav>

    <!-- Hero Section -->
    <div class="min-h-screen flex items-center justify-center px-6 pt-20">
        <div class="max-w-5xl w-full text-center">
            <!-- Badge -->
            <div class="animate-fade-in delay-100">
                <span class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 backdrop-blur-md rounded-full border border-white/20 text-white/80 text-xs font-medium tracking-wide">
                    <span class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse"></span>
                    CORETECH ELECTRONICS
                </span>
            </div>

            <!-- Main Title -->
            <h1 class="mt-8 text-5xl md:text-7xl lg:text-8xl font-black text-white tracking-tight leading-none animate-fade-in delay-200">
                CORETEX
                <span class="block text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 via-teal-300 to-cyan-400">
                    EDSS
                </span>
            </h1>

            <!-- Subtitle -->
            <p class="mt-6 text-lg md:text-xl text-white/70 max-w-2xl mx-auto leading-relaxed animate-fade-in delay-300">
                Executive Decision Support System — Real-time KPIs, predictive analytics, and intelligent reporting across all branches.
            </p>

            <!-- CTA Buttons -->
            <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4 animate-fade-in delay-400">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    var dashboardUrl = "/ceo/dashboard";
                    if (User.IsInRole("ADMIN")) dashboardUrl = "/Admin";
                    else if (User.IsInRole("FINANCE")) dashboardUrl = "/finance/dashboard";
                    else if (User.IsInRole("CASHIER")) dashboardUrl = "/cashier/pos";
                    else if (User.IsInRole("CEO")) dashboardUrl = "/ceo/dashboard";

                    <a href="@dashboardUrl" class="group px-8 py-4 bg-white text-slate-900 font-bold rounded-xl hover:bg-white/90 transition-all shadow-2xl shadow-white/20 flex items-center gap-3">
                        <span>Go to Dashboard</span>
                        <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
                    </a>
                }
                else
                {
                    <a href="/Home/Login" class="group px-8 py-4 bg-white text-slate-900 font-bold rounded-xl hover:bg-white/90 transition-all shadow-2xl shadow-white/20 flex items-center gap-3">
                        <span>Get Started</span>
                        <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
                    </a>
                }
                <a href="#features" class="px-8 py-4 bg-white/10 backdrop-blur-md text-white font-semibold rounded-xl border border-white/20 hover:bg-white/20 transition-all flex items-center gap-3">
                    <span>Learn More</span>
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                </a>
            </div>

            <!-- Role Badges -->
            <div class="mt-12 animate-fade-in delay-500">
                <p class="text-white/40 text-xs uppercase tracking-widest mb-4">Authorized Personnel</p>
                <div class="flex flex-wrap justify-center gap-3">
                    <span class="px-4 py-2 bg-slate-500/20 backdrop-blur-sm text-white/80 rounded-lg text-xs font-medium border border-white/10">System Admin</span>
                    <span class="px-4 py-2 bg-blue-500/20 backdrop-blur-sm text-blue-300 rounded-lg text-xs font-medium border border-blue-400/20">CEO</span>
                    <span class="px-4 py-2 bg-emerald-500/20 backdrop-blur-sm text-emerald-300 rounded-lg text-xs font-medium border border-emerald-400/20">Finance Officer</span>
                    <span class="px-4 py-2 bg-amber-500/20 backdrop-blur-sm text-amber-300 rounded-lg text-xs font-medium border border-amber-400/20">Branch Cashier</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Features Section -->
    <div id="features" class="py-24 px-6">
        <div class="max-w-6xl mx-auto">
            <div class="text-center mb-16">
                <h2 class="text-3xl md:text-4xl font-bold text-white">Powerful Features</h2>
                <p class="mt-4 text-white/60 max-w-xl mx-auto">Everything you need to make data-driven executive decisions</p>
            </div>

            <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
                <!-- Feature 1 -->
                <div class="glass-card rounded-2xl p-6 hover:bg-white/12 transition-all group">
                    <div class="w-14 h-14 bg-gradient-to-br from-blue-500 to-blue-600 rounded-xl flex items-center justify-center mb-5 group-hover:scale-110 transition-transform shadow-lg shadow-blue-500/30">
                        <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
                    </div>
                    <h3 class="text-lg font-bold text-white mb-2">KPI Dashboard</h3>
                    <p class="text-white/50 text-sm leading-relaxed">Real-time metrics and performance indicators across all branches</p>
                </div>

                <!-- Feature 2 -->
                <div class="glass-card rounded-2xl p-6 hover:bg-white/12 transition-all group">
                    <div class="w-14 h-14 bg-gradient-to-br from-emerald-500 to-teal-600 rounded-xl flex items-center justify-center mb-5 group-hover:scale-110 transition-transform shadow-lg shadow-emerald-500/30">
                        <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
                    </div>
                    <h3 class="text-lg font-bold text-white mb-2">Trend Analysis</h3>
                    <p class="text-white/50 text-sm leading-relaxed">Predictive insights and forecasting powered by historical data</p>
                </div>

                <!-- Feature 3 -->
                <div class="glass-card rounded-2xl p-6 hover:bg-white/12 transition-all group">
                    <div class="w-14 h-14 bg-gradient-to-br from-amber-500 to-orange-600 rounded-xl flex items-center justify-center mb-5 group-hover:scale-110 transition-transform shadow-lg shadow-amber-500/30">
                        <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
                    </div>
                    <h3 class="text-lg font-bold text-white mb-2">SMS Alerts</h3>
                    <p class="text-white/50 text-sm leading-relaxed">Instant Twilio notifications when KPIs breach thresholds</p>
                </div>

                <!-- Feature 4 -->
                <div class="glass-card rounded-2xl p-6 hover:bg-white/12 transition-all group">
                    <div class="w-14 h-14 bg-gradient-to-br from-purple-500 to-indigo-600 rounded-xl flex items-center justify-center mb-5 group-hover:scale-110 transition-transform shadow-lg shadow-purple-500/30">
                        <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                    </div>
                    <h3 class="text-lg font-bold text-white mb-2">Auto Reports</h3>
                    <p class="text-white/50 text-sm leading-relaxed">Scheduled PDF reports delivered via SendGrid email</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer class="py-8 px-6 border-t border-white/10">
        <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
            <p class="text-white/40 text-sm">© 2026 Coretex EDSS. Coretech Electronics.</p>
            <p class="text-white/40 text-xs">IT15/L — Integrative Programming and Technologies</p>
        </div>
    </footer>
</body>
</html>
