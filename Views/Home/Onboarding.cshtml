@{
    ViewData["Title"] = "Onboard Your Company";

    Layout = "_Layout";
}

<div class="min-h-screen bg-slate-50 py-12 px-4 sm:px-6 lg:px-8 font-sans">
    <div class="max-w-4xl mx-auto">
        <!-- Progress Bar -->
        <div class="mb-12">
            <div class="flex items-center justify-between mb-4">
                <span class="text-xs font-black uppercase tracking-[0.2em] text-slate-400" id="step-label">Step 1 of 4:
                    Registration</span>
                <span class="text-xs font-black text-blue-600" id="step-percentage">25% Complete</span>
            </div>
            <div class="h-2 w-full bg-slate-200 rounded-full overflow-hidden">
                <div id="progress-bar" class="h-full bg-blue-600 transition-all duration-500 ease-out"
                    style="width: 25%"></div>
            </div>
        </div>

        <!-- Step Containers -->
        <div id="onboarding-steps" class="relative">

            <!-- STEP 1: REGISTRATION -->
            <div id="step-1" class="step-content space-y-8 animate-in fade-in slide-in-from-bottom-4 duration-500">
                <div class="text-center mb-10">
                    <h2 class="text-3xl font-black text-slate-900 tracking-tight">Register Your Company</h2>
                    <p class="text-slate-500 mt-2 font-medium">Let's get your electronics business started on Coretex.
                    </p>
                </div>

                <div class="bg-white rounded-[2.5rem] p-10 shadow-xl shadow-slate-200/50 border border-slate-100">
                    <form id="reg-form" class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="space-y-2">
                            <label class="text-[10px] font-black uppercase tracking-widest text-slate-400 ml-1">Company
                                Name</label>
                            <input type="text" id="companyName" required placeholder="e.g. Nexus Electronics"
                                class="w-full px-5 py-4 bg-slate-50 border-none rounded-2xl focus:ring-2 focus:ring-blue-500/20 font-bold text-slate-700 transition-all">
                        </div>
                        <div class="space-y-2">
                            <label class="text-[10px] font-black uppercase tracking-widest text-slate-400 ml-1">Business
                                Address</label>
                            <input type="text" id="address" required placeholder="123 Innovation Way"
                                class="w-full px-5 py-4 bg-slate-50 border-none rounded-2xl focus:ring-2 focus:ring-blue-500/20 font-bold text-slate-700 transition-all">
                        </div>
                        <div class="space-y-2">
                            <label class="text-[10px] font-black uppercase tracking-widest text-slate-400 ml-1">Contact
                                Number</label>
                            <input type="tel" id="contact" required placeholder="+63 900 000 0000"
                                class="w-full px-5 py-4 bg-slate-50 border-none rounded-2xl focus:ring-2 focus:ring-blue-500/20 font-bold text-slate-700 transition-all">
                        </div>
                        <div class="space-y-2">
                            <label
                                class="text-[10px] font-black uppercase tracking-widest text-slate-400 ml-1">Industry</label>
                            <select id="industry"
                                class="w-full px-5 py-4 bg-slate-50 border-none rounded-2xl focus:ring-2 focus:ring-blue-500/20 font-bold text-slate-700 transition-all">
                                <option>Consumer Electronics</option>
                                <option>Semiconductors</option>
                                <option>Telecommunications</option>
                                <option>Industrial Automation</option>
                            </select>
                        </div>
                        <div class="md:col-span-2 pt-4 border-t border-slate-50 mt-4">
                            <p
                                class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-300 mb-6 text-center">
                                Owner Information</p>
                        </div>
                        <div class="space-y-2">
                            <label class="text-[10px] font-black uppercase tracking-widest text-slate-400 ml-1">Full
                                Name</label>
                            <input type="text" id="ownerName" required placeholder="Full Name"
                                class="w-full px-5 py-4 bg-slate-50 border-none rounded-2xl focus:ring-2 focus:ring-blue-500/20 font-bold text-slate-700 transition-all">
                        </div>
                        <div class="space-y-2">
                            <label class="text-[10px] font-black uppercase tracking-widest text-slate-400 ml-1">Email
                                Address</label>
                            <input type="email" id="ownerEmail" required placeholder="owner@company.com"
                                class="w-full px-5 py-4 bg-slate-50 border-none rounded-2xl focus:ring-2 focus:ring-blue-500/20 font-bold text-slate-700 transition-all">
                        </div>
                    </form>

                    <div class="mt-10">
                        <button onclick="nextStep(2)"
                            class="w-full py-5 bg-blue-600 text-white font-black rounded-[2rem] hover:bg-blue-700 transition-all shadow-xl shadow-blue-600/20 flex items-center justify-center space-x-3 group">
                            <span>Proceed to Plan Selection</span>
                            <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none"
                                stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M14 5l7 7m0 0l-7 7m7-7H3" />
                            </svg>
                        </button>
                    </div>
                </div>
            </div>

            <!-- STEP 2: PLAN SELECTION -->
            <div id="step-2"
                class="step-content hidden space-y-8 animate-in fade-in slide-in-from-right-4 duration-500">
                <div class="text-center mb-10">
                    <h2 class="text-3xl font-black text-slate-900 tracking-tight">Choose Your Solution</h2>
                    <p class="text-slate-500 mt-2 font-medium">Select a tier that matches your operational scale.</p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <!-- Starter Card -->
                    <div class="bg-white rounded-[2rem] p-8 border border-slate-100 shadow-lg flex flex-col hover:border-blue-500/30 transition-all cursor-pointer group"
                        onclick="selectPlan('Starter Analytics', 49)">
                        <span
                            class="text-[9px] font-black uppercase tracking-[0.2em] text-slate-400 bg-slate-50 px-3 py-1 rounded-full w-fit mb-4">Core</span>
                        <h3 class="text-xl font-black text-slate-800">Starter</h3>
                        <div class="my-4">
                            <span class="text-3xl font-black tracking-tighter text-slate-900">$49</span>
                            <span class="text-[10px] text-slate-400 font-bold">/mo</span>
                        </div>
                        <button
                            class="mt-auto w-full py-3 bg-slate-50 text-slate-600 font-bold rounded-xl group-hover:bg-blue-600 group-hover:text-white transition-all">Select
                            Plan</button>
                    </div>

                    <!-- Pro Card -->
                    <div class="bg-slate-900 rounded-[2rem] p-8 shadow-2xl relative overflow-hidden flex flex-col cursor-pointer group"
                        onclick="selectPlan('Predictive Hub', 149)">
                        <div class="absolute top-0 right-0 -mt-4 -mr-4 w-20 h-20 bg-blue-500 opacity-20 blur-2xl"></div>
                        <span
                            class="text-[9px] font-black uppercase tracking-[0.2em] text-blue-300 bg-blue-500/20 px-3 py-1 rounded-full w-fit mb-4">Pro</span>
                        <h3 class="text-xl font-black text-white">Predictive Hub</h3>
                        <div class="my-4">
                            <span class="text-3xl font-black tracking-tighter text-white">$149</span>
                            <span class="text-[10px] text-slate-400 font-bold">/mo</span>
                        </div>
                        <button
                            class="mt-auto w-full py-3 bg-blue-600 text-white font-bold rounded-xl shadow-lg shadow-blue-500/20 transition-all">Select
                            Pro</button>
                    </div>

                    <!-- Enterprise Card -->
                    <div class="bg-white rounded-[2rem] p-8 border border-slate-100 shadow-lg flex flex-col hover:border-blue-500/30 transition-all cursor-pointer group"
                        onclick="selectPlan('Enterprise Grade', 499)">
                        <span
                            class="text-[9px] font-black uppercase tracking-[0.2em] text-slate-400 bg-slate-50 px-3 py-1 rounded-full w-fit mb-4">Suite</span>
                        <h3 class="text-xl font-black text-slate-800">Enterprise</h3>
                        <div class="my-4">
                            <span class="text-3xl font-black tracking-tighter text-slate-900">$499</span>
                            <span class="text-[10px] text-slate-400 font-bold">/mo</span>
                        </div>
                        <button
                            class="mt-auto w-full py-3 bg-slate-50 text-slate-600 font-bold rounded-xl group-hover:bg-blue-600 group-hover:text-white transition-all">Select
                            Plan</button>
                    </div>
                </div>

                <div class="flex justify-center pt-8">
                    <button onclick="nextStep(1)"
                        class="text-xs font-black text-slate-400 uppercase tracking-widest hover:text-slate-600 transition-all flex items-center space-x-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                        </svg>
                        <span>Back to Details</span>
                    </button>
                </div>
            </div>

            <!-- STEP 3: PAYMENT (PAYMONGO MOCK) -->
            <div id="step-3"
                class="step-content hidden space-y-8 animate-in fade-in slide-in-from-right-4 duration-500">
                <div class="text-center mb-10">
                    <h2 class="text-3xl font-black text-slate-900 tracking-tight">Secure Payment</h2>
                    <p class="text-slate-500 mt-2 font-medium">Complete your subscription via PayMongo.</p>
                </div>

                <div
                    class="max-w-md mx-auto bg-white rounded-[2.5rem] border border-slate-100 shadow-2xl overflow-hidden relative">
                    <!-- PayMongo Branding Header -->
                    <div class="bg-blue-600 p-8 text-white flex justify-between items-center">
                        <div class="flex items-center space-x-2">
                            <div class="w-8 h-8 bg-white/20 rounded-lg flex items-center justify-center font-black">P
                            </div>
                            <span class="font-bold tracking-tight">PayMongo Checkout</span>
                        </div>
                        <div id="payment-amount" class="text-xl font-black">$149.00</div>
                    </div>

                    <div class="p-8 space-y-6">
                        <div
                            class="flex items-center space-x-4 p-4 bg-slate-50 rounded-2xl border-2 border-blue-500/10">
                            <div class="w-12 h-12 bg-white rounded-xl shadow-sm flex items-center justify-center">
                                <svg class="w-6 h-6 text-blue-600" fill="currentColor" viewBox="0 0 20 20">
                                    <path d="M4 4a2 2 0 00-2 2v1h16V6a2 2 0 00-2-2H4z"></path>
                                    <path fill-rule="evenodd"
                                        d="M18 9H2v5a2 2 0 002 2h12a2 2 0 002-2V9zM5 12a1 1 0 112 0 1 1 0 01-2 0zm7-1a1 1 0 100 2 1 1 0 000-2z"
                                        clip-rule="evenodd"></path>
                                </svg>
                            </div>
                            <div>
                                <p class="text-xs font-black text-slate-900">Card Payment</p>
                                <p class="text-[10px] text-slate-400 font-bold">Safe & Encrypted</p>
                            </div>
                            <div class="ml-auto w-4 h-4 rounded-full border-4 border-blue-600"></div>
                        </div>

                        <div class="space-y-4">
                            <input type="text" placeholder="Card Number" value="4242 4242 4242 4242"
                                class="w-full px-5 py-4 bg-slate-50 border-none rounded-xl text-sm font-bold text-slate-600 cursor-not-allowed">
                            <div class="grid grid-cols-2 gap-4">
                                <input type="text" placeholder="MM/YY" value="12/26"
                                    class="w-full px-5 py-4 bg-slate-50 border-none rounded-xl text-sm font-bold text-slate-600 cursor-not-allowed">
                                <input type="text" placeholder="CVC" value="•••"
                                    class="w-full px-5 py-4 bg-slate-50 border-none rounded-xl text-sm font-bold text-slate-600 cursor-not-allowed">
                            </div>
                        </div>

                        <button id="pay-btn" onclick="startPayment()"
                            class="w-full py-5 bg-blue-600 text-white font-black rounded-2xl hover:bg-blue-700 transition-all shadow-xl shadow-blue-600/20 active:scale-95">
                            Pay Now
                        </button>

                        <!-- Loading Overlay (Initial Hidden) -->
                        <div id="payment-loading"
                            class="hidden absolute inset-0 bg-white/90 backdrop-blur-sm z-20 flex flex-col items-center justify-center space-y-4">
                            <div
                                class="w-12 h-12 border-4 border-blue-600 border-t-transparent rounded-full animate-spin">
                            </div>
                            <p class="text-xs font-black text-slate-900 animate-pulse">Processing Payment...</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- STEP 4: SUCCESS & PROVISIONING -->
            <div id="step-4" class="step-content hidden space-y-8 animate-in zoom-in-95 duration-700 text-center">
                <div
                    class="bg-white rounded-[3rem] p-12 shadow-2xl border border-slate-100 max-w-2xl mx-auto relative overflow-hidden">
                    <div class="absolute -top-20 -right-20 w-64 h-64 bg-emerald-500/10 blur-[80px] rounded-full"></div>

                    <div
                        class="w-24 h-24 bg-emerald-50 text-emerald-500 rounded-full flex items-center justify-center mx-auto mb-8 shadow-inner">
                        <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                        </svg>
                    </div>

                    <h2 class="text-4xl font-black text-slate-900 tracking-tight">Onboarding Complete!</h2>
                    <p class="text-slate-500 mt-4 font-medium mb-10">Welcome to the Coretex ecosystem. Your isolated
                        company environment has been provisioned.</p>

                    <!-- Provisioning Log Animation -->
                    <div
                        class="bg-slate-900 rounded-3xl p-8 text-left font-mono text-[11px] leading-relaxed relative group">
                        <div class="absolute top-4 right-4 flex space-x-1.5">
                            <div class="w-2.5 h-2.5 bg-red-500/50 rounded-full"></div>
                            <div class="w-2.5 h-2.5 bg-amber-500/50 rounded-full"></div>
                            <div class="w-2.5 h-2.5 bg-emerald-500/50 rounded-full"></div>
                        </div>
                        <div class="space-y-1.5" id="prov-log">
                            <p class="text-emerald-400">> [SUCCESS] Payment confirmed via PayMongo</p>
                            <p class="text-slate-400">> Initializing tenant structure...</p>
                            <p class="text-slate-400">> Mapping geolocation metadata...</p>
                            <p class="text-blue-400">> Origin: <span id="geo-location">Detecting...</span></p>
                            <p class="text-slate-400">> Allocating data shards...</p>
                            <p class="text-emerald-400">> Build complete. Environment active.</p>
                        </div>
                    </div>

                    <div class="mt-12 grid grid-cols-2 gap-4">
                        <a href="/Dashboard"
                            class="py-4 bg-slate-900 text-white font-black rounded-2xl hover:bg-slate-800 transition-all shadow-xl shadow-slate-900/10">Go
                            To Admin Dashboard</a>
                        <button onclick="window.location.reload()"
                            class="py-4 bg-slate-100 text-slate-600 font-bold rounded-2xl hover:bg-slate-200 transition-all">Register
                            Another</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    let onboardingData = {
        companyName: '',
        address: '',
        contact: '',
        industry: '',
        ownerName: '',
        ownerEmail: '',
        plan: '',
        price: 0,
        registrationDate: new Date().toISOString(),
        status: 'Active'
    };

    function nextStep(step) {
        // Validation for step 1
        if (step === 2) {
            const form = document.getElementById('reg-form');
            if (!form.checkValidity()) {
                form.reportValidity();
                return;
            }
            // Capture data
            onboardingData.companyName = document.getElementById('companyName').value;
            onboardingData.address = document.getElementById('address').value;
            onboardingData.contact = document.getElementById('contact').value;
            onboardingData.industry = document.getElementById('industry').value;
            onboardingData.ownerName = document.getElementById('ownerName').value;
            onboardingData.ownerEmail = document.getElementById('ownerEmail').value;
        }

        // Hide all steps
        document.querySelectorAll('.step-content').forEach(el => el.classList.add('hidden'));

        // Show current step
        document.getElementById(`step-${step}`).classList.remove('hidden');

        // Update Progress
        const percent = step * 25;
        document.getElementById('progress-bar').style.width = `${percent}%`;
        document.getElementById('step-percentage').innerText = `${percent}% Complete`;

        const labels = ["Registration", "Plan Selection", "Payment", "Completion"];
        document.getElementById('step-label').innerText = `Step ${step} of 4: ${labels[step - 1]}`;
    }

    function selectPlan(name, price) {
        onboardingData.plan = name;
        onboardingData.price = price;
        document.getElementById('payment-amount').innerText = `$${price}.00`;
        nextStep(3);
    }

    async function startPayment() {
        const overlay = document.getElementById('payment-loading');
        overlay.classList.remove('hidden');

        // Simulate Processing Delay
        setTimeout(async () => {
            // Save to LocalStorage
            saveTenantLocally(onboardingData);

            // Move to success
            nextStep(4);

            // Get GeoLocation
            try {
                const response = await fetch('https://ipapi.co/json/');
                const data = await response.json();
                document.getElementById('geo-location').innerText = `${data.city}, ${data.country_name} (${data.ip})`;
            } catch (e) {
                document.getElementById('geo-location').innerText = 'Manila, Philippines (Logged)';
            }
        }, 2500);
    }

    function saveTenantLocally(data) {
        let tenants = JSON.parse(localStorage.getItem('coretex_tenants') || '[]');
        tenants.unshift(data);
        localStorage.setItem('coretex_tenants', JSON.stringify(tenants));
    }
</script>

<style>
    @@keyframes fade-in {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    @@keyframes slide-in-from-bottom-4 {
        from {
            transform: translateY(1rem);
        }

        to {
            transform: translateY(0);
        }
    }

    @@keyframes slide-in-from-right-4 {
        from {
            transform: translateX(1rem);
        }

        to {
            transform: translateX(0);
        }
    }

    @@keyframes zoom-in-95 {
        from {
            transform: scale(0.95);
            opacity: 0;
        }

        to {
            transform: scale(1);
            opacity: 1;
        }
    }

    .animate-in {
        animation: 0.5s ease-out forwards;
    }

    .fade-in {
        animation-name: fade-in;
    }

    .slide-in-from-bottom-4 {
        animation-name: slide-in-from-bottom-4;
    }

    .slide-in-from-right-4 {
        animation-name: slide-in-from-right-4;
    }

    .zoom-in-95 {
        animation-name: zoom-in-95;
        animation-duration: 0.7s;
    }
</style>
