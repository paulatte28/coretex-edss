@{
    ViewData["Title"] = "Onboard Your Company";
    Layout = "_Layout";
}

<div class="min-h-screen py-12 px-4 sm:px-6 lg:px-8 font-sans transition-all duration-700">
    <div class="max-w-5xl mx-auto">
        <!-- Floating Step Indicator -->
        <div class="mb-16 flex items-center justify-center space-x-4 md:space-x-12 animate-in fade-in duration-1000">
            <div id="ind-1" class="step-indicator active">
                <span class="num shadow-[0_0_15px_rgba(37,99,235,0.4)]">1</span>
                <span class="label">Identity</span>
            </div>
            <div class="h-0.5 w-8 md:w-16 bg-slate-200 rounded-full"></div>
            <div id="ind-2" class="step-indicator">
                <span class="num">2</span>
                <span class="label">Plan</span>
            </div>
            <div class="h-0.5 w-8 md:w-16 bg-slate-200 rounded-full"></div>
            <div id="ind-3" class="step-indicator">
                <span class="num">3</span>
                <span class="label">Checkout</span>
            </div>
            <div class="h-0.5 w-8 md:w-16 bg-slate-200 rounded-full"></div>
            <div id="ind-4" class="step-indicator">
                <span class="num">4</span>
                <span class="label">Build</span>
            </div>
        </div>

        <!-- Main Wizard Container -->
        <div id="wizard-container" class="relative group">
            
            <!-- STEP 1: IDENTITY -->
            <div id="step-1" class="step-content glass-card p-10 md:p-16 space-y-12 animate-in fade-in scale-in duration-500">
                <div class="space-y-3">
                    <h2 class="text-4xl font-black text-slate-900 tracking-[-0.03em]">Business Identity</h2>
                    <p class="text-slate-500 font-semibold italic opacity-60">Step 1 — Tell us about your electronics manufacturing hub.</p>
                </div>
                
                <form id="reg-form" class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-10">
                    <div class="space-y-3 group-input">
                        <label class="input-label">Company Name</label>
                        <input type="text" id="companyName" required placeholder="e.g. Nexus Corp" class="premium-input">
                    </div>
                    <div class="space-y-3 group-input">
                        <label class="input-label">Headquarters Address</label>
                        <input type="text" id="address" required placeholder="Main Office Location" class="premium-input">
                    </div>
                    <div class="space-y-3 group-input">
                        <label class="input-label">Communication Lead</label>
                        <input type="tel" id="contact" required placeholder="+63 900 000 0000" class="premium-input">
                    </div>
                    <div class="space-y-3 group-input">
                        <label class="input-label">Manufacturing Sector</label>
                        <select id="industry" class="premium-input appearance-none">
                            <option>Consumer Electronics</option>
                            <option>Semiconductors</option>
                            <option>Robotics & Automation</option>
                            <option>Automotive Electronics</option>
                        </select>
                    </div>
                    <div class="md:col-span-2 pt-6">
                        <div class="h-px bg-slate-200/50 w-full mb-10"></div>
                        <h4 class="text-xs font-black uppercase tracking-[0.4em] text-slate-400 mb-8 text-center bg-white px-4 inline-block transform -translate-y-1/2 left-1/2 absolute -translate-x-1/2">Owner Authority</h4>
                    </div>
                    <div class="space-y-3 group-input">
                        <label class="input-label">Lead Name</label>
                        <input type="text" id="ownerName" required placeholder="Full Name" class="premium-input">
                    </div>
                    <div class="space-y-3 group-input">
                        <label class="input-label">Direct Email</label>
                        <input type="email" id="ownerEmail" required placeholder="lead@@company.com" class="premium-input">
                    </div>
                </form>
                
                <div class="flex justify-end pt-10">
                    <button onclick="nextStep(2)" class="btn-premium px-12 py-6 bg-slate-900 text-white rounded-[2rem] flex items-center space-x-4">
                        <span>Define Plan Architecture</span>
                        <svg class="w-5 h-5 group-hover:translate-x-2 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                    </button>
                </div>
            </div>

            <!-- STEP 2: SOLUTIONS -->
            <div id="step-2" class="step-content hidden space-y-12 animate-in fade-in scale-in duration-500">
                <div class="text-center space-y-3 px-6">
                    <h2 class="text-4xl font-black text-slate-900 tracking-[-0.03em]">Scale Your Engine</h2>
                    <p class="text-slate-500 font-semibold italic opacity-60">Step 2 — Selecting your operational performance tier.</p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-8 px-6">
                    <!-- Starter Selection -->
                    <div class="plan-glass-card group" onclick="selectPlan('Starter Analytics', 49)">
                         <div class="flex flex-col h-full">
                             <div class="mb-8">
                                <span class="badge-blue">Core</span>
                                <h3 class="text-2xl font-black text-slate-800 mt-4 tracking-tight">Starter</h3>
                             </div>
                             <div class="mb-8">
                                 <span class="text-5xl font-black tracking-tighter text-slate-900">$49</span>
                                 <span class="text-sm font-bold text-slate-400">/mo</span>
                             </div>
                             <ul class="space-y-4 mb-10 flex-1 text-xs font-bold text-slate-500 tracking-tight">
                                 <li class="flex items-center space-x-2">🟢 <span>Basic KPI Engine</span></li>
                                 <li class="flex items-center space-x-2">🟢 <span>3 Users Capacity</span></li>
                             </ul>
                             <button class="plan-btn">Initialize Starter</button>
                         </div>
                    </div>
                    
                    <!-- Pro Selection -->
                    <div class="plan-glass-card active highlighted transform md:-translate-y-4 ring-2 ring-emerald-500/50" onclick="selectPlan('Predictive Hub', 149)">
                         <div class="absolute top-0 right-0 -mt-2 -mr-2 px-4 py-1 bg-emerald-500 text-white text-[10px] font-black uppercase tracking-widest rounded-full shadow-lg">Recommended</div>
                         <div class="flex flex-col h-full">
                             <div class="mb-8">
                                <span class="badge-emerald">Plus</span>
                                <h3 class="text-2xl font-black text-slate-800 mt-4 tracking-tight">Predictive Hub</h3>
                             </div>
                             <div class="mb-8">
                                 <span class="text-5xl font-black tracking-tighter text-slate-900">$149</span>
                                 <span class="text-sm font-bold text-slate-400">/mo</span>
                             </div>
                             <ul class="space-y-4 mb-10 flex-1 text-xs font-bold text-slate-500 tracking-tight">
                                 <li class="flex items-center space-x-2">🟢 <span>Everything in Starter</span></li>
                                 <li class="flex items-center space-x-2">🟢 <span>AI Demand Forecasting</span></li>
                             </ul>
                             <button class="plan-btn active">Deploy Hub</button>
                         </div>
                    </div>

                    <!-- Enterprise Selection -->
                    <div class="plan-glass-card group" onclick="selectPlan('Enterprise Grade', 499)">
                         <div class="flex flex-col h-full">
                             <div class="mb-8">
                                <span class="badge-indigo">Ultra</span>
                                <h3 class="text-2xl font-black text-slate-800 mt-4 tracking-tight">Enterprise</h3>
                             </div>
                             <div class="mb-8">
                                 <span class="text-5xl font-black tracking-tighter text-slate-900">$499</span>
                                 <span class="text-sm font-bold text-slate-400">/mo</span>
                             </div>
                             <ul class="space-y-4 mb-10 flex-1 text-xs font-bold text-slate-500 tracking-tight">
                                 <li class="flex items-center space-x-2">🟢 <span>Custom Multi-Tenant Hub</span></li>
                                 <li class="flex items-center space-x-2">🟢 <span>24/7 Dedicated Support</span></li>
                             </ul>
                             <button class="plan-btn">Assemble Suite</button>
                         </div>
                    </div>
                </div>
                
                <div class="flex justify-center">
                    <button onclick="nextStep(1)" class="px-8 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest hover:text-slate-600 transition-all active:scale-95">
                        ← Modification Needed
                    </button>
                </div>
            </div>

            <!-- STEP 3: TRANSACTION -->
            <div id="step-3" class="step-content hidden animate-in fade-in scale-in duration-500">
                <div class="text-center mb-16 space-y-3">
                    <h2 class="text-4xl font-black text-slate-900 tracking-[-0.03em]">Financial Bridge</h2>
                    <p class="text-slate-500 font-semibold italic opacity-60">Step 3 — Secure authorization via PayMongo portal.</p>
                </div>

                <div class="max-w-md mx-auto glass-card overflow-hidden !p-0 shadow-[0_50px_100px_rgba(0,0,0,0.1)]">
                    <div class="bg-slate-900 p-8 text-white flex justify-between items-center border-b border-white/5">
                        <div class="flex items-center space-x-3">
                            <div class="w-10 h-10 bg-gradient-to-br from-blue-600 to-emerald-500 rounded-xl flex items-center justify-center font-black">P</div>
                            <span class="font-black tracking-tighter text-lg uppercase italic">PayMongo</span>
                        </div>
                        <div id="payment-amount" class="text-2xl font-black tracking-tighter">$149.00</div>
                    </div>
                    
                    <div class="p-10 space-y-8">
                        <div class="space-y-4">
                            <div class="group-input space-y-2">
                                <label class="text-[9px] font-bold text-slate-400 uppercase tracking-[0.2em] ml-2">Payment Instrument</label>
                                <div class="w-full px-6 py-5 bg-slate-50 border-2 border-slate-100 rounded-2xl flex items-center justify-between opacity-60">
                                    <span class="text-sm font-bold text-slate-700 underline decoration-slate-300 underline-offset-4 decoration-2">•••• •••• •••• 4242</span>
                                    <span class="num h-6 w-6 bg-emerald-500 text-[10px] flex items-center justify-center rounded-full text-white">✓</span>
                                </div>
                            </div>
                        </div>

                        <button id="pay-btn" onclick="startPayment()" class="btn-premium group w-full py-6 bg-slate-900 text-white font-black rounded-3xl flex items-center justify-center space-x-4">
                            <span>Finalize Transaction</span>
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                        </button>
                    </div>

                    <!-- Portal Overlay -->
                    <div id="payment-loading" class="hidden absolute inset-0 bg-white/60 backdrop-blur-xl z-20 flex flex-col items-center justify-center space-y-6">
                        <div class="h-20 w-20 relative">
                            <div class="absolute inset-0 border-4 border-slate-100 rounded-full"></div>
                            <div class="absolute inset-0 border-4 border-slate-900 border-t-transparent rounded-full animate-spin"></div>
                        </div>
                        <p class="text-[10px] font-black text-slate-900 uppercase tracking-[0.4em] animate-pulse">Syncing Vault...</p>
                    </div>
                </div>
            </div>

            <!-- STEP 4: GENESIS -->
            <div id="step-4" class="step-content hidden animate-in zoom-in-95 duration-700">
                <div class="glass-card !p-16 max-w-3xl mx-auto space-y-12 text-center border-t-4 border-t-emerald-500">
                    <div class="w-32 h-32 bg-emerald-50 text-emerald-500 rounded-full flex items-center justify-center mx-auto shadow-inner ring-8 ring-emerald-50/50">
                        <svg class="w-16 h-16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="4" d="M5 13l4 4L19 7"/></svg>
                    </div>
                    
                    <div class="space-y-4">
                        <h2 class="text-6xl font-black text-slate-900 tracking-tighter">Genesis Alpha</h2>
                        <p class="text-slate-500 font-bold italic opacity-60">System deployed. isolated manufacturing environment is active.</p>
                    </div>
                    
                    <div class="bg-black/95 rounded-[2rem] p-10 text-left font-mono text-[10px] leading-relaxed relative border border-white/10 shadow-2xl overflow-hidden group">
                        <div class="absolute -top-10 -right-10 w-40 h-40 bg-emerald-500/20 blur-[60px] group-hover:bg-blue-500/20 transition-all duration-700"></div>
                        <div class="space-y-2 opacity-80" id="prov-log">
                            <p class="text-emerald-400 font-bold italic">[SYSTEM] VAULT_AUTH: SECURE_TOKEN_ACCEPTED</p>
                            <p class="text-slate-400">$ coretex-cli provisioning --tenant=nexus-alpha</p>
                            <p class="text-slate-200">>> ALLOCATING_DATABASE_SHARD... [COMPLETE]</p>
                            <p class="text-blue-400">>> LOG_GEO_META: <span id="geo-location">PENDING_DETECTION...</span></p>
                            <p class="text-slate-200">>> BOOTING_MULTI_TENANT_BRIDGE... [READY]</p>
                            <p class="text-emerald-400 font-black">>> ENVIRONMENT_STABLE. WELCOME_COMMANDER.</p>
                        </div>
                    </div>

                    <div class="pt-6">
                        <a href="/Dashboard" class="btn-premium group inline-flex items-center space-x-6 px-16 py-8 bg-slate-900 text-white font-black rounded-3xl tracking-tight transition-all active:scale-95 shadow-[0_30px_60px_rgba(15,23,42,0.3)]">
                            <span class="text-xl">Enter Executive Command</span>
                            <svg class="w-6 h-6 group-hover:translate-x-2 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="4" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Premium Design Tokens */
    .glass-card {
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(40px) saturate(200%);
        -webkit-backdrop-filter: blur(40px) saturate(200%);
        border: 1px solid rgba(255, 255, 255, 1);
        border-radius: 3rem;
        box-shadow: 0 40px 100px rgba(0, 0, 0, 0.05);
    }

    .step-indicator {
        display: flex;
        flex-direction: column;
        align-items: center;
        opacity: 0.3;
        transition: all 0.5s ease;
    }
    .step-indicator.active {
        opacity: 1;
        transform: scale(1.1);
    }
    .step-indicator .num {
        width: 3rem;
        height: 3rem;
        background: #fff;
        border-radius: 1.25rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        color: #0f172a;
        margin-bottom: 0.75rem;
        border: 2px solid #e2e8f0;
    }
    .step-indicator.active .num {
        background: #0f172a;
        color: #fff;
        border-color: #0f172a;
    }
    .step-indicator .label {
        font-[9px];
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        color: #64748b;
    }

    .premium-input {
        width: 100%;
        background: #fff;
        border: 2px solid #f1f5f9;
        padding: 1.25rem 1.5rem;
        border-radius: 1.5rem;
        font-weight: 700;
        color: #1e293b;
        transition: all 0.3s ease;
    }
    .premium-input:focus {
        outline: none;
        border-color: #0f172a;
        box-shadow: 0 10px 25px rgba(15, 23, 42, 0.05);
    }
    .input-label {
        font-size: [10px];
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        color: #94a3b8;
        padding-left: 0.5rem;
    }

    .plan-glass-card {
        background: rgba(255, 255, 255, 0.4);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.8);
        border-radius: 2.5rem;
        padding: 2.5rem;
        cursor: pointer;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
    }
    .plan-glass-card:hover {
        background: #fff;
        transform: translateY(-5px);
        box-shadow: 0 30px 60px rgba(0, 0, 0, 0.08);
    }
    .plan-btn {
        background: #f1f5f9;
        color: #64748b;
        font-weight: 800;
        padding: 1rem;
        border-radius: 1.25rem;
        transition: all 0.3s ease;
    }
    .plan-glass-card:hover .plan-btn, .plan-btn.active {
        background: #0f172a;
        color: #fff;
    }

    .badge-blue { background: #eff6ff; color: #2563eb; font-size: 9px; font-weight: 900; padding: 0.25rem 1rem; border-radius: 99px; text-transform: uppercase; letter-spacing: 0.1em; }
    .badge-emerald { background: #ecfdf5; color: #10b981; font-size: 9px; font-weight: 900; padding: 0.25rem 1rem; border-radius: 99px; text-transform: uppercase; letter-spacing: 0.1em; }
    .badge-indigo { background: #eef2ff; color: #4f46e5; font-size: 9px; font-weight: 900; padding: 0.25rem 1rem; border-radius: 99px; text-transform: uppercase; letter-spacing: 0.1em; }

    /* Animations */
    @@keyframes scale-in { from { transform: scale(0.98); opacity: 0; } to { transform: scale(1); opacity: 1; } }
    .scale-in { animation-name: scale-in; }
</style>

<script>
    let onboardingData = {
        companyName: '',
        address: '',
        contact: '',
        industry: '',
        ownerName: '',
        ownerEmail: '',
        plan: '',
        price: 0,
        registrationDate: new Date().toISOString(),
        status: 'Active'
    };

    function nextStep(step) {
        // UI Validation
        if (step === 2) {
            const form = document.getElementById('reg-form');
            if (!form.checkValidity()) {
                form.reportValidity();
                return;
            }
            onboardingData.companyName = document.getElementById('companyName').value;
            onboardingData.address = document.getElementById('address').value;
            onboardingData.contact = document.getElementById('contact').value;
            onboardingData.industry = document.getElementById('industry').value;
            onboardingData.ownerName = document.getElementById('ownerName').value;
            onboardingData.ownerEmail = document.getElementById('ownerEmail').value;
        }

        // Transitions
        document.querySelectorAll('.step-content').forEach(el => el.classList.add('hidden'));
        document.getElementById(`step-${step}`).classList.remove('hidden');
        
        // Update Indicators
        document.querySelectorAll('.step-indicator').forEach(el => el.classList.remove('active'));
        document.getElementById(`ind-${step}`).classList.add('active');
        
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function selectPlan(name, price) {
        onboardingData.plan = name;
        onboardingData.price = price;
        document.getElementById('payment-amount').innerText = `$${price}.00`;
        nextStep(3);
    }

    async function startPayment() {
        const overlay = document.getElementById('payment-loading');
        overlay.classList.remove('hidden');
        
        setTimeout(async () => {
            saveTenantLocally(onboardingData);
            nextStep(4);
            try {
                const response = await fetch('https://ipapi.co/json/');
                const data = await response.json();
                document.getElementById('geo-location').innerText = `${data.city}, ${data.country_name} (${data.ip})`;
            } catch (e) {
                document.getElementById('geo-location').innerText = 'MANILA_HUB, PH (OVERRIDE)';
            }
        }, 3000);
    }

    function saveTenantLocally(data) {
        let tenants = JSON.parse(localStorage.getItem('coretex_tenants') || '[]');
        tenants.unshift(data);
        localStorage.setItem('coretex_tenants', JSON.stringify(tenants));
    }
</script>
