@{
    ViewData["Title"] = "Finance Officer Portal";
    Layout = "_AdminLayout";
}

<div class="space-y-8">
    <!-- Header with IPGeolocation & Branch Info -->
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
        <div>
            <div class="flex flex-wrap items-center gap-2 mb-2">
                <span id="login-badge" class="px-3 py-1 bg-emerald-100 text-emerald-700 font-black text-[10px] uppercase tracking-widest rounded-full flex items-center space-x-2">
                    <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full animate-pulse"></span>
                    <span>Finance Officer Session</span>
                </span>
                <span id="geo-location" class="px-3 py-1 bg-slate-100 text-slate-500 font-bold text-[10px] uppercase tracking-widest rounded-full">
                    Detecting Location...
                </span>
                <span id="branch-badge" class="px-3 py-1 bg-blue-100 text-blue-700 font-black text-[10px] uppercase tracking-widest rounded-full">
                    Branch: Loading...
                </span>
            </div>
            <h2 class="text-3xl font-black text-slate-900 tracking-tight">Transaction Entry</h2>
            <p class="text-xs text-slate-400 font-bold uppercase tracking-widest mt-1">Record daily sales, expenses, and imports</p>
        </div>
        
        <div class="flex items-center gap-3">
            <a href="/DataEntry/History" class="px-4 py-2 bg-slate-100 text-slate-700 text-xs font-bold rounded-xl hover:bg-slate-200 transition-all flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                Transaction History
            </a>
            <button onclick="showMonthlySummary()" class="px-4 py-2 bg-indigo-600 text-white text-xs font-bold rounded-xl hover:bg-indigo-700 transition-all flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                Monthly Summary
            </button>
        </div>
    </div>

    <!-- Tab Navigation -->
    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-1.5">
        <div class="flex gap-1">
            <button onclick="switchTab('sales')" id="tab-sales" class="tab-btn flex-1 px-6 py-3 text-xs font-black uppercase tracking-widest rounded-xl transition-all bg-emerald-500 text-white">
                <span class="flex items-center justify-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    Record Sale
                </span>
            </button>
            <button onclick="switchTab('expenses')" id="tab-expenses" class="tab-btn flex-1 px-6 py-3 text-xs font-black uppercase tracking-widest rounded-xl transition-all bg-slate-100 text-slate-500 hover:bg-slate-200">
                <span class="flex items-center justify-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    Record Expense
                </span>
            </button>
            <button onclick="switchTab('imports')" id="tab-imports" class="tab-btn flex-1 px-6 py-3 text-xs font-black uppercase tracking-widest rounded-xl transition-all bg-slate-100 text-slate-500 hover:bg-slate-200">
                <span class="flex items-center justify-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>
                    Record Import
                </span>
            </button>
        </div>
    </div>

    <!-- Main Content Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
        
        <!-- Form Panel -->
        <div class="lg:col-span-8">
            <!-- Sales Form -->
            <div id="panel-sales" class="tab-panel bg-white rounded-3xl shadow-xl shadow-slate-200/50 border border-slate-100 overflow-hidden">
                <div class="p-8 border-b border-slate-100">
                    <h3 class="text-lg font-black text-slate-900">Record Sale Transaction</h3>
                    <p class="text-xs text-slate-400 mt-1">Enter individual sale details</p>
                </div>
                <div class="p-8 space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="space-y-2">
                            <label class="text-[10px] font-black text-slate-500 uppercase tracking-widest">Date</label>
                            <input type="date" id="sale-date" class="w-full bg-slate-50 border-2 border-slate-100 rounded-xl py-3 px-4 text-sm font-bold focus:border-emerald-500 outline-none transition-all">
                        </div>
                        <div class="space-y-2">
                            <label class="text-[10px] font-black text-slate-500 uppercase tracking-widest">Amount (PHP)</label>
                            <div class="relative">
                                <span class="absolute left-4 top-1/2 -translate-y-1/2 font-black text-slate-400 text-sm">₱</span>
                                <input type="number" id="sale-amount" placeholder="0.00" step="0.01" class="w-full bg-slate-50 border-2 border-slate-100 rounded-xl py-3 pl-10 pr-4 text-sm font-bold focus:border-emerald-500 outline-none transition-all">
                            </div>
                        </div>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="space-y-2">
                            <label class="text-[10px] font-black text-slate-500 uppercase tracking-widest">Customer Name (Optional)</label>
                            <input type="text" id="sale-customer" placeholder="Walk-in Customer" class="w-full bg-slate-50 border-2 border-slate-100 rounded-xl py-3 px-4 text-sm font-bold focus:border-emerald-500 outline-none transition-all">
                        </div>
                        <div class="space-y-2">
                            <label class="text-[10px] font-black text-slate-500 uppercase tracking-widest">Payment Method</label>
                            <select id="sale-payment" class="w-full bg-slate-50 border-2 border-slate-100 rounded-xl py-3 px-4 text-sm font-bold focus:border-emerald-500 outline-none transition-all">
                                <option value="Cash">Cash</option>
                                <option value="GCash">GCash</option>
                                <option value="Maya">Maya</option>
                                <option value="Card">Credit/Debit Card</option>
                                <option value="Bank Transfer">Bank Transfer</option>
                            </select>
                        </div>
                    </div>
                    <div class="space-y-2">
                        <label class="text-[10px] font-black text-slate-500 uppercase tracking-widest">Notes (Optional)</label>
                        <textarea id="sale-notes" rows="2" placeholder="Additional details..." class="w-full bg-slate-50 border-2 border-slate-100 rounded-xl py-3 px-4 text-sm font-bold focus:border-emerald-500 outline-none transition-all resize-none"></textarea>
                    </div>
                </div>
                <div class="p-6 bg-slate-50 border-t border-slate-100">
                    <button onclick="saveSale()" class="w-full py-4 bg-emerald-600 text-white font-black rounded-xl shadow-lg shadow-emerald-600/20 hover:bg-emerald-700 active:scale-[0.98] transition-all flex items-center justify-center gap-2">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
                        Save Sale Transaction
                    </button>
                </div>
            </div>

            <!-- Expenses Form -->
            <div id="panel-expenses" class="tab-panel hidden bg-white rounded-3xl shadow-xl shadow-slate-200/50 border border-slate-100 overflow-hidden">
                <div class="p-8 border-b border-slate-100">
                    <h3 class="text-lg font-black text-slate-900">Record Expense Transaction</h3>
                    <p class="text-xs text-slate-400 mt-1">Enter operational costs and expenses</p>
                </div>
                <div class="p-8 space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="space-y-2">
                            <label class="text-[10px] font-black text-slate-500 uppercase tracking-widest">Date</label>
                            <input type="date" id="expense-date" class="w-full bg-slate-50 border-2 border-slate-100 rounded-xl py-3 px-4 text-sm font-bold focus:border-red-500 outline-none transition-all">
                        </div>
                        <div class="space-y-2">
                            <label class="text-[10px] font-black text-slate-500 uppercase tracking-widest">Amount (PHP)</label>
                            <div class="relative">
                                <span class="absolute left-4 top-1/2 -translate-y-1/2 font-black text-slate-400 text-sm">₱</span>
                                <input type="number" id="expense-amount" placeholder="0.00" step="0.01" class="w-full bg-slate-50 border-2 border-slate-100 rounded-xl py-3 pl-10 pr-4 text-sm font-bold focus:border-red-500 outline-none transition-all">
                            </div>
                        </div>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="space-y-2">
                            <label class="text-[10px] font-black text-slate-500 uppercase tracking-widest">Category</label>
                            <select id="expense-category" class="w-full bg-slate-50 border-2 border-slate-100 rounded-xl py-3 px-4 text-sm font-bold focus:border-red-500 outline-none transition-all">
                                <option value="Utilities">Utilities (Electric, Water, Internet)</option>
                                <option value="Rent">Rent / Lease</option>
                                <option value="Payroll">Payroll / Salaries</option>
                                <option value="Supplies">Office Supplies</option>
                                <option value="Maintenance">Maintenance / Repairs</option>
                                <option value="Marketing">Marketing / Advertising</option>
                                <option value="Transportation">Transportation / Logistics</option>
                                <option value="Insurance">Insurance</option>
                                <option value="Taxes">Taxes / Government Fees</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>
                        <div class="space-y-2">
                            <label class="text-[10px] font-black text-slate-500 uppercase tracking-widest">Vendor / Supplier</label>
                            <input type="text" id="expense-vendor" placeholder="e.g., PLDT, Meralco" class="w-full bg-slate-50 border-2 border-slate-100 rounded-xl py-3 px-4 text-sm font-bold focus:border-red-500 outline-none transition-all">
                        </div>
                    </div>
                    <div class="space-y-2">
                        <label class="text-[10px] font-black text-slate-500 uppercase tracking-widest">Description</label>
                        <textarea id="expense-description" rows="2" placeholder="What was this expense for?" class="w-full bg-slate-50 border-2 border-slate-100 rounded-xl py-3 px-4 text-sm font-bold focus:border-red-500 outline-none transition-all resize-none"></textarea>
                    </div>
                </div>
                <div class="p-6 bg-slate-50 border-t border-slate-100">
                    <button onclick="saveExpense()" class="w-full py-4 bg-red-600 text-white font-black rounded-xl shadow-lg shadow-red-600/20 hover:bg-red-700 active:scale-[0.98] transition-all flex items-center justify-center gap-2">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
                        Save Expense Transaction
                    </button>
                </div>
            </div>

            <!-- Imports Form -->
            <div id="panel-imports" class="tab-panel hidden bg-white rounded-3xl shadow-xl shadow-slate-200/50 border border-slate-100 overflow-hidden">
                <div class="p-8 border-b border-slate-100">
                    <h3 class="text-lg font-black text-slate-900">Record Import Transaction</h3>
                    <p class="text-xs text-slate-400 mt-1">Enter imported product costs (auto-converts to PHP)</p>
                </div>
                <div class="p-8 space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="space-y-2">
                            <label class="text-[10px] font-black text-slate-500 uppercase tracking-widest">Date</label>
                            <input type="date" id="import-date" class="w-full bg-slate-50 border-2 border-slate-100 rounded-xl py-3 px-4 text-sm font-bold focus:border-orange-500 outline-none transition-all">
                        </div>
                        <div class="space-y-2">
                            <label class="text-[10px] font-black text-slate-500 uppercase tracking-widest">Currency</label>
                            <select id="import-currency" onchange="updateExchangeRate()" class="w-full bg-slate-50 border-2 border-slate-100 rounded-xl py-3 px-4 text-sm font-bold focus:border-orange-500 outline-none transition-all">
                                <option value="USD">USD - US Dollar ($)</option>
                                <option value="CNY">CNY - Chinese Yuan (¥)</option>
                                <option value="EUR">EUR - Euro (€)</option>
                                <option value="JPY">JPY - Japanese Yen (¥)</option>
                            </select>
                        </div>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="space-y-2">
                            <label class="text-[10px] font-black text-slate-500 uppercase tracking-widest">Amount (Foreign Currency)</label>
                            <input type="number" id="import-amount" placeholder="0.00" step="0.01" oninput="calculatePHPAmount()" class="w-full bg-slate-50 border-2 border-slate-100 rounded-xl py-3 px-4 text-sm font-bold focus:border-orange-500 outline-none transition-all">
                        </div>
                        <div class="space-y-2">
                            <label class="text-[10px] font-black text-slate-500 uppercase tracking-widest">Supplier</label>
                            <input type="text" id="import-supplier" placeholder="e.g., Shenzhen Electronics Co." class="w-full bg-slate-50 border-2 border-slate-100 rounded-xl py-3 px-4 text-sm font-bold focus:border-orange-500 outline-none transition-all">
                        </div>
                    </div>
                    
                    <!-- Exchange Rate Display -->
                    <div id="exchange-panel" class="bg-gradient-to-r from-orange-50 to-amber-50 p-6 rounded-2xl border border-orange-100 space-y-3">
                        <div class="flex items-center justify-between">
                            <div class="flex items-center gap-3">
                                <div class="w-10 h-10 bg-white shadow-sm rounded-xl flex items-center justify-center text-orange-500">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
                                </div>
                                <div>
                                    <p class="text-[9px] font-black uppercase tracking-[0.15em] text-orange-500">Exchange Rate API</p>
                                    <p id="exchange-rate-text" class="text-sm font-bold text-slate-700">1 USD = ₱ 56.50</p>
                                </div>
                            </div>
                            <div class="text-right">
                                <p class="text-[9px] font-black uppercase tracking-[0.15em] text-orange-500">Converted Amount</p>
                                <p id="import-php-amount" class="text-2xl font-black text-slate-900">₱ 0.00</p>
                            </div>
                        </div>
                    </div>

                    <div class="space-y-2">
                        <label class="text-[10px] font-black text-slate-500 uppercase tracking-widest">Product Category</label>
                        <select id="import-category" class="w-full bg-slate-50 border-2 border-slate-100 rounded-xl py-3 px-4 text-sm font-bold focus:border-orange-500 outline-none transition-all">
                            <option value="Electronics">Electronics / Components</option>
                            <option value="Raw Materials">Raw Materials</option>
                            <option value="Finished Goods">Finished Goods</option>
                            <option value="Machinery">Machinery / Equipment</option>
                            <option value="Packaging">Packaging Materials</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>
                    <div class="space-y-2">
                        <label class="text-[10px] font-black text-slate-500 uppercase tracking-widest">Description</label>
                        <textarea id="import-description" rows="2" placeholder="What products were imported?" class="w-full bg-slate-50 border-2 border-slate-100 rounded-xl py-3 px-4 text-sm font-bold focus:border-orange-500 outline-none transition-all resize-none"></textarea>
                    </div>
                </div>
                <div class="p-6 bg-slate-50 border-t border-slate-100">
                    <button onclick="saveImport()" class="w-full py-4 bg-orange-600 text-white font-black rounded-xl shadow-lg shadow-orange-600/20 hover:bg-orange-700 active:scale-[0.98] transition-all flex items-center justify-center gap-2">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
                        Save Import Transaction
                    </button>
                </div>
            </div>
        </div>

        <!-- Sidebar: Today's Summary & Quick Stats -->
        <div class="lg:col-span-4 space-y-6">
            <!-- Today's Summary -->
            <div class="bg-white p-6 rounded-2xl border border-slate-100 shadow-sm">
                <h4 class="text-xs font-black uppercase tracking-widest text-slate-400 mb-4">Today's Transactions</h4>
                <div class="space-y-4">
                    <div class="flex items-center justify-between p-3 bg-emerald-50 rounded-xl">
                        <span class="text-xs font-bold text-slate-600">Sales</span>
                        <span id="today-sales" class="text-sm font-black text-emerald-600">₱ 0.00</span>
                    </div>
                    <div class="flex items-center justify-between p-3 bg-red-50 rounded-xl">
                        <span class="text-xs font-bold text-slate-600">Expenses</span>
                        <span id="today-expenses" class="text-sm font-black text-red-600">₱ 0.00</span>
                    </div>
                    <div class="flex items-center justify-between p-3 bg-orange-50 rounded-xl">
                        <span class="text-xs font-bold text-slate-600">Imports</span>
                        <span id="today-imports" class="text-sm font-black text-orange-600">₱ 0.00</span>
                    </div>
                    <div class="pt-3 border-t border-slate-100">
                        <div class="flex items-center justify-between">
                            <span class="text-xs font-black text-slate-500 uppercase">Net Today</span>
                            <span id="today-net" class="text-lg font-black text-slate-900">₱ 0.00</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- This Month's Running Total -->
            <div class="bg-gradient-to-br from-slate-900 to-slate-800 p-6 rounded-2xl shadow-xl">
                <h4 class="text-xs font-black uppercase tracking-widest text-slate-400 mb-4">This Month's Total</h4>
                <div class="space-y-4">
                    <div class="flex items-center justify-between">
                        <span class="text-xs font-medium text-slate-400">Total Sales</span>
                        <span id="month-sales" class="text-sm font-black text-emerald-400">₱ 0.00</span>
                    </div>
                    <div class="flex items-center justify-between">
                        <span class="text-xs font-medium text-slate-400">Total Expenses</span>
                        <span id="month-expenses" class="text-sm font-black text-red-400">₱ 0.00</span>
                    </div>
                    <div class="flex items-center justify-between">
                        <span class="text-xs font-medium text-slate-400">Total Imports (PHP)</span>
                        <span id="month-imports" class="text-sm font-black text-orange-400">₱ 0.00</span>
                    </div>
                    <div class="pt-3 border-t border-slate-700">
                        <div class="flex items-center justify-between">
                            <span class="text-xs font-black text-white uppercase">Gross Profit</span>
                            <span id="month-profit" class="text-xl font-black text-white">₱ 0.00</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- API Status -->
            <div class="bg-white p-6 rounded-2xl border border-slate-100 shadow-sm">
                <h4 class="text-xs font-black uppercase tracking-widest text-slate-400 mb-4">System Status</h4>
                <div class="space-y-3">
                    <div class="flex items-center justify-between">
                        <span class="text-xs font-bold text-slate-600">Exchange Rate API</span>
                        <span id="api-status" class="px-2 py-0.5 bg-emerald-100 text-emerald-600 text-[9px] font-black uppercase rounded">Connected</span>
                    </div>
                    <div class="flex items-center justify-between">
                        <span class="text-xs font-bold text-slate-600">IPGeolocation</span>
                        <span class="px-2 py-0.5 bg-emerald-100 text-emerald-600 text-[9px] font-black uppercase rounded">Active</span>
                    </div>
                    <div class="flex items-center justify-between">
                        <span class="text-xs font-bold text-slate-600">Auto-Save</span>
                        <span class="px-2 py-0.5 bg-blue-100 text-blue-600 text-[9px] font-black uppercase rounded">Enabled</span>
                    </div>
                </div>
            </div>

            <!-- Recent Transactions -->
            <div class="bg-white p-6 rounded-2xl border border-slate-100 shadow-sm">
                <h4 class="text-xs font-black uppercase tracking-widest text-slate-400 mb-4">Recent Transactions</h4>
                <div id="recent-transactions" class="space-y-2 max-h-48 overflow-y-auto">
                    <p class="text-xs text-slate-400 text-center py-4">No transactions yet</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Monthly Summary Modal -->
<div id="monthly-summary-modal" class="fixed inset-0 z-50 bg-slate-900/60 backdrop-blur-sm flex items-center justify-center opacity-0 pointer-events-none transition-all duration-300">
    <div class="max-w-2xl w-full mx-4 bg-white rounded-3xl shadow-2xl overflow-hidden transform scale-95 transition-all duration-300" id="summary-card">
        <div class="p-6 border-b border-slate-100 flex items-center justify-between">
            <div>
                <h3 class="text-lg font-black text-slate-900">Monthly Summary</h3>
                <p class="text-xs text-slate-400 mt-1">Auto-aggregated from your transactions</p>
            </div>
            <button onclick="closeMonthlySummary()" class="w-8 h-8 bg-slate-100 rounded-lg flex items-center justify-center hover:bg-slate-200 transition-all">
                <svg class="w-4 h-4 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>
        <div class="p-6">
            <div class="flex items-center gap-3 mb-6">
                <select id="summary-month" class="text-sm font-bold bg-slate-50 border border-slate-200 rounded-xl py-2 px-3">
                    <option value="1">January</option>
                    <option value="2">February</option>
                    <option value="3">March</option>
                    <option value="4">April</option>
                    <option value="5">May</option>
                    <option value="6">June</option>
                    <option value="7">July</option>
                    <option value="8">August</option>
                    <option value="9">September</option>
                    <option value="10">October</option>
                    <option value="11">November</option>
                    <option value="12">December</option>
                </select>
                <select id="summary-year" class="text-sm font-bold bg-slate-50 border border-slate-200 rounded-xl py-2 px-3">
                    <option value="2026">2026</option>
                    <option value="2025">2025</option>
                </select>
                <button onclick="loadMonthlySummary()" class="px-4 py-2 bg-slate-900 text-white text-xs font-bold rounded-xl hover:bg-slate-800 transition-all">
                    Load
                </button>
            </div>
            
            <div class="grid grid-cols-2 gap-4 mb-6">
                <div class="p-4 bg-emerald-50 rounded-xl">
                    <p class="text-[10px] font-black text-emerald-600 uppercase tracking-widest">Total Sales</p>
                    <p id="summary-sales" class="text-2xl font-black text-emerald-700 mt-1">₱ 0.00</p>
                    <p id="summary-sales-count" class="text-xs text-emerald-600 mt-1">0 transactions</p>
                </div>
                <div class="p-4 bg-red-50 rounded-xl">
                    <p class="text-[10px] font-black text-red-600 uppercase tracking-widest">Total Expenses</p>
                    <p id="summary-expenses" class="text-2xl font-black text-red-700 mt-1">₱ 0.00</p>
                    <p id="summary-expenses-count" class="text-xs text-red-600 mt-1">0 transactions</p>
                </div>
                <div class="p-4 bg-orange-50 rounded-xl">
                    <p class="text-[10px] font-black text-orange-600 uppercase tracking-widest">Total Imports (PHP)</p>
                    <p id="summary-imports" class="text-2xl font-black text-orange-700 mt-1">₱ 0.00</p>
                    <p id="summary-imports-count" class="text-xs text-orange-600 mt-1">0 transactions</p>
                </div>
                <div class="p-4 bg-blue-50 rounded-xl">
                    <p class="text-[10px] font-black text-blue-600 uppercase tracking-widest">Unique Customers</p>
                    <p id="summary-customers" class="text-2xl font-black text-blue-700 mt-1">0</p>
                    <p class="text-xs text-blue-600 mt-1">from sales records</p>
                </div>
            </div>

            <div class="p-4 bg-slate-900 rounded-xl mb-6">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Gross Profit</p>
                        <p id="summary-profit" class="text-3xl font-black text-white mt-1">₱ 0.00</p>
                    </div>
                    <div class="text-right">
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Profit Margin</p>
                        <p id="summary-margin" class="text-3xl font-black text-emerald-400 mt-1">0%</p>
                    </div>
                </div>
            </div>

            <button onclick="submitToEDSS()" class="w-full py-4 bg-indigo-600 text-white font-black rounded-xl shadow-lg shadow-indigo-600/20 hover:bg-indigo-700 active:scale-[0.98] transition-all flex items-center justify-center gap-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                Submit to EDSS for Analysis
            </button>
        </div>
    </div>
</div>

<!-- Success Toast -->
<div id="success-toast" class="fixed bottom-6 right-6 z-50 transform translate-y-20 opacity-0 transition-all duration-300">
    <div class="bg-emerald-600 text-white px-6 py-4 rounded-xl shadow-lg flex items-center gap-3">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
        <span id="toast-message" class="font-bold text-sm">Transaction saved successfully!</span>
    </div>
</div>

@section Scripts {
    <script>
        // Global state
        let currentExchangeRate = 56.50; // Default USD to PHP
        let currentBranch = null;

        // Initialize on page load
        document.addEventListener('DOMContentLoaded', async () => {
            // Set today's date as default
            const today = new Date().toISOString().split('T')[0];
            document.getElementById('sale-date').value = today;
            document.getElementById('expense-date').value = today;
            document.getElementById('import-date').value = today;

            // Set current month/year for summary
            const now = new Date();
            document.getElementById('summary-month').value = now.getMonth() + 1;
            document.getElementById('summary-year').value = now.getFullYear();

            // Load branch info
            loadBranchInfo();

            // Load IPGeolocation
            loadGeoLocation();

            // Load exchange rate
            updateExchangeRate();

            // Update all stats
            updateAllStats();
        });

        // Load branch info from logged-in user
        function loadBranchInfo() {
            const users = JSON.parse(localStorage.getItem('coretex_users') || '[]');
            const branches = JSON.parse(localStorage.getItem('coretex_branches') || '[]');
            
            // Simulate logged-in Finance Officer (first one found)
            const financeOfficer = users.find(u => u.role === 'Finance Officer' && u.status === 'Active');
            
            if (financeOfficer && financeOfficer.branchId) {
                const branch = branches.find(b => b.id === financeOfficer.branchId);
                if (branch) {
                    currentBranch = branch;
                    document.getElementById('branch-badge').textContent = `Branch: ${branch.name}`;
                    return;
                }
            }
            
            // Default branch if none found
            if (branches.length > 0) {
                currentBranch = branches[0];
                document.getElementById('branch-badge').textContent = `Branch: ${branches[0].name}`;
            } else {
                document.getElementById('branch-badge').textContent = 'Branch: Davao Main';
                currentBranch = { id: 'default', name: 'Davao Main' };
            }
        }

        // IPGeolocation
        async function loadGeoLocation() {
            const geoEl = document.getElementById('geo-location');
            try {
                const response = await fetch('https://ipapi.co/json/');
                const data = await response.json();
                geoEl.textContent = `${data.city}, ${data.country_name}`;
                
                // Log activity
                logActivity('LOGIN', `Finance Officer logged in from ${data.city}, ${data.country_name}`);
            } catch (e) {
                geoEl.textContent = 'Davao City, Philippines';
            }
        }

        // Tab switching
        function switchTab(tab) {
            // Update buttons
            document.querySelectorAll('.tab-btn').forEach(btn => {
                btn.classList.remove('bg-emerald-500', 'bg-red-500', 'bg-orange-500', 'text-white');
                btn.classList.add('bg-slate-100', 'text-slate-500');
            });
            
            const activeBtn = document.getElementById(`tab-${tab}`);
            activeBtn.classList.remove('bg-slate-100', 'text-slate-500');
            
            if (tab === 'sales') activeBtn.classList.add('bg-emerald-500', 'text-white');
            else if (tab === 'expenses') activeBtn.classList.add('bg-red-500', 'text-white');
            else if (tab === 'imports') activeBtn.classList.add('bg-orange-500', 'text-white');

            // Update panels
            document.querySelectorAll('.tab-panel').forEach(panel => panel.classList.add('hidden'));
            document.getElementById(`panel-${tab}`).classList.remove('hidden');
        }

        // Exchange Rate API
        async function updateExchangeRate() {
            const currency = document.getElementById('import-currency').value;
            const rateText = document.getElementById('exchange-rate-text');
            const apiStatus = document.getElementById('api-status');
            
            try {
                const res = await fetch(`https://api.exchangerate-api.com/v4/latest/${currency}`);
                const data = await res.json();
                currentExchangeRate = data.rates.PHP;
                rateText.textContent = `1 ${currency} = ₱ ${currentExchangeRate.toFixed(2)}`;
                apiStatus.textContent = 'Connected';
                apiStatus.classList.remove('bg-yellow-100', 'text-yellow-600');
                apiStatus.classList.add('bg-emerald-100', 'text-emerald-600');
            } catch (e) {
                // Fallback rates
                const fallbacks = { 'USD': 56.50, 'CNY': 7.85, 'EUR': 61.20, 'JPY': 0.38 };
                currentExchangeRate = fallbacks[currency] || 56.50;
                rateText.textContent = `1 ${currency} = ₱ ${currentExchangeRate.toFixed(2)} (Cached)`;
                apiStatus.textContent = 'Cached';
                apiStatus.classList.remove('bg-emerald-100', 'text-emerald-600');
                apiStatus.classList.add('bg-yellow-100', 'text-yellow-600');
            }
            
            calculatePHPAmount();
        }

        function calculatePHPAmount() {
            const foreignAmount = parseFloat(document.getElementById('import-amount').value) || 0;
            const phpAmount = foreignAmount * currentExchangeRate;
            document.getElementById('import-php-amount').textContent = `₱ ${phpAmount.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2})}`;
        }

        // Save Sale
        function saveSale() {
            const date = document.getElementById('sale-date').value;
            const amount = parseFloat(document.getElementById('sale-amount').value);
            const customer = document.getElementById('sale-customer').value || 'Walk-in Customer';
            const payment = document.getElementById('sale-payment').value;
            const notes = document.getElementById('sale-notes').value;

            if (!date || !amount || amount <= 0) {
                alert('Please enter a valid date and amount.');
                return;
            }

            const sales = JSON.parse(localStorage.getItem('coretex_sales') || '[]');
            const sale = {
                id: generateId(),
                date,
                amount,
                customer,
                paymentMethod: payment,
                notes,
                branchId: currentBranch?.id || 'default',
                branchName: currentBranch?.name || 'Davao Main',
                createdAt: new Date().toISOString()
            };
            
            sales.push(sale);
            localStorage.setItem('coretex_sales', JSON.stringify(sales));

            // Clear form
            document.getElementById('sale-amount').value = '';
            document.getElementById('sale-customer').value = '';
            document.getElementById('sale-notes').value = '';

            showToast('Sale transaction saved!');
            logActivity('SALE', `Recorded sale of ₱${amount.toLocaleString()} from ${customer}`);
            updateAllStats();
        }

        // Save Expense
        function saveExpense() {
            const date = document.getElementById('expense-date').value;
            const amount = parseFloat(document.getElementById('expense-amount').value);
            const category = document.getElementById('expense-category').value;
            const vendor = document.getElementById('expense-vendor').value;
            const description = document.getElementById('expense-description').value;

            if (!date || !amount || amount <= 0) {
                alert('Please enter a valid date and amount.');
                return;
            }

            const expenses = JSON.parse(localStorage.getItem('coretex_expenses') || '[]');
            const expense = {
                id: generateId(),
                date,
                amount,
                category,
                vendor,
                description,
                branchId: currentBranch?.id || 'default',
                branchName: currentBranch?.name || 'Davao Main',
                createdAt: new Date().toISOString()
            };
            
            expenses.push(expense);
            localStorage.setItem('coretex_expenses', JSON.stringify(expenses));

            // Clear form
            document.getElementById('expense-amount').value = '';
            document.getElementById('expense-vendor').value = '';
            document.getElementById('expense-description').value = '';

            showToast('Expense transaction saved!');
            logActivity('EXPENSE', `Recorded expense of ₱${amount.toLocaleString()} for ${category}`);
            updateAllStats();
        }

        // Save Import
        function saveImport() {
            const date = document.getElementById('import-date').value;
            const currency = document.getElementById('import-currency').value;
            const foreignAmount = parseFloat(document.getElementById('import-amount').value);
            const supplier = document.getElementById('import-supplier').value;
            const category = document.getElementById('import-category').value;
            const description = document.getElementById('import-description').value;
            const phpAmount = foreignAmount * currentExchangeRate;

            if (!date || !foreignAmount || foreignAmount <= 0) {
                alert('Please enter a valid date and amount.');
                return;
            }

            const imports = JSON.parse(localStorage.getItem('coretex_imports') || '[]');
            const importTx = {
                id: generateId(),
                date,
                currency,
                foreignAmount,
                exchangeRate: currentExchangeRate,
                phpAmount,
                supplier,
                category,
                description,
                branchId: currentBranch?.id || 'default',
                branchName: currentBranch?.name || 'Davao Main',
                createdAt: new Date().toISOString()
            };
            
            imports.push(importTx);
            localStorage.setItem('coretex_imports', JSON.stringify(imports));

            // Clear form
            document.getElementById('import-amount').value = '';
            document.getElementById('import-supplier').value = '';
            document.getElementById('import-description').value = '';
            document.getElementById('import-php-amount').textContent = '₱ 0.00';

            showToast('Import transaction saved!');
            logActivity('IMPORT', `Recorded import of ${currency} ${foreignAmount.toLocaleString()} (₱${phpAmount.toLocaleString()}) from ${supplier || 'Unknown Supplier'}`);
            updateAllStats();
        }

        // Update all statistics
        function updateAllStats() {
            const today = new Date().toISOString().split('T')[0];
            const now = new Date();
            const currentMonth = now.getMonth();
            const currentYear = now.getFullYear();

            const sales = JSON.parse(localStorage.getItem('coretex_sales') || '[]');
            const expenses = JSON.parse(localStorage.getItem('coretex_expenses') || '[]');
            const imports = JSON.parse(localStorage.getItem('coretex_imports') || '[]');

            // Filter by branch
            const branchId = currentBranch?.id || 'default';
            const branchSales = sales.filter(s => s.branchId === branchId);
            const branchExpenses = expenses.filter(e => e.branchId === branchId);
            const branchImports = imports.filter(i => i.branchId === branchId);

            // Today's totals
            const todaySales = branchSales.filter(s => s.date === today).reduce((sum, s) => sum + s.amount, 0);
            const todayExpenses = branchExpenses.filter(e => e.date === today).reduce((sum, e) => sum + e.amount, 0);
            const todayImports = branchImports.filter(i => i.date === today).reduce((sum, i) => sum + i.phpAmount, 0);

            document.getElementById('today-sales').textContent = `₱ ${todaySales.toLocaleString(undefined, {minimumFractionDigits: 2})}`;
            document.getElementById('today-expenses').textContent = `₱ ${todayExpenses.toLocaleString(undefined, {minimumFractionDigits: 2})}`;
            document.getElementById('today-imports').textContent = `₱ ${todayImports.toLocaleString(undefined, {minimumFractionDigits: 2})}`;
            document.getElementById('today-net').textContent = `₱ ${(todaySales - todayExpenses - todayImports).toLocaleString(undefined, {minimumFractionDigits: 2})}`;

            // This month's totals
            const monthSales = branchSales.filter(s => {
                const d = new Date(s.date);
                return d.getMonth() === currentMonth && d.getFullYear() === currentYear;
            }).reduce((sum, s) => sum + s.amount, 0);

            const monthExpenses = branchExpenses.filter(e => {
                const d = new Date(e.date);
                return d.getMonth() === currentMonth && d.getFullYear() === currentYear;
            }).reduce((sum, e) => sum + e.amount, 0);

            const monthImports = branchImports.filter(i => {
                const d = new Date(i.date);
                return d.getMonth() === currentMonth && d.getFullYear() === currentYear;
            }).reduce((sum, i) => sum + i.phpAmount, 0);

            document.getElementById('month-sales').textContent = `₱ ${monthSales.toLocaleString(undefined, {minimumFractionDigits: 2})}`;
            document.getElementById('month-expenses').textContent = `₱ ${monthExpenses.toLocaleString(undefined, {minimumFractionDigits: 2})}`;
            document.getElementById('month-imports').textContent = `₱ ${monthImports.toLocaleString(undefined, {minimumFractionDigits: 2})}`;
            document.getElementById('month-profit').textContent = `₱ ${(monthSales - monthExpenses - monthImports).toLocaleString(undefined, {minimumFractionDigits: 2})}`;

            // Recent transactions
            updateRecentTransactions(branchSales, branchExpenses, branchImports);
        }

        function updateRecentTransactions(sales, expenses, imports) {
            const all = [
                ...sales.map(s => ({ ...s, type: 'sale' })),
                ...expenses.map(e => ({ ...e, type: 'expense' })),
                ...imports.map(i => ({ ...i, type: 'import', amount: i.phpAmount }))
            ].sort((a, b) => new Date(b.createdAt) - new Date(a.createdAt)).slice(0, 5);

            const container = document.getElementById('recent-transactions');
            
            if (all.length === 0) {
                container.innerHTML = '<p class="text-xs text-slate-400 text-center py-4">No transactions yet</p>';
                return;
            }

            container.innerHTML = all.map(tx => {
                const colors = {
                    sale: 'bg-emerald-100 text-emerald-600',
                    expense: 'bg-red-100 text-red-600',
                    import: 'bg-orange-100 text-orange-600'
                };
                const signs = { sale: '+', expense: '-', import: '-' };
                
                return `
                    <div class="flex items-center justify-between p-2 bg-slate-50 rounded-lg">
                        <div class="flex items-center gap-2">
                            <span class="px-2 py-0.5 ${colors[tx.type]} text-[9px] font-black uppercase rounded">${tx.type}</span>
                            <span class="text-xs text-slate-600 truncate max-w-[100px]">${tx.customer || tx.category || tx.supplier || 'Transaction'}</span>
                        </div>
                        <span class="text-xs font-bold ${tx.type === 'sale' ? 'text-emerald-600' : 'text-red-600'}">${signs[tx.type]}₱${tx.amount.toLocaleString()}</span>
                    </div>
                `;
            }).join('');
        }

        // Monthly Summary Modal
        function showMonthlySummary() {
            const modal = document.getElementById('monthly-summary-modal');
            const card = document.getElementById('summary-card');
            modal.classList.remove('opacity-0', 'pointer-events-none');
            card.classList.remove('scale-95');
            card.classList.add('scale-100');
            loadMonthlySummary();
        }

        function closeMonthlySummary() {
            const modal = document.getElementById('monthly-summary-modal');
            const card = document.getElementById('summary-card');
            modal.classList.add('opacity-0', 'pointer-events-none');
            card.classList.add('scale-95');
            card.classList.remove('scale-100');
        }

        function loadMonthlySummary() {
            const month = parseInt(document.getElementById('summary-month').value) - 1;
            const year = parseInt(document.getElementById('summary-year').value);
            const branchId = currentBranch?.id || 'default';

            const sales = JSON.parse(localStorage.getItem('coretex_sales') || '[]')
                .filter(s => {
                    const d = new Date(s.date);
                    return d.getMonth() === month && d.getFullYear() === year && s.branchId === branchId;
                });

            const expenses = JSON.parse(localStorage.getItem('coretex_expenses') || '[]')
                .filter(e => {
                    const d = new Date(e.date);
                    return d.getMonth() === month && d.getFullYear() === year && e.branchId === branchId;
                });

            const imports = JSON.parse(localStorage.getItem('coretex_imports') || '[]')
                .filter(i => {
                    const d = new Date(i.date);
                    return d.getMonth() === month && d.getFullYear() === year && i.branchId === branchId;
                });

            const totalSales = sales.reduce((sum, s) => sum + s.amount, 0);
            const totalExpenses = expenses.reduce((sum, e) => sum + e.amount, 0);
            const totalImports = imports.reduce((sum, i) => sum + i.phpAmount, 0);
            const profit = totalSales - totalExpenses - totalImports;
            const margin = totalSales > 0 ? ((profit / totalSales) * 100).toFixed(1) : 0;

            // Unique customers
            const uniqueCustomers = new Set(sales.map(s => s.customer).filter(c => c && c !== 'Walk-in Customer')).size;

            document.getElementById('summary-sales').textContent = `₱ ${totalSales.toLocaleString(undefined, {minimumFractionDigits: 2})}`;
            document.getElementById('summary-sales-count').textContent = `${sales.length} transactions`;
            document.getElementById('summary-expenses').textContent = `₱ ${totalExpenses.toLocaleString(undefined, {minimumFractionDigits: 2})}`;
            document.getElementById('summary-expenses-count').textContent = `${expenses.length} transactions`;
            document.getElementById('summary-imports').textContent = `₱ ${totalImports.toLocaleString(undefined, {minimumFractionDigits: 2})}`;
            document.getElementById('summary-imports-count').textContent = `${imports.length} transactions`;
            document.getElementById('summary-customers').textContent = uniqueCustomers + sales.filter(s => s.customer === 'Walk-in Customer').length;
            document.getElementById('summary-profit').textContent = `₱ ${profit.toLocaleString(undefined, {minimumFractionDigits: 2})}`;
            document.getElementById('summary-margin').textContent = `${margin}%`;
        }

        function submitToEDSS() {
            const month = parseInt(document.getElementById('summary-month').value);
            const year = parseInt(document.getElementById('summary-year').value);
            const branchId = currentBranch?.id || 'default';
            
            // Get summary data
            const sales = JSON.parse(localStorage.getItem('coretex_sales') || '[]')
                .filter(s => {
                    const d = new Date(s.date);
                    return d.getMonth() === month - 1 && d.getFullYear() === year && s.branchId === branchId;
                });
            const expenses = JSON.parse(localStorage.getItem('coretex_expenses') || '[]')
                .filter(e => {
                    const d = new Date(e.date);
                    return d.getMonth() === month - 1 && d.getFullYear() === year && e.branchId === branchId;
                });
            const imports = JSON.parse(localStorage.getItem('coretex_imports') || '[]')
                .filter(i => {
                    const d = new Date(i.date);
                    return d.getMonth() === month - 1 && d.getFullYear() === year && i.branchId === branchId;
                });

            const totalSales = sales.reduce((sum, s) => sum + s.amount, 0);
            const totalExpenses = expenses.reduce((sum, e) => sum + e.amount, 0);
            const totalImports = imports.reduce((sum, i) => sum + i.phpAmount, 0);
            const customers = new Set(sales.map(s => s.customer)).size + sales.filter(s => s.customer === 'Walk-in Customer').length;

            // Save to monthly summaries for EDSS
            const summaries = JSON.parse(localStorage.getItem('coretex_monthly_summaries') || '[]');
            const existingIdx = summaries.findIndex(s => s.month === month && s.year === year && s.branchId === branchId);
            
            const summary = {
                id: generateId(),
                month,
                year,
                branchId,
                branchName: currentBranch?.name || 'Davao Main',
                totalSales,
                totalExpenses,
                totalImports,
                customers,
                profit: totalSales - totalExpenses - totalImports,
                profitMargin: totalSales > 0 ? ((totalSales - totalExpenses - totalImports) / totalSales * 100).toFixed(1) : 0,
                status: 'Submitted',
                submittedAt: new Date().toISOString()
            };

            if (existingIdx >= 0) {
                summaries[existingIdx] = summary;
            } else {
                summaries.push(summary);
            }

            localStorage.setItem('coretex_monthly_summaries', JSON.stringify(summaries));

            // Also save to the old format for dashboard compatibility
            const monthNames = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];
            const dashboardData = JSON.parse(localStorage.getItem('coretex_monthly_data') || '[]');
            dashboardData.push({
                month: monthNames[month - 1],
                year: year.toString(),
                sales: totalSales,
                expenses: totalExpenses,
                customers,
                importedPHP: totalImports,
                profit: totalSales - totalExpenses - totalImports,
                profitMargin: summary.profitMargin,
                branchId,
                branchName: currentBranch?.name || 'Davao Main',
                timestamp: new Date().toISOString()
            });
            localStorage.setItem('coretex_monthly_data', JSON.stringify(dashboardData));

            logActivity('SUBMIT_EDSS', `Submitted ${monthNames[month - 1]} ${year} data for ${currentBranch?.name || 'Davao Main'} to EDSS`);
            
            closeMonthlySummary();
            showToast('Monthly data submitted to EDSS for analysis!');
        }

        // Utility functions
        function generateId() {
            return Date.now().toString(36) + Math.random().toString(36).substr(2);
        }

        function showToast(message) {
            const toast = document.getElementById('success-toast');
            document.getElementById('toast-message').textContent = message;
            toast.classList.remove('translate-y-20', 'opacity-0');
            setTimeout(() => {
                toast.classList.add('translate-y-20', 'opacity-0');
            }, 3000);
        }

        function logActivity(action, description) {
            const activities = JSON.parse(localStorage.getItem('coretex_activities') || '[]');
            activities.unshift({
                id: generateId(),
                action,
                description,
                type: action.includes('SALE') ? 'transaction' : action.includes('EXPENSE') ? 'transaction' : action.includes('IMPORT') ? 'transaction' : 'system',
                user: 'Finance Officer',
                branch: currentBranch?.name || 'Davao Main',
                timestamp: new Date().toISOString()
            });
            // Keep only last 500 activities
            localStorage.setItem('coretex_activities', JSON.stringify(activities.slice(0, 500)));
        }
    </script>
}
