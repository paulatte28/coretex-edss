@{
    ViewData["Title"] = "Business Data Entry";
    Layout = "_AdminLayout";
}

<div class="space-y-10">
    <div>
        <div class="flex items-center space-x-3 mb-2">
            <span class="px-3 py-1 bg-indigo-100 text-indigo-700 font-black text-[10px] uppercase tracking-widest rounded-full">Secure Entry</span>
            <span class="px-3 py-1 bg-slate-100 text-slate-500 font-bold text-[10px] uppercase tracking-widest rounded-full">Monthly Figures</span>
        </div>
        <h2 class="text-3xl font-black text-slate-900 tracking-tight">Submit Business Data</h2>
        <p class="text-xs text-slate-400 font-bold uppercase tracking-widest mt-2">Log your simple monthly figures. Automated currency conversion included.</p>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="p-4 mb-4 text-sm text-emerald-800 rounded-2xl bg-emerald-50 border border-emerald-100 shadow-sm" role="alert">
            <strong class="font-black tracking-tight">Success!</strong> @TempData["SuccessMessage"]
        </div>
    }

    <div class="max-w-4xl">
        <div class="bg-white p-8 rounded-[2.5rem] shadow-lg shadow-slate-200/50 border border-slate-100 relative overflow-hidden group">
            <div class="absolute -right-10 -top-10 w-40 h-40 bg-emerald-50 rounded-full blur-3xl opacity-50 group-hover:opacity-100 transition-opacity"></div>
            
            <div class="relative z-10">
                <div class="flex items-center space-x-4 mb-8">
                     <div class="w-14 h-14 bg-gradient-to-br from-emerald-400 to-emerald-600 text-white rounded-2xl flex items-center justify-center shadow-lg shadow-emerald-500/30 transform -rotate-3 group-hover:rotate-0 transition-transform">
                          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                     </div>
                     <div>
                         <h3 class="text-xl font-black text-slate-800 tracking-tight">Monthly Performance</h3>
                         <p class="text-[10px] uppercase tracking-widest font-bold text-slate-400 mt-1">Record totals for the current month</p>
                     </div>
                </div>
                
                <form asp-action="SubmitMonthlyData" method="post" class="space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <!-- Left Column -->
                        <div class="space-y-6">
                            <div>
                                <label class="block text-[10px] font-black text-slate-700 uppercase tracking-widest mb-2 pl-2">Total Sales Revenue (₱)</label>
                                <input type="number" step="0.01" name="TotalRevenue" class="w-full bg-slate-50 border-2 border-slate-100 rounded-2xl py-3.5 px-5 text-sm font-semibold focus:border-emerald-500 focus:ring-4 focus:ring-emerald-500/10 outline-none transition-all" placeholder="500000" required>
                                <p class="text-[9px] font-bold text-slate-400 uppercase tracking-widest mt-1 pl-2">Currency: PHP</p>
                            </div>
                            
                            <div>
                                <label class="block text-[10px] font-black text-slate-700 uppercase tracking-widest mb-2 pl-2">Total Expenses (₱)</label>
                                <input type="number" step="0.01" name="TotalExpenses" class="w-full bg-slate-50 border-2 border-slate-100 rounded-2xl py-3.5 px-5 text-sm font-semibold focus:border-emerald-500 focus:ring-4 focus:ring-emerald-500/10 outline-none transition-all" placeholder="200000" required>
                                <p class="text-[9px] font-bold text-slate-400 uppercase tracking-widest mt-1 pl-2">Currency: PHP</p>
                            </div>

                            <div>
                                <label class="block text-[10px] font-black text-slate-700 uppercase tracking-widest mb-2 pl-2">Number of Customers</label>
                                <input type="number" name="CustomerCount" class="w-full bg-slate-50 border-2 border-slate-100 rounded-2xl py-3.5 px-5 text-sm font-semibold focus:border-emerald-500 focus:ring-4 focus:ring-emerald-500/10 outline-none transition-all" placeholder="150" required>
                            </div>
                        </div>

                        <!-- Right Column (Import/Supplier Data) -->
                        <div class="space-y-6">
                            <div>
                                <label class="block text-[10px] font-black text-slate-700 uppercase tracking-widest mb-2 pl-2">Cost of Imported Products</label>
                                <div class="flex space-x-2">
                                    <input type="number" step="0.01" id="ImportedCost" name="ImportedCostRaw" class="w-full bg-slate-50 border-2 border-slate-100 rounded-2xl py-3.5 px-5 text-sm font-semibold focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 outline-none transition-all" placeholder="2000" oninput="convertCurrency()" onchange="convertCurrency()">
                                    <select id="ImportedCurrency" class="w-32 bg-slate-50 border-2 border-slate-100 rounded-2xl py-3.5 px-3 text-sm font-black focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 outline-none transition-all cursor-pointer" onchange="convertCurrency()">
                                        <option value="PHP">PHP</option>
                                        <option value="USD" selected>USD</option>
                                        <option value="CNY">CNY</option>
                                        <option value="EUR">EUR</option>
                                    </select>
                                </div>
                                <input type="hidden" id="HiddenPhpCost" name="CostOfImportedProducts_PHP" value="0" />
                                
                                <!-- Dynamic Convert UI Box -->
                                <div id="convertedDisplay" class="hidden mt-3 p-3 bg-indigo-50/50 border border-indigo-100 rounded-xl flex items-center justify-between transition-all duration-300">
                                    <div>
                                        <p class="text-[9px] font-bold text-indigo-400 uppercase tracking-widest">Auto-Converted to PHP</p>
                                        <p id="rateText" class="text-[10px] font-semibold text-slate-500 mt-0.5">Live Rate: Fetching...</p>
                                    </div>
                                    <div class="text-right">
                                        <p id="convertedAmount" class="text-base font-black text-indigo-700 tracking-tight">₱...</p>
                                    </div>
                                </div>
                            </div>
                            
                            <div>
                                <label class="block text-[10px] font-black text-slate-700 uppercase tracking-widest mb-2 pl-2">Supplier Name</label>
                                <input type="text" name="SupplierName" class="w-full bg-slate-50 border-2 border-slate-100 rounded-2xl py-3.5 px-5 text-sm font-semibold focus:border-emerald-500 focus:ring-4 focus:ring-emerald-500/10 outline-none transition-all" placeholder="e.g. Shenzhen Tech Co.">
                            </div>

                            <div>
                                <label class="block text-[10px] font-black text-slate-700 uppercase tracking-widest mb-2 pl-2">Product Category</label>
                                <input type="text" name="ProductCategory" class="w-full bg-slate-50 border-2 border-slate-100 rounded-2xl py-3.5 px-5 text-sm font-semibold focus:border-emerald-500 focus:ring-4 focus:ring-emerald-500/10 outline-none transition-all" placeholder="e.g. Smartphones, Accessories">
                            </div>
                        </div>
                    </div>
                    
                    <div class="pt-4 border-t border-slate-100 mt-6">
                        <button type="submit" class="w-full bg-slate-900 text-white font-black py-4 rounded-2xl hover:bg-emerald-500 hover:shadow-lg hover:shadow-emerald-500/30 transition-all transform hover:-translate-y-1">Submit Monthly Business Data</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    let convertTimeout;
    
    async function convertCurrency() {
        const amountInput = document.getElementById('ImportedCost');
        const currencySelect = document.getElementById('ImportedCurrency');
        const displayDiv = document.getElementById('convertedDisplay');
        const convertedAmount = document.getElementById('convertedAmount');
        const rateText = document.getElementById('rateText');
        const hiddenPhpCost = document.getElementById('HiddenPhpCost');
        
        let amount = parseFloat(amountInput.value);
        let currency = currencySelect.value;
        
        if (!amount || amount <= 0 || currency === 'PHP') {
            displayDiv.classList.add('hidden');
            hiddenPhpCost.value = amount || 0;
            return;
        }
        
        // Add debounce so it doesn't spam api
        clearTimeout(convertTimeout);
        
        // Show loading state immediately
        displayDiv.classList.remove('hidden');
        convertedAmount.innerHTML = '<span class="flex items-center space-x-2 text-sm"><svg class="animate-spin h-4 w-4 text-indigo-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> <span class="text-indigo-400">Fetching rate...</span></span>';
        rateText.innerText = `Connecting to API...`;

        convertTimeout = setTimeout(async () => {
            try {
                let response = await fetch(`https://api.exchangerate-api.com/v4/latest/${currency}`);
                let data = await response.json();
                let rate = data.rates['PHP'];
                let finalPhp = amount * rate;
                
                hiddenPhpCost.value = finalPhp;
                
                // Output display
                convertedAmount.innerHTML = `₱${finalPhp.toLocaleString('en-PH', {minimumFractionDigits: 2, maximumFractionDigits:2})}`;
                rateText.innerText = `Live Rate: 1 ${currency} = ₱${rate.toFixed(2)}`;
            } catch(e) {
                convertedAmount.innerHTML = `<span class="text-rose-500 text-sm">Conversion Error</span>`;
                rateText.innerText = `Could not fetch live rate.`;
                hiddenPhpCost.value = amount;
            }
        }, 600); // 600ms debounce
    }
    
    // Trigger conversion if pre-filled on load
    window.addEventListener('load', () => {
        if (document.getElementById('ImportedCost').value) convertCurrency();
    });
</script>
}
