@{
    ViewData["Title"] = "Record Business Data";
    Layout = "_AdminLayout";
}

<div class="space-y-10">
    <!-- Header with IPGeolocation Tracking -->
    <div class="flex items-center justify-between">
        <div>
            <div class="flex items-center space-x-3 mb-2">
                <span id="login-badge" class="px-3 py-1 bg-emerald-100 text-emerald-700 font-black text-[10px] uppercase tracking-widest rounded-full flex items-center space-x-2">
                    <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full animate-pulse"></span>
                    <span>Finance Officer Session</span>
                </span>
                <span id="geo-location" class="px-3 py-1 bg-slate-100 text-slate-500 font-bold text-[10px] uppercase tracking-widest rounded-full">
                    Detecting Login Location...
                </span>
            </div>
            <h2 class="text-3xl font-black text-slate-900 tracking-tight">Monthly Performance Entry</h2>
            <p class="text-xs text-slate-400 font-bold uppercase tracking-widest mt-2">Initialize your monthly metrics for KPI analysis</p>
        </div>
        
        <div class="flex items-center space-x-3">
             <div class="text-right">
                <p class="text-[10px] font-black uppercase text-slate-400">Reporting For</p>
                <div class="flex space-x-2 mt-1">
                    <select id="report-month" class="text-xs font-bold bg-white border border-slate-200 rounded-lg py-1 px-2">
                        <option value="January">January</option>
                        <option value="February">February</option>
                        <option value="March" selected>March</option>
                        <option value="April">April</option>
                        <option value="May">May</option>
                        <option value="June">June</option>
                        <option value="July">July</option>
                        <option value="August">August</option>
                        <option value="September">September</option>
                        <option value="October">October</option>
                        <option value="November">November</option>
                        <option value="December">December</option>
                    </select>
                    <select id="report-year" class="text-xs font-bold bg-white border border-slate-200 rounded-lg py-1 px-2">
                        <option value="2026" selected>2026</option>
                        <option value="2025">2025</option>
                    </select>
                </div>
             </div>
        </div>
    </div>

    <!-- Data Entry Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">
        
        <!-- Primary Form -->
        <div class="lg:col-span-8 bg-white rounded-[3rem] shadow-xl shadow-slate-200/50 border border-slate-100 overflow-hidden">
            <div class="p-10 space-y-10">
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
                    <!-- Total Sales Revenue in PHP -->
                    <div class="space-y-3">
                        <label class="text-[10px] font-black text-slate-500 uppercase tracking-widest ml-2 flex items-center space-x-2">
                            <svg class="w-3 h-3 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                            <span>Total Sales Revenue (PHP)</span>
                        </label>
                        <div class="relative">
                            <span class="absolute left-6 top-1/2 -translate-y-1/2 font-black text-slate-400">₱</span>
                            <input type="number" id="sales" placeholder="0.00" class="w-full bg-slate-50 border-2 border-slate-100 rounded-2xl py-4 pl-12 pr-6 text-lg font-black focus:border-emerald-500 outline-none transition-all">
                        </div>
                    </div>

                    <!-- Total Expenses in PHP -->
                    <div class="space-y-3">
                        <label class="text-[10px] font-black text-slate-500 uppercase tracking-widest ml-2 flex items-center space-x-2">
                            <svg class="w-3 h-3 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                            <span>Total Expenses (PHP)</span>
                        </label>
                        <div class="relative">
                            <span class="absolute left-6 top-1/2 -translate-y-1/2 font-black text-slate-400">₱</span>
                            <input type="number" id="expenses" placeholder="0.00" class="w-full bg-slate-50 border-2 border-slate-100 rounded-2xl py-4 pl-12 pr-6 text-lg font-black focus:border-red-500 outline-none transition-all">
                        </div>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-10 pt-10 border-t border-slate-50">
                    <!-- Customer Count -->
                    <div class="space-y-3">
                        <label class="text-[10px] font-black text-slate-500 uppercase tracking-widest ml-2 flex items-center space-x-2">
                            <svg class="w-3 h-3 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
                            <span>Customers Served</span>
                        </label>
                        <input type="number" id="customers" placeholder="e.g. 1450" class="w-full bg-slate-50 border-2 border-slate-100 rounded-2xl py-4 px-6 text-lg font-black focus:border-blue-500 outline-none transition-all">
                    </div>

                    <!-- Imported Cost - PHP Automated Conversion -->
                    <div class="space-y-3 min-w-0">
                        <label class="text-[10px] font-black text-slate-500 uppercase tracking-widest ml-2 flex items-center space-x-2">
                            <svg class="w-3 h-3 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>
                            <span class="truncate">Imported Product Cost (Foreign)</span>
                        </label>
                        <div class="flex items-center space-x-3 w-full">
                            <div class="relative shrink-0">
                                <select id="currency" class="w-28 bg-slate-100 border-none rounded-2xl py-4 px-3 text-[10px] font-black text-slate-700 outline-none cursor-pointer appearance-none">
                                    <option value="USD">USD ($)</option>
                                    <option value="CNY">CNY (¥)</option>
                                    <option value="EUR">EUR (€)</option>
                                    <option value="JPY">JPY (¥)</option>
                                </select>
                                <svg class="w-3 h-3 absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                            </div>
                            <input type="number" id="imported-foreign" placeholder="0.00" class="min-w-0 flex-1 bg-slate-50 border-2 border-slate-100 rounded-2xl py-4 px-6 text-lg font-black focus:border-orange-500 outline-none transition-all">
                        </div>
                    </div>
                </div>

                <!-- Conversion Output -->
                <div id="conversion-panel" class="bg-gradient-to-r from-orange-50 to-amber-50 p-8 rounded-[2rem] border border-orange-100 space-y-4 opacity-50 grayscale transition-all duration-500">
                    <div class="flex items-center justify-between">
                        <div class="flex items-center space-x-3">
                            <div class="w-10 h-10 bg-white shadow-sm rounded-xl flex items-center justify-center text-orange-500">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
                            </div>
                            <div>
                                <p class="text-[9px] font-black uppercase tracking-[0.2em] text-orange-400">Live Exchange Rate Engine</p>
                                <p id="exchange-rate-text" class="text-xs font-bold text-slate-700">1 USD = ₱ 0.00</p>
                            </div>
                        </div>
                        <div class="text-right">
                            <p class="text-[9px] font-black uppercase tracking-[0.2em] text-orange-400">Converted Amount</p>
                            <p id="imported-php" class="text-2xl font-black text-slate-900 tracking-tighter">₱ 0.00</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="p-10 bg-slate-50 border-t border-slate-100">
                <button onclick="submitPerformanceData()" class="w-full py-5 bg-slate-900 text-white font-black rounded-[1.5rem] shadow-xl shadow-slate-900/20 hover:scale-[1.01] active:scale-95 transition-all">
                    Register Monthly Performance
                </button>
            </div>
        </div>

        <!-- System Intelligence Sidebar (Static Context) -->
        <div class="lg:col-span-4 space-y-8">
            <div class="bg-white p-8 rounded-[2.5rem] border border-slate-50 shadow-sm relative overflow-hidden group">
                <div class="absolute top-0 right-0 w-32 h-32 bg-indigo-50 rounded-full blur-3xl opacity-50 group-hover:opacity-100 transition-all"></div>
                <h4 class="text-xs font-black uppercase tracking-widest text-slate-400 mb-6">Automation Status</h4>
                
                <div class="space-y-6 relative z-10">
                    <div class="flex items-center justify-between">
                         <span class="text-xs font-bold text-slate-600">ExchangeRate-API</span>
                         <span class="px-2 py-0.5 bg-emerald-100 text-emerald-600 text-[9px] font-black uppercase rounded">Connected</span>
                    </div>
                    <div class="flex items-center justify-between">
                         <span class="text-xs font-bold text-slate-600">Normalization</span>
                         <span class="px-2 py-0.5 bg-emerald-100 text-emerald-600 text-[9px] font-black uppercase rounded">Auto-PHP</span>
                    </div>
                    <div class="flex items-center justify-between">
                         <span class="text-xs font-bold text-slate-600">IP-Tracking</span>
                         <span class="px-2 py-0.5 bg-blue-100 text-blue-600 text-[9px] font-black uppercase rounded">Identity Verified</span>
                    </div>
                </div>
            </div>

            <div class="bg-slate-900 p-8 rounded-[2.5rem] shadow-2xl space-y-6">
                <div class="flex items-center space-x-3">
                    <div class="w-8 h-8 bg-amber-500 rounded-xl flex items-center justify-center text-white">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    </div>
                    <p class="text-[10px] font-black uppercase tracking-widest text-amber-200">System Tip</p>
                </div>
                <p class="text-xs text-slate-400 font-medium leading-relaxed">
                    Accurate Imported Costs are critical for determining final profit margins. The system uses real-time market rates for translation.
                </p>
            </div>
        </div>
    </div>
</div>

<!-- PHASE 4: AUTOMATED PROCESSING OVERLAY -->
<div id="processing-overlay" class="fixed inset-0 z-[100] bg-slate-900/60 backdrop-blur-xl flex items-center justify-center opacity-0 pointer-events-none transition-all duration-700">
    <div class="max-w-2xl w-full mx-6 bg-white rounded-[3rem] shadow-2xl overflow-hidden transform scale-90 transition-all duration-700" id="processing-card">
        <div class="p-12 space-y-10">
            <div class="text-center space-y-4">
                <div class="inline-flex items-center justify-center w-20 h-20 bg-indigo-50 rounded-3xl relative">
                    <div class="absolute inset-0 border-4 border-indigo-500 border-t-transparent rounded-3xl animate-spin"></div>
                    <svg class="w-10 h-10 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>
                </div>
                <h3 class="text-2xl font-black text-slate-900">Intelligence Engine Processing</h3>
                <p class="text-xs font-bold text-slate-400 uppercase tracking-[0.2em]">Phase 4: Automated Data Computation</p>
            </div>

            <div class="space-y-6" id="process-steps">
                <!-- Step 1: Computations -->
                <div class="flex items-center justify-between p-5 bg-slate-50 rounded-2xl border border-slate-100 transition-all duration-500 opacity-40" id="step-compute">
                    <div class="flex items-center space-x-4">
                        <div class="w-8 h-8 bg-white shadow-sm rounded-lg flex items-center justify-center text-slate-400" id="icon-compute">
                            <span class="text-xs font-black">01</span>
                        </div>
                        <div>
                            <p class="text-[10px] font-black uppercase text-slate-400">Step 1</p>
                            <p class="text-sm font-bold text-slate-700">Financial Metric Calculations</p>
                        </div>
                    </div>
                    <div class="text-right" id="status-compute">
                        <span class="text-[10px] font-black text-slate-400">WAITING</span>
                    </div>
                </div>

                <!-- Step 2: Forecasts -->
                <div class="flex items-center justify-between p-5 bg-slate-50 rounded-2xl border border-slate-100 transition-all duration-500 opacity-40" id="step-forecast">
                    <div class="flex items-center space-x-4">
                        <div class="w-8 h-8 bg-white shadow-sm rounded-lg flex items-center justify-center text-slate-400" id="icon-forecast">
                            <span class="text-xs font-black">02</span>
                        </div>
                        <div>
                            <p class="text-[10px] font-black uppercase text-slate-400">Step 2</p>
                            <p class="text-sm font-bold text-slate-700">Predictive Trend Forecasting</p>
                        </div>
                    </div>
                    <div class="text-right" id="status-forecast">
                        <span class="text-[10px] font-black text-slate-400">WAITING</span>
                    </div>
                </div>

                <!-- Step 3: Thresholds -->
                <div class="flex items-center justify-between p-5 bg-slate-50 rounded-2xl border border-slate-100 transition-all duration-500 opacity-40" id="step-threshold">
                    <div class="flex items-center space-x-4">
                        <div class="w-8 h-8 bg-white shadow-sm rounded-lg flex items-center justify-center text-slate-400" id="icon-threshold">
                            <span class="text-xs font-black">03</span>
                        </div>
                        <div>
                            <p class="text-[10px] font-black uppercase text-slate-400">Step 3</p>
                            <p class="text-sm font-bold text-slate-700">KPI Threshold Comparison</p>
                        </div>
                    </div>
                    <div class="text-right" id="status-threshold">
                        <span class="text-[10px] font-black text-slate-400">WAITING</span>
                    </div>
                </div>
            </div>

            <div id="processing-result" class="hidden animate-in fade-in slide-in-from-bottom-4">
                <div class="p-6 bg-emerald-50 rounded-[2rem] border border-emerald-100 flex items-center justify-between">
                    <div class="flex items-center space-x-4">
                        <div class="w-12 h-12 bg-emerald-500 text-white rounded-2xl flex items-center justify-center shadow-lg shadow-emerald-500/20">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                        </div>
                        <div>
                            <p class="text-sm font-black text-emerald-900">Processing Complete</p>
                            <p class="text-[10px] font-bold text-emerald-600 uppercase tracking-widest">Insights Generated</p>
                        </div>
                    </div>
                    <button onclick="window.location.href='/Dashboard'" class="px-6 py-3 bg-emerald-600 text-white text-xs font-black rounded-xl hover:bg-emerald-700 transition-all">
                        View Analytics
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- TWILIO SMS HUD -->
<div id="twilio-hud" class="fixed top-10 right-10 z-[110] transform translate-x-[120%] transition-all duration-500 pointer-events-none">
    <div class="bg-slate-900 text-white p-6 rounded-[2rem] shadow-[0_20px_50px_rgba(0,0,0,0.3)] border border-slate-800 flex items-start space-x-5 max-w-sm">
        <div class="w-12 h-12 bg-[#F22F46] rounded-2xl flex items-center justify-center shrink-0">
            <svg class="w-6 h-6 text-white" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.5 15.5h-9c-.83 0-1.5-.67-1.5-1.5V8c0-.83.67-1.5 1.5-1.5h9c.83 0 1.5.67 1.5 1.5v8c0 .83-.67 1.5-1.5 1.5zM12 8.5c-1.38 0-2.5 1.12-2.5 2.5s1.12 2.5 2.5 2.5 2.5-1.12 2.5-2.5-1.12-2.5-2.5-2.5z"/></svg>
        </div>
        <div class="space-y-1">
            <div class="flex items-center justify-between">
                <p class="text-[10px] font-black uppercase text-red-500 tracking-widest">Twilio SMS Triggered</p>
                <div class="w-1.5 h-1.5 bg-red-500 rounded-full animate-ping"></div>
            </div>
            <p class="text-xs font-bold text-white">Alert Sent to Business Owner</p>
            <p class="text-[10px] text-slate-400 leading-relaxed font-medium">Critical KPI Breach: Profit dropped below configured threshold (₱50,000).</p>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let currentRate = 0;

        // 1. IPGeolocation on Login (Simulation)
        document.addEventListener('DOMContentLoaded', async () => {
            const geoEl = document.getElementById('geo-location');
            try {
                const response = await fetch('https://ipapi.co/json/');
                const data = await response.json();
                geoEl.innerText = `${data.city}, ${data.country_name} (${data.ip})`;
            } catch (e) {
                geoEl.innerText = 'Quezon City, PH (Static context 192.168.1.5)';
            }
            updateRate();
            loadMonthYear();
        });

        function loadMonthYear() {
            // Optional: Auto-select previous month as defaults
            const d = new Date();
            d.setMonth(d.getMonth() - 1);
            const months = ["January","February","March","April","May","June","July","August","September","October","November","December"];
            document.getElementById('report-month').value = months[d.getMonth()];
        }

        // 2. Real-time Currency Conversion Logic
        async function updateRate() {
            const currency = document.getElementById('currency').value;
            const rateText = document.getElementById('exchange-rate-text');
            
            try {
                // Use ExchangeRate-API (USD base typically)
                const res = await fetch(`https://api.exchangerate-api.com/v4/latest/${currency}`);
                const data = await res.json();
                currentRate = data.rates.PHP;
                rateText.innerText = `1 ${currency} = ₱ ${currentRate.toFixed(2)}`;
                calculateConvertedTotal();
            } catch (e) {
                // Fallbacks if API blocked
                const fallbacks = { 'USD': 57.20, 'CNY': 7.90, 'EUR': 62.10, 'JPY': 0.38 };
                currentRate = fallbacks[currency] || 1;
                rateText.innerText = `1 ${currency} = ₱ ${currentRate.toFixed(2)} (Cached)`;
                calculateConvertedTotal();
            }
        }

        function calculateConvertedTotal() {
            const foreignVal = parseFloat(document.getElementById('imported-foreign').value) || 0;
            const phpOutput = document.getElementById('imported-php');
            const panel = document.getElementById('conversion-panel');

            if (foreignVal > 0) {
                const converted = foreignVal * currentRate;
                phpOutput.innerText = `₱ ${converted.toLocaleString(undefined, {minimumFractionDigits: 2})}`;
                panel.classList.remove('opacity-50', 'grayscale');
            } else {
                phpOutput.innerText = `₱ 0.00`;
                panel.classList.add('opacity-50', 'grayscale');
            }
        }

        document.getElementById('currency').addEventListener('change', updateRate);
        document.getElementById('imported-foreign').addEventListener('input', calculateConvertedTotal);

        // 3. Submission & Phase 4 Automated Processing
        async function submitPerformanceData() {
            const data = {
                month: document.getElementById('report-month').value,
                year: document.getElementById('report-year').value,
                sales: parseFloat(document.getElementById('sales').value) || 0,
                expenses: parseFloat(document.getElementById('expenses').value) || 0,
                customers: parseInt(document.getElementById('customers').value) || 0,
                importedForeign: parseFloat(document.getElementById('imported-foreign').value) || 0,
                currency: document.getElementById('currency').value,
                importedPHP: (parseFloat(document.getElementById('imported-foreign').value) || 0) * currentRate,
                timestamp: new Date().toISOString()
            };

            if (data.sales === 0) {
                alert('Sales revenue must be recorded.');
                return;
            }

            // Start Overlay
            const overlay = document.getElementById('processing-overlay');
            const card = document.getElementById('processing-card');
            overlay.classList.remove('opacity-0', 'pointer-events-none');
            card.classList.remove('scale-90');
            card.classList.add('scale-100');

            await delay(800);

            // Step 1: Computations
            updateStepState('compute', 'RUNNING');
            const metrics = calculateMetrics(data);
            await delay(1200);
            updateStepState('compute', 'COMPLETED', metrics.profitMargin + '%');

            // Step 2: Forecasts
            updateStepState('forecast', 'RUNNING');
            const forecasts = generateForecasts(data);
            await delay(1500);
            updateStepState('forecast', 'COMPLETED', forecasts.trend);

            // Step 3: Thresholds & SMS
            updateStepState('threshold', 'RUNNING');
            const alerts = checkThresholds(metrics);
            await delay(1000);
            updateStepState('threshold', 'COMPLETED', alerts.length > 0 ? 'BREACH FOUND' : 'OPTIMAL');

            if (alerts.length > 0) {
                triggerTwilioSMS(alerts);
                await delay(1000);
            }

            // Persistence
            saveProcessedData(data, metrics, forecasts, alerts);

            // Finish
            document.getElementById('processing-result').classList.remove('hidden');
        }

        function delay(ms) { return new Promise(res => setTimeout(res, ms)); }

        function updateStepState(step, state, value = '') {
            const row = document.getElementById(`step-${step}`);
            const icon = document.getElementById(`icon-${step}`);
            const status = document.getElementById(`status-${step}`);

            if (state === 'RUNNING') {
                row.classList.remove('opacity-40');
                row.classList.add('bg-indigo-50/50', 'border-indigo-200');
                status.innerHTML = `<div class="w-4 h-4 border-2 border-indigo-600 border-t-transparent rounded-full animate-spin"></div>`;
            } else if (state === 'COMPLETED') {
                row.classList.remove('bg-indigo-50/50', 'border-indigo-200');
                row.classList.add('bg-white', 'border-slate-100');
                icon.innerHTML = `<svg class="w-5 h-5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>`;
                icon.classList.remove('text-slate-400');
                icon.classList.add('bg-emerald-50');
                status.innerHTML = `<span class="text-[10px] font-black text-emerald-600">${value}</span>`;
            }
        }

        function calculateMetrics(data) {
            const profit = data.sales - data.expenses;
            const margin = ((profit / data.sales) * 100).toFixed(1);
            const ratio = ((data.expenses / data.sales) * 100).toFixed(1);
            return { profit, profitMargin: margin, expenseRatio: ratio };
        }

        function generateForecasts(data) {
            const history = JSON.parse(localStorage.getItem('coretex_monthly_data') || '[]');
            if (history.length < 2) return { trend: 'STABLE (Insuff. Data)', forecast: data.sales };
            
            const lastMonth = history[history.length - 1].sales;
            const trend = data.sales > lastMonth ? 'UPWARD' : data.sales < lastMonth ? 'DOWNWARD' : 'FLAT';
            return { trend: trend, forecast: data.sales * 1.05 }; // Simple 5% growth projection
        }

        function checkThresholds(metrics) {
            const config = JSON.parse(localStorage.getItem('coretex_system_config') || '{"profitFloor": 50000, "expenseCap": 80}');
            const breaches = [];
            
            if (metrics.profit < parseFloat(config.profitFloor)) breaches.push(`Profit below Floor: ₱${metrics.profit.toLocaleString()}`);
            if (parseFloat(metrics.expenseRatio) > parseFloat(config.expenseCap)) breaches.push(`Expenses above Cap: ${metrics.expenseRatio}%`);
            
            return breaches;
        }

        function triggerTwilioSMS(alerts) {
            const hud = document.getElementById('twilio-hud');
            hud.classList.remove('translate-x-[120%]', 'pointer-events-none');
            setTimeout(() => {
                hud.classList.add('translate-x-[120%]', 'pointer-events-none');
            }, 5000);
        }

        function saveProcessedData(data, metrics, forecasts, alerts) {
            let dashboardData = JSON.parse(localStorage.getItem('coretex_monthly_data') || '[]');
            const entry = { ...data, ...metrics, ...forecasts, alerts };
            dashboardData.push(entry);
            localStorage.setItem('coretex_monthly_data', JSON.stringify(dashboardData));
            
            // Branch comparison mock
            const branchPerf = {
                mainBranch: metrics.profitMargin,
                eastBranch: (parseFloat(metrics.profitMargin) - 2.5).toFixed(1),
                westBranch: (parseFloat(metrics.profitMargin) + 1.2).toFixed(1)
            };
            localStorage.setItem('coretex_branch_latest', JSON.stringify(branchPerf));
            
            // Health Summary
            let health = 'B+';
            if (parseFloat(metrics.profitMargin) > 30) health = 'A';
            if (parseFloat(metrics.profitMargin) > 45) health = 'A+';
            if (alerts.length > 0) health = 'C-';
            localStorage.setItem('coretex_business_health', health);
        }
    </script>
}
