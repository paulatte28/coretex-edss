@{
	ViewData["Title"] = "Data Entry History";
	Layout = "_AdminLayout";
}

<div class="space-y-8">
	<div class="bg-white rounded-3xl border border-slate-100 shadow-sm p-6">
		<div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
			<div>
				<h2 class="text-3xl font-black text-slate-900 tracking-tight">Data Entry History</h2>
				<p class="text-xs text-slate-500 font-bold uppercase tracking-widest mt-1">Filter and maintain monthly records used by CEO analytics</p>
			</div>
			<a href="/DataEntry" class="px-4 py-2 bg-slate-900 text-white text-xs font-black rounded-xl hover:bg-slate-800 transition-colors">
				Add New Entry
			</a>
		</div>
	</div>

	<div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-6">
		<div class="grid grid-cols-1 md:grid-cols-3 gap-4">
			<div>
				<label for="filter-month" class="block text-[10px] font-black text-slate-500 uppercase tracking-widest mb-2">Month</label>
				<input id="filter-month" type="month" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm font-semibold" />
			</div>
			<div>
				<label for="filter-branch" class="block text-[10px] font-black text-slate-500 uppercase tracking-widest mb-2">Branch</label>
				<select id="filter-branch" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm font-semibold"></select>
			</div>
			<div>
				<label for="filter-search" class="block text-[10px] font-black text-slate-500 uppercase tracking-widest mb-2">Search Branch Name</label>
				<input id="filter-search" type="text" placeholder="Type branch name" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm font-semibold" />
			</div>
		</div>
	</div>

	<div class="bg-white rounded-3xl border border-slate-100 shadow-sm overflow-hidden">
		<div class="overflow-x-auto">
			<table class="w-full">
				<thead class="bg-slate-50">
					<tr>
						<th class="px-5 py-4 text-left text-[10px] font-black text-slate-500 uppercase tracking-widest">Month</th>
						<th class="px-5 py-4 text-left text-[10px] font-black text-slate-500 uppercase tracking-widest">Branch</th>
						<th class="px-5 py-4 text-right text-[10px] font-black text-slate-500 uppercase tracking-widest">Sales</th>
						<th class="px-5 py-4 text-right text-[10px] font-black text-slate-500 uppercase tracking-widest">Expenses</th>
						<th class="px-5 py-4 text-right text-[10px] font-black text-slate-500 uppercase tracking-widest">Profit</th>
						<th class="px-5 py-4 text-right text-[10px] font-black text-slate-500 uppercase tracking-widest">Margin</th>
						<th class="px-5 py-4 text-right text-[10px] font-black text-slate-500 uppercase tracking-widest">Updated</th>
						<th class="px-5 py-4 text-center text-[10px] font-black text-slate-500 uppercase tracking-widest">Actions</th>
					</tr>
				</thead>
				<tbody id="history-rows" class="divide-y divide-slate-100">
					<tr>
						<td colspan="8" class="px-5 py-10 text-center text-xs text-slate-400 italic">No records found.</td>
					</tr>
				</tbody>
			</table>
		</div>
	</div>
</div>

<div id="history-toast" class="fixed bottom-6 right-6 z-50 transform translate-y-20 opacity-0 transition-all duration-300">
	<div class="bg-slate-900 text-white px-5 py-3 rounded-xl shadow-lg text-sm font-bold">Record archived.</div>
</div>

@section Scripts {
	<script>
		(function () {
			'use strict';

			const STORAGE_KEY = 'coretex_monthly_data';
			const BRANCH_KEY = 'coretex_branches';

			const filterMonth = document.getElementById('filter-month');
			const filterBranch = document.getElementById('filter-branch');
			const filterSearch = document.getElementById('filter-search');

			function toNumber(value) {
				const parsed = Number(value);
				return Number.isFinite(parsed) ? parsed : 0;
			}

			function readEntries() {
				try {
					const parsed = JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
					return Array.isArray(parsed) ? parsed : [];
				} catch (_error) {
					return [];
				}
			}

			function writeEntries(entries) {
				localStorage.setItem(STORAGE_KEY, JSON.stringify(entries.slice(0, 1500)));
			}

			function readBranches() {
				try {
					const parsed = JSON.parse(localStorage.getItem(BRANCH_KEY) || '[]');
					if (!Array.isArray(parsed) || parsed.length === 0) {
						return [{ id: 'branch_default', name: 'Main Branch' }];
					}

					return parsed.map(item => ({
						id: String(item.id || 'branch_default'),
						name: String(item.name || 'Unnamed Branch')
					}));
				} catch (_error) {
					return [{ id: 'branch_default', name: 'Main Branch' }];
				}
			}

			function monthKeyFromEntry(entry) {
				if (entry && /^\d{4}-\d{2}$/.test(String(entry.monthKey || ''))) {
					return entry.monthKey;
				}

				if (entry && entry.month && entry.year) {
					const parsed = new Date(`${entry.month} 1, ${entry.year}`);
					if (!Number.isNaN(parsed.getTime())) {
						const year = parsed.getFullYear();
						const month = String(parsed.getMonth() + 1).padStart(2, '0');
						return `${year}-${month}`;
					}
				}

				return null;
			}

			function monthLabelFromKey(monthKey) {
				const parsed = new Date(`${monthKey}-01T00:00:00`);
				if (Number.isNaN(parsed.getTime())) return monthKey;

				return parsed.toLocaleDateString('en-US', {
					month: 'short',
					year: 'numeric'
				});
			}

			function formatCurrency(value) {
				return `PHP ${toNumber(value).toLocaleString('en-PH', {
					minimumFractionDigits: 2,
					maximumFractionDigits: 2
				})}`;
			}

			function fillBranchFilter() {
				const branches = readBranches();
				filterBranch.innerHTML = ['<option value="">All Branches</option>']
					.concat(branches.map(branch => `<option value="${escapeHtml(branch.id)}">${escapeHtml(branch.name)}</option>`))
					.join('');
			}

			function getFilteredRows() {
				const monthKey = filterMonth.value;
				const branchId = filterBranch.value;
				const search = String(filterSearch.value || '').trim().toLowerCase();

				return readEntries()
					.map(item => ({ ...item, __monthKey: monthKeyFromEntry(item) }))
					.filter(item => item.__monthKey)
					.filter(item => !monthKey || item.__monthKey === monthKey)
					.filter(item => !branchId || String(item.branchId || 'branch_default') === branchId)
					.filter(item => !search || String(item.branchName || '').toLowerCase().includes(search))
					.sort((a, b) => new Date(b.timestamp || 0) - new Date(a.timestamp || 0));
			}

			function renderRows() {
				const target = document.getElementById('history-rows');
				const rows = getFilteredRows();

				if (rows.length === 0) {
					target.innerHTML = '<tr><td colspan="8" class="px-5 py-10 text-center text-xs text-slate-400 italic">No records found.</td></tr>';
					return;
				}

				target.innerHTML = rows.map(item => {
					const sales = toNumber(item.sales || item.revenue);
					const expenses = toNumber(item.expenses || item.totalExpenses);
					const profit = toNumber(item.profit || (sales - expenses));
					const margin = sales > 0 ? (profit / sales) * 100 : 0;

					return `
						<tr class="hover:bg-slate-50 transition-colors">
							<td class="px-5 py-4 text-sm font-semibold text-slate-900">${monthLabelFromKey(item.__monthKey)}</td>
							<td class="px-5 py-4 text-sm text-slate-700">${escapeHtml(item.branchName || 'Main Branch')}</td>
							<td class="px-5 py-4 text-sm text-slate-900 text-right">${formatCurrency(sales)}</td>
							<td class="px-5 py-4 text-sm text-slate-900 text-right">${formatCurrency(expenses)}</td>
							<td class="px-5 py-4 text-sm font-black text-right ${profit < 0 ? 'text-red-600' : 'text-emerald-700'}">${formatCurrency(profit)}</td>
							<td class="px-5 py-4 text-sm font-black text-slate-900 text-right">${margin.toFixed(1)}%</td>
							<td class="px-5 py-4 text-xs text-slate-500 text-right">${formatDate(item.timestamp)}</td>
							<td class="px-5 py-4 text-center">
								<div class="inline-flex items-center gap-2">
									<a href="/DataEntry?month=${encodeURIComponent(item.__monthKey)}&branch=${encodeURIComponent(item.branchId || 'branch_default')}" class="px-3 py-1.5 bg-blue-50 text-blue-700 text-xs font-bold rounded-lg hover:bg-blue-100 transition-colors">Open</a>
									<button data-id="${escapeHtml(item.id || '')}" class="delete-btn px-3 py-1.5 bg-slate-100 text-slate-700 text-xs font-bold rounded-lg hover:bg-slate-200 transition-colors">Archive</button>
								</div>
							</td>
						</tr>
					`;
				}).join('');

				bindDeleteActions();
			}

			function bindDeleteActions() {
				document.querySelectorAll('.delete-btn').forEach(button => {
					button.addEventListener('click', function () {
						const id = this.getAttribute('data-id');
						if (!id) return;

						const ok = confirm('Archive this monthly record? This will move it out of active reports.');
						if (!ok) return;

						const kept = readEntries().filter(item => String(item.id || '') !== id);
						writeEntries(kept);
						renderRows();
						showToast();
					});
				});
			}

			function formatDate(iso) {
				const parsed = new Date(iso || '');
				if (Number.isNaN(parsed.getTime())) return '-';

				return parsed.toLocaleDateString('en-US', {
					month: 'short',
					day: 'numeric',
					year: 'numeric'
				});
			}

			function showToast() {
				const toast = document.getElementById('history-toast');
				toast.classList.remove('translate-y-20', 'opacity-0');

				setTimeout(function () {
					toast.classList.add('translate-y-20', 'opacity-0');
				}, 2200);
			}

			function escapeHtml(value) {
				const map = { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;' };
				return String(value || '').replace(/[&<>"']/g, char => map[char]);
			}

			document.addEventListener('DOMContentLoaded', function () {
				fillBranchFilter();
				renderRows();

				[filterMonth, filterBranch, filterSearch].forEach(input => {
					input.addEventListener('input', renderRows);
					input.addEventListener('change', renderRows);
				});
			});
		})();
	</script>
}
