@{
    ViewData["Title"] = "Transaction History";
    Layout = "_AdminLayout";
}

<div class="space-y-8">
    <!-- Header -->
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
        <div>
            <h2 class="text-3xl font-black text-slate-900 tracking-tight">Transaction History</h2>
            <p class="text-xs text-slate-400 font-bold uppercase tracking-widest mt-1">View and manage all your transactions</p>
        </div>
        
        <div class="flex items-center gap-3">
            <a href="/DataEntry" class="px-4 py-2 bg-slate-100 text-slate-700 text-xs font-bold rounded-xl hover:bg-slate-200 transition-all flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
                Back to Entry
            </a>
            <button onclick="exportToCSV()" class="px-4 py-2 bg-indigo-600 text-white text-xs font-bold rounded-xl hover:bg-indigo-700 transition-all flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                Export CSV
            </button>
        </div>
    </div>

    <!-- Filters -->
    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
            <div>
                <label class="text-[10px] font-black text-slate-500 uppercase tracking-widest mb-2 block">Transaction Type</label>
                <select id="filter-type" onchange="loadTransactions()" class="w-full bg-slate-50 border-2 border-slate-100 rounded-xl py-2 px-3 text-sm font-bold focus:border-indigo-500 outline-none transition-all">
                    <option value="all">All Types</option>
                    <option value="sale">Sales</option>
                    <option value="expense">Expenses</option>
                    <option value="import">Imports</option>
                </select>
            </div>
            <div>
                <label class="text-[10px] font-black text-slate-500 uppercase tracking-widest mb-2 block">Month</label>
                <select id="filter-month" onchange="loadTransactions()" class="w-full bg-slate-50 border-2 border-slate-100 rounded-xl py-2 px-3 text-sm font-bold focus:border-indigo-500 outline-none transition-all">
                    <option value="all">All Months</option>
                    <option value="1">January</option>
                    <option value="2">February</option>
                    <option value="3">March</option>
                    <option value="4">April</option>
                    <option value="5">May</option>
                    <option value="6">June</option>
                    <option value="7">July</option>
                    <option value="8">August</option>
                    <option value="9">September</option>
                    <option value="10">October</option>
                    <option value="11">November</option>
                    <option value="12">December</option>
                </select>
            </div>
            <div>
                <label class="text-[10px] font-black text-slate-500 uppercase tracking-widest mb-2 block">Year</label>
                <select id="filter-year" onchange="loadTransactions()" class="w-full bg-slate-50 border-2 border-slate-100 rounded-xl py-2 px-3 text-sm font-bold focus:border-indigo-500 outline-none transition-all">
                    <option value="all">All Years</option>
                    <option value="2026">2026</option>
                    <option value="2025">2025</option>
                </select>
            </div>
            <div>
                <label class="text-[10px] font-black text-slate-500 uppercase tracking-widest mb-2 block">Search</label>
                <input type="text" id="filter-search" oninput="loadTransactions()" placeholder="Search..." class="w-full bg-slate-50 border-2 border-slate-100 rounded-xl py-2 px-3 text-sm font-bold focus:border-indigo-500 outline-none transition-all">
            </div>
        </div>
    </div>

    <!-- Summary Cards -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        <div class="bg-white p-6 rounded-2xl border border-slate-100 shadow-sm">
            <div class="flex items-center justify-between mb-2">
                <span class="text-[10px] font-black text-emerald-600 uppercase tracking-widest">Total Sales</span>
                <div class="w-8 h-8 bg-emerald-100 rounded-lg flex items-center justify-center">
                    <svg class="w-4 h-4 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
            </div>
            <p id="summary-total-sales" class="text-2xl font-black text-slate-900">₱ 0.00</p>
            <p id="summary-sales-count" class="text-xs text-slate-400 mt-1">0 transactions</p>
        </div>
        <div class="bg-white p-6 rounded-2xl border border-slate-100 shadow-sm">
            <div class="flex items-center justify-between mb-2">
                <span class="text-[10px] font-black text-red-600 uppercase tracking-widest">Total Expenses</span>
                <div class="w-8 h-8 bg-red-100 rounded-lg flex items-center justify-center">
                    <svg class="w-4 h-4 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
            </div>
            <p id="summary-total-expenses" class="text-2xl font-black text-slate-900">₱ 0.00</p>
            <p id="summary-expenses-count" class="text-xs text-slate-400 mt-1">0 transactions</p>
        </div>
        <div class="bg-white p-6 rounded-2xl border border-slate-100 shadow-sm">
            <div class="flex items-center justify-between mb-2">
                <span class="text-[10px] font-black text-orange-600 uppercase tracking-widest">Total Imports</span>
                <div class="w-8 h-8 bg-orange-100 rounded-lg flex items-center justify-center">
                    <svg class="w-4 h-4 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>
                </div>
            </div>
            <p id="summary-total-imports" class="text-2xl font-black text-slate-900">₱ 0.00</p>
            <p id="summary-imports-count" class="text-xs text-slate-400 mt-1">0 transactions</p>
        </div>
        <div class="bg-gradient-to-br from-slate-900 to-slate-800 p-6 rounded-2xl shadow-xl">
            <div class="flex items-center justify-between mb-2">
                <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Net Amount</span>
                <div class="w-8 h-8 bg-white/10 rounded-lg flex items-center justify-center">
                    <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
                </div>
            </div>
            <p id="summary-net" class="text-2xl font-black text-white">₱ 0.00</p>
            <p id="summary-total-count" class="text-xs text-slate-400 mt-1">0 total</p>
        </div>
    </div>

    <!-- Transactions Table -->
    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead class="bg-slate-50 border-b border-slate-100">
                    <tr>
                        <th class="text-left px-6 py-4 text-[10px] font-black text-slate-500 uppercase tracking-widest">Date</th>
                        <th class="text-left px-6 py-4 text-[10px] font-black text-slate-500 uppercase tracking-widest">Type</th>
                        <th class="text-left px-6 py-4 text-[10px] font-black text-slate-500 uppercase tracking-widest">Description</th>
                        <th class="text-right px-6 py-4 text-[10px] font-black text-slate-500 uppercase tracking-widest">Amount</th>
                        <th class="text-right px-6 py-4 text-[10px] font-black text-slate-500 uppercase tracking-widest">Actions</th>
                    </tr>
                </thead>
                <tbody id="transactions-table" class="divide-y divide-slate-100">
                    <tr>
                        <td colspan="5" class="px-6 py-12 text-center text-sm text-slate-400">
                            Loading transactions...
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Edit Transaction Modal -->
<div id="edit-modal" class="fixed inset-0 z-50 bg-slate-900/60 backdrop-blur-sm flex items-center justify-center opacity-0 pointer-events-none transition-all duration-300">
    <div class="max-w-lg w-full mx-4 bg-white rounded-3xl shadow-2xl overflow-hidden transform scale-95 transition-all duration-300" id="edit-card">
        <div class="p-6 border-b border-slate-100 flex items-center justify-between">
            <h3 class="text-lg font-black text-slate-900">Edit Transaction</h3>
            <button onclick="closeEditModal()" class="w-8 h-8 bg-slate-100 rounded-lg flex items-center justify-center hover:bg-slate-200 transition-all">
                <svg class="w-4 h-4 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>
        <div id="edit-form" class="p-6">
            <!-- Form will be populated dynamically -->
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div id="delete-modal" class="fixed inset-0 z-50 bg-slate-900/60 backdrop-blur-sm flex items-center justify-center opacity-0 pointer-events-none transition-all duration-300">
    <div class="max-w-md w-full mx-4 bg-white rounded-3xl shadow-2xl overflow-hidden transform scale-95 transition-all duration-300">
        <div class="p-8 text-center">
            <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
            </div>
            <h3 class="text-xl font-black text-slate-900 mb-2">Delete Transaction?</h3>
            <p class="text-sm text-slate-500 mb-6">This action cannot be undone.</p>
            <div class="flex gap-3">
                <button onclick="closeDeleteModal()" class="flex-1 px-4 py-3 bg-slate-100 text-slate-700 font-bold rounded-xl hover:bg-slate-200 transition-all">Cancel</button>
                <button onclick="confirmDelete()" class="flex-1 px-4 py-3 bg-red-600 text-white font-bold rounded-xl hover:bg-red-700 transition-all">Delete</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let currentBranch = null;
        let deleteTarget = null;

        document.addEventListener('DOMContentLoaded', () => {
            loadBranchInfo();
            loadTransactions();
        });

        function loadBranchInfo() {
            const users = JSON.parse(localStorage.getItem('coretex_users') || '[]');
            const branches = JSON.parse(localStorage.getItem('coretex_branches') || '[]');
            const financeOfficer = users.find(u => u.role === 'Finance Officer' && u.status === 'Active');
            
            if (financeOfficer && financeOfficer.branchId) {
                const branch = branches.find(b => b.id === financeOfficer.branchId);
                if (branch) currentBranch = branch;
            }
            
            if (!currentBranch && branches.length > 0) {
                currentBranch = branches[0];
            } else if (!currentBranch) {
                currentBranch = { id: 'default', name: 'Davao Main' };
            }
        }

        function loadTransactions() {
            const branchId = currentBranch?.id || 'default';
            const type = document.getElementById('filter-type').value;
            const month = document.getElementById('filter-month').value;
            const year = document.getElementById('filter-year').value;
            const search = document.getElementById('filter-search').value.toLowerCase();

            const sales = JSON.parse(localStorage.getItem('coretex_sales') || '[]')
                .filter(s => s.branchId === branchId)
                .map(s => ({ ...s, type: 'sale', displayAmount: s.amount }));
            
            const expenses = JSON.parse(localStorage.getItem('coretex_expenses') || '[]')
                .filter(e => e.branchId === branchId)
                .map(e => ({ ...e, type: 'expense', displayAmount: e.amount }));
            
            const imports = JSON.parse(localStorage.getItem('coretex_imports') || '[]')
                .filter(i => i.branchId === branchId)
                .map(i => ({ ...i, type: 'import', displayAmount: i.phpAmount }));

            let all = [...sales, ...expenses, ...imports];

            // Apply filters
            if (type !== 'all') all = all.filter(t => t.type === type);
            if (month !== 'all') all = all.filter(t => new Date(t.date).getMonth() + 1 === parseInt(month));
            if (year !== 'all') all = all.filter(t => new Date(t.date).getFullYear() === parseInt(year));
            if (search) {
                all = all.filter(t => 
                    (t.customer && t.customer.toLowerCase().includes(search)) ||
                    (t.category && t.category.toLowerCase().includes(search)) ||
                    (t.vendor && t.vendor.toLowerCase().includes(search)) ||
                    (t.supplier && t.supplier.toLowerCase().includes(search)) ||
                    (t.description && t.description.toLowerCase().includes(search))
                );
            }

            // Sort by date (newest first)
            all.sort((a, b) => new Date(b.date) - new Date(a.date));

            // Update summaries
            updateSummaries(all);

            // Render table
            renderTable(all);
        }

        function updateSummaries(transactions) {
            const sales = transactions.filter(t => t.type === 'sale');
            const expenses = transactions.filter(t => t.type === 'expense');
            const imports = transactions.filter(t => t.type === 'import');

            const totalSales = sales.reduce((sum, s) => sum + s.displayAmount, 0);
            const totalExpenses = expenses.reduce((sum, e) => sum + e.displayAmount, 0);
            const totalImports = imports.reduce((sum, i) => sum + i.displayAmount, 0);
            const net = totalSales - totalExpenses - totalImports;

            document.getElementById('summary-total-sales').textContent = `₱ ${totalSales.toLocaleString(undefined, {minimumFractionDigits: 2})}`;
            document.getElementById('summary-sales-count').textContent = `${sales.length} transactions`;
            
            document.getElementById('summary-total-expenses').textContent = `₱ ${totalExpenses.toLocaleString(undefined, {minimumFractionDigits: 2})}`;
            document.getElementById('summary-expenses-count').textContent = `${expenses.length} transactions`;
            
            document.getElementById('summary-total-imports').textContent = `₱ ${totalImports.toLocaleString(undefined, {minimumFractionDigits: 2})}`;
            document.getElementById('summary-imports-count').textContent = `${imports.length} transactions`;
            
            document.getElementById('summary-net').textContent = `₱ ${net.toLocaleString(undefined, {minimumFractionDigits: 2})}`;
            document.getElementById('summary-total-count').textContent = `${transactions.length} total`;
        }

        function renderTable(transactions) {
            const tbody = document.getElementById('transactions-table');
            
            if (transactions.length === 0) {
                tbody.innerHTML = `
                    <tr>
                        <td colspan="5" class="px-6 py-12 text-center text-sm text-slate-400">
                            No transactions found. Try adjusting your filters.
                        </td>
                    </tr>
                `;
                return;
            }

            tbody.innerHTML = transactions.map(tx => {
                const typeColors = {
                    sale: 'bg-emerald-100 text-emerald-700',
                    expense: 'bg-red-100 text-red-700',
                    import: 'bg-orange-100 text-orange-700'
                };
                const typeLabels = { sale: 'Sale', expense: 'Expense', import: 'Import' };
                const description = tx.customer || tx.category || tx.supplier || tx.description || 'N/A';
                const sign = tx.type === 'sale' ? '+' : '-';
                const amountColor = tx.type === 'sale' ? 'text-emerald-600' : 'text-red-600';

                return `
                    <tr class="hover:bg-slate-50 transition-colors">
                        <td class="px-6 py-4 text-sm font-bold text-slate-600">${new Date(tx.date).toLocaleDateString()}</td>
                        <td class="px-6 py-4">
                            <span class="px-3 py-1 ${typeColors[tx.type]} text-[10px] font-black uppercase rounded-full">${typeLabels[tx.type]}</span>
                        </td>
                        <td class="px-6 py-4 text-sm font-medium text-slate-700">${description}</td>
                        <td class="px-6 py-4 text-right">
                            <span class="text-sm font-black ${amountColor}">${sign}₱${tx.displayAmount.toLocaleString(undefined, {minimumFractionDigits: 2})}</span>
                        </td>
                        <td class="px-6 py-4 text-right">
                            <div class="flex items-center justify-end gap-2">
                                <button onclick="editTransaction('${tx.type}', '${tx.id}')" class="p-2 bg-blue-100 text-blue-600 rounded-lg hover:bg-blue-200 transition-all">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                                </button>
                                <button onclick="deleteTransaction('${tx.type}', '${tx.id}')" class="p-2 bg-red-100 text-red-600 rounded-lg hover:bg-red-200 transition-all">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                                </button>
                            </div>
                        </td>
                    </tr>
                `;
            }).join('');
        }

        function editTransaction(type, id) {
            // This would open an edit modal - simplified for now
            alert('Edit functionality coming soon!');
        }

        function deleteTransaction(type, id) {
            deleteTarget = { type, id };
            const modal = document.getElementById('delete-modal');
            modal.classList.remove('opacity-0', 'pointer-events-none');
        }

        function closeDeleteModal() {
            const modal = document.getElementById('delete-modal');
            modal.classList.add('opacity-0', 'pointer-events-none');
            deleteTarget = null;
        }

        function confirmDelete() {
            if (!deleteTarget) return;

            const { type, id } = deleteTarget;
            const storageKeys = { sale: 'coretex_sales', expense: 'coretex_expenses', import: 'coretex_imports' };
            const data = JSON.parse(localStorage.getItem(storageKeys[type]) || '[]');
            const filtered = data.filter(item => item.id !== id);
            localStorage.setItem(storageKeys[type], JSON.stringify(filtered));

            closeDeleteModal();
            loadTransactions();
        }

        function closeEditModal() {
            const modal = document.getElementById('edit-modal');
            modal.classList.add('opacity-0', 'pointer-events-none');
        }

        function exportToCSV() {
            const branchId = currentBranch?.id || 'default';
            const sales = JSON.parse(localStorage.getItem('coretex_sales') || '[]').filter(s => s.branchId === branchId);
            const expenses = JSON.parse(localStorage.getItem('coretex_expenses') || '[]').filter(e => e.branchId === branchId);
            const imports = JSON.parse(localStorage.getItem('coretex_imports') || '[]').filter(i => i.branchId === branchId);

            let csv = 'Date,Type,Description,Amount (PHP),Payment Method,Category,Vendor,Supplier,Currency,Foreign Amount,Notes\n';
            
            sales.forEach(s => {
                csv += `${s.date},Sale,"${s.customer}",${s.amount},${s.paymentMethod || ''},,,,,,${s.notes || ''}\n`;
            });
            
            expenses.forEach(e => {
                csv += `${e.date},Expense,"${e.description || e.category}",${e.amount},,${e.category},${e.vendor || ''},,,,\n`;
            });
            
            imports.forEach(i => {
                csv += `${e.date},Import,"${i.description || i.category}",${i.phpAmount},,${i.category},,${i.supplier},${i.currency},${i.foreignAmount},\n`;
            });

            const blob = new Blob([csv], { type: 'text/csv' });
            const url = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `transactions_${currentBranch?.name || 'branch'}_${new Date().toISOString().split('T')[0]}.csv`;
            a.click();
        }
    </script>
}
