@{
    ViewData["Title"] = "Tenant Management";
    Layout = "_AdminLayout";
}

<div class="space-y-10">
    <div class="flex items-center justify-between">
        <div>
            <h2 class="text-3xl font-black text-slate-900 tracking-tight">Tenant & Subscription</h2>
            <p class="text-xs text-slate-400 font-bold uppercase tracking-widest mt-2">Managing global business accounts & licensing</p>
        </div>
        <div class="flex items-center space-x-3">
             <div class="px-3 py-1.5 bg-blue-100 text-blue-700 rounded-full text-[10px] font-black uppercase tracking-widest">
                PayMongo: Connected
            </div>
            <button class="px-5 py-2.5 bg-secondary text-white font-bold rounded-xl text-xs hover:bg-teal-600 transition-all shadow-lg shadow-teal-900/30 flex items-center space-x-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" /></svg>
                <span>Provision New Tenant</span>
            </button>
        </div>
    </div>

    <!-- Tenant Grid -->
    <div class="bg-white border border-slate-100 rounded-[3rem] shadow-sm overflow-hidden flex flex-col">
        <div class="p-8 border-b border-slate-50 flex justify-between items-center bg-slate-50/10">
            <h3 class="font-black text-slate-800 text-lg">Active Business Accounts</h3>
            <div class="flex items-center space-x-4">
                <div class="relative">
                    <input type="text" placeholder="Search companies..." class="bg-slate-50 border border-slate-200 rounded-xl py-2 pl-10 pr-4 text-xs focus:ring-2 focus:ring-secondary/20 w-64" />
                    <svg class="w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                </div>
            </div>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead class="bg-slate-50/10 border-b border-slate-100">
                    <tr>
                        <th class="px-10 py-5 text-[10px] font-black text-slate-400 uppercase tracking-widest">Company Presence</th>
                        <th class="px-10 py-5 text-[10px] font-black text-slate-400 uppercase tracking-widest">License Tier</th>
                        <th class="px-10 py-5 text-[10px] font-black text-slate-400 uppercase tracking-widest">Security Status</th>
                        <th class="px-10 py-5 text-[10px] font-black text-slate-400 uppercase tracking-widest">Usage Meta</th>
                        <th class="px-10 py-5 text-[10px] font-black text-slate-400 uppercase tracking-widest text-right">Actions</th>
                    </tr>
                </thead>
                <tbody id="tenant-list" class="divide-y divide-slate-50">
                    <!-- Default Mock Companies -->
                    <tr class="hover:bg-slate-50/50 transition-all group">
                        <td class="px-10 py-6">
                            <div class="flex items-center space-x-4">
                                <div class="w-12 h-12 bg-indigo-50 text-indigo-600 rounded-2xl flex items-center justify-center font-black text-xs shadow-sm shadow-indigo-100 italic transition-transform group-hover:scale-105">
                                    ED
                                </div>
                                <div>
                                    <p class="font-black text-slate-900 text-sm tracking-tight">EcoDynamic Electronics</p>
                                    <p class="text-[9px] text-slate-400 font-bold uppercase tracking-widest mt-1">UUID: 824-XT-129</p>
                                </div>
                            </div>
                        </td>
                        <td class="px-10 py-6">
                            <span class="px-4 py-1.5 bg-slate-900 text-white rounded-full text-[9px] font-black uppercase tracking-widest">Enterprise</span>
                            <p class="text-[9px] text-slate-400 font-bold mt-1.5">Expires: Dec 2026</p>
                        </td>
                        <td class="px-10 py-6">
                            <div class="flex items-center space-x-2">
                                <div class="w-1.5 h-1.5 bg-emerald-500 rounded-full"></div>
                                <span class="text-xs font-bold text-slate-700 tracking-tight">Active</span>
                            </div>
                        </td>
                        <td class="px-10 py-6">
                            <div class="flex flex-col space-y-1">
                                <span class="text-xs text-slate-500 font-medium">CPU: 0.12%</span>
                                <span class="text-xs text-slate-500 font-medium">NET: 1.4 GB/mo</span>
                            </div>
                        </td>
                        <td class="px-10 py-6 text-right">
                             <div class="flex items-center justify-end space-x-2">
                                <button onclick="toggleTenant(this)" class="px-4 py-2 bg-slate-100 text-slate-700 text-[10px] font-black uppercase tracking-widest rounded-xl hover:bg-slate-200 transition-all">
                                    Manage
                                </button>
                                <button onclick="toggleTenant(this, true)" class="p-2 text-red-100 bg-red-600 rounded-xl hover:bg-red-700 transition-all opacity-0 group-hover:opacity-100 shadow-lg shadow-red-900/20">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/></svg>
                                </button>
                            </div>
                        </td>
                    </tr>

                    <tr class="hover:bg-slate-50/50 transition-all group">
                        <td class="px-10 py-6">
                            <div class="flex items-center space-x-4">
                                <div class="w-12 h-12 bg-blue-50 text-blue-600 rounded-2xl flex items-center justify-center font-black text-xs shadow-sm shadow-blue-100 italic transition-transform group-hover:scale-105">
                                    ST
                                </div>
                                <div>
                                    <p class="font-black text-slate-900 text-sm tracking-tight">SmartTech Logistics</p>
                                    <p class="text-[9px] text-slate-400 font-bold uppercase tracking-widest mt-1">UUID: 492-QL-883</p>
                                </div>
                            </div>
                        </td>
                        <td class="px-10 py-6">
                            <span class="px-4 py-1.5 bg-blue-50 text-blue-600 rounded-full text-[9px] font-black uppercase tracking-widest">Business</span>
                            <p class="text-[9px] text-slate-400 font-bold mt-1.5">Expires: Oct 2026</p>
                        </td>
                        <td class="px-10 py-6">
                            <div class="flex items-center space-x-2">
                                <div class="w-1.5 h-1.5 bg-emerald-500 rounded-full"></div>
                                <span class="text-xs font-bold text-slate-700 tracking-tight">Active</span>
                            </div>
                        </td>
                         <td class="px-10 py-6">
                            <div class="flex flex-col space-y-1">
                                <span class="text-xs text-slate-500 font-medium">CPU: 0.05%</span>
                                <span class="text-xs text-slate-500 font-medium">NET: 420 MB/mo</span>
                            </div>
                        </td>
                        <td class="px-10 py-6 text-right">
                             <div class="flex items-center justify-end space-x-2">
                                <button class="px-4 py-2 bg-slate-100 text-slate-700 text-[10px] font-black uppercase tracking-widest rounded-xl hover:bg-slate-200 transition-all">
                                    Manage
                                </button>
                                <button class="p-2 text-red-100 bg-red-600 rounded-xl hover:bg-red-700 transition-all opacity-0 group-hover:opacity-100 shadow-lg shadow-red-900/20">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/></svg>
                                </button>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Subscription Management (Phase 8 Plan Manager) -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-white p-8 rounded-[2.5rem] shadow-sm border border-slate-100 hover:border-slate-300 transition-all">
            <div class="flex items-center space-x-3 mb-6">
                <div class="w-10 h-10 bg-slate-100 rounded-xl flex items-center justify-center">
                    <svg class="w-5 h-5 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                </div>
                <h4 class="font-black text-slate-800">Basic Tier</h4>
            </div>
            <p class="text-xs text-slate-400 mb-6 font-medium">Standard KPI dashboard and reporting tools for single-branch electronics shops.</p>
            <div class="flex items-baseline space-x-1 mb-8">
                <span class="text-3xl font-black text-slate-900 tracking-tighter">₱14.5k</span>
                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">/ month</span>
            </div>
            <button class="w-full py-3 bg-slate-50 text-slate-400 font-bold border border-slate-200 cursor-not-allowed rounded-xl text-[10px] uppercase tracking-widest">Edit Plan Tiers</button>
        </div>

        <div class="bg-slate-900 p-8 rounded-[2.5rem] shadow-xl text-white relative overflow-hidden group">
            <div class="absolute -top-10 -right-10 w-32 h-32 bg-secondary/20 rounded-full blur-3xl"></div>
             <div class="flex items-center space-x-3 mb-6">
                <div class="w-10 h-10 bg-white/10 rounded-xl flex items-center justify-center">
                    <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-7.714 2.143L11 21l-2.286-6.857L1 12l7.714-2.143L11 3z"/></svg>
                </div>
                <h4 class="font-black">Enterprise VIP</h4>
            </div>
            <p class="text-xs text-slate-400 mb-6 font-medium">Multi-branch support, AI trend forecasting, and unlimited executive users.</p>
            <div class="flex items-baseline space-x-1 mb-8">
                <span class="text-3xl font-black text-white tracking-tighter">₱48.2k</span>
                <span class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">/ month</span>
            </div>
             <button class="w-full py-3 bg-secondary text-white font-black rounded-xl text-[10px] uppercase tracking-widest hover:bg-teal-600 transition-all shadow-lg shadow-teal-900/30">Scale Plan Limits</button>
        </div>

        <div class="bg-indigo-50 p-8 border border-indigo-100 rounded-[2.5rem] flex flex-col justify-center items-center text-center">
            <div class="w-16 h-16 bg-white rounded-3xl shadow-sm border border-indigo-100 flex items-center justify-center mb-6">
                <svg class="w-8 h-8 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
            </div>
            <h4 class="font-black text-slate-800">New Tier</h4>
            <p class="text-[10px] text-slate-400 font-bold uppercase tracking-widest mt-1">Expansion Configuration</p>
            <button class="mt-8 px-6 py-2 bg-indigo-600 text-white font-black rounded-lg text-[10px] uppercase tracking-widest hover:bg-indigo-700 transition-all shadow-lg shadow-indigo-600/30">Add Plan</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function toggleTenant(btn, isDeactivate = false) {
            const row = btn.closest('tr');
            if (isDeactivate) {
                if(confirm("Confirm security lockout for this company? Access will be revoked immediately.")) {
                    row.classList.add('opacity-40', 'grayscale');
                    row.querySelector('.bg-emerald-500').classList.replace('bg-emerald-500', 'bg-slate-400');
                    row.querySelector('span.text-slate-700').innerText = 'Suspended';
                    btn.classList.add('hidden');
                    alert("Account Deactivated. Platform credentials invalidated.");
                }
            } else {
                alert("Redirecting to individual Business Tenant Configuration...");
            }
        }

        // Simulate PayMongo Automation (New Company Appears)
        function simulateNewSignup() {
            const tbody = document.getElementById('tenant-list');
            const row = document.createElement('tr');
            row.className = 'hover:bg-slate-50/50 transition-all group bg-emerald-50/20';
            row.innerHTML = `
                <td class="px-10 py-6">
                    <div class="flex items-center space-x-4">
                        <div class="w-12 h-12 bg-emerald-100 text-emerald-600 rounded-2xl flex items-center justify-center font-black text-xs shadow-sm shadow-emerald-100 italic transition-transform group-hover:scale-105">
                            NX
                        </div>
                        <div>
                            <div class="flex items-center space-x-2">
                                <p class="font-black text-slate-900 text-sm tracking-tight">NexGen Electronics</p>
                                <span class="px-2 py-0.5 bg-emerald-100 text-emerald-700 rounded text-[8px] font-black uppercase">NEW</span>
                            </div>
                            <p class="text-[9px] text-slate-400 font-bold uppercase tracking-widest mt-1">UUID: 104-AZ-992</p>
                        </div>
                    </div>
                </td>
                <td class="px-10 py-6">
                    <span class="px-4 py-1.5 bg-blue-50 text-blue-600 rounded-full text-[9px] font-black uppercase tracking-widest">Business</span>
                    <p class="text-[9px] text-slate-400 font-bold mt-1.5">Expires: Apr 2027</p>
                </td>
                <td class="px-10 py-6">
                    <div class="flex items-center space-x-2">
                        <div class="w-1.5 h-1.5 bg-emerald-500 rounded-full"></div>
                        <span class="text-xs font-bold text-slate-700 tracking-tight">Active</span>
                    </div>
                </td>
                <td class="px-10 py-6">
                    <div class="flex flex-col space-y-1">
                        <span class="text-xs text-slate-500 font-medium italic animate-pulse">Initializing...</span>
                    </div>
                </td>
                <td class="px-10 py-6 text-right">
                    <div class="flex items-center justify-end space-x-2">
                        <button class="px-4 py-2 bg-slate-100 text-slate-700 text-[10px] font-black uppercase tracking-widest rounded-xl hover:bg-slate-200 transition-all">Manage</button>
                    </div>
                </td>
            `;
            tbody.prepend(row);
        }

        // Simulate a new signup after 10 seconds for demo purposes
        setTimeout(() => {
            simulateNewSignup();
        }, 10000);
    </script>
}
