@{
    ViewData["Title"] = "System Configuration";
    Layout = "_AdminLayout";
}

<div class="space-y-10">
    <div class="flex items-center justify-between">
        <div>
            <div class="flex items-center space-x-3 mb-2">
                <span class="px-3 py-1 bg-amber-100 text-amber-700 font-black text-[10px] uppercase tracking-widest rounded-full">Operational Core</span>
                <span class="px-3 py-1 bg-slate-100 text-slate-500 font-bold text-[10px] uppercase tracking-widest rounded-full">Automation</span>
            </div>
            <h2 class="text-3xl font-black text-slate-900 tracking-tight">Intelligence Configuration</h2>
            <p class="text-xs text-slate-400 font-bold uppercase tracking-widest mt-2">Set KPI alert thresholds and automate executive delivery</p>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
        <!-- KPI Thresholds -->
        <div class="bg-white p-10 rounded-[3rem] shadow-xl shadow-slate-200/50 border border-slate-100 space-y-12">
            <div>
                <h3 class="text-xl font-black text-slate-900">KPI Alert Thresholds</h3>
                <p class="text-[10px] font-black uppercase tracking-widest text-slate-400 mt-1">Configure triggers for Twilio SMS alerts</p>
            </div>

            <div class="space-y-10">
                <div class="space-y-4">
                    <label class="flex justify-between items-center px-2">
                        <span class="text-[10px] font-black text-slate-600 uppercase tracking-widest">Monthly Profit Floor (₱)</span>
                        <span id="profit-val" class="text-lg font-black text-emerald-600 tracking-tighter">₱ 50,000</span>
                    </label>
                    <input type="range" id="profit-range" min="10000" max="250000" step="5000" value="50000" class="w-full h-3 bg-slate-100 rounded-full appearance-none cursor-pointer accent-emerald-500" oninput="updateVal('profit-val', this.value, '₱ ')">
                    <p class="text-[9px] font-bold text-slate-400 italic px-2">Trigger: "Send alert to Owner if profit < ₱50,000"</p>
                </div>

                <div class="space-y-4">
                    <label class="flex justify-between items-center px-2">
                        <span class="text-[10px] font-black text-slate-600 uppercase tracking-widest">Expense Cap (% of Revenue)</span>
                        <span id="expense-val" class="text-lg font-black text-red-500 tracking-tighter">80%</span>
                    </label>
                    <input type="range" id="expense-range" min="50" max="95" step="1" value="80" class="w-full h-3 bg-slate-100 rounded-full appearance-none cursor-pointer accent-red-500" oninput="updateVal('expense-val', this.value, '', '%')">
                    <p class="text-[9px] font-bold text-slate-400 italic px-2">Trigger: "Alert when expenses exceed 80% of revenue"</p>
                </div>
            </div>
        </div>

        <!-- Auto-Report Scheduling -->
        <div class="bg-slate-900 p-10 rounded-[3rem] shadow-2xl text-white space-y-12 relative overflow-hidden">
            <div class="absolute top-0 right-0 w-64 h-64 bg-indigo-500/10 rounded-full blur-[100px]"></div>
            
            <div class="relative z-10">
                <h3 class="text-xl font-black">Executive Auto-Reports</h3>
                <p class="text-[10px] font-black uppercase tracking-widest text-indigo-300 mt-1">Scheduled delivery via SendGrid API</p>
            </div>

            <div class="space-y-8 relative z-10">
                <div class="p-6 bg-white/5 border border-white/10 rounded-3xl space-y-6">
                    <div class="grid grid-cols-2 gap-4">
                        <div class="space-y-2">
                            <label class="text-[9px] font-black uppercase tracking-widest text-indigo-200">Delivery Day</label>
                            <select id="report-day" class="w-full bg-slate-800 border-none rounded-xl py-3 px-4 text-xs font-bold text-white focus:ring-2 focus:ring-indigo-400 outline-none cursor-pointer">
                                <option value="Monday" selected>Every Monday</option>
                                <option value="Tuesday">Every Tuesday</option>
                                <option value="Friday">Every Friday</option>
                                <option value="1">1st of the Month</option>
                            </select>
                        </div>
                        <div class="space-y-2">
                            <label class="text-[9px] font-black uppercase tracking-widest text-indigo-200">Execution Time</label>
                            <input type="time" id="report-time" value="08:00" class="w-full bg-slate-800 border-none rounded-xl py-3 px-4 text-xs font-bold text-white focus:ring-2 focus:ring-indigo-400 outline-none">
                        </div>
                    </div>
                </div>

                <div class="flex items-center space-x-4 p-5 bg-indigo-500/10 border border-indigo-400/20 rounded-[1.5rem]">
                    <div class="w-10 h-10 bg-indigo-500 text-white rounded-xl flex items-center justify-center font-black text-xs">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    </div>
                    <div>
                        <p class="text-[10px] font-black uppercase tracking-widest text-indigo-300">Next Distribution</p>
                        <p id="next-delivery" class="text-sm font-bold text-white">Monday at 08:00 AM</p>
                    </div>
                </div>
            </div>

            <button onclick="saveConfig()" class="w-full py-5 bg-white text-slate-900 font-black rounded-[1.5rem] shadow-xl hover:bg-indigo-400 hover:text-white transition-all transform active:scale-95 relative z-10">
                Deploy Configuration
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function updateVal(id, val, prefix, suffix = '') {
            const el = document.getElementById(id);
            if (prefix === '₱ ') {
                el.innerText = prefix + parseInt(val).toLocaleString();
            } else {
                el.innerText = val + suffix;
            }
            updateTimerDisplay();
        }

        function updateTimerDisplay() {
            const day = document.getElementById('report-day').value;
            const time = document.getElementById('report-time').value;
            const ampm = parseInt(time.split(':')[0]) >= 12 ? 'PM' : 'AM';
            document.getElementById('next-delivery').innerText = `${day === '1' ? '1st of the Month' : day} at ${time} ${ampm}`;
        }

        document.getElementById('report-day').addEventListener('change', updateTimerDisplay);
        document.getElementById('report-time').addEventListener('input', updateTimerDisplay);

        function saveConfig() {
            const config = {
                profitFloor: document.getElementById('profit-range').value,
                expenseCap: document.getElementById('expense-range').value,
                reportDay: document.getElementById('report-day').value,
                reportTime: document.getElementById('report-time').value
            };
            localStorage.setItem('coretex_system_config', JSON.stringify(config));
            
            // Animation for success
            const btn = event.target;
            const oldText = btn.innerText;
            btn.innerText = '✓ Configuration Deployed';
            btn.classList.add('bg-emerald-400', 'text-white');
            setTimeout(() => {
                btn.innerText = oldText;
                btn.classList.remove('bg-emerald-400', 'text-white');
            }, 2000);
        }
    </script>
}
