@model IEnumerable<coretex_finalproj.Models.BranchSubmission>
@{
    ViewData["Title"] = "Branch Submissions";
    Layout = "_AdminLayout";
}

<div class="space-y-8">
    <div class="flex items-center justify-between">
        <div>
            <h2 class="text-3xl font-black text-slate-900 tracking-tight">Branch Submissions</h2>
            <p class="text-sm text-slate-500 mt-1">Monitor monthly financial reports from all branches</p>
        </div>
        <div class="flex gap-4">
             <div class="px-4 py-2 bg-indigo-50 border border-indigo-100 rounded-xl flex items-center gap-2">
                <span class="text-[10px] font-black text-indigo-700 uppercase tracking-widest">Active Month: @DateTime.Now.ToString("MMMM yyyy")</span>
            </div>
        </div>
    </div>

    <!-- Status Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-white rounded-3xl p-6 shadow-sm border border-slate-100 border-b-4 border-b-emerald-500">
            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Submitted Today</p>
            <h4 class="text-3xl font-black text-slate-900 mt-1">@Model.Count(s => s.SubmittedAt.Date == DateTime.Today)</h4>
        </div>
        <div class="bg-white rounded-3xl p-6 shadow-sm border border-slate-100 border-b-4 border-b-amber-500">
            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Pending Review</p>
            <h4 class="text-3xl font-black text-slate-900 mt-1">@Model.Count(s => s.Status == "Pending")</h4>
        </div>
    </div>

    <!-- Submissions Table -->
    <div class="bg-white rounded-[2.5rem] shadow-sm border border-slate-100 overflow-hidden">
        <table class="w-full">
            <thead class="bg-slate-50 font-black text-slate-400 text-[10px] uppercase tracking-widest">
                <tr>
                    <th class="px-8 py-5 text-left">Branch Name</th>
                    <th class="px-8 py-5 text-left">Period</th>
                    <th class="px-8 py-5 text-right">Revenue Recorded</th>
                    <th class="px-8 py-5 text-center">Status</th>
                    <th class="px-8 py-5 text-center">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="p-20 text-center text-slate-400 italic">No submissions recorded yet for this month.</td>
                    </tr>
                }
                @foreach (var sub in Model)
                {
                    <tr class="hover:bg-slate-50 transition-colors group">
                        <td class="px-8 py-5 font-bold text-slate-900">@sub.Branch?.Name</td>
                        <td class="px-8 py-5 text-sm text-slate-500">@sub.SubmissionMonth/@sub.SubmissionYear</td>
                        <td class="px-8 py-5 text-right font-black text-indigo-600">₱@sub.TotalSales.ToString("N2")</td>
                        <td class="px-8 py-5 text-center">
                            <span class="px-3 py-1 bg-emerald-100 text-emerald-700 text-[9px] font-black uppercase rounded-full">@sub.Status</span>
                        </td>
                        <td class="px-8 py-5 text-center whitespace-nowrap">
                            <button class="px-4 py-2 bg-indigo-50 text-indigo-600 text-[10px] font-black rounded-lg hover:bg-indigo-600 hover:text-white transition-all">View Details</button>
                            <button onclick="sendReminder('@sub.BranchId')" class="px-4 py-2 bg-amber-50 text-amber-600 text-[10px] font-black rounded-lg hover:bg-amber-500 hover:text-white transition-all ml-2">Send Reminder</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        function sendReminder(branchId) {
            alert("Strategic reminder sent to Finance Officer. (Connected to Notification Service)");
        }
    </script>
}
