@model IEnumerable<coretex_finalproj.Models.BranchSubmission>
@{
    ViewData["Title"] = "Branch Submissions";
    Layout = "_AdminLayout";
    var branches = (IEnumerable<coretex_finalproj.Models.Branch>)ViewBag.Branches;
    var submittedCount = Model.Count();
    var totalBranches = branches?.Count() ?? 0;
    var pendingCount = totalBranches - submittedCount;
}

<div class="space-y-8">
    <!-- Header -->
    <div class="flex items-center justify-between">
        <div>
            <div class="flex items-center space-x-3 mb-2">
                <a href="/Admin" class="text-slate-400 hover:text-slate-600 transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                </a>
                <span class="px-3 py-1 bg-emerald-100 text-emerald-700 font-black text-[10px] uppercase tracking-widest rounded-full">Reporting Hub</span>
            </div>
            <h2 class="text-3xl font-black text-slate-900 tracking-tight">System-Wide Submission Audit</h2>
            <p class="text-sm text-slate-500 mt-1">Real-time monitoring of node compliance and data integrity</p>
        </div>
    </div>

    <!-- Summary Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white rounded-3xl p-8 shadow-sm border border-slate-100">
            <p class="text-sm font-black text-slate-400 uppercase tracking-widest mb-1">Active Nodes</p>
            <p class="text-5xl font-black text-slate-900">@totalBranches</p>
            <div class="mt-4 flex items-center text-xs font-bold text-slate-400">
                <span class="w-2 h-2 bg-blue-500 rounded-full mr-2"></span>
                MONITORED BRANCHES
            </div>
        </div>

        <div class="bg-white rounded-3xl p-8 shadow-sm border border-slate-100">
            <p class="text-sm font-black text-emerald-600 uppercase tracking-widest mb-1">Submitted</p>
            <p class="text-5xl font-black text-emerald-600">@submittedCount</p>
            <div class="mt-4 flex items-center text-xs font-bold text-emerald-600">
                <span class="w-2 h-2 bg-emerald-500 rounded-full mr-2 animate-pulse"></span>
                DATA RECEIVED
            </div>
        </div>

        <div class="bg-white rounded-3xl p-8 shadow-sm border border-slate-100">
            <p class="text-sm font-black text-amber-600 uppercase tracking-widest mb-1">Pending</p>
            <p class="text-5xl font-black text-amber-600">@pendingCount</p>
            <div class="mt-4 flex items-center text-xs font-bold text-amber-600">
                <span class="w-2 h-2 bg-amber-500 rounded-full mr-2"></span>
                AWAITING ACTION
            </div>
        </div>
    </div>

    <!-- Submissions Table -->
    <div class="bg-white rounded-3xl shadow-sm border border-slate-100 overflow-hidden">
        <div class="p-6 border-b border-slate-100 flex items-center justify-between bg-slate-50/50">
            <h3 class="text-lg font-black text-slate-900">Branch Compliance Audit</h3>
            <span class="px-3 py-1 bg-white border border-slate-200 text-slate-500 text-[10px] font-bold rounded-full uppercase">Current Cycle</span>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead>
                    <tr class="bg-slate-50">
                        <th class="px-6 py-4 text-left text-[10px] font-black text-slate-500 uppercase tracking-widest">Branch Node</th>
                        <th class="px-6 py-4 text-left text-[10px] font-black text-slate-500 uppercase tracking-widest">Status</th>
                        <th class="px-6 py-4 text-left text-[10px] font-black text-slate-500 uppercase tracking-widest">Revenue Impact</th>
                        <th class="px-6 py-4 text-left text-[10px] font-black text-slate-500 uppercase tracking-widest">Timestamp</th>
                        <th class="px-6 py-4 text-right text-[10px] font-black text-slate-500 uppercase tracking-widest">Control</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @if (branches != null)
                    {
                        foreach (var branch in branches)
                        {
                            var submission = Model.FirstOrDefault(s => s.BranchId == branch.Id);
                            <tr class="hover:bg-slate-50 transition-colors group">
                                <td class="px-6 py-4">
                                    <div class="flex items-center space-x-3">
                                        <div class="w-10 h-10 bg-slate-100 rounded-xl flex items-center justify-center text-slate-400 group-hover:bg-indigo-600 group-hover:text-white transition-all duration-300">
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
                                        </div>
                                        <div>
                                            <p class="font-bold text-slate-900">@branch.Name</p>
                                            <p class="text-[10px] text-slate-400 uppercase font-black">ID: @branch.BranchCode</p>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4">
                                    @if (submission != null)
                                    {
                                        <span class="inline-flex items-center px-3 py-1 bg-emerald-100 text-emerald-700 text-[10px] font-black uppercase rounded-full">
                                            <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full mr-2"></span>
                                            ✅ Finalized
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center px-3 py-1 bg-amber-100 text-amber-700 text-[10px] font-black uppercase rounded-full">
                                            <span class="w-1.5 h-1.5 bg-amber-500 rounded-full mr-2 animate-pulse"></span>
                                            ⏳ Awaiting
                                        </span>
                                    }
                                </td>
                                <td class="px-6 py-4">
                                    <p class="text-sm font-bold text-slate-700">@(submission != null ? submission.SalesRevenue.ToString("C0") : "—")</p>
                                </td>
                                <td class="px-6 py-4 text-sm text-slate-500">
                                    @(submission != null ? submission.SubmittedAt.ToString("MMM dd, yyyy HH:mm") : "N/A")
                                </td>
                                <td class="px-6 py-4 text-right">
                                    @if (submission != null)
                                    {
                                        <button class="px-4 py-2 bg-indigo-50 text-indigo-600 text-[10px] font-black uppercase rounded-xl hover:bg-indigo-600 hover:text-white transition-all">Audit Data</button>
                                    }
                                    else
                                    {
                                        <button onclick="openReminderModal('@branch.Id')" class="px-4 py-2 bg-amber-50 text-amber-600 text-[10px] font-black uppercase rounded-xl hover:bg-amber-600 hover:text-white transition-all">Send Alert</button>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
    
    <!-- Recent Activity Timeline -->
    <div class="bg-white rounded-3xl shadow-sm border border-slate-100 overflow-hidden">
        <div class="p-6 border-b border-slate-100">
            <h3 class="text-lg font-black text-slate-900">Recent Activity Timeline</h3>
        </div>
        <div class="p-6">
            <div id="submission-timeline" class="space-y-4">
                <p class="text-slate-400 text-sm italic">Initializing timeline...</p>
            </div>
        </div>
    </div>
</div>

<!-- Send Reminder Modal (Executive Edition) -->
<div id="reminder-modal" class="fixed inset-0 z-50 hidden items-center justify-center modal-backdrop-premium animate-in fade-in duration-300">
    <div class="glass-card w-full max-w-lg mx-4 rounded-[2.5rem] shadow-2xl relative overflow-hidden">
        <div class="p-6 border-b border-slate-100 flex items-center justify-between">
            <h3 class="text-xl font-black text-slate-900">Send Reminder</h3>
            <button onclick="closeReminderModal()" class="text-slate-400 hover:text-slate-600 transition-colors">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>
        <div class="p-6">
            <div class="flex items-center space-x-4 mb-6">
                <div class="w-14 h-14 bg-amber-100 rounded-2xl flex items-center justify-center">
                    <svg class="w-7 h-7 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                </div>
                <div>
                    <p class="font-bold text-slate-900">Send reminder to</p>
                    <p id="reminder-fo-name" class="text-slate-500"></p>
                </div>
            </div>
            
            <div class="space-y-4">
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-2">To:</label>
                    <input type="email" id="reminder-email" readonly class="w-full px-4 py-3 bg-slate-100 border border-slate-200 rounded-xl text-sm">
                </div>
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-2">Message:</label>
                    <textarea id="reminder-message" rows="4" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-amber-500/20 focus:border-amber-500 resize-none">Hi,

This is a friendly reminder to submit your monthly financial data for the current period.

Please log in to the Coretex EDSS system and complete your submission at your earliest convenience.

Thank you,
System Administrator</textarea>
                </div>
            </div>
            
            <input type="hidden" id="reminder-branch-id">
            @Html.AntiForgeryToken()
            <div class="flex items-center space-x-4 mt-6">
                <button onclick="confirmSendReminder(event)" class="flex-1 px-6 py-3 bg-amber-500 text-white font-bold rounded-xl hover:bg-amber-600 transition-colors flex items-center justify-center space-x-2 cursor-pointer">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
                    <span>Send Reminder</span>
                </button>
                <button onclick="closeReminderModal()" class="px-6 py-3 bg-slate-100 text-slate-600 font-bold rounded-xl hover:bg-slate-200 transition-colors">
                    Cancel
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Success Toast -->
<div id="toast" class="fixed bottom-6 right-6 bg-emerald-500 text-white px-6 py-4 rounded-2xl shadow-2xl hidden items-center space-x-3 z-50">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
    <span id="toast-message" class="font-bold">Reminder sent!</span>
</div>

@section Scripts {
    <script>
        function openReminderModal(branchId) {
            document.getElementById('reminder-branch-id').value = branchId;
            const modal = document.getElementById('reminder-modal');
            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }

        function closeReminderModal() {
            const modal = document.getElementById('reminder-modal');
            modal.classList.remove('flex');
            modal.classList.add('hidden');
        }

        function confirmSendReminder(e) {
            const btn = e.currentTarget;
            const originalText = btn.innerHTML;
            
            const branchId = document.getElementById('reminder-branch-id').value;
            const message = document.getElementById('reminder-message').value;
            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

            if (!branchId) {
                alert('ERROR: Node ID missing.');
                return;
            }

            // Visual Loading State
            btn.disabled = true;
            btn.innerHTML = '<span>DISPATCHING...</span>';

            const formData = new URLSearchParams();
            formData.append('branchId', branchId);
            formData.append('message', message);
            formData.append('__RequestVerificationToken', token);

            fetch('/Admin/SendReminder', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: formData.toString()
            })
            .then(async response => {
                if (response.ok) {
                    showToast('✅ Tactical Alert Dispatched Successfully!');
                    setTimeout(() => {
                        closeReminderModal();
                        btn.disabled = false;
                        btn.innerHTML = originalText;
                    }, 1000);
                } else {
                    const text = await response.text();
                    alert('SERVER ERROR: ' + response.status + ' - ' + text);
                    btn.disabled = false;
                    btn.innerHTML = originalText;
                }
            })
            .catch(error => {
                alert('NETWORK ERROR: ' + error.message);
                btn.disabled = false;
                btn.innerHTML = originalText;
            });
        }

        function showToast(msg) {
            const t = document.getElementById('toast');
            document.getElementById('toast-message').textContent = msg;
            t.classList.replace('hidden', 'flex');
            setTimeout(() => {
                t.classList.replace('flex', 'hidden');
            }, 3000);
        }
    </script>
}
