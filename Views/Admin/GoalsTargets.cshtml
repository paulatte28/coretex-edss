@{
    ViewData["Title"] = "Goals & Targets";
    Layout = "_AdminLayout";
}

<div class="space-y-8">
    <!-- Header -->
    <div class="flex items-center justify-between">
        <div>
            <div class="flex items-center space-x-3 mb-2">
                <a href="/Admin" class="text-slate-400 hover:text-slate-600 transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                </a>
                <span class="px-3 py-1 bg-purple-100 text-purple-700 font-black text-[10px] uppercase tracking-widest rounded-full">Target Setting</span>
            </div>
            <h2 class="text-3xl font-black text-slate-900 tracking-tight">Goals & Targets</h2>
            <p class="text-sm text-slate-500 mt-1">Set performance targets for the company and individual branches.</p>
        </div>
        <button onclick="openGoalModal()" class="px-6 py-3 bg-purple-600 text-white font-bold text-sm rounded-xl hover:bg-purple-700 transition-colors flex items-center space-x-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            <span>Add Goal</span>
        </button>
    </div>

    <!-- Info Banner -->
    <div class="bg-gradient-to-r from-purple-50 to-indigo-50 border border-purple-200 rounded-2xl p-6">
        <div class="flex items-start space-x-4">
            <div class="w-10 h-10 bg-purple-100 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <div>
                <h4 class="font-bold text-purple-900">How Goals Work</h4>
                <p class="text-sm text-purple-700 mt-1">Set monthly or quarterly targets for each branch. Progress is calculated automatically based on submitted financial data. The Dashboard compares actual performance vs. targets.</p>
            </div>
        </div>
    </div>

    <!-- Summary Stats -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-xs text-slate-500 uppercase tracking-widest">Total Goals</p>
                    <p class="text-3xl font-black text-slate-900 mt-1" id="total-goals">0</p>
                </div>
                <div class="w-12 h-12 bg-purple-100 rounded-xl flex items-center justify-center">
                    <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
            </div>
        </div>
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-xs text-slate-500 uppercase tracking-widest">Company-Wide</p>
                    <p class="text-3xl font-black text-indigo-600 mt-1" id="company-goals">0</p>
                </div>
                <div class="w-12 h-12 bg-indigo-100 rounded-xl flex items-center justify-center">
                    <svg class="w-6 h-6 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                </div>
            </div>
        </div>
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-xs text-slate-500 uppercase tracking-widest">Branch-Specific</p>
                    <p class="text-3xl font-black text-blue-600 mt-1" id="branch-goals">0</p>
                </div>
                <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center">
                    <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
                </div>
            </div>
        </div>
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-xs text-slate-500 uppercase tracking-widest">Active Goals</p>
                    <p class="text-3xl font-black text-emerald-600 mt-1" id="active-goals">0</p>
                </div>
                <div class="w-12 h-12 bg-emerald-100 rounded-xl flex items-center justify-center">
                    <svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                </div>
            </div>
        </div>
    </div>

    <!-- Goals List -->
    <div class="bg-white rounded-3xl shadow-sm border border-slate-100 overflow-hidden">
        <div class="p-6 border-b border-slate-100">
            <div class="flex items-center justify-between">
                <h3 class="font-bold text-slate-900">All Goals & Targets</h3>
                <div class="flex items-center space-x-3">
                    <select id="filter-period" onchange="renderGoals()" class="px-4 py-2 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-purple-500 focus:border-transparent outline-none">
                        <option value="">All Periods</option>
                        <option value="monthly">Monthly</option>
                        <option value="quarterly">Quarterly</option>
                        <option value="yearly">Yearly</option>
                    </select>
                    <select id="filter-scope" onchange="renderGoals()" class="px-4 py-2 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-purple-500 focus:border-transparent outline-none">
                        <option value="">All Scopes</option>
                        <option value="company">Company-Wide</option>
                        <option value="branch">Branch-Specific</option>
                    </select>
                </div>
            </div>
        </div>
        
        <div id="goals-list" class="divide-y divide-slate-100">
            <!-- Goals will be rendered here -->
        </div>

        <div id="empty-state" class="hidden p-12 text-center">
            <div class="w-16 h-16 bg-slate-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <h4 class="font-bold text-slate-900 mb-2">No goals set</h4>
            <p class="text-sm text-slate-500 mb-4">Add performance targets to track progress.</p>
            <button onclick="openGoalModal()" class="px-4 py-2 bg-purple-600 text-white font-bold text-sm rounded-xl hover:bg-purple-700 transition-colors">Add First Goal</button>
        </div>
    </div>
</div>

<!-- Add/Edit Goal Modal -->
<div id="goal-modal" class="fixed inset-0 bg-black/50 z-50 hidden flex items-center justify-center p-4">
    <div class="bg-white rounded-3xl w-full max-w-lg shadow-2xl transform transition-all max-h-[90vh] overflow-y-auto">
        <div class="p-6 border-b border-slate-100 sticky top-0 bg-white">
            <div class="flex items-center justify-between">
                <h3 class="text-xl font-black text-slate-900" id="modal-title">Add Goal</h3>
                <button onclick="closeGoalModal()" class="w-10 h-10 bg-slate-100 rounded-xl flex items-center justify-center hover:bg-slate-200 transition-colors">
                    <svg class="w-5 h-5 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
            </div>
        </div>
        <form id="goal-form" class="p-6 space-y-5">
            <input type="hidden" id="goal-id">
            
            <div>
                <label class="block text-sm font-bold text-slate-700 mb-2">Goal Name <span class="text-red-500">*</span></label>
                <input type="text" id="goal-name" required placeholder="e.g., Q1 Revenue Target" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-purple-500 focus:border-transparent outline-none">
            </div>

            <div>
                <label class="block text-sm font-bold text-slate-700 mb-2">Metric <span class="text-red-500">*</span></label>
                <select id="goal-metric" required class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-purple-500 focus:border-transparent outline-none">
                    <option value="">Select Metric</option>
                    <option value="revenue">Total Revenue (₱)</option>
                    <option value="profit">Net Profit (₱)</option>
                    <option value="profit_margin">Profit Margin (%)</option>
                    <option value="expense_ratio">Expense Ratio (%)</option>
                    <option value="customer_count">Customer Count</option>
                    <option value="sales_growth">Sales Growth (%)</option>
                </select>
            </div>

            <div>
                <label class="block text-sm font-bold text-slate-700 mb-2">Target Value <span class="text-red-500">*</span></label>
                <input type="number" id="goal-target" required step="0.01" placeholder="e.g., 500000" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-purple-500 focus:border-transparent outline-none">
            </div>

            <div>
                <label class="block text-sm font-bold text-slate-700 mb-2">Period <span class="text-red-500">*</span></label>
                <select id="goal-period" required class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-purple-500 focus:border-transparent outline-none">
                    <option value="monthly">Monthly</option>
                    <option value="quarterly">Quarterly</option>
                    <option value="yearly">Yearly</option>
                </select>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-2">Start Date <span class="text-red-500">*</span></label>
                    <input type="date" id="goal-start" required class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-purple-500 focus:border-transparent outline-none">
                </div>
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-2">End Date <span class="text-red-500">*</span></label>
                    <input type="date" id="goal-end" required class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-purple-500 focus:border-transparent outline-none">
                </div>
            </div>

            <div>
                <label class="block text-sm font-bold text-slate-700 mb-2">Scope</label>
                <select id="goal-scope" onchange="toggleBranchSelect()" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-purple-500 focus:border-transparent outline-none">
                    <option value="company">Company-Wide (All Branches)</option>
                    <option value="branch">Branch-Specific</option>
                </select>
            </div>

            <div id="branch-select-container" class="hidden">
                <label class="block text-sm font-bold text-slate-700 mb-2">Select Branch <span class="text-red-500">*</span></label>
                <select id="goal-branch" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-purple-500 focus:border-transparent outline-none">
                    <option value="">Select Branch</option>
                </select>
            </div>

            <div>
                <label class="block text-sm font-bold text-slate-700 mb-2">Description</label>
                <textarea id="goal-description" rows="2" placeholder="Optional notes about this goal" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-purple-500 focus:border-transparent outline-none resize-none"></textarea>
            </div>

            <div>
                <label class="block text-sm font-bold text-slate-700 mb-2">Status</label>
                <select id="goal-status" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-purple-500 focus:border-transparent outline-none">
                    <option value="active">Active</option>
                    <option value="completed">Completed</option>
                    <option value="inactive">Inactive</option>
                </select>
            </div>

            <div class="flex space-x-3 pt-4">
                <button type="button" onclick="closeGoalModal()" class="flex-1 px-4 py-3 border border-slate-200 text-slate-700 font-bold rounded-xl hover:bg-slate-50 transition-colors">Cancel</button>
                <button type="submit" class="flex-1 px-4 py-3 bg-purple-600 text-white font-bold rounded-xl hover:bg-purple-700 transition-colors">Save Goal</button>
            </div>
        </form>
    </div>
</div>

<!-- Archive Confirmation Modal -->
<div id="delete-modal" class="fixed inset-0 bg-black/50 z-50 hidden flex items-center justify-center p-4">
    <div class="bg-white rounded-3xl w-full max-w-md shadow-2xl p-6">
        <div class="w-16 h-16 bg-slate-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/></svg>
        </div>
        <h3 class="text-xl font-black text-center text-slate-900 mb-2">Archive Goal?</h3>
        <p class="text-sm text-slate-500 text-center mb-6">This goal will be archived. You can still access historical reports.</p>
        <input type="hidden" id="delete-goal-id">
        <div class="flex space-x-3">
            <button onclick="closeDeleteModal()" class="flex-1 px-4 py-3 border border-slate-200 text-slate-700 font-bold rounded-xl hover:bg-slate-50 transition-colors">Cancel</button>
            <button onclick="confirmDelete()" class="flex-1 px-4 py-3 bg-slate-900 text-white font-bold rounded-xl hover:bg-slate-800 transition-colors">Archive Now</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let goals = [];
        const branches = @Html.Raw(Json.Serialize(ViewBag.Branches));

        const metricLabels = {
            'revenue': 'Total Revenue',
            'profit': 'Net Profit',
            'profit_margin': 'Profit Margin',
            'expense_ratio': 'Expense Ratio',
            'customer_count': 'Customer Count',
            'sales_growth': 'Sales Growth'
        };

        const metricUnits = {
            'revenue': '₱',
            'profit': '₱',
            'profit_margin': '%',
            'expense_ratio': '%',
            'customer_count': '',
            'sales_growth': '%'
        };

        const periodLabels = {
            'Monthly': 'Monthly',
            'Quarterly': 'Quarterly',
            'Yearly': 'Yearly'
        };

        async function fetchGoals() {
            try {
                const response = await fetch('/Admin/GetGoalTargets');
                if (response.ok) {
                    goals = await response.json();
                    renderGoals();
                }
            } catch (error) {
                console.error('Error fetching goals:', error);
            }
        }

        function updateStats() {
            document.getElementById('total-goals').textContent = goals.length;
            document.getElementById('company-goals').textContent = goals.filter(g => g.branchId === '00000000-0000-0000-0000-000000000000' || !g.branchId).length;
            document.getElementById('branch-goals').textContent = goals.filter(g => g.branchId && g.branchId !== '00000000-0000-0000-0000-000000000000').length;
            document.getElementById('active-goals').textContent = goals.filter(g => g.isActive).length;
        }

        function toggleBranchSelect() {
            const scope = document.getElementById('goal-scope').value;
            const container = document.getElementById('branch-select-container');
            const select = document.getElementById('goal-branch');
            
            if (scope === 'branch') {
                container.classList.remove('hidden');
                select.required = true;
                populateBranches();
            } else {
                container.classList.add('hidden');
                select.required = false;
                select.value = '';
            }
        }

        function populateBranches() {
            const select = document.getElementById('goal-branch');
            const currentVal = select.value;
            select.innerHTML = '<option value="">Select Branch</option>';
            
            branches.forEach(branch => {
                select.innerHTML += `<option value="${branch.id}">${branch.name}</option>`;
            });
            if (currentVal) select.value = currentVal;
        }

        function renderGoals() {
            const container = document.getElementById('goals-list');
            const emptyState = document.getElementById('empty-state');
            const periodFilter = document.getElementById('filter-period').value;
            const scopeFilter = document.getElementById('filter-scope').value;

            let filteredGoals = goals.filter(g => {
                const matchesPeriod = !periodFilter || g.periodType.toLowerCase() === periodFilter.toLowerCase();
                const isCompany = !g.branchId || g.branchId === '00000000-0000-0000-0000-000000000000';
                const matchesScope = !scopeFilter || (scopeFilter === 'company' ? isCompany : !isCompany);
                return matchesPeriod && matchesScope;
            });

            updateStats();

            if (filteredGoals.length === 0) {
                container.innerHTML = '';
                emptyState.classList.remove('hidden');
                return;
            }

            emptyState.classList.add('hidden');
            container.innerHTML = filteredGoals.map(goal => {
                const branch = branches.find(b => b.id === goal.branchId);
                const unit = metricUnits[goal.metricName.toLowerCase()] || '';
                const targetDisplay = unit === '₱' 
                    ? `₱${Number(goal.targetValue).toLocaleString()}`
                    : unit === '%' 
                        ? `${goal.targetValue}%`
                        : goal.targetValue;

                const endDate = new Date(goal.effectiveTo || goal.effectiveFrom);
                const today = new Date();
                const daysRemaining = Math.ceil((endDate - today) / (1000 * 60 * 60 * 24));
                const isExpired = daysRemaining < 0;

                return `
                    <div class="p-6 hover:bg-slate-50 transition-colors">
                        <div class="flex items-center justify-between">
                            <div class="flex items-center space-x-4">
                                <div class="w-12 h-12 ${!branch ? 'bg-indigo-100' : 'bg-blue-100'} rounded-xl flex items-center justify-center">
                                    <svg class="w-6 h-6 ${!branch ? 'text-indigo-600' : 'text-blue-600'}" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                </div>
                                <div>
                                    <div class="flex items-center space-x-2">
                                        <h4 class="font-bold text-slate-900 capitalize">${goal.metricName.replace('_', ' ')}</h4>
                                        <span class="px-2 py-0.5 text-[10px] font-bold uppercase tracking-widest rounded-full ${goal.isActive ? 'bg-emerald-100 text-emerald-700' : 'bg-slate-100 text-slate-500'}">${goal.isActive ? 'active' : 'inactive'}</span>
                                        <span class="px-2 py-0.5 text-[10px] font-bold uppercase tracking-widest rounded-full bg-slate-100 text-slate-600">${goal.periodType}</span>
                                    </div>
                                    <div class="flex items-center space-x-3 mt-1">
                                        <span class="text-sm text-slate-600">
                                            <span class="font-bold">Target:</span> 
                                            <span class="text-purple-600 font-bold">${targetDisplay}</span>
                                        </span>
                                        ${branch ? `<span class="text-xs px-2 py-0.5 bg-blue-50 text-blue-600 rounded-full">${branch.name}</span>` : '<span class="text-xs px-2 py-0.5 bg-indigo-50 text-indigo-600 rounded-full">All Branches</span>'}
                                    </div>
                                    <div class="flex items-center space-x-3 mt-2 text-xs text-slate-400">
                                        <span>${new Date(goal.effectiveFrom).toLocaleDateString()} - ${goal.effectiveTo ? new Date(goal.effectiveTo).toLocaleDateString() : 'N/A'}</span>
                                        ${!isExpired && goal.isActive ? `<span class="text-amber-600 font-bold">${daysRemaining} days remaining</span>` : ''}
                                        ${isExpired && goal.isActive ? `<span class="text-red-600 font-bold">Expired</span>` : ''}
                                    </div>
                                </div>
                            </div>
                            <div class="flex items-center space-x-2">
                                <button onclick="editGoal('${goal.id}')" class="w-10 h-10 bg-slate-100 rounded-xl flex items-center justify-center hover:bg-purple-100 hover:text-purple-600 transition-colors">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                                </button>
                                <button onclick="deleteGoal('${goal.id}')" class="w-10 h-10 bg-slate-100 rounded-xl flex items-center justify-center hover:bg-slate-200 hover:text-slate-900 transition-colors" title="Archive Goal">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/></svg>
                                </button>
                            </div>
                        </div>
                    </div>
                `;
            }).join('');
        }

        function openGoalModal(goalId = null) {
            const modal = document.getElementById('goal-modal');
            const title = document.getElementById('modal-title');
            const form = document.getElementById('goal-form');
            
            form.reset();
            document.getElementById('goal-id').value = '';
            document.getElementById('branch-select-container').classList.add('hidden');

            const today = new Date();
            const nextMonth = new Date(today);
            nextMonth.setMonth(nextMonth.getMonth() + 1);
            document.getElementById('goal-start').value = today.toISOString().split('T')[0];
            document.getElementById('goal-end').value = nextMonth.toISOString().split('T')[0];

            if (goalId) {
                const goal = goals.find(g => g.id === goalId);
                if (goal) {
                    title.textContent = 'Edit Goal';
                    document.getElementById('goal-id').value = goal.id;
                    document.getElementById('goal-name').value = goal.metricName;
                    document.getElementById('goal-metric').value = goal.metricName.toLowerCase();
                    document.getElementById('goal-target').value = goal.targetValue;
                    document.getElementById('goal-period').value = goal.periodType;
                    document.getElementById('goal-start').value = goal.effectiveFrom.split('T')[0];
                    document.getElementById('goal-end').value = goal.effectiveTo ? goal.effectiveTo.split('T')[0] : '';
                    document.getElementById('goal-scope').value = (goal.branchId && goal.branchId !== '00000000-0000-0000-0000-000000000000') ? 'branch' : 'company';
                    document.getElementById('goal-status').value = goal.isActive ? 'active' : 'inactive';
                    
                    if (document.getElementById('goal-scope').value === 'branch') {
                        document.getElementById('branch-select-container').classList.remove('hidden');
                        populateBranches();
                        document.getElementById('goal-branch').value = goal.branchId;
                    }
                }
            } else {
                title.textContent = 'Add Goal';
            }

            modal.classList.remove('hidden');
        }

        function closeGoalModal() {
            document.getElementById('goal-modal').classList.add('hidden');
        }

        function editGoal(id) {
            openGoalModal(id);
        }

        function deleteGoal(id) {
            document.getElementById('delete-goal-id').value = id;
            document.getElementById('delete-modal').classList.remove('hidden');
        }

        function closeDeleteModal() {
            document.getElementById('delete-modal').classList.add('hidden');
        }

        async function confirmDelete() {
            const id = document.getElementById('delete-goal-id').value;
            try {
                const response = await fetch(`/Admin/DeleteGoalTarget?id=${id}`, { method: 'POST' });
                if (response.ok) {
                    closeDeleteModal();
                    fetchGoals();
                }
            } catch (error) {
                console.error('Error deleting goal:', error);
            }
        }

        document.getElementById('goal-form').addEventListener('submit', async function(e) {
            e.preventDefault();
            
            const id = document.getElementById('goal-id').value;
            const scope = document.getElementById('goal-scope').value;
            
            if (scope === 'branch' && !document.getElementById('goal-branch').value) {
                alert('Please select a branch for this goal.');
                return;
            }

            const goalData = {
                id: id || '00000000-0000-0000-0000-000000000000',
                metricName: document.getElementById('goal-metric').value,
                targetValue: parseFloat(document.getElementById('goal-target').value),
                periodType: document.getElementById('goal-period').value,
                effectiveFrom: document.getElementById('goal-start').value,
                effectiveTo: document.getElementById('goal-end').value || null,
                branchId: scope === 'branch' ? document.getElementById('goal-branch').value : '00000000-0000-0000-0000-000000000000',
                isActive: document.getElementById('goal-status').value === 'active'
            };

            try {
                const response = await fetch('/Admin/SaveGoalTarget', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(goalData)
                });

                if (response.ok) {
                    closeGoalModal();
                    fetchGoals();
                }
            } catch (error) {
                console.error('Error saving goal:', error);
            }
        });

        document.addEventListener('DOMContentLoaded', fetchGoals);
    </script>
}
