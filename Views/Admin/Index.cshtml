@{
    ViewData["Title"] = "Platform Overview";
    Layout = "_AdminLayout";
}

<div class="space-y-10">
    <div class="flex items-center justify-between">
        <div>
            <h2 class="text-3xl font-black text-slate-900 tracking-tight">Platform Overview</h2>
            <p class="text-xs text-slate-400 font-bold uppercase tracking-widest mt-2">Global System Monitoring & Subscription Performance</p>
        </div>
        <div class="flex space-x-3">
            <div class="px-4 py-2 bg-emerald-50 border border-emerald-100 rounded-xl flex items-center space-x-2">
                <span class="w-2 h-2 bg-emerald-500 rounded-full animate-pulse"></span>
                <span class="text-[10px] font-black text-emerald-700 uppercase tracking-widest">Network Status: Optimal</span>
            </div>
        </div>
    </div>

    <!-- Platform Stats -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-white p-7 rounded-[2.5rem] shadow-sm border border-slate-100 group hover:shadow-xl transition-all">
            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Global Tenants</p>
            <div class="flex items-baseline justify-between mt-2">
                <h4 class="text-3xl font-black text-slate-900 tracking-tighter">142</h4>
                <span class="text-emerald-500 text-xs font-bold">+5 this week</span>
            </div>
            <div class="mt-4 h-1 w-full bg-slate-50 rounded-full overflow-hidden">
                <div class="h-full bg-indigo-500 rounded-full" style="width: 70%"></div>
            </div>
        </div>

        <div class="bg-white p-7 rounded-[2.5rem] shadow-sm border border-slate-100">
            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Active Trials</p>
            <div class="flex items-baseline justify-between mt-2">
                <h4 class="text-3xl font-black text-slate-900 tracking-tighter">28</h4>
                <span class="text-slate-400 text-xs font-bold">12 expire soon</span>
            </div>
             <div class="mt-4 h-1 w-full bg-slate-50 rounded-full overflow-hidden">
                <div class="h-full bg-blue-400 rounded-full" style="width: 40%"></div>
            </div>
        </div>

        <div class="bg-slate-900 p-7 rounded-[2.5rem] text-white shadow-xl">
            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">MRR Estimate</p>
            <div class="flex items-baseline justify-between mt-2">
                <h4 class="text-3xl font-black tracking-tighter">₱2.4M</h4>
                <span class="text-emerald-400 text-xs font-bold">+12% WoW</span>
            </div>
             <div class="mt-4 h-1 w-full bg-white/10 rounded-full overflow-hidden">
                <div class="h-full bg-emerald-500 rounded-full" style="width: 85%"></div>
            </div>
        </div>

        <div class="bg-white p-7 rounded-[2.5rem] shadow-sm border border-slate-100">
            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Uptime (30d)</p>
            <div class="flex items-baseline justify-between mt-2">
                <h4 class="text-3xl font-black text-slate-900 tracking-tighter">99.98%</h4>
                <span class="text-emerald-500 text-xs font-bold">Stable</span>
            </div>
             <div class="mt-4 h-1 w-full bg-slate-50 rounded-full overflow-hidden">
                <div class="h-full bg-indigo-600 rounded-full" style="width: 98%"></div>
            </div>
        </div>
    </div>

    <!-- Platform Insights Chart -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div class="lg:col-span-2 bg-white p-8 rounded-[2.5rem] shadow-sm border border-slate-100">
            <div class="flex justify-between items-center mb-8">
                <div>
                    <h3 class="font-black text-slate-800 text-lg">Tenant Growth Pattern</h3>
                    <p class="text-[10px] text-slate-400 font-bold uppercase tracking-widest">6-Month Acquisition Tracking</p>
                </div>
            </div>
            <div class="h-72">
                <canvas id="growthChart"></canvas>
            </div>
        </div>

        <div class="bg-gradient-to-br from-indigo-600 to-primary p-8 rounded-[2.5rem] text-white shadow-xl flex flex-col justify-between">
            <div>
                <h3 class="font-bold text-lg mb-2">System Broadcast</h3>
                <p class="text-xs text-indigo-200 mb-6">Send platform-wide alerts to all registered business owners.</p>
                
                <textarea class="w-full bg-white/5 border border-white/10 rounded-2xl p-4 text-xs text-white placeholder-indigo-300 focus:ring-2 focus:ring-white/20 transition-all outline-none" rows="4" placeholder="Enter system announcement..."></textarea>
                <button class="mt-4 w-full py-3 bg-white text-primary font-black rounded-xl text-[10px] uppercase tracking-widest hover:bg-white/90 transition-all">
                    Push Broadcast
                </button>
            </div>

            <div class="mt-8 pt-8 border-t border-white/10">
                <p class="text-[10px] font-bold uppercase tracking-widest text-indigo-300">Total Notifications Sent</p>
                <p class="text-2xl font-black mt-1">1,245 Events</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const ctx = document.getElementById('growthChart').getContext('2d');
            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: ['Nov', 'Dec', 'Jan', 'Feb', 'Mar', 'Apr'],
                    datasets: [{
                        label: 'New Tenants',
                        data: [85, 92, 110, 105, 130, 142],
                        borderColor: '#4F46E5',
                        borderWidth: 4,
                        tension: 0.4,
                        fill: true,
                        backgroundColor: 'rgba(79, 70, 229, 0.05)',
                        pointRadius: 0,
                        pointHoverRadius: 6
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { 
                            beginAtZero: true, 
                            grid: { color: '#F1F5F9', borderDash: [5, 5] },
                            ticks: { font: { size: 10, weight: 'bold' } }
                        },
                        x: { 
                            grid: { display: false },
                            ticks: { font: { size: 10, weight: 'black' } }
                        }
                    }
                }
            });
        });
    </script>
}
