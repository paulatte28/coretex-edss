@using coretex_finalproj.Models
@using Microsoft.AspNetCore.Identity
@inject UserManager<AppUser> UserManager
@{
    ViewData["Title"] = "Dashboard";
    Layout = "_AdminLayout";
    var currentUser = await UserManager.GetUserAsync(User);
    var isManager = User.IsInRole("BRANCH_ADMIN");
    var branchName = ViewBag.BranchName ?? "Main Office";
    var recentActivity = ViewBag.RecentActivity as List<ActivityLogEntry> ?? new List<ActivityLogEntry>();
}

<div class="space-y-8 animate-in fade-in duration-700">
    <!-- Hero Banner -->
    <div class="relative overflow-hidden bg-slate-900 rounded-[2rem] p-8 md:p-12 text-white shadow-2xl shadow-slate-200">
        <div class="relative z-10">
            <div class="flex items-center space-x-3 mb-4">
                <span class="px-3 py-1 bg-white/10 backdrop-blur-md text-white/80 font-black text-[10px] uppercase tracking-[0.2em] rounded-full border border-white/10">
                    @(isManager ? "Branch Management Console" : "System Infrastructure Console")
                </span>
                <span class="w-1.5 h-1.5 bg-emerald-400 rounded-full animate-pulse"></span>
            </div>
            <h1 class="text-4xl md:text-5xl font-black tracking-tight mb-4">
                @(isManager ? $"Hello, Manager" : "Systems Online")
            </h1>
            <p class="text-slate-400 max-w-xl text-lg leading-relaxed">
                @(isManager ? $"Overseeing operations for the {branchName}. All systems are optimized and active." : "CORETEX Executive EDSS is monitoring all 5 operational nodes across the region.")
            </p>
        </div>
        
        <!-- Abstract Decoration -->
        <div class="absolute top-0 right-0 -mt-20 -mr-20 w-96 h-96 bg-primary/20 rounded-full blur-[100px]"></div>
        <div class="absolute bottom-0 left-0 -mb-20 -ml-20 w-64 h-64 bg-secondary/10 rounded-full blur-[80px]"></div>
    </div>

    <!-- Stats Section -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Staff Card -->
        <div onclick="location.href='/Admin/UserManagement'" class="group bg-white rounded-3xl p-6 border border-slate-100 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 cursor-pointer">
            <div class="flex items-center justify-between mb-4">
                <div class="w-12 h-12 bg-indigo-50 rounded-2xl flex items-center justify-center group-hover:bg-indigo-600 transition-colors duration-300">
                    <svg class="w-6 h-6 text-indigo-600 group-hover:text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
                </div>
                <div class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Active Staff</div>
            </div>
            <div class="flex items-baseline space-x-2">
                <span class="text-4xl font-black text-slate-900">@ViewBag.UserCount</span>
                <span class="text-sm font-bold text-slate-400">Deployed</span>
            </div>
            <div class="mt-4 pt-4 border-t border-slate-50 flex items-center justify-between">
                <span class="text-[10px] font-bold text-slate-400 uppercase">Manage Team</span>
                <a href="/Admin/UserManagement" class="text-indigo-600 hover:translate-x-1 transition-transform">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </a>
            </div>
        </div>

        <!-- Alerts Card -->
        <div onclick="location.href='/Admin/ActivityLog'" class="group bg-white rounded-3xl p-6 border border-slate-100 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 cursor-pointer">
            <div class="flex items-center justify-between mb-4">
                <div class="w-12 h-12 bg-rose-50 rounded-2xl flex items-center justify-center group-hover:bg-rose-600 transition-colors duration-300">
                    <svg class="w-6 h-6 text-rose-600 group-hover:text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                </div>
                <div class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Security Events</div>
            </div>
            <div class="flex items-baseline space-x-2">
                <span class="text-4xl font-black text-slate-900">@ViewBag.SecurityEventsCount</span>
                <span class="text-sm font-bold text-rose-500">Alerts</span>
            </div>
            <div class="mt-4 pt-4 border-t border-slate-50 flex items-center justify-between">
                <span class="text-[10px] font-bold text-slate-400 uppercase">View Audit</span>
                <a href="/Admin/ActivityLog" class="text-rose-600 hover:translate-x-1 transition-transform">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </a>
            </div>
        </div>

        <!-- Submission Status -->
        <div onclick="location.href='/Admin/BranchSubmissions'" class="group bg-white rounded-3xl p-6 border border-slate-100 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 cursor-pointer">
            <div class="flex items-center justify-between mb-4">
                <div class="w-12 h-12 bg-amber-50 rounded-2xl flex items-center justify-center group-hover:bg-amber-600 transition-colors duration-300">
                    <svg class="w-6 h-6 text-amber-600 group-hover:text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
                <div class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Reporting</div>
            </div>
            <div class="flex items-baseline space-x-2">
                <span class="text-4xl font-black text-slate-900">@(ViewBag.PendingSubmissions > 0 ? "Pending" : "Ready")</span>
            </div>
            <div class="mt-4 pt-4 border-t border-slate-50 flex items-center justify-between">
                <span class="text-[10px] font-bold text-slate-400 uppercase">@(isManager ? "Submit Now" : "Branch Status")</span>
                <a href="/Admin/BranchSubmissions" class="text-amber-600 hover:translate-x-1 transition-transform">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </a>
            </div>
        </div>

        <!-- Audit Logs Quick Link -->
        <div onclick="location.href='/Admin/ActivityLog'" class="group bg-white rounded-3xl p-6 border border-slate-100 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 cursor-pointer">
            <div class="flex items-center justify-between mb-4">
                <div class="w-12 h-12 bg-indigo-50 rounded-2xl flex items-center justify-center group-hover:bg-indigo-600 transition-colors duration-300">
                    <svg class="w-6 h-6 text-indigo-600 group-hover:text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01m-.01 4h.01"/></svg>
                </div>
                <div class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Compliance</div>
            </div>
            <div class="flex items-baseline space-x-2">
                <span class="text-4xl font-black text-slate-900">Live</span>
                <span class="text-sm font-bold text-indigo-500">Audit</span>
            </div>
            <div class="mt-4 pt-4 border-t border-slate-50 flex items-center justify-between">
                <span class="text-[10px] font-bold text-slate-400 uppercase">Monitor Activity</span>
                <a href="/Admin/ActivityLog" class="text-indigo-600 hover:translate-x-1 transition-transform">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </a>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Financial Summary Panel -->
        <div class="lg:col-span-1 space-y-6">
            <h3 class="text-xl font-black text-slate-900 tracking-tight">Financial Health</h3>
            
            <div class="bg-white rounded-[2rem] p-8 border border-slate-100 shadow-sm space-y-8">
                <!-- Today's Performance -->
                <div>
                    <div class="flex items-center justify-between mb-4">
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Today's Revenue</p>
                        <span class="px-2 py-0.5 bg-emerald-100 text-emerald-700 text-[8px] font-black uppercase rounded-full">Live</span>
                    </div>
                    <div class="flex items-baseline space-x-1">
                        <span class="text-xs font-bold text-slate-400">₱</span>
                        <span class="text-3xl font-black text-slate-900">@ViewBag.TodaySales.ToString("N2")</span>
                    </div>
                </div>

                <!-- Monthly Progress -->
                <div class="space-y-4">
                    <div class="flex items-center justify-between">
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Monthly Target Progress</p>
                        <p class="text-[10px] font-black text-indigo-600 uppercase">@(ViewBag.MonthSales > 100000 ? "100%" : (ViewBag.MonthSales / 1000).ToString("F0") + "%")</p>
                    </div>
                    <div class="h-2 bg-slate-50 rounded-full overflow-hidden">
                        <div class="h-full bg-indigo-600 rounded-full" style="width: @(ViewBag.MonthSales > 100000 ? "100%" : (ViewBag.MonthSales / 1000).ToString("F0") + "%")"></div>
                    </div>
                    <p class="text-[10px] text-slate-400 font-bold italic">Based on active transactions</p>
                </div>

                <!-- Monthly Summary -->
                <div class="pt-6 border-t border-slate-50 grid grid-cols-2 gap-4">
                    <div>
                        <p class="text-[9px] font-black text-slate-400 uppercase mb-1">Mtd Sales</p>
                        <p class="font-black text-slate-900">₱@ViewBag.MonthSales.ToString("N0")</p>
                    </div>
                    <div>
                        <p class="text-[9px] font-black text-slate-400 uppercase mb-1">Mtd Expenses</p>
                        <p class="font-black text-rose-500">₱@ViewBag.MonthExpenses.ToString("N0")</p>
                    </div>
                </div>
            </div>

            <!-- Mini Action Links -->
            <div class="grid grid-cols-2 gap-3">
                <a href="/Admin/UserManagement" class="flex flex-col items-center justify-center p-4 bg-white rounded-2xl border border-slate-100 hover:bg-slate-50 transition-colors group">
                    <svg class="w-5 h-5 text-indigo-500 mb-2 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
                    <span class="text-[10px] font-black text-slate-900 uppercase">Staff</span>
                </a>
                <a href="/Admin/ActivityLog" class="flex flex-col items-center justify-center p-4 bg-white rounded-2xl border border-slate-100 hover:bg-slate-50 transition-colors group">
                    <svg class="w-5 h-5 text-rose-500 mb-2 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                    <span class="text-[10px] font-black text-slate-900 uppercase">Logs</span>
                </a>
            </div>
        </div>

        <!-- Recent Activity Feed -->
        <div class="lg:col-span-2 bg-white rounded-[2rem] p-8 border border-slate-100 shadow-sm flex flex-col h-full">
            <div class="flex items-center justify-between mb-8">
                <div>
                    <h3 class="text-xl font-black text-slate-900 tracking-tight">Incident & Activity Feed</h3>
                    <p class="text-xs text-slate-400 font-bold uppercase tracking-widest mt-1">Real-time surveillance</p>
                </div>
                <a href="/Admin/ActivityLog" class="px-4 py-2 bg-slate-50 text-slate-600 text-[10px] font-black uppercase tracking-widest rounded-xl hover:bg-slate-100 transition-colors border border-slate-100">
                    Audit History
                </a>
            </div>

            <div class="flex-1 space-y-6 overflow-y-auto pr-2 custom-scrollbar">
                @if (!recentActivity.Any())
                {
                    <div class="flex flex-col items-center justify-center py-20 text-center">
                        <div class="w-20 h-20 bg-slate-50 rounded-full flex items-center justify-center mb-4">
                            <svg class="w-10 h-10 text-slate-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        </div>
                        <p class="text-slate-400 font-medium">System records are currently clear.</p>
                    </div>
                }
                else
                {
                    @foreach (var log in recentActivity)
                    {
                        <div class="flex items-start space-x-4 group p-4 rounded-2xl hover:bg-slate-50/80 transition-colors border border-transparent hover:border-slate-100">
                            <div class="w-10 h-10 shrink-0 rounded-full flex items-center justify-center bg-white shadow-sm ring-1 ring-slate-100">
                                @if (log.ActionType.Contains("LOGIN")) {
                                    <svg class="w-5 h-5 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"/></svg>
                                } else if (log.ActionType.Contains("USER")) {
                                    <svg class="w-5 h-5 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                                } else if (log.ActionType.Contains("FAILURE")) {
                                    <svg class="w-5 h-5 text-rose-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
                                } else {
                                    <svg class="w-5 h-5 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                }
                            </div>
                            <div class="flex-1 min-w-0">
                                <div class="flex items-center justify-between">
                                    <p class="text-sm font-black text-slate-900 truncate">@log.ActionType</p>
                                    <span class="text-[10px] font-bold text-slate-400 whitespace-nowrap ml-2">@log.CreatedAt.ToString("MMM dd, HH:mm")</span>
                                </div>
                                <p class="text-xs text-slate-500 mt-0.5 line-clamp-1">@log.Description</p>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Smooth animations for cards
            const cards = document.querySelectorAll('.group');
            cards.forEach((card, index) => {
                card.style.opacity = '0';
                card.style.transform = 'translateY(10px)';
                setTimeout(() => {
                    card.style.transition = 'all 0.5s ease';
                    card.style.opacity = '1';
                    card.style.transform = 'translateY(0)';
                }, index * 50);
            });
        });
    </script>
}
