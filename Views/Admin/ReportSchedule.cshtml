@model coretex_finalproj.Models.BusinessSummaryViewModel
@{
    ViewData["Title"] = "Executive Reports";
    Layout = "_AdminLayout";
}

<div class="space-y-8">
    <div class="flex items-center justify-between no-print">
        <div>
            <h2 class="text-3xl font-black text-slate-900 tracking-tight">Executive Summaries</h2>
            <p class="text-sm text-slate-500 mt-1">Generate strategic intelligence reports for stakeholders</p>
        </div>
        <div class="flex gap-3">
             <button onclick="window.print()" class="px-5 py-2 bg-indigo-600 text-white font-bold rounded-xl hover:bg-indigo-700 transition-all flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/></svg>
                Print Report
            </button>
        </div>
    </div>

    <!-- The Report Document -->
    <div class="bg-white rounded-[3rem] p-12 shadow-2xl border border-slate-100 max-w-5xl mx-auto print:shadow-none print:border-none print:p-0">
        <!-- Logo & Header -->
        <div class="flex justify-between items-center border-b-4 border-indigo-600 pb-8 mb-12">
            <div>
                <h1 class="text-5xl font-black text-slate-900 tracking-tighter">CORETEX<span class="text-indigo-600">.</span></h1>
                <p class="text-slate-400 font-black uppercase tracking-[0.3em] text-xs mt-2">Executive Decision Support System</p>
            </div>
            <div class="text-right">
                <p class="text-sm font-black text-slate-900 uppercase">Monthly Performance Report</p>
                <p class="text-slate-500 text-xs">Generated: @DateTime.Now.ToString("MMMM dd, yyyy")</p>
                <p class="text-indigo-600 font-bold text-xs">Period: @DateTime.Now.ToString("MMMM yyyy")</p>
            </div>
        </div>

        <!-- 3-Column Summary Stats -->
        <div class="grid grid-cols-3 gap-8 mb-16">
            <div class="bg-slate-50 p-8 rounded-[2rem]">
                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Total Revenue</p>
                <h4 class="text-3xl font-black text-slate-900">₱@Model.TotalRevenue.ToString("N2")</h4>
            </div>
            <div class="bg-slate-50 p-8 rounded-[2rem]">
                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Total Expenses</p>
                <h4 class="text-3xl font-black text-slate-900">₱@Model.TotalExpenses.ToString("N2")</h4>
            </div>
            <div class="bg-indigo-600 p-8 rounded-[2rem] text-white">
                <p class="text-[10px] font-black text-indigo-200 uppercase tracking-widest mb-2">Net Profit</p>
                <h4 class="text-3xl font-black text-white">₱@Model.NetProfit.ToString("N2")</h4>
            </div>
        </div>

        <!-- Insights Grid -->
        <div class="grid grid-cols-2 gap-12 mb-16">
            <div>
                <h5 class="text-xs font-black text-indigo-600 uppercase tracking-widest mb-6 border-b border-slate-100 pb-2">Operational Insights</h5>
                <ul class="space-y-4">
                    <li class="flex items-start gap-3">
                        <div class="w-5 h-5 bg-emerald-100 text-emerald-600 rounded-full flex items-center justify-center shrink-0 mt-1">
                             <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                        </div>
                        <p class="text-slate-600 text-sm">System healthy with all @Model.ActiveBranches active branches.</p>
                    </li>
                    <li class="flex items-start gap-3">
                        <div class="w-5 h-5 bg-indigo-100 text-indigo-600 rounded-full flex items-center justify-center shrink-0 mt-1">
                             <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
                        </div>
                        <p class="text-slate-600 text-sm">Revenue trend shows stability across core regions.</p>
                    </li>
                </ul>
            </div>
            <div>
                <h5 class="text-xs font-black text-rose-600 uppercase tracking-widest mb-6 border-b border-slate-100 pb-2">Forecasting Alerts</h5>
                <div class="p-6 bg-rose-50 rounded-3xl border border-rose-100">
                    <p class="text-rose-900 font-bold text-sm mb-2">Attention Required</p>
                    <p class="text-rose-700 text-xs leading-relaxed">Branch audit trails indicate increasing operational costs. Recommend reviewing KPI goals for next month.</p>
                </div>
            </div>
        </div>

        <!-- Footer -->
        <div class="text-center pt-12 border-t border-slate-50">
            <p class="text-[10px] text-slate-300 font-black uppercase tracking-widest italic">Coretex Proprietary Strategic Document • Internal Use Only</p>
        </div>
    </div>
</div>

<style>
    @@media print {
        .no-print { display: none !important; }
        body { background-color: white !important; }
        nav { display: none !important; }
        main { padding: 0 !important; margin: 0 !important; width: 100% !important; }
    }
</style>
