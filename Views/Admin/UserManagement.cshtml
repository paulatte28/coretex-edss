@using coretex_finalproj.Models
@using Microsoft.AspNetCore.Identity
@inject UserManager<AppUser> UserManager
@model List<AppUser>
@{
    ViewData["Title"] = "User Management";
    Layout = "_AdminLayout";
    var currentUser = await UserManager.GetUserAsync(User);
    var isManager = User.IsInRole("BRANCH_ADMIN");
    var branches = ViewBag.Branches as List<Branch> ?? new List<Branch>();
    
    // Filter out the current user if they are a manager
    var displayUsers = Model.Where(u => u.Id != currentUser?.Id).ToList();
    
    // Calculate stats based on the filtered model
    var totalStaff = displayUsers.Count;
    var foCount = displayUsers.Count(u => u.Role == "FINANCE");
    var cashierCount = displayUsers.Count(u => u.Role == "CASHIER");
    var activeStaff = displayUsers.Count(u => u.IsActive);

    // Manager-Specific Operational Logic
    var hasFinance = foCount > 0;
    var isOperational = hasFinance && displayUsers.Any(u => u.Role == "BRANCH_ADMIN");
    var securityRisk = displayUsers.Any(u => !u.EmailConfirmed || !u.TwoFactorEnabled);

    // CEO Quota Logic
    var ceoExists = Model.Any(u => u.Role == "CEO");
}

<div class="space-y-10 pb-10">
    <!-- Premium Header -->
    <div class="relative overflow-hidden bg-slate-900 rounded-[2.5rem] p-10 text-white shadow-2xl">
        <div class="relative z-10 flex items-center justify-between">
            <div>
                <div class="flex items-center space-x-3 mb-4">
                    <a href="/Admin" class="w-8 h-8 flex items-center justify-center bg-white/10 hover:bg-white/20 rounded-full transition-all">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M15 19l-7-7 7-7"/></svg>
                    </a>
                    <span class="px-3 py-1 bg-indigo-500/20 text-indigo-300 font-black text-[10px] uppercase tracking-widest rounded-full border border-indigo-500/30">Workforce Provisioning</span>
                </div>
                <h2 class="text-4xl font-black tracking-tight">Staff Management</h2>
                <p class="text-slate-400 mt-2 text-sm font-medium">
                    @(isManager ? $"Overseeing operational personnel for {currentUser?.Branch?.Name ?? "Assigned Branch"}." : "Global workforce administration and node access control.")
                </p>
            </div>
            <button onclick="openCreateModal()" class="px-8 py-4 bg-emerald-500 hover:bg-emerald-400 text-white font-black text-sm uppercase tracking-widest rounded-2xl transition-all shadow-xl shadow-emerald-500/20 flex items-center space-x-3 group">
                <div class="p-1 bg-white/20 rounded-lg group-hover:rotate-90 transition-transform">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M12 4v16m8-8H4"/></svg>
                </div>
                <span>Deploy New Staff</span>
            </button>
        </div>
        <!-- Decorative Background Elements -->
        <div class="absolute top-0 right-0 -mr-20 -mt-20 w-80 h-80 bg-indigo-500/10 rounded-full blur-3xl"></div>
        <div class="absolute bottom-0 left-0 -ml-20 -mb-20 w-80 h-80 bg-emerald-500/10 rounded-full blur-3xl"></div>
    </div>

    <!-- Integrated Archiving Tabs -->
    <div class="flex border-b border-slate-200 gap-8 mb-6">
        <button onclick="switchTab('active')" id="tab-active" class="pb-4 px-2 text-xs font-black uppercase tracking-widest border-b-2 border-indigo-600 text-indigo-600 transition-all">Active Personnel (@displayUsers.Count(u => u.IsActive && (u.Branch == null || !u.Branch.IsArchived)))</button>
        <button onclick="switchTab('archived')" id="tab-archived" class="pb-4 px-2 text-xs font-black uppercase tracking-widest border-b-2 border-transparent text-slate-400 hover:text-slate-600 transition-all">Archived Staff (@Model.Count(u => (!u.IsActive || (u.Branch != null && u.Branch.IsArchived)) && u.Id != currentUser?.Id))</button>
    </div>

    <!-- Active Staff Section -->
    <div id="section-active" class="tab-section bg-white rounded-[2.5rem] border border-slate-100 shadow-sm overflow-hidden mb-10">
        <div class="p-10 border-b border-slate-50 bg-slate-50/30">
            <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-6">
                <div>
                    <h3 class="text-2xl font-black text-slate-900 tracking-tight">Deployment Roster</h3>
                    <p class="text-xs text-slate-400 font-bold uppercase mt-1 tracking-widest">Active Personnel Directory</p>
                </div>
                
                <div class="flex flex-wrap items-center gap-3">
                    <!-- Branch Filter -->
                    @if (!isManager) {
                        <div class="relative">
                            <select id="branch-filter" onchange="filterUsers()" class="appearance-none pl-4 pr-10 py-2.5 bg-slate-50 border border-slate-200 rounded-xl text-xs focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 outline-none transition-all font-bold text-slate-600 cursor-pointer">
                                <option value="">All Branches</option>
                                @foreach(var b in branches.Where(x => !x.IsArchived)) {
                                    <option value="@b.Id">@b.Name</option>
                                }
                            </select>
                            <div class="absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none text-slate-400">
                                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7"/></svg>
                            </div>
                        </div>
                    }

                    <!-- Role Filters -->
                    <div class="flex items-center bg-slate-100 p-1 rounded-xl border border-slate-200">
                        <button onclick="filterByRole('')" class="role-pill active px-4 py-1.5 text-[9px] font-black uppercase tracking-widest rounded-lg transition-all active-pill">All</button>
                        <button onclick="filterByRole('BRANCH_ADMIN')" class="role-pill px-4 py-1.5 text-[9px] font-black uppercase tracking-widest rounded-lg transition-all text-slate-400">Managers</button>
                        <button onclick="filterByRole('FINANCE')" class="role-pill px-4 py-1.5 text-[9px] font-black uppercase tracking-widest rounded-lg transition-all text-slate-400">Finance</button>
                        <button onclick="filterByRole('CASHIER')" class="role-pill px-4 py-1.5 text-[9px] font-black uppercase tracking-widest rounded-lg transition-all text-slate-400">Cashiers</button>
                        <button onclick="filterByStatus('locked')" class="role-pill px-4 py-1.5 text-[9px] font-black uppercase tracking-widest rounded-lg transition-all text-rose-500 hover:bg-rose-50">
                            Locked Out
                            @if (displayUsers.Any(u => u.LockoutEnd > DateTimeOffset.UtcNow))
                            {
                                <span class="ml-1 w-1.5 h-1.5 bg-rose-500 rounded-full animate-ping"></span>
                            }
                        </button>
                    </div>
                    
                    <div class="relative group">
                        <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400 group-focus-within:text-indigo-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                        <input type="text" id="search-input" onkeyup="filterUsers()" placeholder="Search active..." class="pl-11 pr-6 py-2.5 bg-slate-50 border border-slate-200 rounded-xl text-xs focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 outline-none transition-all w-48 font-medium">
                    </div>
                </div>
            </div>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead>
                    <tr class="border-b border-slate-50">
                        <th class="px-10 py-6 text-left text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">Personnel Identity</th>
                        <th class="px-10 py-6 text-left text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">Role</th>
                        <th class="px-10 py-6 text-left text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">Node</th>
                        <th class="px-10 py-6 text-center text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">Management</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50" id="userTableBody">
                    @foreach (var user in displayUsers.Where(u => u.IsActive && (u.Branch == null || !u.Branch.IsArchived)))
                    {
                        <tr class="user-row hover:bg-slate-50/50 transition-all duration-200" 
                            data-name="@(user.FullName?.ToLower() ?? "")" 
                            data-email="@(user.Email?.ToLower() ?? "")"
                            data-role="@(user.Role ?? "")"
                            data-branch="@(user.BranchId?.ToString() ?? "")"
                            data-is-locked="@(user.LockoutEnd > DateTimeOffset.UtcNow ? "true" : "false")">
                            <td class="px-10 py-6">
                                <div class="flex items-center space-x-4">
                                    <div class="w-12 h-12 bg-slate-100 rounded-2xl flex items-center justify-center text-slate-600 font-black text-lg border border-slate-200">
                                        @((user.FullName ?? "U").Substring(0, 1).ToUpper())
                                    </div>
                                    <div>
                                        <div class="flex items-center space-x-2">
                                            <p class="font-black text-slate-900 text-sm tracking-tight">@user.FullName</p>
                                            @if (user.LockoutEnd > DateTimeOffset.UtcNow)
                                            {
                                                <span class="p-1 bg-rose-100 text-rose-600 rounded-md" title="SECURITY LOCKOUT ACTIVE">
                                                    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/></svg>
                                                </span>
                                            }
                                        </div>
                                        <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mt-0.5">@user.Email</p>
                                    </div>
                                </div>
                            </td>
                            <td class="px-10 py-6">
                                @{
                                    var isLead = user.Role == "BRANCH_ADMIN";
                                    var roleColor = user.Role switch {
                                        "ADMIN" => "bg-rose-500",
                                        "CEO" => "bg-indigo-600",
                                        "BRANCH_ADMIN" => "bg-amber-500 ring-4 ring-amber-500/20",
                                        "FINANCE" => "bg-emerald-500",
                                        "CASHIER" => "bg-slate-500",
                                        _ => "bg-slate-400"
                                    };
                                }
                                <div class="flex items-center space-x-2">
                                    <span class="px-3 py-1.5 @roleColor text-white font-black text-[9px] uppercase tracking-[0.15em] rounded-lg shadow-sm min-w-[80px] text-center">
                                        @(string.IsNullOrEmpty(user.Role) ? "USER" : user.Role.Replace("_", " "))
                                    </span>
                                    @if (isLead) {
                                        <div class="p-1 bg-amber-100 text-amber-600 rounded-md" title="Branch Lead">
                                            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                                        </div>
                                    }
                                </div>
                            </td>
                            <td class="px-10 py-6 text-sm font-bold text-slate-600">@(user.Branch?.Name ?? "General Ops")</td>
                            <td class="px-10 py-6 text-center">
                                <div class="flex items-center justify-center space-x-2">
                                    @if (user.Role == "CEO" && !User.IsInRole("CEO"))
                                    {
                                        <div class="p-2.5 text-amber-500/50 cursor-not-allowed" title="CEO Security Shield Active">
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                                        </div>
                                    }
                                    else
                                    {
                                         <button onclick="openEditModal('@user.Id', '@user.FullName', '@user.Role', '@user.IsActive')" class="p-2.5 text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-xl transition-all" title="Edit Profile">
                                             <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                                         </button>

                                         @if (user.LockoutEnd > DateTimeOffset.UtcNow)
                                         {
                                             <form asp-action="UnlockUser" method="post" class="inline" onsubmit="return confirm('Immediately unlock access for this personnel?')">
                                                 <input type="hidden" name="userId" value="@user.Id" />
                                                 @Html.AntiForgeryToken()
                                                 <button type="submit" class="p-2.5 text-rose-500 hover:bg-rose-50 rounded-xl transition-all animate-pulse" title="FORCE UNLOCK">
                                                     <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/></svg>
                                                 </button>
                                             </form>
                                         }

                                         <button onclick="openDeleteModal('@user.Id', '@user.FullName')" class="p-2.5 text-slate-400 hover:text-rose-600 hover:bg-rose-50 rounded-xl transition-all" title="Archive Personnel">
                                             <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                                         </button>
                                     }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Archived Staff Section -->
    <div id="section-archived" class="tab-section hidden bg-white rounded-[2.5rem] border border-slate-100 shadow-sm overflow-hidden">
        <div class="p-10 border-b border-slate-50 bg-slate-50/30">
            <h3 class="text-2xl font-black text-slate-900 tracking-tight">Revoked Personnel</h3>
            <p class="text-xs text-slate-400 font-bold uppercase mt-1 tracking-widest">Historical Staff Archive</p>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead>
                    <tr class="border-b border-slate-50">
                        <th class="px-10 py-6 text-left text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">Personnel Identity</th>
                        <th class="px-10 py-6 text-left text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">Former Role</th>
                        <th class="px-10 py-6 text-left text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">Last Branch</th>
                        <th class="px-10 py-6 text-center text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">Recovery</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50">
                    @{
                        var archivedUsers = Model.Where(u => (!u.IsActive || (u.Branch != null && u.Branch.IsArchived)) && u.Id != currentUser?.Id).ToList();
                    }
                    @foreach (var user in archivedUsers)
                    {
                        <tr>
                            <td class="px-10 py-6">
                                <div class="flex items-center space-x-4 grayscale">
                                    <div class="w-12 h-12 bg-slate-50 rounded-2xl flex items-center justify-center text-slate-400 font-black text-lg border border-slate-100">
                                        @((user.FullName ?? "U").Substring(0, 1).ToUpper())
                                    </div>
                                    <div>
                                        <p class="font-black text-slate-400 text-sm tracking-tight">@user.FullName</p>
                                        <p class="text-[10px] font-bold text-slate-300 uppercase tracking-widest mt-0.5">@user.Email</p>
                                    </div>
                                </div>
                            </td>
                            <td class="px-10 py-6">
                                <span class="px-3 py-1.5 bg-slate-50 text-slate-400 font-black text-[9px] uppercase tracking-[0.15em] rounded-lg">@user.Role</span>
                            </td>
                            <td class="px-10 py-6 text-sm font-bold text-slate-400">@(user.Branch?.Name ?? "General Ops")</td>
                            <td class="px-10 py-6 text-center">
                                <form asp-action="UnarchiveStaff" asp-route-id="@user.Id" method="post">
                                    <button type="submit" class="px-5 py-2 bg-emerald-500 text-white font-black text-[10px] uppercase tracking-widest rounded-xl hover:bg-emerald-600 transition-all shadow-lg shadow-emerald-100">Re-Activate</button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any(u => !u.IsActive))
                    {
                        <tr>
                            <td colspan="4" class="px-10 py-20 text-center text-slate-300 font-black text-xs uppercase tracking-widest">No archived personnel found</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Modals {
    <!-- Create User Modal -->
    <div id="user-modal" class="fixed inset-0 bg-slate-900/40 backdrop-blur-md z-[9999] hidden items-center justify-center animate-in fade-in duration-300">
        <div class="bg-white rounded-[2rem] shadow-2xl w-full max-w-md mx-4 overflow-hidden animate-in zoom-in duration-300">
            <div class="p-8 border-b border-slate-100 flex items-center justify-between bg-slate-50/50">
                <h3 class="text-2xl font-black text-slate-900">Provision User</h3>
                <button onclick="closeModal('user-modal')" class="text-slate-400 hover:text-slate-600 transition-colors">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
            </div>
            <form action="/Admin/CreateUser" method="post" class="p-8 space-y-6">
                @Html.AntiForgeryToken()
                <div>
                    <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Full Name</label>
                    <input type="text" name="fullName" required class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-secondary/20 outline-none transition-all" placeholder="Enter name">
                </div>
                <div>
                    <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Security Role</label>
                    <select name="role" id="create-role" onchange="suggestCredentials()" required class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-secondary/20 outline-none transition-all appearance-none">
                        @if (isManager) {
                            <option value="FINANCE">Finance Officer</option>
                            <option value="CASHIER" selected>Branch Cashier</option>
                        } else {
                            @if (!ceoExists) {
                                <option value="CEO">CEO / Owner</option>
                            }
                            <option value="BRANCH_ADMIN">Branch Manager</option>
                            <option value="FINANCE">Finance Officer</option>
                            <option value="CASHIER">Branch Cashier</option>
                        }
                    </select>
                </div>
                <div>
                    <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Assigned Node (Branch)</label>
                    @if (isManager) {
                        <input type="hidden" name="branchId" id="create-branch" value="@(branches.FirstOrDefault()?.Id)" />
                        <div class="w-full px-4 py-3 bg-slate-100 border border-slate-200 rounded-xl text-slate-500 font-bold text-sm">
                            @(branches.FirstOrDefault()?.Name ?? "Main Branch")
                        </div>
                        <p class="text-[10px] text-amber-600 font-bold mt-2 uppercase tracking-tight">Locked to your operational branch</p>
                    } else {
                        <select name="branchId" id="create-branch" onchange="suggestCredentials()" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-secondary/20 outline-none transition-all appearance-none">
                            <option value="">Global Access (No Branch)</option>
                            @foreach (var branch in branches) {
                                <option value="@branch.Id" data-name="@branch.Name">@branch.Name</option>
                            }
                        </select>
                    }
                </div>
                <div>
                    <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Suggested Email Address</label>
                    <input type="email" id="create-email" name="email" required class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-secondary/20 outline-none transition-all" placeholder="user@@coretex.com">
                    <p id="suggested-pass-hint" class="text-[9px] text-indigo-500 font-bold mt-2 uppercase tracking-tight hidden">System will auto-generate secure password</p>
                </div>
                <div class="pt-4 flex space-x-3">
                    <button type="submit" class="flex-1 px-6 py-4 bg-secondary text-white font-black text-sm uppercase tracking-widest rounded-xl hover:bg-teal-700 transition-all shadow-lg shadow-teal-500/20">
                        Deploy User
                    </button>
                    <button type="button" onclick="closeModal('user-modal')" class="px-6 py-4 bg-slate-100 text-slate-500 font-black text-sm uppercase tracking-widest rounded-xl hover:bg-slate-200 transition-all">
                        Cancel
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Edit User Modal -->
    <div id="edit-user-modal" class="fixed inset-0 bg-slate-900/40 backdrop-blur-md z-[9999] hidden items-center justify-center animate-in fade-in duration-300">
        <div class="bg-white rounded-[2rem] shadow-2xl w-full max-w-md mx-4 overflow-hidden">
            <div class="p-8 border-b border-slate-100 flex items-center justify-between bg-slate-50/50">
                <h3 class="text-2xl font-black text-slate-900">Modify Personnel</h3>
                <button onclick="closeModal('edit-user-modal')" class="text-slate-400 hover:text-slate-600 transition-colors">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
            </div>
            <form action="/Admin/UpdateUser" method="post" class="p-8 space-y-6">
                @Html.AntiForgeryToken()
                <input type="hidden" name="userId" id="edit-user-id">
                <div>
                    <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Updated Full Name</label>
                    <input type="text" name="fullName" id="edit-full-name" required class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-secondary/20 outline-none transition-all">
                </div>
                <div>
                    <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Role Reassignment</label>
                    <select name="role" id="edit-role" required class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-secondary/20 outline-none transition-all">
                        @if (isManager) {
                            <option value="FINANCE">Finance Officer</option>
                            <option value="CASHIER">Branch Cashier</option>
                        } else {
                            @if (!ceoExists) {
                                <option value="CEO">CEO / Owner</option>
                            }
                            <option value="BRANCH_ADMIN">Branch Manager</option>
                            <option value="FINANCE">Finance Officer</option>
                            <option value="CASHIER">Branch Cashier</option>
                        }
                    </select>
                </div>
                <div class="flex items-center justify-between p-4 bg-slate-50 rounded-xl border border-slate-200">
                    <div>
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Account Status</p>
                        <p class="text-xs font-bold text-slate-600 mt-0.5">Toggle operational access</p>
                    </div>
                    <label class="relative inline-flex items-center cursor-pointer">
                        <input type="checkbox" name="isActive" id="edit-is-active" class="sr-only peer" value="true">
                        <div class="w-11 h-6 bg-slate-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-emerald-500"></div>
                    </label>
                </div>

                <div class="p-4 bg-amber-50 rounded-xl border border-amber-100">
                    <p class="text-[10px] font-black text-amber-600 uppercase tracking-widest">Security Override</p>
                    <p class="text-[10px] text-amber-500 font-medium mt-1 leading-relaxed">If the employee is locked out, you can reset their password to the system default.</p>
                    <button type="button" onclick="resetUserPassword()" class="mt-3 w-full py-2 bg-white border border-amber-200 text-amber-600 font-black text-[10px] uppercase tracking-widest rounded-lg hover:bg-amber-100 transition-all">
                        Reset to Default Password
                    </button>
                </div>

                <div class="pt-4 flex space-x-3">
                    <button type="submit" class="flex-1 px-6 py-4 bg-indigo-600 text-white font-black text-sm uppercase tracking-widest rounded-xl hover:bg-indigo-700 transition-all shadow-lg shadow-indigo-500/20">
                        Update Records
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Delete User Modal -->
    <div id="delete-user-modal" class="fixed inset-0 bg-slate-900/40 backdrop-blur-md z-[9999] hidden items-center justify-center animate-in fade-in duration-300">
        <div class="bg-white rounded-[2rem] shadow-2xl w-full max-w-md mx-4 overflow-hidden">
            <div class="p-8 bg-rose-50 border-b border-rose-100 flex items-center justify-between">
                <h3 class="text-2xl font-black text-rose-900">Revoke Access</h3>
                <button onclick="closeModal('delete-user-modal')" class="text-rose-400 hover:text-rose-600">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
            </div>
            <form action="/Admin/DeleteUser" method="post" class="p-8 space-y-6">
                @Html.AntiForgeryToken()
                <input type="hidden" name="userId" id="delete-user-id">
                <div class="text-center">
                    <div class="w-20 h-20 bg-rose-100 text-rose-600 rounded-full flex items-center justify-center mx-auto mb-4">
                        <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.876c1.27 0 2.09-1.383 1.458-2.455L13.458 4.455c-.632-1.072-2.174-1.072-2.806 0L3.062 15.545c-.632 1.072.188 2.455 1.458 2.455z"/></svg>
                    </div>
                    <h4 class="text-xl font-black text-slate-900">Are you sure?</h4>
                    <p class="text-slate-500 mt-2 font-medium">You are about to terminate access for <span id="delete-user-name" class="font-black text-slate-900 text-rose-600"></span>. This action is recorded in the audit logs.</p>
                </div>
                <div class="pt-4 flex space-x-3">
                    <button type="submit" class="flex-1 px-6 py-4 bg-rose-600 text-white font-black text-sm uppercase tracking-widest rounded-xl hover:bg-rose-700 transition-all">
                        Terminate Access
                    </button>
                    <button type="button" onclick="closeModal('delete-user-modal')" class="flex-1 px-6 py-4 bg-slate-100 text-slate-500 font-black text-sm uppercase tracking-widest rounded-xl">
                        Cancel
                    </button>
                </div>
            </form>
        </div>
    </div>
}

@section Scripts {
    <script>
        function switchTab(tab) {
            document.querySelectorAll('.tab-section').forEach(s => s.classList.add('hidden'));
            document.getElementById('section-' + tab).classList.remove('hidden');
            
            document.querySelectorAll('button[id^="tab-"]').forEach(b => {
                b.classList.remove('border-indigo-600', 'text-indigo-600');
                b.classList.add('border-transparent', 'text-slate-400');
            });
            
            const activeTab = document.getElementById('tab-' + tab);
            activeTab.classList.remove('border-transparent', 'text-slate-400');
            activeTab.classList.add('border-indigo-600', 'text-indigo-600');
        }

        function openCreateModal() {
            document.getElementById('user-modal').classList.remove('hidden');
            document.getElementById('user-modal').classList.add('flex');
            suggestCredentials(); // Auto-suggest immediately based on current context
        }
        function openEditModal(id, name, role, isActive) {
            document.getElementById('edit-user-id').value = id;
            document.getElementById('edit-full-name').value = name;
            document.getElementById('edit-role').value = role;
            document.getElementById('edit-is-active').checked = isActive === 'True';
            document.getElementById('edit-user-modal').classList.remove('hidden');
            document.getElementById('edit-user-modal').classList.add('flex');
        }
        async function resetUserPassword() {
            const userId = document.getElementById('edit-user-id').value;
            if (!confirm('Are you sure you want to reset this user\'s password to the default "CoretexReset123!"?')) return;
            
            try {
                const response = await fetch(`/Admin/ResetPassword?userId=${userId}`, { method: 'POST' });
                if (response.ok) {
                    alert('Password has been reset to: CoretexReset123!');
                } else {
                    alert('Failed to reset password.');
                }
            } catch (err) {
                console.error(err);
                alert('An error occurred.');
            }
        }
        function openDeleteModal(id, name) {
            document.getElementById('delete-user-id').value = id;
            document.getElementById('delete-user-name').innerText = name;
            document.getElementById('delete-user-modal').classList.remove('hidden');
            document.getElementById('delete-user-modal').classList.add('flex');
        }
        function closeModal(modalId) {
            document.getElementById(modalId).classList.add('hidden');
            document.getElementById(modalId).classList.remove('flex');
        }
        let currentRoleFilter = "";
        let currentStatusFilter = "";

        function filterByStatus(status) {
            currentStatusFilter = status;
            currentRoleFilter = ""; // Reset role filter when looking at status
            updateFilterUI(event.currentTarget);
            filterUsers();
        }

        function filterByRole(role) {
            currentRoleFilter = role;
            currentStatusFilter = ""; // Reset status filter when looking at roles
            updateFilterUI(event.currentTarget);
            filterUsers();
        }

        function updateFilterUI(activeBtn) {
            document.querySelectorAll('.role-pill').forEach(btn => {
                btn.classList.remove('active-pill', 'bg-white', 'shadow-sm', 'text-indigo-600', 'text-rose-600');
                btn.classList.add('text-slate-400');
            });
            
            activeBtn.classList.add('active-pill', 'bg-white', 'shadow-sm');
            activeBtn.classList.remove('text-slate-400');
            
            if (currentStatusFilter === 'locked') {
                activeBtn.classList.add('text-rose-600');
            } else {
                activeBtn.classList.add('text-indigo-600');
            }
        }

        function filterUsers() {
            const search = document.getElementById('search-input').value.toLowerCase();
            const branchFilter = document.getElementById('branch-filter')?.value || "";
            const rows = document.querySelectorAll('.user-row');
            
            rows.forEach(row => {
                const name = row.getAttribute('data-name');
                const email = row.getAttribute('data-email');
                const branchId = row.getAttribute('data-branch');
                const role = row.getAttribute('data-role');
                const isLocked = row.getAttribute('data-is-locked') === "true";
                
                const matchesSearch = name.includes(search) || email.includes(search);
                const matchesBranch = branchFilter === "" || branchId === branchFilter;
                const matchesRole = currentRoleFilter === "" || role === currentRoleFilter;
                const matchesStatus = currentStatusFilter === "" || (currentStatusFilter === "locked" && isLocked);
                
                if (matchesSearch && matchesBranch && matchesRole && matchesStatus) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        }
        // Dynamic Quota Tracking
        const branchOccupancy = @Html.Raw(Json.Serialize(ViewBag.BranchOccupancy ?? new Dictionary<Guid, List<string>>()));

        function suggestCredentials() {
            const roleSelect = document.getElementById('create-role');
            const branchSelect = document.getElementById('create-branch');
            const emailInput = document.getElementById('create-email');
            const hint = document.getElementById('suggested-pass-hint');

            if (!roleSelect || !branchSelect || !emailInput) return;

            const branchId = branchSelect.value;
            const occupied = branchOccupancy[branchId] || [];

            // DYNAMIC QUOTA LOCKING: Disable roles already filled at this node
            Array.from(roleSelect.options).forEach(opt => {
                if (branchId && occupied.includes(opt.value)) {
                    opt.disabled = true;
                    opt.text = opt.text.includes(" (QUOTA FULL)") ? opt.text : opt.text + " (QUOTA FULL)";
                    if (opt.selected) roleSelect.selectedIndex = -1; // Reset selection if we just disabled the selected one
                } else {
                    opt.disabled = false;
                    opt.text = opt.text.replace(" (QUOTA FULL)", "");
                }
            });

            // If everything was disabled, try to find a valid one
            if (roleSelect.selectedIndex === -1) {
                const firstEnabled = Array.from(roleSelect.options).find(opt => !opt.disabled);
                if (firstEnabled) firstEnabled.selected = true;
            }

            const role = roleSelect.value.toLowerCase().split('_')[0]; // finance, cashier, branch (manager)
            let branchName = "";
            
            if (branchSelect.tagName === "SELECT") {
                const selectedOption = branchSelect.options[branchSelect.selectedIndex];
                branchName = selectedOption.getAttribute('data-name') || "";
            } else {
                // For Branch Managers (hidden input)
                branchName = "@(branches.FirstOrDefault()?.Name ?? "")";
            }

            if (branchName) {
                const branchClean = branchName.toLowerCase().replace(" branch", "").replace(" ", "");
                emailInput.value = `${role}.${branchClean}@@coretex.com`;
                hint.classList.remove('hidden');
            } else {
                emailInput.value = `${role}@@coretex.com`;
                hint.classList.add('hidden');
            }
        }
    </script>
}
