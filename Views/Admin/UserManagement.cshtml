@{
    ViewData["Title"] = "User Management";
    Layout = "_AdminLayout";
}

<div class="space-y-8">
    <!-- Header -->
    <div class="flex items-center justify-between">
        <div>
            <div class="flex items-center space-x-3 mb-2">
                <a href="/Admin" class="text-slate-400 hover:text-slate-600 transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                </a>
                <span class="px-3 py-1 bg-purple-100 text-purple-700 font-black text-[10px] uppercase tracking-widest rounded-full">User Setup</span>
            </div>
            <h2 class="text-3xl font-black text-slate-900 tracking-tight">User Management</h2>
            <p class="text-sm text-slate-500 mt-1">Create and manage system users (CEO, Finance Officers, Branch Cashiers)</p>
        </div>
        <button onclick="openCreateModal()" class="px-6 py-3 bg-secondary text-white font-bold text-sm rounded-xl hover:bg-teal-700 transition-colors flex items-center space-x-2 shadow-lg shadow-teal-500/20">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            <span>Create User</span>
        </button>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-1 md:grid-cols-5 gap-6">
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-xs text-slate-500 uppercase tracking-widest">Total Users</p>
                    <p class="text-3xl font-black text-slate-900 mt-1" id="total-users">0</p>
                </div>
                <div class="w-12 h-12 bg-slate-100 rounded-xl flex items-center justify-center">
                    <svg class="w-6 h-6 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
                </div>
            </div>
        </div>
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-xs text-slate-500 uppercase tracking-widest">CEO</p>
                    <p class="text-3xl font-black text-blue-600 mt-1" id="ceo-count">0</p>
                </div>
                <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center">
                    <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                </div>
            </div>
        </div>
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-xs text-slate-500 uppercase tracking-widest">Finance Officers</p>
                    <p class="text-3xl font-black text-emerald-600 mt-1" id="fo-count">0</p>
                </div>
                <div class="w-12 h-12 bg-emerald-100 rounded-xl flex items-center justify-center">
                    <svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
                </div>
            </div>
        </div>
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-xs text-slate-500 uppercase tracking-widest">Branch Cashiers</p>
                    <p class="text-3xl font-black text-amber-600 mt-1" id="cashier-count">0</p>
                </div>
                <div class="w-12 h-12 bg-amber-100 rounded-xl flex items-center justify-center">
                    <svg class="w-6 h-6 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
                </div>
            </div>
        </div>
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-xs text-slate-500 uppercase tracking-widest">Active</p>
                    <p class="text-3xl font-black text-green-600 mt-1" id="active-users">0</p>
                </div>
                <div class="w-12 h-12 bg-green-100 rounded-xl flex items-center justify-center">
                    <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
            </div>
        </div>
    </div>

    <!-- Users Table -->
    <div class="bg-white rounded-3xl shadow-sm border border-slate-100 overflow-hidden">
        <div class="p-6 border-b border-slate-100 flex items-center justify-between">
            <h3 class="text-lg font-black text-slate-900">All Users</h3>
            <div class="flex items-center space-x-3">
                <select id="role-filter" onchange="filterUsers()" class="px-4 py-2 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-secondary/20">
                    <option value="">All Roles</option>
                    <option value="CEO">CEO</option>
                    <option value="Finance Officer">Finance Officer</option>
                    <option value="Branch Cashier">Branch Cashier</option>
                </select>
                <select id="status-filter" onchange="filterUsers()" class="px-4 py-2 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-secondary/20">
                    <option value="">All Status</option>
                    <option value="Active">Active</option>
                    <option value="Inactive">Inactive</option>
                </select>
                <input type="text" id="search-input" onkeyup="filterUsers()" placeholder="Search users..." class="px-4 py-2 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-secondary/20 w-64">
            </div>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead class="bg-slate-50">
                    <tr>
                        <th class="px-6 py-4 text-left text-[10px] font-black text-slate-500 uppercase tracking-widest">Name</th>
                        <th class="px-6 py-4 text-left text-[10px] font-black text-slate-500 uppercase tracking-widest">Email</th>
                        <th class="px-6 py-4 text-left text-[10px] font-black text-slate-500 uppercase tracking-widest">Role</th>
                        <th class="px-6 py-4 text-left text-[10px] font-black text-slate-500 uppercase tracking-widest">Branch</th>
                        <th class="px-6 py-4 text-left text-[10px] font-black text-slate-500 uppercase tracking-widest">Status</th>
                        <th class="px-6 py-4 text-center text-[10px] font-black text-slate-500 uppercase tracking-widest">Actions</th>
                    </tr>
                </thead>
                <tbody id="users-list" class="divide-y divide-slate-100">
                </tbody>
            </table>
            <div id="empty-state" class="hidden p-12 text-center">
                <div class="w-16 h-16 mx-auto bg-slate-100 rounded-full flex items-center justify-center mb-4">
                    <svg class="w-8 h-8 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
                </div>
                <h3 class="text-lg font-bold text-slate-900">No users yet</h3>
                <p class="text-sm text-slate-500 mt-1">Click "Create User" to add your first user</p>
            </div>
        </div>
    </div>
</div>

<!-- Create/Edit User Modal -->
<div id="user-modal" class="fixed inset-0 bg-black/50 backdrop-blur-sm z-50 hidden items-center justify-center">
    <div class="bg-white rounded-3xl shadow-2xl w-full max-w-lg mx-4 max-h-[90vh] overflow-y-auto">
        <div class="p-6 border-b border-slate-100 flex items-center justify-between">
            <h3 id="modal-title" class="text-xl font-black text-slate-900">Create User</h3>
            <button onclick="closeModal()" class="text-slate-400 hover:text-slate-600 transition-colors">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>
        <form id="user-form" onsubmit="saveUser(event)" class="p-6 space-y-5">
            <input type="hidden" id="user-id">
            <input type="hidden" id="edit-mode" value="false">
            
            <div>
                <label class="block text-sm font-bold text-slate-700 mb-2">Full Name <span class="text-red-500">*</span></label>
                <input type="text" id="user-name" required class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-secondary/20 focus:border-secondary transition-all" placeholder="e.g. Juan Dela Cruz">
            </div>

            <div>
                <label class="block text-sm font-bold text-slate-700 mb-2">Email <span class="text-red-500">*</span></label>
                <input type="email" id="user-email" required class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-secondary/20 focus:border-secondary transition-all" placeholder="e.g. juan@coretex.com">
            </div>

            <div>
                <label class="block text-sm font-bold text-slate-700 mb-2">Role <span class="text-red-500">*</span></label>
                <select id="user-role" required onchange="toggleBranchField()" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-secondary/20 focus:border-secondary transition-all">
                    <option value="">Select Role</option>
                    <option value="CEO">CEO / Business Owner</option>
                    <option value="Finance Officer">Finance Officer</option>
                    <option value="Branch Cashier">Branch Cashier</option>
                </select>
                <p id="role-disabled-msg" class="hidden text-xs text-amber-600 mt-1 flex items-center space-x-1">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
                    <span>Role cannot be changed after creation</span>
                </p>
            </div>

            <div id="branch-field">
                <label class="block text-sm font-bold text-slate-700 mb-2">Assigned Branch <span class="text-red-500">*</span></label>
                <select id="user-branch" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-secondary/20 focus:border-secondary transition-all">
                    <option value="">Select Branch</option>
                </select>
                <p id="branch-info" class="hidden text-xs text-blue-600 mt-1">CEO has access to all branches</p>
            </div>

            <div id="phone-field">
                <label class="block text-sm font-bold text-slate-700 mb-2">Phone Number <span class="text-slate-400 text-xs font-normal">(for SMS alerts)</span></label>
                <input type="tel" id="user-phone" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-secondary/20 focus:border-secondary transition-all" placeholder="+63 912 345 6789">
            </div>

            <div class="flex items-center space-x-4 pt-4">
                <button type="submit" class="flex-1 px-6 py-3 bg-secondary text-white font-bold rounded-xl hover:bg-teal-700 transition-colors">
                    <span id="submit-btn-text">Create User</span>
                </button>
                <button type="button" onclick="closeModal()" class="px-6 py-3 bg-slate-100 text-slate-600 font-bold rounded-xl hover:bg-slate-200 transition-colors">
                    Cancel
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Reset Password Modal -->
<div id="reset-modal" class="fixed inset-0 bg-black/50 backdrop-blur-sm z-50 hidden items-center justify-center">
    <div class="bg-white rounded-3xl shadow-2xl w-full max-w-md mx-4">
        <div class="p-6 border-b border-slate-100">
            <h3 class="text-xl font-black text-slate-900">Reset Password</h3>
        </div>
        <div class="p-6">
            <div class="flex items-center space-x-4 mb-6">
                <div class="w-14 h-14 bg-amber-100 rounded-2xl flex items-center justify-center">
                    <svg class="w-7 h-7 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/></svg>
                </div>
                <div>
                    <p class="font-bold text-slate-900">Reset password for</p>
                    <p id="reset-user-name" class="text-slate-500"></p>
                </div>
            </div>
            <p class="text-sm text-slate-600 mb-6">A new temporary password will be generated and sent to the user's email. They will be required to change it on first login.</p>
            <input type="hidden" id="reset-user-id">
            <div class="flex items-center space-x-4">
                <button onclick="confirmResetPassword()" class="flex-1 px-6 py-3 bg-amber-500 text-white font-bold rounded-xl hover:bg-amber-600 transition-colors">
                    Reset Password
                </button>
                <button onclick="closeResetModal()" class="px-6 py-3 bg-slate-100 text-slate-600 font-bold rounded-xl hover:bg-slate-200 transition-colors">
                    Cancel
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Deactivate User Modal -->
<div id="deactivate-modal" class="fixed inset-0 bg-black/50 backdrop-blur-sm z-50 hidden items-center justify-center">
    <div class="bg-white rounded-3xl shadow-2xl w-full max-w-md mx-4">
        <div class="p-6 border-b border-slate-100">
            <h3 class="text-xl font-black text-slate-900">Deactivate User</h3>
        </div>
        <div class="p-6">
            <div class="flex items-center space-x-4 mb-6">
                <div class="w-14 h-14 bg-red-100 rounded-2xl flex items-center justify-center">
                    <svg class="w-7 h-7 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/></svg>
                </div>
                <div>
                    <p class="font-bold text-slate-900">Deactivate</p>
                    <p id="deactivate-user-name" class="text-slate-500"></p>
                </div>
            </div>
            <p class="text-sm text-slate-600 mb-6">This user will no longer be able to login to the system. You can reactivate them later if needed.</p>
            <input type="hidden" id="deactivate-user-id">
            <div class="flex items-center space-x-4">
                <button onclick="confirmDeactivate()" class="flex-1 px-6 py-3 bg-red-500 text-white font-bold rounded-xl hover:bg-red-600 transition-colors">
                    Deactivate User
                </button>
                <button onclick="closeDeactivateModal()" class="px-6 py-3 bg-slate-100 text-slate-600 font-bold rounded-xl hover:bg-slate-200 transition-colors">
                    Cancel
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Success Toast -->
<div id="toast" class="fixed bottom-6 right-6 bg-emerald-500 text-white px-6 py-4 rounded-2xl shadow-2xl hidden items-center space-x-3 z-50">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
    <span id="toast-message" class="font-bold">Success!</span>
</div>

@section Scripts {
    <script>
        let allUsers = [];
        let branches = [];

        function loadData() {
            allUsers = JSON.parse(localStorage.getItem('coretex_users') || '[]');
            branches = JSON.parse(localStorage.getItem('coretex_branches') || '[]');
            populateBranches();
            updateStats();
            filterUsers();
        }

        function populateBranches() {
            const select = document.getElementById('user-branch');
            select.innerHTML = '<option value="">Select Branch</option>';
            branches.forEach(branch => {
                select.innerHTML += `<option value="${branch.id}">${branch.name}</option>`;
            });
        }

        function updateStats() {
            document.getElementById('total-users').textContent = allUsers.length;
            document.getElementById('ceo-count').textContent = allUsers.filter(u => u.role === 'CEO').length;
            document.getElementById('fo-count').textContent = allUsers.filter(u => u.role === 'Finance Officer').length;
            document.getElementById('cashier-count').textContent = allUsers.filter(u => u.role === 'Branch Cashier').length;
            document.getElementById('active-users').textContent = allUsers.filter(u => u.status === 'Active').length;
        }

        function filterUsers() {
            const roleFilter = document.getElementById('role-filter').value;
            const statusFilter = document.getElementById('status-filter').value;
            const searchTerm = document.getElementById('search-input').value.toLowerCase();

            const filtered = allUsers.filter(user => {
                const matchesRole = !roleFilter || user.role === roleFilter;
                const matchesStatus = !statusFilter || user.status === statusFilter;
                const matchesSearch = !searchTerm || 
                    user.name.toLowerCase().includes(searchTerm) ||
                    user.email.toLowerCase().includes(searchTerm);
                return matchesRole && matchesStatus && matchesSearch;
            });

            renderTable(filtered);
        }

        function renderTable(users) {
            const tbody = document.getElementById('users-list');
            const emptyState = document.getElementById('empty-state');

            if (users.length === 0) {
                tbody.innerHTML = '';
                emptyState.classList.remove('hidden');
                return;
            }

            emptyState.classList.add('hidden');
            tbody.innerHTML = users.map(user => {
                const branch = branches.find(b => b.id === user.branchId);
                const branchName = user.role === 'CEO' ? '<span class="text-blue-600 font-bold">All Branches</span>' : (branch ? branch.name : '<span class="text-slate-400">Unassigned</span>');
                const roleColors = {
                    'CEO': 'bg-blue-100 text-blue-700',
                    'Finance Officer': 'bg-emerald-100 text-emerald-700',
                    'Branch Cashier': 'bg-amber-100 text-amber-700'
                };
                const statusColor = user.status === 'Active' ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700';

                return `
                    <tr class="hover:bg-slate-50 transition-colors">
                        <td class="px-6 py-4">
                            <div class="flex items-center space-x-3">
                                <div class="w-10 h-10 bg-gradient-to-br from-slate-600 to-slate-800 rounded-xl flex items-center justify-center text-white font-bold text-sm">
                                    ${user.name.split(' ').map(n => n[0]).join('').slice(0, 2).toUpperCase()}
                                </div>
                                <span class="font-bold text-slate-900">${user.name}</span>
                            </div>
                        </td>
                        <td class="px-6 py-4 text-sm text-slate-600">${user.email}</td>
                        <td class="px-6 py-4">
                            <span class="px-3 py-1 ${roleColors[user.role] || 'bg-slate-100 text-slate-700'} text-[10px] font-black uppercase rounded-full">${user.role}</span>
                        </td>
                        <td class="px-6 py-4 text-sm">${branchName}</td>
                        <td class="px-6 py-4">
                            <span class="px-3 py-1 ${statusColor} text-[10px] font-black uppercase rounded-full">${user.status}</span>
                        </td>
                        <td class="px-6 py-4">
                            <div class="flex items-center justify-center space-x-2">
                                <button onclick="editUser('${user.id}')" class="p-2 text-blue-600 hover:bg-blue-50 rounded-lg transition-colors" title="Edit">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                                </button>
                                <button onclick="openResetModal('${user.id}', '${user.name}')" class="p-2 text-amber-600 hover:bg-amber-50 rounded-lg transition-colors" title="Reset Password">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/></svg>
                                </button>
                                ${user.status === 'Active' 
                                    ? `<button onclick="openDeactivateModal('${user.id}', '${user.name}')" class="p-2 text-red-600 hover:bg-red-50 rounded-lg transition-colors" title="Deactivate">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/></svg>
                                       </button>`
                                    : `<button onclick="activateUser('${user.id}')" class="p-2 text-green-600 hover:bg-green-50 rounded-lg transition-colors" title="Activate">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                       </button>`
                                }
                            </div>
                        </td>
                    </tr>
                `;
            }).join('');
        }

        function openCreateModal() {
            document.getElementById('modal-title').textContent = 'Create User';
            document.getElementById('submit-btn-text').textContent = 'Create User';
            document.getElementById('edit-mode').value = 'false';
            document.getElementById('user-form').reset();
            document.getElementById('user-role').disabled = false;
            document.getElementById('role-disabled-msg').classList.add('hidden');
            toggleBranchField();
            document.getElementById('user-modal').classList.remove('hidden');
            document.getElementById('user-modal').classList.add('flex');
        }

        function editUser(id) {
            const user = allUsers.find(u => u.id === id);
            if (!user) return;

            document.getElementById('modal-title').textContent = 'Edit User';
            document.getElementById('submit-btn-text').textContent = 'Save Changes';
            document.getElementById('edit-mode').value = 'true';
            document.getElementById('user-id').value = user.id;
            document.getElementById('user-name').value = user.name;
            document.getElementById('user-email').value = user.email;
            document.getElementById('user-role').value = user.role;
            document.getElementById('user-role').disabled = true;
            document.getElementById('role-disabled-msg').classList.remove('hidden');
            document.getElementById('user-branch').value = user.branchId || '';
            document.getElementById('user-phone').value = user.phone || '';
            
            toggleBranchField();
            document.getElementById('user-modal').classList.remove('hidden');
            document.getElementById('user-modal').classList.add('flex');
        }

        function closeModal() {
            document.getElementById('user-modal').classList.add('hidden');
            document.getElementById('user-modal').classList.remove('flex');
        }

        function toggleBranchField() {
            const role = document.getElementById('user-role').value;
            const branchField = document.getElementById('branch-field');
            const branchSelect = document.getElementById('user-branch');
            const branchInfo = document.getElementById('branch-info');
            const phoneField = document.getElementById('phone-field');

            if (role === 'CEO') {
                branchField.classList.add('opacity-50');
                branchSelect.disabled = true;
                branchSelect.required = false;
                branchInfo.classList.remove('hidden');
                phoneField.classList.remove('hidden');
            } else {
                branchField.classList.remove('opacity-50');
                branchSelect.disabled = false;
                branchSelect.required = true;
                branchInfo.classList.add('hidden');
                if (role === 'CEO') {
                    phoneField.classList.remove('hidden');
                } else {
                    phoneField.classList.add('hidden');
                }
            }
        }

        function saveUser(event) {
            event.preventDefault();
            
            const isEdit = document.getElementById('edit-mode').value === 'true';
            const user = {
                id: isEdit ? document.getElementById('user-id').value : 'user_' + Date.now(),
                name: document.getElementById('user-name').value,
                email: document.getElementById('user-email').value,
                role: document.getElementById('user-role').value,
                branchId: document.getElementById('user-branch').value || null,
                phone: document.getElementById('user-phone').value || null,
                status: 'Active',
                createdAt: isEdit ? allUsers.find(u => u.id === document.getElementById('user-id').value)?.createdAt : new Date().toISOString()
            };

            if (isEdit) {
                const index = allUsers.findIndex(u => u.id === user.id);
                if (index !== -1) {
                    user.status = allUsers[index].status;
                    allUsers[index] = user;
                    showToast('User updated successfully!');
                }
            } else {
                allUsers.push(user);
                const tempPassword = generateTempPassword();
                showToast(`User created! Temp password: ${tempPassword}`);
                logActivity('User Created', `${user.name} (${user.role})`, 'user');
            }

            localStorage.setItem('coretex_users', JSON.stringify(allUsers));
            closeModal();
            loadData();
        }

        function generateTempPassword() {
            const chars = 'ABCDEFGHJKMNPQRSTUVWXYZabcdefghjkmnpqrstuvwxyz23456789';
            let password = '';
            for (let i = 0; i < 8; i++) {
                password += chars.charAt(Math.floor(Math.random() * chars.length));
            }
            return password;
        }

        function openResetModal(id, name) {
            document.getElementById('reset-user-id').value = id;
            document.getElementById('reset-user-name').textContent = name;
            document.getElementById('reset-modal').classList.remove('hidden');
            document.getElementById('reset-modal').classList.add('flex');
        }

        function closeResetModal() {
            document.getElementById('reset-modal').classList.add('hidden');
            document.getElementById('reset-modal').classList.remove('flex');
        }

        function confirmResetPassword() {
            const id = document.getElementById('reset-user-id').value;
            const user = allUsers.find(u => u.id === id);
            if (user) {
                const tempPassword = generateTempPassword();
                showToast(`Password reset! New: ${tempPassword}`);
                logActivity('Password Reset', `Password reset for ${user.name}`, 'user');
            }
            closeResetModal();
        }

        function openDeactivateModal(id, name) {
            document.getElementById('deactivate-user-id').value = id;
            document.getElementById('deactivate-user-name').textContent = name;
            document.getElementById('deactivate-modal').classList.remove('hidden');
            document.getElementById('deactivate-modal').classList.add('flex');
        }

        function closeDeactivateModal() {
            document.getElementById('deactivate-modal').classList.add('hidden');
            document.getElementById('deactivate-modal').classList.remove('flex');
        }

        function confirmDeactivate() {
            const id = document.getElementById('deactivate-user-id').value;
            const user = allUsers.find(u => u.id === id);
            if (user) {
                user.status = 'Inactive';
                localStorage.setItem('coretex_users', JSON.stringify(allUsers));
                logActivity('User Deactivated', `${user.name} deactivated`, 'user');
                showToast('User deactivated');
                loadData();
            }
            closeDeactivateModal();
        }

        function activateUser(id) {
            const user = allUsers.find(u => u.id === id);
            if (user) {
                user.status = 'Active';
                localStorage.setItem('coretex_users', JSON.stringify(allUsers));
                logActivity('User Activated', `${user.name} activated`, 'user');
                showToast('User activated');
                loadData();
            }
        }

        function logActivity(action, description, type) {
            const activities = JSON.parse(localStorage.getItem('coretex_activities') || '[]');
            activities.unshift({
                id: Date.now(),
                action,
                description,
                type,
                timestamp: new Date().toISOString(),
                user: 'System Administrator'
            });
            localStorage.setItem('coretex_activities', JSON.stringify(activities.slice(0, 100)));
        }

        function showToast(message) {
            const toast = document.getElementById('toast');
            document.getElementById('toast-message').textContent = message;
            toast.classList.remove('hidden');
            toast.classList.add('flex');
            setTimeout(() => {
                toast.classList.add('hidden');
                toast.classList.remove('flex');
            }, 4000);
        }

        document.addEventListener('DOMContentLoaded', loadData);
    </script>
}
