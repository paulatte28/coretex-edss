@model IEnumerable<coretex_finalproj.Models.AppUser>
@inject Microsoft.AspNetCore.Identity.UserManager<coretex_finalproj.Models.AppUser> _userManager
@inject coretex_finalproj.Data.ApplicationDbContext _context
@{
    ViewData["Title"] = "User Management";

    Layout = "_AdminLayout";
}

<div class="space-y-8">
    @if (TempData["Error"] != null)

    {
        <div class="p-4 bg-rose-50 border border-rose-100 text-rose-700 rounded-2xl flex items-center gap-3 animate-pulse">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
            <span class="font-bold">@TempData["Error"]</span>
        </div>
    }
    @if (TempData["Message"] != null)

    {
        <div class="p-4 bg-emerald-50 border border-emerald-100 text-emerald-700 rounded-2xl flex items-center gap-3">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="font-bold">@TempData["Message"]</span>
        </div>
    }

    <!-- Header -->
    <div class="flex items-center justify-between">
        <div>
            <div class="flex items-center space-x-3 mb-2">
                <a href="/Admin" class="text-slate-400 hover:text-slate-600 transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                    </svg>
                </a>
                <span
                    class="px-3 py-1 bg-purple-100 text-purple-700 font-black text-[10px] uppercase tracking-widest rounded-full">Access
                    Control</span>
            </div>
            <h2 class="text-3xl font-black text-slate-900 tracking-tight">System Users</h2>
            <p class="text-sm text-slate-500 mt-1">Manage @Model.Count() team members and their permissions</p>
        </div>
        <button onclick="openAddModal()"
            class="px-6 py-3 bg-purple-600 text-white font-bold text-sm rounded-xl hover:bg-purple-700 hover:scale-105 transition-all flex items-center space-x-2 shadow-lg shadow-purple-100">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M18 9v3m0 0v3m0-3h3m-3 0h-3m3 8c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h13z" />
            </svg>
            <span>Provision User</span>
        </button>
    </div>

    <!-- Corporate Ownership Section (The "Boss" Area) -->
    @{
        var ceoUsers = new List<coretex_finalproj.Models.AppUser>();
        var staffUsers = new List<coretex_finalproj.Models.AppUser>();
        
        foreach(var user in Model)
        {
            if ((await _userManager.GetRolesAsync(user)).Contains("CEO"))
                ceoUsers.Add(user);
            else
                staffUsers.Add(user);
        }
    }

    @if (ceoUsers.Any())
    {
        <div class="mb-12">
            <div class="flex items-center gap-3 mb-6">
                <div class="w-1.5 h-6 bg-indigo-500 rounded-full shadow-lg shadow-indigo-200"></div>
                <h3 class="text-xl font-black text-slate-900 tracking-tight">Corporate Ownership</h3>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                @foreach (var ceo in ceoUsers)
                {
                    <div class="bg-slate-900 rounded-[2.5rem] p-8 border border-slate-800 shadow-2xl relative overflow-hidden group">
                        <div class="absolute -right-8 -top-8 w-32 h-32 bg-indigo-500/10 rounded-full group-hover:scale-150 transition-transform duration-1000"></div>
                        
                        <div class="flex items-center justify-between relative z-10">
                            <div class="flex items-center gap-5">
                                <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-indigo-500 to-indigo-700 flex items-center justify-center text-white text-2xl font-black shadow-xl shadow-indigo-900/40 group-hover:rotate-6 transition-transform">
                                    @(ceo.FullName?.Length > 0 ? ceo.FullName.Substring(0, 1).ToUpper() : "C")
                                </div>
                                <div>
                                    <h4 class="text-xl font-black text-white tracking-tight">@ceo.FullName</h4>
                                    <div class="flex items-center gap-2 mt-1">
                                        <span class="px-3 py-0.5 bg-indigo-500/10 border border-indigo-500/20 text-indigo-400 text-[10px] font-black uppercase tracking-widest rounded-full">System Owner</span>
                                        <span class="text-[10px] text-slate-500 font-bold">@ceo.Email</span>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="flex gap-2">
                                <button onclick="openPasswordModal('@ceo.Id', '@ceo.Email')" class="w-10 h-10 rounded-xl bg-white/5 text-slate-400 hover:text-white hover:bg-white/10 flex items-center justify-center transition-all" title="Secure Credentials">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/></svg>
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    <div class="flex items-center gap-3 mb-6">
        <div class="w-1.5 h-6 bg-purple-500 rounded-full"></div>
        <h3 class="text-xl font-black text-slate-900 tracking-tight">Operational Workforce</h3>
    </div>

    <!-- High-Density Staff Directory (Collapsible Accordion) -->
    <div class="space-y-4">
        @foreach (var branchGroup in staffUsers.GroupBy(u => u.Branch?.Name ?? "Main Branch"))
        {
            var groupId = branchGroup.Key.Replace(" ", "-").ToLower();
            <div class="bg-white rounded-3xl border border-slate-100 overflow-hidden shadow-sm">
                <!-- Branch Header Toggle -->
                <button onclick="toggleBranch('@groupId')" 
                        class="w-full flex items-center justify-between p-6 hover:bg-slate-50 transition-colors text-left group">
                    <div class="flex items-center gap-4">
                        <div class="w-10 h-10 bg-slate-100 rounded-xl flex items-center justify-center text-slate-400 group-hover:bg-purple-600 group-hover:text-white transition-all">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
                        </div>
                        <div>
                            <h3 class="font-black text-slate-900 tracking-tight">@branchGroup.Key</h3>
                            <p class="text-[10px] text-slate-400 font-bold uppercase tracking-widest">@branchGroup.Count() Staff Members Assigned</p>
                        </div>
                    </div>
                    <svg id="icon-@groupId" class="w-5 h-5 text-slate-300 transform transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                </button>

                <!-- Staff List Area (Compact Table) -->
                <div id="content-@groupId" class="hidden border-t border-slate-50 overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead class="bg-slate-50/50 border-b border-slate-100">
                            <tr>
                                <th class="px-8 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest">Employee</th>
                                <th class="px-8 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest">Authorized Role</th>
                                <th class="px-8 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest text-center">Status</th>
                                <th class="px-8 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest text-right">Security Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-50">
                            @foreach (var user in branchGroup)
                            {
                                var roles = await _userManager.GetRolesAsync(user);
                                var role = roles.FirstOrDefault() ?? "USER";
                                var roleColor = role switch {
                                    "FINANCE" => "text-blue-600 bg-blue-50 border-blue-100",
                                    "CASHIER" => "text-emerald-600 bg-emerald-50 border-emerald-100",
                                    "ADMIN" => "text-purple-600 bg-purple-50 border-purple-100",
                                    _ => "text-slate-500 bg-slate-50 border-slate-100"
                                };

                                <tr class="hover:bg-slate-50/50 transition-colors group @(user.IsActive ? "" : "opacity-60")">
                                    <td class="px-8 py-4">
                                        <div class="flex items-center gap-4">
                                            <div class="w-10 h-10 rounded-xl @(user.IsActive ? "bg-slate-900" : "bg-slate-300") flex items-center justify-center text-white text-xs font-black shadow-sm group-hover:scale-110 transition-transform">
                                                @(user.FullName?.Length > 0 ? user.FullName.Substring(0, 1).ToUpper() : "U")
                                            </div>
                                            <div>
                                                <p class="text-sm font-black text-slate-900">@user.FullName</p>
                                                <p class="text-[10px] text-slate-400 font-bold uppercase tracking-tight">@user.Email</p>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-8 py-4">
                                        <span class="px-2.5 py-1 @roleColor border text-[9px] font-black uppercase tracking-widest rounded-md">
                                            @role
                                        </span>
                                    </td>
                                    <td class="px-8 py-4">
                                        <div class="flex items-center justify-center gap-2">
                                            <div class="w-1.5 h-1.5 rounded-full @(user.IsActive ? "bg-emerald-400 animate-pulse" : "bg-slate-300")"></div>
                                            <span class="text-[10px] font-black uppercase tracking-widest @(user.IsActive ? "text-emerald-600" : "text-slate-400")">
                                                @(user.IsActive ? "Active" : "Disabled")
                                            </span>
                                        </div>
                                    </td>
                                    <td class="px-8 py-4">
                                        <div class="flex items-center justify-end gap-2">
                                            <form asp-action="ToggleUserStatus" method="post" class="inline">
                                                <input type="hidden" name="userId" value="@user.Id" />
                                                <button type="submit" class="w-9 h-9 rounded-lg @(user.IsActive ? "bg-rose-50 text-rose-400 hover:text-rose-600 hover:bg-rose-100" : "bg-emerald-50 text-emerald-600 hover:bg-emerald-100") flex items-center justify-center transition-all" title="@(user.IsActive ? "Deactivate" : "Activate")">
                                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/></svg>
                                                </button>
                                            </form>
                                            <button onclick="openPasswordModal('@user.Id', '@user.Email')" class="w-9 h-9 rounded-lg bg-slate-50 text-slate-400 hover:text-amber-600 hover:bg-amber-100 flex items-center justify-center transition-all" title="Reset Credentials">
                                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/></svg>
                                            </button>
                                            <button onclick="openRoleModal('@user.Id', '@user.Email')" class="w-9 h-9 rounded-lg bg-slate-50 text-slate-400 hover:text-indigo-600 hover:bg-indigo-100 flex items-center justify-center transition-all" title="Manage Permissions">
                                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/></svg>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
</div>


<!-- Password Reset Modal -->
<div id="password-modal" class="fixed inset-0 bg-white/60 backdrop-blur-2xl z-50 hidden flex items-center justify-center p-4 transition-all duration-500">
    <div class="bg-white rounded-[3.5rem] p-12 w-full max-w-md shadow-[0_32px_80px_-15px_rgba(0,0,0,0.2)] transform transition-all duration-500 scale-95 opacity-0" id="password-modal-card">
        <h3 class="text-2xl font-black text-slate-900 mb-2">Reset Password</h3>
        <p id="pass-email" class="text-sm text-slate-500 mb-6 font-bold"></p>
        <form asp-action="ResetUserPassword" method="post" class="space-y-4" onsubmit="return validatePasswordSubmit()">
            <input type="hidden" name="userId" id="pass-target-id" />
            <div>
                <label class="block text-xs font-black uppercase tracking-widest text-slate-500 mb-2">New Security Password</label>
                <div class="relative">
                    <input type="password" name="newPassword" id="new-password-input"
                        class="w-full px-5 py-3 bg-slate-50 border border-slate-200 rounded-2xl outline-none focus:border-indigo-500 transition-all font-bold"
                        placeholder="••••••••" required oninput="checkNistStrength(this.value)" />
                    <button type="button" onclick="togglePassVisibility('new-password-input', this)" class="absolute right-4 top-3.5 text-slate-400">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                    </button>
                </div>
                <!-- NIST Strength Meter -->
                <div class="mt-4 space-y-2 p-4 bg-slate-50 rounded-2xl border border-slate-100">
                    <p class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-2">NIST Security Rules</p>
                    <div id="rule-length" class="flex items-center gap-2 text-xs font-bold text-slate-400"><div class="w-1.5 h-1.5 rounded-full bg-current"></div> Min 12 Characters</div>
                    <div id="rule-upper" class="flex items-center gap-2 text-xs font-bold text-slate-400"><div class="w-1.5 h-1.5 rounded-full bg-current"></div> Uppercase & Lowercase</div>
                    <div id="rule-number" class="flex items-center gap-2 text-xs font-bold text-slate-400"><div class="w-1.5 h-1.5 rounded-full bg-current"></div> Numbers & Symbols</div>
                </div>
            </div>
            <div class="flex gap-3 pt-4">
                <button type="button" onclick="closePasswordModal()"
                    class="flex-1 py-3 bg-slate-100 text-slate-600 font-bold rounded-xl">Cancel</button>
                <button type="submit" id="reset-submit-btn" disabled
                    class="flex-1 py-3 bg-slate-200 text-slate-400 font-bold rounded-xl cursor-not-allowed transition-all">Apply Change</button>
            </div>
        </form>
    </div>
</div>

<!-- Add User Modal -->
<div id="add-modal" class="fixed inset-0 bg-white/60 backdrop-blur-2xl z-50 hidden flex items-center justify-center p-4 transition-all duration-500">
    <div class="bg-white rounded-[3.5rem] p-12 w-full max-w-md shadow-[0_32px_80px_-15px_rgba(0,0,0,0.2)] transform transition-all duration-500 scale-95 opacity-0" id="add-modal-card">
        <h3 class="text-2xl font-black text-slate-900 mb-6">Provision New User</h3>
        <form asp-action="CreateUser" method="post" class="space-y-4">
            <div>
                <label class="block text-xs font-black uppercase tracking-widest text-slate-500 mb-2">Full Name</label>
                <input name="fullName" required placeholder="Ex: John Doe"
                    class="w-full px-5 py-3 bg-slate-50 border border-slate-200 rounded-2xl focus:ring-4 focus:ring-purple-100 outline-none transition-all font-bold" />
            </div>
            <div>
                <label class="block text-xs font-black uppercase tracking-widest text-slate-500 mb-2">Email Address</label>
                <input name="email" type="email" required placeholder="user@coretex.com"
                    class="w-full px-5 py-3 bg-slate-50 border border-slate-200 rounded-2xl focus:ring-4 focus:ring-purple-100 outline-none transition-all font-bold" />
            </div>
            <div>
                <label class="block text-xs font-black uppercase tracking-widest text-slate-500 mb-2">System Role</label>
                <select name="role" required
                    class="w-full px-5 py-3 bg-slate-50 border border-slate-200 rounded-2xl outline-none appearance-none font-bold">
                    <option value="ADMIN">Branch Administrator</option>
                    <option value="FINANCE">Finance Officer</option>
                    <option value="CASHIER">Branch Cashier</option>
                </select>
            </div>
            <div>
                <label class="block text-xs font-black uppercase tracking-widest text-slate-500 mb-2">Assign Branch</label>
                <select name="branchId"
                    class="w-full px-5 py-3 bg-slate-50 border border-slate-200 rounded-2xl outline-none appearance-none font-bold">
                    <option value="">Main Branch</option>
                    @if (ViewBag.Branches is List<Branch> userBranches)
                    {
                        foreach (var b in userBranches)
                        {
                            <option value="@b.Id">@b.Name</option>
                        }
                    }
                </select>
            </div>
            
            <!-- REALISTIC SECURITY NOTICE -->
            <div class="p-4 bg-indigo-50 rounded-2xl border border-indigo-100 mt-4">
                <div class="flex items-start gap-3">
                    <div class="mt-0.5">
                        <svg class="w-5 h-5 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    </div>
                    <p class="text-[11px] text-indigo-700 leading-relaxed font-medium">
                        <b>SECURITY AUTOMATION:</b> A unique NIST-compliant temporary password will be generated and emailed to the user upon provisioning.
                    </p>
                </div>
            </div>

            <div class="flex gap-3 pt-6">
                <button type="button" onclick="closeAddModal()"
                    class="flex-1 py-3 bg-slate-100 text-slate-600 font-bold rounded-xl">Cancel</button>
                <button type="submit" class="flex-1 py-3 bg-purple-600 text-white font-bold rounded-xl shadow-lg shadow-purple-100">Provision User</button>
            </div>
        </form>
    </div>
</div>

<!-- Role Update Modal -->
<div id="role-modal" class="fixed inset-0 bg-white/60 backdrop-blur-2xl z-50 hidden flex items-center justify-center p-4 transition-all duration-500">
    <div class="bg-white rounded-[3.5rem] p-12 w-full max-w-md shadow-[0_32px_80px_-15px_rgba(0,0,0,0.2)] transform transition-all duration-500 scale-95 opacity-0" id="role-modal-card">
        <h3 class="text-2xl font-black text-slate-900 mb-2">Change Account Rights</h3>
        <p id="role-email" class="text-sm text-slate-500 mb-6 font-bold"></p>
        <form asp-action="UpdateUserRole" method="post" class="space-y-4"
            onsubmit="return confirm('CRITICAL SECURITY ACTION: You are about to change system access rights. Do you have official authorization to proceed?')">
            <input type="hidden" name="userId" id="role-target-id" />
            <div>
                <label class="block text-xs font-black uppercase tracking-widest text-slate-500 mb-2">Select Primary
                    Role</label>
                <select name="newRole"
                    class="w-full px-5 py-3 bg-slate-50 border border-slate-200 rounded-2xl outline-none appearance-none font-bold">
                    <option value="ADMIN">BRANCH ADMINISTRATOR</option>
                    <option value="FINANCE">FINANCE OFFICER</option>
                    <option value="CASHIER">BRANCH CASHIER</option>
                    <option value="USER">BASIC STAFF</option>
                </select>
            </div>
            <div class="flex gap-3 pt-4">
                <button type="button" onclick="closeRoleModal()"
                    class="flex-1 py-3 bg-slate-100 text-slate-600 font-bold rounded-xl">Cancel</button>
                <button type="submit"
                    class="flex-1 py-3 bg-indigo-600 text-white font-bold rounded-xl shadow-lg shadow-indigo-100">Apply
                    New Role</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function openAddModal() { 
            const m = document.getElementById('add-modal');
            const c = document.getElementById('add-modal-card');
            m.classList.remove('hidden'); 
            setTimeout(() => { c.classList.remove('scale-95', 'opacity-0'); c.classList.add('scale-100', 'opacity-100'); }, 10);
        }
        function closeAddModal() { 
            const m = document.getElementById('add-modal');
            const c = document.getElementById('add-modal-card');
            c.classList.remove('scale-100', 'opacity-100'); c.classList.add('scale-95', 'opacity-0');
            setTimeout(() => { m.classList.add('hidden'); }, 500);
        }

        function openPasswordModal(id, email) {
            document.getElementById('pass-target-id').value = id;
            document.getElementById('pass-email').textContent = email;
            document.getElementById('new-password-input').value = '';
            checkNistStrength(''); // Reset meter
            
            const m = document.getElementById('password-modal');
            const c = document.getElementById('password-modal-card');
            m.classList.remove('hidden'); 
            setTimeout(() => { c.classList.remove('scale-95', 'opacity-0'); c.classList.add('scale-100', 'opacity-100'); }, 10);
        }
        function closePasswordModal() { 
            const m = document.getElementById('password-modal');
            const c = document.getElementById('password-modal-card');
            c.classList.remove('scale-100', 'opacity-100'); c.classList.add('scale-95', 'opacity-0');
            setTimeout(() => { m.classList.add('hidden'); }, 500);
        }

        function togglePassVisibility(inputId, btn) {
            const input = document.getElementById(inputId);
            if (input.type === 'password') {
                input.type = 'text';
                btn.innerHTML = '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/></svg>';
            } else {
                input.type = 'password';
                btn.innerHTML = '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>';
            }
        }

        function checkNistStrength(val) {
            const rules = {
                length: val.length >= 12,
                upper: /[A-Z]/.test(val) && /[a-z]/.test(val),
                number: /[0-9]/.test(val) && /[^A-Za-z0-9]/.test(val)
            };

            const updateRule = (id, met) => {
                const el = document.getElementById(id);
                if (met) {
                    el.classList.remove('text-slate-400');
                    el.classList.add('text-emerald-500');
                } else {
                    el.classList.add('text-slate-400');
                    el.classList.remove('text-emerald-500');
                }
            };

            updateRule('rule-length', rules.length);
            updateRule('rule-upper', rules.upper);
            updateRule('rule-number', rules.number);

            const btn = document.getElementById('reset-submit-btn');
            if (rules.length && rules.upper && rules.number) {
                btn.disabled = false;
                btn.classList.remove('bg-slate-200', 'text-slate-400', 'cursor-not-allowed');
                btn.classList.add('bg-indigo-600', 'text-white', 'hover:bg-indigo-700', 'shadow-lg', 'shadow-indigo-100');
            } else {
                btn.disabled = true;
                btn.classList.add('bg-slate-200', 'text-slate-400', 'cursor-not-allowed');
                btn.classList.remove('bg-indigo-600', 'text-white', 'hover:bg-indigo-700', 'shadow-lg', 'shadow-indigo-100');
            }
        }

        function validatePasswordSubmit() {
            return confirm('CRITICAL SECURITY OVERRIDE: You are about to change this user\'s authentication credentials. Proceed?');
        }

        function openRoleModal(id, email) {
            document.getElementById('role-target-id').value = id;
            document.getElementById('role-email').textContent = email;
            
            const m = document.getElementById('role-modal');
            const c = document.getElementById('role-modal-card');
            m.classList.remove('hidden'); 
            setTimeout(() => { c.classList.remove('scale-95', 'opacity-0'); c.classList.add('scale-100', 'opacity-100'); }, 10);
        }
        function closeRoleModal() { 
            const m = document.getElementById('role-modal');
            const c = document.getElementById('role-modal-card');
            c.classList.remove('scale-100', 'opacity-100'); c.classList.add('scale-95', 'opacity-0');
            setTimeout(() => { m.classList.add('hidden'); }, 500);
        }
        function toggleBranch(id) {
            const content = document.getElementById('content-' + id);
            const icon = document.getElementById('icon-' + id);
            
            if (content.classList.contains('hidden')) {
                content.classList.remove('hidden');
                icon.classList.add('rotate-180');
            } else {
                content.classList.add('hidden');
                icon.classList.remove('rotate-180');
            }
        }
    </script>
}
