@model coretex_finalproj.Models.ArchivesViewModel
@{
    ViewData["Title"] = "System Backups";
    Layout = "_AdminLayout";
}

<div class="max-w-5xl mx-auto space-y-8 animate-in fade-in slide-in-from-bottom-4 duration-700">
    <!-- Header: High-Tech Dashboard -->
    <div class="flex items-center justify-between">
        <div class="space-y-1">
            <h2 class="text-3xl font-black text-slate-900 tracking-tight flex items-center gap-3">
                <span class="w-2 h-8 bg-indigo-600 rounded-full"></span>
                System Data Hub
            </h2>
            <p class="text-[10px] font-black text-slate-400 uppercase tracking-[0.3em]">Operational Snapshot & Recovery Management</p>
        </div>
    </div>

    <!-- Quantum Control Panel -->
    <div class="bg-slate-900 rounded-[2.5rem] overflow-hidden shadow-2xl shadow-indigo-200/50 border border-slate-800">
        <div class="grid grid-cols-1 lg:grid-cols-2">
            
            <!-- Left: Export Module -->
            <div class="p-12 border-b lg:border-b-0 lg:border-r border-slate-800 bg-gradient-to-br from-slate-900 to-slate-800 relative group">
                <div class="relative z-10">
                    <div class="w-14 h-14 bg-indigo-600/10 text-indigo-400 rounded-2xl flex items-center justify-center mb-8 border border-indigo-500/20 shadow-lg shadow-indigo-500/10">
                        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                    </div>
                    <h3 class="text-2xl font-black text-white mb-3">Export Snapshot</h3>
                    <p class="text-xs text-slate-400 font-bold leading-relaxed mb-10 max-w-xs">Pack your entire organizational state into a portable <span class="text-indigo-400">.snap</span> file for secure off-site storage.</p>
                    
                    <form asp-action="GenerateSnapshot" method="post">
                        <button type="submit" class="group/btn flex items-center gap-4 px-8 py-4 bg-indigo-600 hover:bg-indigo-500 text-white rounded-2xl font-black text-[10px] uppercase tracking-[0.2em] transition-all duration-300 shadow-xl shadow-indigo-900/20">
                            <span>Initialize Download</span>
                            <svg class="w-4 h-4 group-hover/btn:translate-y-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
                        </button>
                    </form>
                </div>
                <!-- Decorative Grid -->
                <div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: radial-gradient(#6366f1 1px, transparent 0); background-size: 24px 24px;"></div>
            </div>

            <!-- Right: Import Module -->
            <div class="p-12 bg-slate-900/50 backdrop-blur-sm relative">
                <div class="w-14 h-14 bg-rose-600/10 text-rose-400 rounded-2xl flex items-center justify-center mb-8 border border-rose-500/20">
                    <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                </div>
                <h3 class="text-2xl font-black text-white mb-3">Rebuild System</h3>
                <p class="text-xs text-slate-400 font-bold leading-relaxed mb-10">Restore your infrastructure by uploading a valid system snapshot. <span class="text-rose-500">All current data will be purged.</span></p>

                <form asp-action="UploadAndRestore" method="post" enctype="multipart/form-data" class="space-y-4">
                    <div class="relative group">
                        <input type="file" name="snapshotFile" accept=".snap" required 
                            class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10" 
                            onchange="document.getElementById('file-label').innerText = this.files[0].name" />
                        <div class="px-6 py-4 bg-slate-800/50 border border-slate-700 rounded-2xl flex items-center justify-between group-hover:border-rose-500/50 transition-all">
                            <span id="file-label" class="text-[10px] font-black text-slate-500 uppercase tracking-widest truncate max-w-[200px]">Select Snapshot File</span>
                            <div class="px-3 py-1 bg-slate-700 text-slate-400 text-[9px] font-black rounded-lg uppercase tracking-widest">Browse</div>
                        </div>
                    </div>

                    <button type="submit" onclick="return confirm('CRITICAL ACTION: Purge all current data and rebuild from snapshot?')" 
                        class="w-full py-4 bg-white text-slate-900 font-black text-[10px] uppercase tracking-[0.2em] rounded-2xl hover:bg-slate-100 transition-all shadow-xl shadow-black/20 flex items-center justify-center gap-3">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                        <span>Execute Restoration</span>
                    </button>
                </form>
            </div>

        </div>
    </div>

    <!-- Security Status Bar -->
    <div class="flex items-center gap-6 px-10 py-6 bg-white rounded-3xl border border-slate-100 shadow-sm">
        <div class="flex items-center gap-3">
            <div class="w-2 h-2 bg-emerald-500 rounded-full animate-pulse"></div>
            <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Snapshot Engine Active</span>
        </div>
        <div class="h-4 w-px bg-slate-100"></div>
        <div class="flex items-center gap-3">
            <svg class="w-4 h-4 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
            <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">AES-256 Readiness Verified</span>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Simplified UI: No frozen spinner logic needed -->
}


