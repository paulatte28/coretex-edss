@model coretex_finalproj.Models.ArchivesViewModel
@{
    ViewData["Title"] = "System Backups";
    Layout = "_AdminLayout";
}

<div class="space-y-8">
    <!-- Clean Header -->
    <div class="flex items-center justify-between">
        <div>
            <h2 class="text-3xl font-black text-slate-900 tracking-tight">System Data Backups</h2>
            <p class="text-sm text-slate-500 mt-1">Manage technical snapshots and restore deleted operational data.</p>
        </div>
        <button onclick="location.reload()" class="px-6 py-3 bg-indigo-600 text-white font-black text-xs uppercase tracking-widest rounded-xl hover:bg-indigo-700 transition-all shadow-lg shadow-indigo-100">
            Generate New Backup
        </button>
    </div>

    <!-- Simplified Backup List -->
    <div class="bg-white rounded-[2.5rem] border border-slate-100 shadow-sm overflow-hidden">
        <div class="p-6 border-b border-slate-50 bg-slate-50/50">
            <h3 class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Recent System Snapshots</h3>
        </div>
        <div class="divide-y divide-slate-50">
            <div class="flex items-center justify-between p-6 hover:bg-slate-50 transition-colors">
                <div class="flex items-center gap-4">
                    <div class="w-10 h-10 bg-indigo-100 text-indigo-600 rounded-xl flex items-center justify-center font-black text-xs">BK</div>
                    <div>
                        <p class="text-sm font-bold text-slate-900">System_Backup_Current_State.bak</p>
                        <p class="text-[10px] text-slate-400 font-bold uppercase">Size: 42 MB • Created: Today</p>
                    </div>
                </div>
                <button class="px-4 py-2 bg-slate-100 text-slate-600 text-[10px] font-black rounded-lg hover:bg-indigo-600 hover:text-white transition-all uppercase">Restore</button>
            </div>
        </div>
    </div>

    <!-- Data Restoration Section -->
    <div class="pt-6 space-y-6">
        <h3 class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Operational Restore Point</h3>

        @if (TempData["Message"] != null)
        {
            <div class="bg-emerald-50 border border-emerald-200 text-emerald-800 px-6 py-4 rounded-2xl text-sm font-bold animate-slide-in">
                @TempData["Message"]
            </div>
        }

        <!-- Tabs -->
        <div class="flex border-b border-slate-200 gap-8">
            <button onclick="switchTab('branches')" id="tab-branches" class="pb-4 px-2 text-xs font-black uppercase tracking-widest border-b-2 border-indigo-600 text-indigo-600 transition-all">Branches (@Model.ArchivedBranches.Count)</button>
            <button onclick="switchTab('sales')" id="tab-sales" class="pb-4 px-2 text-xs font-black uppercase tracking-widest border-b-2 border-transparent text-slate-400 hover:text-slate-600 transition-all">Sales (@Model.ArchivedSales.Count)</button>
            <button onclick="switchTab('expenses')" id="tab-expenses" class="pb-4 px-2 text-xs font-black uppercase tracking-widest border-b-2 border-transparent text-slate-400 hover:text-slate-600 transition-all">Expenses (@Model.ArchivedExpenses.Count)</button>
        </div>

        <div id="section-branches" class="tab-section grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            @if (!Model.ArchivedBranches.Any())
            {
                <div class="col-span-full py-12 text-center text-slate-400 text-xs font-bold uppercase tracking-widest">No data available</div>
            }
            @foreach (var branch in Model.ArchivedBranches)
            {
                <div class="bg-white rounded-3xl p-6 border border-slate-100 shadow-sm flex items-center justify-between">
                    <div>
                        <h4 class="font-black text-slate-900">@branch.Name</h4>
                        <p class="text-[10px] text-slate-400 font-bold uppercase">Code: @branch.BranchCode</p>
                    </div>
                    <form asp-action="UnarchiveBranch" asp-route-id="@branch.Id" method="post">
                        <button type="submit" class="px-4 py-2 bg-indigo-50 text-indigo-600 text-[10px] font-black rounded-xl hover:bg-indigo-600 hover:text-white transition-all uppercase tracking-widest">Restore</button>
                    </form>
                </div>
            }
        </div>

        <div id="section-sales" class="tab-section hidden bg-white rounded-3xl border border-slate-100 shadow-sm overflow-hidden">
            <table class="w-full text-left">
                <thead class="bg-slate-50/50">
                    <tr>
                        <th class="px-8 py-4 text-[10px] font-black text-slate-400 uppercase">ID</th>
                        <th class="px-8 py-4 text-[10px] font-black text-slate-400 uppercase">Branch</th>
                        <th class="px-8 py-4 text-right text-[10px] font-black text-slate-400 uppercase">Amount</th>
                        <th class="px-8 py-4 text-right text-[10px] font-black text-slate-400 uppercase">Action</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50">
                    @foreach (var sale in Model.ArchivedSales)
                    {
                        <tr>
                            <td class="px-8 py-4 font-bold text-sm">#@sale.OrderId</td>
                            <td class="px-8 py-4 text-sm text-slate-600">@sale.Branch?.Name</td>
                            <td class="px-8 py-4 font-black text-sm text-right">₱@sale.Amount.ToString("N0")</td>
                            <td class="px-8 py-4 text-right">
                                <form asp-action="UnarchiveSale" asp-route-id="@sale.Id" method="post">
                                    <button class="text-[10px] font-black text-indigo-600 hover:underline uppercase">Restore</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div id="section-expenses" class="tab-section hidden bg-white rounded-3xl border border-slate-100 shadow-sm overflow-hidden">
            <table class="w-full text-left">
                <thead class="bg-slate-50/50">
                    <tr>
                        <th class="px-8 py-4 text-[10px] font-black text-slate-400 uppercase">Description</th>
                        <th class="px-8 py-4 text-right text-[10px] font-black text-slate-400 uppercase">Amount</th>
                        <th class="px-8 py-4 text-right text-[10px] font-black text-slate-400 uppercase">Action</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50">
                    @foreach (var exp in Model.ArchivedExpenses)
                    {
                        <tr>
                            <td class="px-8 py-4 font-bold text-sm">@exp.Description</td>
                            <td class="px-8 py-4 font-black text-sm text-right text-rose-500">₱@exp.Amount.ToString("N0")</td>
                            <td class="px-8 py-4 text-right">
                                <form asp-action="UnarchiveExpense" asp-route-id="@exp.Id" method="post">
                                    <button class="text-[10px] font-black text-indigo-600 hover:underline uppercase">Restore</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function switchTab(tab) {
            document.querySelectorAll('.tab-section').forEach(s => s.classList.add('hidden'));
            document.getElementById('section-' + tab).classList.remove('hidden');
            
            document.querySelectorAll('button[id^="tab-"]').forEach(b => {
                b.classList.remove('border-indigo-600', 'text-indigo-600');
                b.classList.add('border-transparent', 'text-slate-400');
            });
            
            const activeTab = document.getElementById('tab-' + tab);
            activeTab.classList.remove('border-transparent', 'text-slate-400');
            activeTab.classList.add('border-indigo-600', 'text-indigo-600');
        }
    </script>
}


