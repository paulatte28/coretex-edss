@model IEnumerable<coretex_finalproj.Models.ActivityLogEntry>
@{
    ViewData["Title"] = "Audit Trail";
    Layout = "_AdminLayout";
}

<div class="space-y-8">
    <div class="flex items-center justify-between">
        <div>
            <h2 class="text-3xl font-black text-slate-900 tracking-tight">System Audit Trail</h2>
            <p class="text-sm text-slate-500 mt-1">Immutable record of all strategic system actions</p>
        </div>
        <div class="flex gap-3">
             <button onclick="location.reload()" class="px-5 py-2 bg-white border border-slate-200 text-slate-600 font-bold rounded-xl hover:bg-slate-50 transition-all flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 1111 21.277M15.351 7.096A8.001 8.001 0 005.106 17.658"/></svg>
                Refresh
            </button>
        </div>
    </div>

    <!-- Activity Feed -->
    <div class="bg-white rounded-[3rem] shadow-sm border border-slate-100 overflow-hidden">
        <div class="p-8 border-b border-slate-50 flex items-center justify-between">
            <h3 class="font-black text-slate-900">Live System Events</h3>
            <span class="px-3 py-1 bg-emerald-100 text-emerald-700 text-[10px] font-black uppercase rounded-full animate-pulse">Live Tracking</span>
        </div>
        <div class="divide-y divide-slate-50">
            @foreach (var log in Model)
            {
                <div class="p-8 hover:bg-slate-50 transition-all flex items-start gap-6 group">
                    <div class="w-14 h-14 rounded-2xl flex items-center justify-center shrink-0 @(log.ActionType.Contains("CRITICAL") ? "bg-rose-100 text-rose-600" : "bg-indigo-100 text-indigo-600")">
                        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    </div>
                    <div class="flex-1">
                        <div class="flex items-center justify-between mb-1">
                            <h4 class="font-black text-slate-900 group-hover:text-indigo-600 transition-colors">@log.ActionType</h4>
                            <span class="text-xs text-slate-400 font-bold uppercase tracking-widest">@log.CreatedAt.ToString("MMM dd, HH:mm:ss")</span>
                        </div>
                        <p class="text-slate-600 text-sm leading-relaxed mb-3">@log.Description</p>
                        <div class="flex items-center gap-4">
                            <div class="flex items-center gap-2">
                                <div class="w-5 h-5 bg-slate-100 rounded-lg flex items-center justify-center text-[10px] font-black text-slate-500">U</div>
                                <span class="text-xs font-bold text-slate-500">@log.UserName</span>
                            </div>
                            <div class="flex items-center gap-2">
                                <div class="w-5 h-5 bg-slate-100 rounded-lg flex items-center justify-center text-[10px] font-black text-slate-500">IP</div>
                                <span class="text-xs font-bold text-slate-400">@log.IpAddress</span>
                            </div>
                            @if (!string.IsNullOrEmpty(log.Location))
                            {
                                <div class="flex items-center gap-2">
                                    <div class="w-5 h-5 bg-indigo-50 rounded-lg flex items-center justify-center text-[10px] font-black text-indigo-500">🌍</div>
                                    <span class="text-xs font-bold text-indigo-500/80">@log.Location</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
