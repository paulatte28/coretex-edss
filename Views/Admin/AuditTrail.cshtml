@{
    ViewData["Title"] = "Audit Trail";
    Layout = "_AdminLayout";
}

<div class="space-y-8">
    <div class="flex items-center justify-between">
        <div>
            <div class="flex items-center space-x-3 mb-2">
                <a href="/Admin" class="text-slate-400 hover:text-slate-600 transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
                </a>
                <span class="px-3 py-1 bg-slate-100 text-slate-700 font-black text-[10px] uppercase tracking-widest rounded-full">Change Log</span>
            </div>
            <h2 class="text-3xl font-black text-slate-900 tracking-tight">Audit Trail</h2>
            <p class="text-sm text-slate-500 mt-1">Track created, updated, and deleted records across modules</p>
        </div>
    </div>

    <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100">
        <div class="flex flex-wrap items-end gap-4">
            <div>
                <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">Date From</label>
                <input type="date" id="date-from" class="px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl text-sm font-semibold focus:ring-2 focus:ring-slate-500/20 focus:border-slate-500" />
            </div>
            <div>
                <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">Date To</label>
                <input type="date" id="date-to" class="px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl text-sm font-semibold focus:ring-2 focus:ring-slate-500/20 focus:border-slate-500" />
            </div>
            <div>
                <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">User</label>
                <select id="user-filter" class="px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl text-sm font-semibold focus:ring-2 focus:ring-slate-500/20 focus:border-slate-500">
                    <option value="">All Users</option>
                </select>
            </div>
            <div>
                <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">Module</label>
                <select id="module-filter" class="px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl text-sm font-semibold focus:ring-2 focus:ring-slate-500/20 focus:border-slate-500">
                    <option value="">All Modules</option>
                </select>
            </div>
            <button id="clear-filters" class="px-4 py-2.5 bg-slate-100 text-slate-600 rounded-xl hover:bg-slate-200 transition-colors text-sm font-bold">
                Clear Filters
            </button>
        </div>
    </div>

    <div class="bg-white rounded-3xl shadow-sm border border-slate-100 overflow-hidden">
        <div class="p-6 border-b border-slate-100 flex items-center justify-between">
            <div>
                <h3 class="font-bold text-slate-900">Change Log Table</h3>
                <p class="text-xs text-slate-500 mt-1">Timestamp, user, module, action, field changes, and record references</p>
            </div>
            <p class="text-xs text-slate-400" id="showing-count">Showing 0 of 0 changes</p>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full">
                <thead class="bg-slate-50">
                    <tr>
                        <th class="px-6 py-4 text-left text-[10px] font-black text-slate-500 uppercase tracking-widest">Timestamp</th>
                        <th class="px-6 py-4 text-left text-[10px] font-black text-slate-500 uppercase tracking-widest">User</th>
                        <th class="px-6 py-4 text-left text-[10px] font-black text-slate-500 uppercase tracking-widest">Module</th>
                        <th class="px-6 py-4 text-left text-[10px] font-black text-slate-500 uppercase tracking-widest">Action</th>
                        <th class="px-6 py-4 text-left text-[10px] font-black text-slate-500 uppercase tracking-widest">Field Changed</th>
                        <th class="px-6 py-4 text-left text-[10px] font-black text-slate-500 uppercase tracking-widest">Old Value</th>
                        <th class="px-6 py-4 text-left text-[10px] font-black text-slate-500 uppercase tracking-widest">New Value</th>
                        <th class="px-6 py-4 text-left text-[10px] font-black text-slate-500 uppercase tracking-widest">Record ID</th>
                    </tr>
                </thead>
                <tbody id="change-log-table" class="divide-y divide-slate-100">
                    <tr>
                        <td colspan="8" class="px-6 py-12 text-center text-slate-400 text-sm italic">No change logs yet.</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const KNOWN_MODULES = [
            'POS',
            'Expenses',
            'KPI Settings',
            'Goals & Targets',
            'Report Schedule',
            'Branch Submission',
            'User Management',
            'System'
        ];

        const MODULE_HINTS = {
            pos: 'POS',
            sale: 'POS',
            sales: 'POS',
            expense: 'Expenses',
            expenses: 'Expenses',
            kpi: 'KPI Settings',
            threshold: 'KPI Settings',
            goal: 'Goals & Targets',
            target: 'Goals & Targets',
            schedule: 'Report Schedule',
            report: 'Report Schedule',
            branch: 'Branch Submission',
            submission: 'Branch Submission',
            user: 'User Management'
        };

        let allEntries = [];
        let filteredEntries = [];

        function normalizeAction(rawAction) {
            const value = String(rawAction || '').toLowerCase();

            if (!value) return null;
            if (value.includes('login') || value.includes('logout') || value.includes('auth')) return null;
            if (value.includes('create') || value.includes('add') || value.includes('new')) return 'Created';
            if (value.includes('update') || value.includes('edit') || value.includes('change') || value.includes('submit')) return 'Updated';
            if (value.includes('delete') || value.includes('remove')) return 'Deleted';

            return null;
        }

        function toTitleCase(value) {
            return String(value || '')
                .replace(/[_-]/g, ' ')
                .trim()
                .replace(/\s+/g, ' ')
                .replace(/\b\w/g, char => char.toUpperCase());
        }

        function safeString(value, fallback = '-') {
            if (value === null || value === undefined) return fallback;
            const text = String(value).trim();
            return text ? text : fallback;
        }

        function inferModule(moduleValue, contextText) {
            const source = (safeString(moduleValue, '') + ' ' + safeString(contextText, '')).toLowerCase();

            for (const [hint, label] of Object.entries(MODULE_HINTS)) {
                if (source.includes(hint)) return label;
            }

            if (safeString(moduleValue, '') !== '') {
                return toTitleCase(moduleValue);
            }

            return 'System';
        }

        function normalizeAuditEntry(entry) {
            const action = normalizeAction(entry.action);
            if (!action) return null;

            const details = safeString(entry.details || entry.description, '');
            const timestamp = entry.timestamp || entry.createdAt || entry.date || new Date().toISOString();

            return {
                timestamp,
                user: safeString(entry.user || entry.userName || entry.actor, 'System Administrator'),
                module: inferModule(entry.module || entry.entity || entry.type, (entry.action || '') + ' ' + details),
                action,
                fieldChanged: safeString(entry.fieldChanged || entry.field || entry.property || entry.column, '-'),
                oldValue: safeString(entry.oldValue ?? entry.before ?? entry.previousValue ?? entry.old, '-'),
                newValue: safeString(entry.newValue ?? entry.after ?? entry.currentValue ?? entry.new, '-'),
                recordId: safeString(entry.recordId || entry.referenceId || entry.entityId || entry.targetId || entry.id, '-'),
                sortDate: new Date(timestamp)
            };
        }

        function normalizeActivityEntry(entry) {
            const action = normalizeAction(entry.action);
            if (!action) return null;

            const details = safeString(entry.description, '');
            const timestamp = entry.timestamp || new Date().toISOString();

            return {
                timestamp,
                user: safeString(entry.user, 'System Administrator'),
                module: inferModule(entry.type, (entry.action || '') + ' ' + details),
                action,
                fieldChanged: safeString(entry.fieldChanged || entry.field, '-'),
                oldValue: safeString(entry.oldValue ?? entry.before ?? entry.previousValue, '-'),
                newValue: safeString(entry.newValue ?? entry.after ?? entry.currentValue, '-'),
                recordId: safeString(entry.recordId || entry.entityId || entry.id, '-'),
                sortDate: new Date(timestamp)
            };
        }

        function setSelectOptions(selectId, values, placeholder) {
            const select = document.getElementById(selectId);
            const currentValue = select.value;

            const optionHtml = values
                .map(value => '<option value="' + escapeHtml(value) + '">' + escapeHtml(value) + '</option>')
                .join('');

            select.innerHTML = '<option value="">' + placeholder + '</option>' + optionHtml;

            if (values.includes(currentValue)) {
                select.value = currentValue;
            }
        }

        function initFilterOptions() {
            const usersFromEntries = allEntries.map(entry => entry.user);
            const usersFromStore = JSON.parse(localStorage.getItem('coretex_users') || '[]').map(user => user.name);
            const allUsers = [...new Set([...usersFromEntries, ...usersFromStore, 'System Administrator'])]
                .filter(Boolean)
                .sort((a, b) => a.localeCompare(b));

            const modulesFromEntries = allEntries.map(entry => entry.module);
            const allModules = [...new Set([...KNOWN_MODULES, ...modulesFromEntries])]
                .filter(Boolean)
                .sort((a, b) => a.localeCompare(b));

            setSelectOptions('user-filter', allUsers, 'All Users');
            setSelectOptions('module-filter', allModules, 'All Modules');
        }

        function loadEntries() {
            const auditEntriesRaw = JSON.parse(localStorage.getItem('coretex_audit_log') || '[]');
            const activityEntriesRaw = JSON.parse(localStorage.getItem('coretex_activities') || '[]');

            const auditEntries = auditEntriesRaw.map(normalizeAuditEntry).filter(Boolean);
            const activityEntries = activityEntriesRaw.map(normalizeActivityEntry).filter(Boolean);

            const combined = [...auditEntries, ...activityEntries];
            const seen = new Set();

            allEntries = combined
                .filter(entry => {
                    const key = [
                        safeString(entry.timestamp, ''),
                        safeString(entry.user, ''),
                        safeString(entry.module, ''),
                        safeString(entry.action, ''),
                        safeString(entry.fieldChanged, ''),
                        safeString(entry.recordId, '')
                    ].join('|');

                    if (seen.has(key)) return false;
                    seen.add(key);
                    return true;
                })
                .sort((a, b) => b.sortDate - a.sortDate);

            initFilterOptions();
            applyFilters();
        }

        function applyFilters() {
            const dateFromValue = document.getElementById('date-from').value;
            const dateToValue = document.getElementById('date-to').value;
            const userFilter = document.getElementById('user-filter').value;
            const moduleFilter = document.getElementById('module-filter').value;

            const dateFrom = dateFromValue ? new Date(dateFromValue + 'T00:00:00') : null;
            const dateTo = dateToValue ? new Date(dateToValue + 'T23:59:59.999') : null;

            filteredEntries = allEntries.filter(entry => {
                const entryDate = new Date(entry.timestamp);

                const matchesFrom = !dateFrom || entryDate >= dateFrom;
                const matchesTo = !dateTo || entryDate <= dateTo;
                const matchesUser = !userFilter || entry.user === userFilter;
                const matchesModule = !moduleFilter || entry.module === moduleFilter;

                return matchesFrom && matchesTo && matchesUser && matchesModule;
            });

            renderTable();
        }

        function getActionBadge(action) {
            if (action === 'Created') {
                return '<span class="px-3 py-1 bg-emerald-100 text-emerald-700 text-[10px] font-black uppercase rounded-full">Created</span>';
            }

            if (action === 'Updated') {
                return '<span class="px-3 py-1 bg-amber-100 text-amber-700 text-[10px] font-black uppercase rounded-full">Updated</span>';
            }

            return '<span class="px-3 py-1 bg-red-100 text-red-700 text-[10px] font-black uppercase rounded-full">Deleted</span>';
        }

        function formatDate(timestamp) {
            const date = new Date(timestamp);
            if (Number.isNaN(date.getTime())) return '-';

            return date.toLocaleDateString('en-US', {
                month: 'short',
                day: 'numeric',
                year: 'numeric'
            });
        }

        function formatTime(timestamp) {
            const date = new Date(timestamp);
            if (Number.isNaN(date.getTime())) return '-';

            return date.toLocaleTimeString('en-US', {
                hour: '2-digit',
                minute: '2-digit'
            });
        }

        function escapeHtml(value) {
            const map = {
                '&': '&amp;',
                '<': '&lt;',
                '>': '&gt;',
                '"': '&quot;',
                "'": '&#039;'
            };

            return String(value || '').replace(/[&<>"']/g, char => map[char]);
        }

        function renderTable() {
            const tbody = document.getElementById('change-log-table');
            const showingCount = document.getElementById('showing-count');

            showingCount.textContent = 'Showing ' + filteredEntries.length + ' of ' + allEntries.length + ' changes';

            if (filteredEntries.length === 0) {
                tbody.innerHTML = `
                    <tr>
                        <td colspan="8" class="px-6 py-12 text-center text-slate-400 text-sm italic">
                            No change logs match the selected filters.
                        </td>
                    </tr>`;
                return;
            }

            tbody.innerHTML = filteredEntries.map(entry => `
                <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-6 py-4">
                        <p class="font-semibold text-slate-900 text-sm">${escapeHtml(formatDate(entry.timestamp))}</p>
                        <p class="text-xs text-slate-500">${escapeHtml(formatTime(entry.timestamp))}</p>
                    </td>
                    <td class="px-6 py-4 text-sm font-semibold text-slate-900">${escapeHtml(entry.user)}</td>
                    <td class="px-6 py-4 text-sm text-slate-600">${escapeHtml(entry.module)}</td>
                    <td class="px-6 py-4">${getActionBadge(entry.action)}</td>
                    <td class="px-6 py-4 text-sm text-slate-600">${escapeHtml(entry.fieldChanged)}</td>
                    <td class="px-6 py-4 text-sm text-slate-500 max-w-[220px] truncate" title="${escapeHtml(entry.oldValue)}">${escapeHtml(entry.oldValue)}</td>
                    <td class="px-6 py-4 text-sm text-slate-500 max-w-[220px] truncate" title="${escapeHtml(entry.newValue)}">${escapeHtml(entry.newValue)}</td>
                    <td class="px-6 py-4 text-sm font-mono text-slate-500">${escapeHtml(entry.recordId)}</td>
                </tr>
            `).join('');
        }

        function clearFilters() {
            document.getElementById('date-from').value = '';
            document.getElementById('date-to').value = '';
            document.getElementById('user-filter').value = '';
            document.getElementById('module-filter').value = '';
            applyFilters();
        }

        document.addEventListener('DOMContentLoaded', function() {
            document.getElementById('date-from').addEventListener('change', applyFilters);
            document.getElementById('date-to').addEventListener('change', applyFilters);
            document.getElementById('user-filter').addEventListener('change', applyFilters);
            document.getElementById('module-filter').addEventListener('change', applyFilters);
            document.getElementById('clear-filters').addEventListener('click', clearFilters);
            loadEntries();
        });
    </script>
}
