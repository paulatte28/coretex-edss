@model IEnumerable<coretex_finalproj.Models.ActivityLogEntry>
@{
    ViewData["Title"] = "Activity Logs";
    Layout = "_AdminLayout";
}

<div class="space-y-8">
    <!-- Header -->
    <div class="flex items-center justify-between">
        <div>
            <div class="flex items-center space-x-3 mb-2">
                <a href="/Admin" class="text-slate-400 hover:text-slate-600 transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                </a>
                <span class="px-3 py-1 bg-slate-100 text-slate-700 font-black text-[10px] uppercase tracking-widest rounded-full">Audit Trail</span>
            </div>
            <h2 class="text-3xl font-black text-slate-900 tracking-tight">Activity Logs</h2>
            <p class="text-sm text-slate-500 mt-1">Track all system activities and real-time integration failures</p>
        </div>
    </div>

    <!-- Logs Table -->
    <div class="bg-white rounded-3xl shadow-sm border border-slate-100 overflow-hidden">
        <div class="p-6 border-b border-slate-100 flex items-center justify-between">
            <div class="flex items-center space-x-3">
                <h3 class="font-bold text-slate-900">System Activity & Debug Log</h3>
                <span class="flex items-center space-x-2 text-xs text-emerald-600 bg-emerald-50 px-3 py-1 rounded-full">
                    <span class="w-2 h-2 bg-emerald-500 rounded-full animate-pulse"></span>
                    <span class="font-bold">Database Live</span>
                </span>
            </div>
            <p class="text-xs text-slate-400">Showing latest @Model.Count() logs</p>
        </div>
        
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead class="bg-slate-50">
                    <tr>
                        <th class="px-6 py-4 text-left text-[10px] font-black text-slate-500 uppercase tracking-widest">Timestamp</th>
                        <th class="px-6 py-4 text-left text-[10px] font-black text-slate-500 uppercase tracking-widest">User / Origin</th>
                        <th class="px-6 py-4 text-left text-[10px] font-black text-slate-500 uppercase tracking-widest">Action / Status</th>
                        <th class="px-6 py-4 text-left text-[10px] font-black text-slate-500 uppercase tracking-widest">Details / Errors</th>
                        <th class="px-6 py-4 text-left text-[10px] font-black text-slate-500 uppercase tracking-widest">Connection</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="px-6 py-12 text-center text-slate-400 text-sm italic">
                                No activity recorded yet.
                            </td>
                        </tr>
                    }
                    @foreach (var log in Model)
                    {
                        var statusClass = log.ActionType.Contains("FAILURE") ? "bg-rose-100 text-rose-700" : "bg-emerald-100 text-emerald-700";
                        if (log.ActionType.Contains("LOGIN")) statusClass = "bg-blue-100 text-blue-700";

                        <tr class="hover:bg-slate-50 transition-colors">
                            <td class="px-6 py-4">
                                <p class="font-bold text-slate-900 text-sm">@log.CreatedAt.ToString("MMM dd, yyyy")</p>
                                <p class="text-xs text-slate-500">@log.CreatedAt.ToString("HH:mm:ss")</p>
                            </td>
                            <td class="px-6 py-4">
                                <div class="flex items-center space-x-3">
                                    <div class="w-8 h-8 bg-slate-100 rounded-full flex items-center justify-center">
                                        <span class="text-xs font-black text-slate-600">@log.UserName.Substring(0, 1).ToUpper()</span>
                                    </div>
                                    <div>
                                        <p class="font-semibold text-slate-900 text-sm">@log.UserName</p>
                                        <p class="text-xs text-slate-500">@log.UserRole</p>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4">
                                <span class="px-3 py-1 @statusClass text-[10px] font-black uppercase rounded-full">@log.ActionType</span>
                            </td>
                            <td class="px-6 py-4">
                                <p class="text-xs text-slate-700 font-bold">@log.Description</p>
                            </td>
                            <td class="px-6 py-4">
                                <code class="px-2 py-1 bg-slate-100 text-slate-700 text-[10px] rounded font-mono">@log.IpAddress</code>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Scripts removed to prioritize server-side logs -->
}

<!-- Toast -->
<div id="toast" class="fixed bottom-6 right-6 bg-emerald-500 text-white px-6 py-4 rounded-2xl shadow-2xl hidden items-center space-x-3 z-50">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
    <span id="toast-message" class="font-bold">Exported successfully!</span>
</div>

@section Scripts {
    <script>
        let activities = [];

        function initFilters() {
            // Set date range defaults (last 30 days)
            const today = new Date();
            const thirtyDaysAgo = new Date(today.getTime() - 30 * 24 * 60 * 60 * 1000);
            
            document.getElementById('filter-date-to').value = today.toISOString().split('T')[0];
            document.getElementById('filter-date-from').value = thirtyDaysAgo.toISOString().split('T')[0];

            // Populate user dropdown
            const users = JSON.parse(localStorage.getItem('coretex_users') || '[]');
            const userSelect = document.getElementById('filter-user');
            
            const uniqueUsers = [...new Set(activities.map(a => a.user))];
            uniqueUsers.forEach(user => {
                const option = document.createElement('option');
                option.value = user;
                option.textContent = user;
                userSelect.appendChild(option);
            });
        }

        function loadActivities() {
            activities = JSON.parse(localStorage.getItem('coretex_activities') || '[]');
            
            // Ensure all activities have IP and location data
            activities = activities.map(a => ({
                ...a,
                ipAddress: a.ipAddress || generateRandomIP(),
                location: a.location || generateRandomLocation()
            }));
            
            initFilters();
            renderLogs();
        }

        function generateRandomIP() {
            // Simulate IP addresses
            const ips = ['192.168.1.45', '192.168.1.102', '10.0.0.15', '172.16.0.88', '192.168.0.201'];
            return ips[Math.floor(Math.random() * ips.length)];
        }

        function generateRandomLocation() {
            // Simulate locations from IPGeolocation
            const locations = [
                { city: 'Manila', country: 'Philippines' },
                { city: 'Cebu City', country: 'Philippines' },
                { city: 'Davao City', country: 'Philippines' },
                { city: 'Quezon City', country: 'Philippines' }
            ];
            const loc = locations[Math.floor(Math.random() * locations.length)];
            return `${loc.city}, ${loc.country}`;
        }

        function renderLogs() {
            const dateFrom = document.getElementById('filter-date-from').value;
            const dateTo = document.getElementById('filter-date-to').value;
            const userFilter = document.getElementById('filter-user').value;
            const typeFilter = document.getElementById('filter-type').value;

            let filtered = activities.filter(a => {
                const activityDate = new Date(a.timestamp).toISOString().split('T')[0];
                
                const matchesDateFrom = !dateFrom || activityDate >= dateFrom;
                const matchesDateTo = !dateTo || activityDate <= dateTo;
                const matchesUser = !userFilter || a.user === userFilter;
                const matchesType = !typeFilter || a.action === typeFilter;
                
                return matchesDateFrom && matchesDateTo && matchesUser && matchesType;
            });

            // Sort by timestamp descending
            filtered.sort((a, b) => new Date(b.timestamp) - new Date(a.timestamp));

            document.getElementById('showing-count').textContent = `Showing ${filtered.length} of ${activities.length} logs`;

            const tbody = document.getElementById('logs-table');

            if (filtered.length === 0) {
                tbody.innerHTML = `
                    <tr>
                        <td colspan="5" class="px-6 py-12 text-center text-slate-400 text-sm italic">
                            No activity logs match the selected filters.
                        </td>
                    </tr>`;
                return;
            }

            tbody.innerHTML = filtered.map(log => {
                const timestamp = new Date(log.timestamp);
                const dateStr = timestamp.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
                const timeStr = timestamp.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });

                const actionColors = {
                    'Login': 'bg-blue-100 text-blue-700',
                    'Logout': 'bg-slate-100 text-slate-700',
                    'Data Entry': 'bg-emerald-100 text-emerald-700',
                    'Submission': 'bg-purple-100 text-purple-700',
                    'User Created': 'bg-amber-100 text-amber-700',
                    'User Updated': 'bg-amber-100 text-amber-700',
                    'Threshold Changed': 'bg-rose-100 text-rose-700',
                    'Schedule Updated': 'bg-indigo-100 text-indigo-700'
                };
                const actionColor = actionColors[log.action] || 'bg-slate-100 text-slate-700';

                return `
                    <tr class="hover:bg-slate-50 transition-colors">
                        <td class="px-6 py-4">
                            <p class="font-bold text-slate-900 text-sm">${dateStr}</p>
                            <p class="text-xs text-slate-500">${timeStr}</p>
                        </td>
                        <td class="px-6 py-4">
                            <div class="flex items-center space-x-3">
                                <div class="w-8 h-8 bg-slate-100 rounded-full flex items-center justify-center">
                                    <span class="text-xs font-black text-slate-600">${log.user.charAt(0).toUpperCase()}</span>
                                </div>
                                <div>
                                    <p class="font-semibold text-slate-900 text-sm">${log.user}</p>
                                    <p class="text-xs text-slate-500">${log.role || 'System'}</p>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-4">
                            <span class="px-3 py-1 ${actionColor} text-[10px] font-black uppercase rounded-full">${log.action}</span>
                            <p class="text-xs text-slate-500 mt-1">${log.description || ''}</p>
                        </td>
                        <td class="px-6 py-4">
                            <code class="px-2 py-1 bg-slate-100 text-slate-700 text-xs rounded font-mono">${log.ipAddress}</code>
                        </td>
                        <td class="px-6 py-4">
                            <div class="flex items-center space-x-2">
                                <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                                <span class="text-sm text-slate-600">${log.location}</span>
                            </div>
                        </td>
                    </tr>
                `;
            }).join('');
        }

        function clearFilters() {
            const today = new Date();
            const thirtyDaysAgo = new Date(today.getTime() - 30 * 24 * 60 * 60 * 1000);
            
            document.getElementById('filter-date-to').value = today.toISOString().split('T')[0];
            document.getElementById('filter-date-from').value = thirtyDaysAgo.toISOString().split('T')[0];
            document.getElementById('filter-user').value = '';
            document.getElementById('filter-type').value = '';
            
            renderLogs();
        }

        function exportCSV() {
            const dateFrom = document.getElementById('filter-date-from').value;
            const dateTo = document.getElementById('filter-date-to').value;
            const userFilter = document.getElementById('filter-user').value;
            const typeFilter = document.getElementById('filter-type').value;

            let filtered = activities.filter(a => {
                const activityDate = new Date(a.timestamp).toISOString().split('T')[0];
                
                const matchesDateFrom = !dateFrom || activityDate >= dateFrom;
                const matchesDateTo = !dateTo || activityDate <= dateTo;
                const matchesUser = !userFilter || a.user === userFilter;
                const matchesType = !typeFilter || a.action === typeFilter;
                
                return matchesDateFrom && matchesDateTo && matchesUser && matchesType;
            });

            const csv = [
                ['Timestamp', 'User', 'Role', 'Action', 'Description', 'IP Address', 'Location'].join(','),
                ...filtered.map(a => [
                    new Date(a.timestamp).toISOString(),
                    `"${a.user}"`,
                    `"${a.role || 'System'}"`,
                    `"${a.action}"`,
                    `"${a.description || ''}"`,
                    `"${a.ipAddress}"`,
                    `"${a.location}"`
                ].join(','))
            ].join('\n');

            const blob = new Blob([csv], { type: 'text/csv' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `coretex-activity-logs-${new Date().toISOString().split('T')[0]}.csv`;
            a.click();
            URL.revokeObjectURL(url);

            showToast('CSV exported successfully!');
        }

        function showToast(message) {
            const toast = document.getElementById('toast');
            document.getElementById('toast-message').textContent = message;
            toast.classList.remove('hidden');
            toast.classList.add('flex');
            setTimeout(() => {
                toast.classList.add('hidden');
                toast.classList.remove('flex');
            }, 3000);
        }

        // Event listeners
        document.getElementById('filter-date-from').addEventListener('change', renderLogs);
        document.getElementById('filter-date-to').addEventListener('change', renderLogs);
        document.getElementById('filter-user').addEventListener('change', renderLogs);
        document.getElementById('filter-type').addEventListener('change', renderLogs);

        // Initialize
        document.addEventListener('DOMContentLoaded', loadActivities);
    </script>
}
