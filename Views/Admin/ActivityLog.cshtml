@model List<coretex_finalproj.Models.ActivityLogEntry>
@using Microsoft.AspNetCore.Identity
@inject UserManager<AppUser> UserManager
@{
    ViewData["Title"] = "Activity Audit";
    Layout = "_AdminLayout";
    var currentUser = await UserManager.GetUserAsync(User);
    var isManager = User.IsInRole("BRANCH_ADMIN");
}

<style>
    .filter-pill.active {
        background-color: #0f172a !important;
        color: white !important;
        border-color: #0f172a !important;
        box-shadow: 0 10px 15px -3px rgba(15, 23, 42, 0.1);
    }
</style>

<div class="space-y-10 pb-10">
    <!-- Header -->
    <div class="relative bg-slate-900 rounded-[3rem] p-12 overflow-hidden shadow-2xl">
        <div class="relative z-10 flex flex-col md:flex-row md:items-center justify-between gap-8">
            <div>
                <div class="flex items-center space-x-3 mb-4">
                    <a href="/Admin" class="w-8 h-8 flex items-center justify-center bg-white/10 hover:bg-white/20 rounded-full transition-all text-white">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M15 19l-7-7 7-7"/></svg>
                    </a>
                    <span class="px-3 py-1 bg-indigo-500/20 text-indigo-300 font-black text-[10px] uppercase tracking-widest rounded-full border border-indigo-500/30">Personal Audit Trail</span>
                </div>
                <h1 class="text-4xl font-black text-white tracking-tighter uppercase">My <span class="text-indigo-400">Audit Logs</span></h1>
                <p class="text-slate-400 mt-2 text-sm font-medium">
                    @(isManager || User.IsInRole("FINANCE") ? "Reviewing your personal operational footprint and authenticated command history." : "Global corporate audit trail and system-wide integrity monitoring.")
                </p>
            </div>
            <button onclick="exportCSV()" class="px-8 py-4 bg-white/10 hover:bg-white/20 border border-white/10 text-white font-black text-sm uppercase tracking-widest rounded-2xl transition-all flex items-center space-x-3">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
                <span>Export Audit</span>
            </button>
        </div>
        <div class="absolute top-0 right-0 -mr-20 -mt-20 w-80 h-80 bg-indigo-500/10 rounded-full blur-3xl"></div>
    </div>

    <!-- High-Fidelity Filter Hub -->
    <div class="bg-white rounded-[2.5rem] border border-slate-100 shadow-sm overflow-hidden p-8">
        <div class="flex flex-col space-y-8">
            <!-- Filter Pills Row -->
            <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-6">
                <div class="inline-flex p-1.5 bg-slate-100/80 backdrop-blur-md rounded-2xl border border-slate-200/50">
                    <button onclick="filterByType('ALL', this)" class="filter-pill active px-6 py-2.5 text-[10px] font-black uppercase tracking-widest rounded-xl transition-all duration-300">
                        Everything
                    </button>
                    <button onclick="filterByType('WORKFORCE', this)" class="filter-pill px-6 py-2.5 text-slate-500 font-black text-[10px] uppercase tracking-widest rounded-xl hover:text-slate-900 transition-all duration-300">
                        Staff & Security
                    </button>
                    @if (isManager || User.IsInRole("FINANCE"))
                    {
                        <button onclick="filterByType('OPERATIONS', this)" class="filter-pill px-6 py-2.5 text-slate-500 font-black text-[10px] uppercase tracking-widest rounded-xl hover:text-slate-900 transition-all duration-300">
                            Management & Operations
                        </button>
                    }
                    @if (User.IsInRole("FINANCE"))
                    {
                        <button onclick="filterByType('FINANCE', this)" class="filter-pill px-6 py-2.5 text-slate-500 font-black text-[10px] uppercase tracking-widest rounded-xl hover:text-slate-900 transition-all duration-300">
                            Money & Expenses
                        </button>
                    }
                    @if (!isManager && !User.IsInRole("FINANCE"))
                    {
                        <button onclick="filterByType('FINANCE', this)" class="filter-pill px-6 py-2.5 text-slate-500 font-black text-[10px] uppercase tracking-widest rounded-xl hover:text-slate-900 transition-all duration-300">
                            Money & Expenses
                        </button>
                        <button onclick="filterByType('REVENUE', this)" class="filter-pill px-6 py-2.5 text-slate-500 font-black text-[10px] uppercase tracking-widest rounded-xl hover:text-slate-900 transition-all duration-300">
                            Sales & Products
                        </button>
                        <button onclick="filterByType('STRATEGIC', this)" class="filter-pill px-6 py-2.5 text-slate-500 font-black text-[10px] uppercase tracking-widest rounded-xl hover:text-slate-900 transition-all duration-300">
                            System & Strategy
                        </button>
                    }
                </div>

                <!-- Search Bar -->
                <div class="relative group min-w-[320px]">
                    <div class="absolute inset-y-0 left-4 flex items-center pointer-events-none">
                        <svg class="w-4 h-4 text-slate-400 group-focus-within:text-indigo-600 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                    </div>
                    <input type="text" id="log-search" onkeyup="searchLogs()" placeholder="Scan company audit trail..." 
                        class="w-full pl-12 pr-6 py-3.5 bg-slate-50 border border-slate-200 rounded-2xl text-sm font-semibold focus:ring-4 focus:ring-indigo-500/10 focus:bg-white focus:border-indigo-500 outline-none transition-all shadow-inner">
                </div>
            </div>
        </div>
    </div>

        <div class="overflow-x-auto">
            <table class="w-full">
                <thead>
                    <tr class="border-b border-slate-50">
                        <th class="px-10 py-6 text-left text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">Temporal Context</th>
                        <th class="px-10 py-6 text-left text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">Operational Node</th>
                        <th class="px-10 py-6 text-left text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">Activity Details</th>
                        <th class="px-10 py-6 text-left text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">Network Context</th>
                    </tr>
                </thead>
                <tbody id="logs-tbody" class="divide-y divide-slate-50">
                    @foreach (var log in Model)
                    {
                        var action = log.ActionType ?? "SYSTEM_ACTION";
                        var category = "OTHER";
                        
                        if (action.Contains("USER") || action.Contains("LOGIN") || action.Contains("LOGOUT")) 
                        {
                            // If it's a provisioning action, it's an OPERATION
                            if (action.Contains("PROVISION")) category = "OPERATIONS";
                            else category = "WORKFORCE";
                        }
                        else if (action.Contains("ADD") || action.Contains("EDIT") || action.Contains("UPDATE") || action.Contains("DELETE") || action.Contains("ARCHIVE")) category = "OPERATIONS";
                        else if (action.Contains("EXPENSE") || action.Contains("MONTH") || action.Contains("FINANCE")) category = "FINANCE";
                        else if (action.Contains("SALE") || action.Contains("POS") || action.Contains("TRANSACTION") || action.Contains("PRODUCT") || action.Contains("STOCK")) category = "REVENUE";
                        else if (action.Contains("KPI") || action.Contains("GOAL") || action.Contains("SYSTEM") || action.Contains("BRANCH") || action.Contains("INFRA")) category = "STRATEGIC";
                        
                        var categoryLabel = category switch {
                            "WORKFORCE" => "Staff & Security",
                            "OPERATIONS" => "Management & Operations",
                            "FINANCE" => "Money & Expenses",
                            "REVENUE" => "Sales & Products",
                            "STRATEGIC" => "System & Strategy",
                            _ => "System Activity"
                        };
                        
                        var color = category switch {
                            "WORKFORCE" => "bg-amber-500",
                            "OPERATIONS" => "bg-purple-600",
                            "FINANCE" => "bg-emerald-500",
                            "REVENUE" => "bg-indigo-500",
                            "STRATEGIC" => "bg-rose-500",
                            _ => "bg-slate-500"
                        };

                        <tr class="log-row hover:bg-slate-50/50 transition-all duration-200" 
                            data-category="@category" 
                            data-search="@(action.ToLower() + " " + (log.Description ?? "").ToLower() + " " + (log.Branch?.Name ?? "global").ToLower())">
                            <td class="px-10 py-6">
                                <div class="flex flex-col">
                                    <span class="font-black text-slate-900 text-sm tracking-tight">@log.CreatedAt.ToString("MMM dd, yyyy")</span>
                                    <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mt-0.5">@log.CreatedAt.ToString("HH:mm:ss")</span>
                                </div>
                            </td>
                            <td class="px-10 py-6">
                                <div class="flex items-center space-x-2">
                                    <div class="w-1.5 h-1.5 rounded-full bg-slate-300"></div>
                                    <span class="text-xs font-bold text-slate-600 uppercase tracking-wider">@(log.Branch?.Name ?? "GLOBAL")</span>
                                </div>
                            </td>
                            <td class="px-10 py-6 max-w-md">
                                <div class="flex flex-col space-y-1">
                                    <span class="px-3 py-1 @color text-white font-black text-[9px] uppercase tracking-widest rounded-lg w-fit">
                                        @categoryLabel
                                    </span>
                                    <p class="text-sm font-medium text-slate-600 line-clamp-2">@log.Description</p>
                                </div>
                            </td>
                            <td class="px-10 py-6">
                                <div class="flex flex-col">
                                    <span class="text-xs font-mono font-bold text-slate-500 tracking-tighter">192.168.1.102</span>
                                    <span class="text-[9px] font-black text-indigo-500 uppercase tracking-widest mt-1">Davao City, PH</span>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    function filterByType(type, el) {
        // Toggle Active Pill
        document.querySelectorAll('.filter-pill').forEach(p => p.classList.remove('active'));
        el.classList.add('active');

        // Filter Rows
        const rows = document.querySelectorAll('.log-row');
        rows.forEach(row => {
            if (type === 'ALL' || row.dataset.category === type) {
                row.style.display = '';
            } else {
                row.style.display = 'none';
            }
        });
    }

    function searchLogs() {
        const query = document.getElementById('log-search').value.toLowerCase();
        const activePill = document.querySelector('.filter-pill.active');
        const activeType = activePill.innerText.trim().toUpperCase() === "EVERYTHING" ? "ALL" : activePill.innerText.trim().toUpperCase();
        
        const rows = document.querySelectorAll('.log-row');
        rows.forEach(row => {
            const matchesSearch = row.dataset.search.includes(query);
            const matchesType = activeType === 'ALL' || row.dataset.category === activeType;
            
            if (matchesSearch && matchesType) {
                row.style.display = '';
            } else {
                row.style.display = 'none';
            }
        });
    }

    function exportCSV() {
        alert("Preparing Audit Export for Branch Node: @(isManager ? (currentUser?.Branch?.Name ?? "Assigned") : "GLOBAL")\nFormat: CSV (Standard Audit Format)");
    }
</script>
