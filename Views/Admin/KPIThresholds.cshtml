@model IEnumerable<coretex_finalproj.Models.BranchGoal>
@{
    ViewData["Title"] = "Strategic KPI Goals";
    Layout = "_AdminLayout";
}

<div class="space-y-8">
    <!-- Premium Header -->
    <div class="flex items-end justify-between bg-white p-10 rounded-[3rem] border border-slate-100 shadow-sm relative overflow-hidden">
        <div class="absolute right-0 top-0 w-64 h-64 bg-indigo-500/5 rounded-full -mr-32 -mt-32"></div>
        <div class="relative z-10">
            <div class="flex items-center gap-3 mb-2">
                <div class="w-2 h-2 bg-indigo-500 rounded-full animate-pulse"></div>
                <span class="text-[10px] font-black uppercase tracking-[0.2em] text-indigo-500">Decision Support System</span>
            </div>
            <h2 class="text-4xl font-black text-slate-900 tracking-tight">Strategic Goals & Targets</h2>
            <p class="text-slate-500 mt-2 font-medium">Define performance benchmarks to guide executive decision-making.</p>
        </div>
        <button onclick="openSetGoalModal()" class="relative z-10 px-8 py-4 bg-indigo-600 text-white font-black text-sm rounded-2xl hover:bg-indigo-700 transition-all flex items-center gap-3 shadow-xl shadow-indigo-100 group">
            <svg class="w-5 h-5 group-hover:rotate-12 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            <span>Set New Strategic Target</span>
        </button>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Main Goals Table -->
        <div class="lg:col-span-2 space-y-6">
            <div class="bg-white rounded-[2.5rem] shadow-sm border border-slate-100 overflow-hidden">
                <div class="p-8 border-b border-slate-50 flex items-center justify-between">
                    <h3 class="font-black text-slate-900 uppercase tracking-widest text-xs">Active Operational Targets</h3>
                    <div class="flex items-center gap-2">
                        <span class="w-2 h-2 rounded-full bg-emerald-400"></span>
                        <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Live: @DateTime.Now.ToString("MMMM yyyy")</span>
                    </div>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-slate-50/50">
                                <th class="px-8 py-5 text-[10px] font-black text-slate-400 uppercase tracking-widest">Assigned Branch</th>
                                <th class="px-8 py-5 text-[10px] font-black text-slate-400 uppercase tracking-widest">Revenue Benchmark</th>
                                <th class="px-8 py-5 text-[10px] font-black text-slate-400 uppercase tracking-widest text-center">Status</th>
                                <th class="px-8 py-5 text-[10px] font-black text-slate-400 uppercase tracking-widest text-right">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-50">
                            @if (!Model.Any())
                            {
                                <tr>
                                    <td colspan="4" class="p-20 text-center">
                                        <div class="flex flex-col items-center opacity-40">
                                            <svg class="w-12 h-12 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                                            <p class="font-bold text-sm uppercase tracking-widest">No Targets Defined</p>
                                        </div>
                                    </td>
                                </tr>
                            }
                            @foreach (var goal in Model)
                            {
                                <tr class="hover:bg-indigo-50/30 transition-colors group">
                                    <td class="px-8 py-6">
                                        <div class="flex items-center gap-4">
                                            <div class="w-12 h-12 bg-slate-900 rounded-2xl flex items-center justify-center text-white text-xs font-black shadow-lg shadow-slate-200 group-hover:scale-110 transition-transform">
                                                @goal.Branch?.Name.Substring(0,1).ToUpper()
                                            </div>
                                            <div>
                                                <p class="text-sm font-black text-slate-900">@goal.Branch?.Name</p>
                                                <p class="text-[10px] text-slate-400 font-bold uppercase tracking-tight">Standard Branch</p>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-8 py-6">
                                        <div class="flex flex-col">
                                            <span class="text-lg font-black text-slate-900 tracking-tighter">₱@goal.TargetRevenue.ToString("N0")</span>
                                            <span class="text-[9px] font-black text-indigo-500 uppercase tracking-widest">Monthly Quota</span>
                                        </div>
                                    </td>
                                    <td class="px-8 py-6 text-center">
                                        <span class="px-3 py-1 bg-indigo-50 text-indigo-600 text-[9px] font-black uppercase tracking-widest rounded-full border border-indigo-100">
                                            Active
                                        </span>
                                    </td>
                                    <td class="px-8 py-6">
                                        <div class="flex items-center justify-end gap-2">
                                            <button onclick="openEditGoalModal('@goal.Id', '@goal.BranchId', '@goal.TargetRevenue', '@goal.Month', '@goal.Year')" class="w-10 h-10 rounded-xl bg-slate-50 text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 flex items-center justify-center transition-all">
                                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
                                            </button>
                                            <form asp-action="DeleteGoal" asp-route-id="@goal.Id" method="post" class="inline">
                                                <button type="submit" class="w-10 h-10 rounded-xl bg-slate-50 text-slate-400 hover:text-rose-600 hover:bg-rose-50 flex items-center justify-center transition-all" onclick="return confirm('Archive this strategic target?')">
                                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Strategic Guidance Sidebar -->
        <div class="space-y-6">
            <div class="bg-indigo-600 rounded-[2.5rem] p-8 text-white shadow-xl shadow-indigo-100 relative overflow-hidden">
                <div class="absolute -right-8 -bottom-8 w-32 h-32 bg-white/10 rounded-full"></div>
                <h4 class="text-xl font-black mb-4 relative z-10">Why set targets?</h4>
                <p class="text-indigo-100 text-sm leading-relaxed mb-6 relative z-10 opacity-80 font-medium">Defined goals allow the system to calculate performance heatmaps for the CEO dashboard. Without targets, analytics remain "Static."</p>
                <div class="space-y-4 relative z-10">
                    <div class="flex items-center gap-3">
                        <div class="w-6 h-6 bg-white/20 rounded-lg flex items-center justify-center"><svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg></div>
                        <span class="text-xs font-black uppercase tracking-widest">Enables Pulse Charts</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <div class="w-6 h-6 bg-white/20 rounded-lg flex items-center justify-center"><svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg></div>
                        <span class="text-xs font-black uppercase tracking-widest">Drives Decision Support</span>
                    </div>
                </div>
            </div>

            <div class="bg-white rounded-[2.5rem] p-8 border border-slate-100 shadow-sm">
                <h4 class="text-xs font-black text-slate-400 uppercase tracking-widest mb-6">Historical Insight</h4>
                <div class="space-y-6">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-sm font-black text-slate-900">Average Growth Target</p>
                            <p class="text-[10px] text-slate-400 font-bold uppercase mt-0.5">Last 6 Months</p>
                        </div>
                        <span class="text-indigo-600 font-black">+12.5%</span>
                    </div>
                    <div class="w-full bg-slate-100 h-1.5 rounded-full overflow-hidden">
                        <div class="bg-indigo-500 h-full w-[65%]"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Premium Strategic Modal (Consistent with Provisioning Style) -->
<div id="goal-modal" class="fixed inset-0 bg-white/60 backdrop-blur-2xl z-50 hidden flex items-center justify-center p-4 transition-all duration-500">
    <div class="bg-white rounded-[3.5rem] p-12 w-full max-w-xl shadow-[0_32px_80px_-15px_rgba(0,0,0,0.2)] transform transition-all duration-500 scale-95 opacity-0" id="goal-modal-card">
        
        <div class="flex items-center gap-4 mb-10">
            <div class="w-14 h-14 bg-indigo-600 rounded-2xl flex items-center justify-center text-white shadow-lg shadow-indigo-100">
                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            </div>
            <div>
                <h3 class="text-2xl font-black text-slate-900 tracking-tight">Set Strategic Target</h3>
                <p class="text-[10px] text-slate-400 font-black uppercase tracking-[0.2em]">Decision Support Configuration</p>
            </div>
        </div>

        <form asp-action="SetGoal" method="post" class="space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="md:col-span-2">
                    <label class="block text-[10px] font-black uppercase tracking-widest text-slate-400 mb-2 ml-1">Select Target Branch</label>
                    <select name="branchId" required class="w-full px-6 py-4 bg-slate-50 border border-slate-200 rounded-2xl outline-none focus:ring-4 focus:ring-indigo-50 transition-all font-bold text-slate-900 appearance-none">
                        <option value="" disabled selected>-- Select Assignment --</option>
                        @if (ViewBag.Branches is List<Branch> kpiBranches)
                        {
                            foreach (var b in kpiBranches)
                            {
                                <option value="@b.Id">@b.Name</option>
                            }
                        }
                    </select>
                </div>

                <div class="md:col-span-2">
                    <label class="block text-[10px] font-black uppercase tracking-widest text-slate-400 mb-2 ml-1">Revenue Goal (PHP)</label>
                    <div class="relative">
                        <span class="absolute left-6 top-1/2 -translate-y-1/2 text-slate-400 font-black">₱</span>
                        <input name="targetRevenue" type="number" step="0.01" required 
                               class="w-full px-12 py-4 bg-slate-50 border border-slate-200 rounded-2xl focus:ring-4 focus:ring-indigo-50 outline-none transition-all font-black text-xl text-slate-900" 
                               placeholder="0.00" oninput="updateImpactPreview(this.value)" />
                    </div>
                </div>

                <div>
                    <label class="block text-[10px] font-black uppercase tracking-widest text-slate-400 mb-2 ml-1">Reporting Month</label>
                    <input name="month" type="number" value="@DateTime.Now.Month" class="w-full px-6 py-4 bg-slate-50 border border-slate-200 rounded-2xl font-bold focus:ring-4 focus:ring-indigo-50 transition-all outline-none" />
                </div>

                <div>
                    <label class="block text-[10px] font-black uppercase tracking-widest text-slate-400 mb-2 ml-1">Fiscal Year</label>
                    <input name="year" type="number" value="@DateTime.Now.Year" class="w-full px-6 py-4 bg-slate-50 border border-slate-200 rounded-2xl font-bold focus:ring-4 focus:ring-indigo-50 transition-all outline-none" />
                </div>
            </div>

            <!-- Mini Impact Tracker -->
            <div class="bg-indigo-50/50 rounded-3xl p-6 border border-indigo-100 mt-4">
                <div class="flex items-center justify-between mb-3">
                    <span class="text-[10px] font-black text-indigo-400 uppercase tracking-widest">Growth Vector</span>
                    <span id="intensity-label" class="text-[10px] font-black text-indigo-600 uppercase tracking-widest">Input Value...</span>
                </div>
                <div class="h-2 w-full bg-indigo-100/50 rounded-full overflow-hidden">
                    <div id="intensity-bar" class="bg-indigo-600 h-full w-0 transition-all duration-700"></div>
                </div>
            </div>

            <div class="flex gap-4 pt-6">
                <button type="button" onclick="closeSetGoalModal()" class="flex-1 py-4 bg-slate-100 text-slate-600 font-black rounded-2xl hover:bg-slate-200 transition-all">CANCEL</button>
                <button type="submit" class="flex-[2] py-4 bg-indigo-600 text-white font-black rounded-2xl shadow-xl shadow-indigo-100 hover:bg-indigo-700 transition-all">ACTIVATE TARGET</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function openSetGoalModal() { 
            const m = document.getElementById('goal-modal');
            const c = document.getElementById('goal-modal-card');
            m.classList.remove('hidden'); 
            setTimeout(() => { c.classList.remove('scale-95', 'opacity-0'); c.classList.add('scale-100', 'opacity-100'); }, 10);
        }
        function closeSetGoalModal() { 
            const m = document.getElementById('goal-modal');
            const c = document.getElementById('goal-modal-card');
            c.classList.remove('scale-100', 'opacity-100'); c.classList.add('scale-95', 'opacity-0');
            setTimeout(() => { m.classList.add('hidden'); }, 500);
        }

        function updateImpactPreview(val) {
            const bar = document.getElementById('intensity-bar');
            const label = document.getElementById('intensity-label');
            const num = parseFloat(val) || 0;
            
            let percentage = Math.min((num / 1000000) * 100, 100);
            bar.style.width = percentage + '%';
            
            if(num > 800000) label.innerText = "Aggressive Growth";
            else if(num > 400000) label.innerText = "Moderate Growth";
            else if(num > 0) label.innerText = "Baseline Stability";
            else label.innerText = "Input Value...";
        }

        function openEditGoalModal(id, branchId, revenue, month, year) {
            // Reusing logic for brevity, you can duplicate the create modal structure for edit
            alert("Strategic editing enabled for: ₱" + revenue);
        }
    </script>
}
