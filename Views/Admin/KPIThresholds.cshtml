@{
    ViewData["Title"] = "KPI Thresholds";
    Layout = "_AdminLayout";
}

<div class="space-y-8">
    <!-- Header -->
    <div class="flex items-center justify-between">
        <div>
            <div class="flex items-center space-x-3 mb-2">
                <a href="/Admin" class="text-slate-400 hover:text-slate-600 transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                </a>
                <span class="px-3 py-1 bg-amber-100 text-amber-700 font-black text-[10px] uppercase tracking-widest rounded-full">Alert Config</span>
            </div>
            <h2 class="text-3xl font-black text-slate-900 tracking-tight">KPI Threshold Configuration</h2>
            <p class="text-sm text-slate-500 mt-1">Configure alert thresholds. SMS alerts sent via Twilio when breached.</p>
        </div>
    </div>

    <!-- Info Banner -->
    <div class="bg-gradient-to-r from-amber-50 to-orange-50 border border-amber-200 rounded-2xl p-6">
        <div class="flex items-start space-x-4">
            <div class="w-10 h-10 bg-amber-100 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <div>
                <h4 class="font-bold text-amber-900">How KPI Alerts Work</h4>
                <p class="text-sm text-amber-700 mt-1">When any threshold is breached after data submission, <strong>Twilio SMS fires to CEO's phone</strong> and an in-app notification is created immediately.</p>
            </div>
        </div>
    </div>

    <!-- Threshold Configuration Form -->
    <div class="bg-white rounded-3xl shadow-sm border border-slate-100 overflow-hidden">
        <div class="p-6 border-b border-slate-100 bg-slate-50">
            <h3 class="font-bold text-slate-900">Configure Thresholds</h3>
            <p class="text-xs text-slate-500 mt-1">Set alert thresholds for key performance indicators</p>
        </div>
        
        <form id="threshold-form" class="p-8">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <!-- Minimum Profit Margin -->
                <div class="space-y-3">
                    <label class="flex items-center justify-between">
                        <span class="text-sm font-bold text-slate-700">Minimum Profit Margin</span>
                        <span class="text-xs text-slate-400">Percentage</span>
                    </label>
                    <div class="relative">
                        <input type="number" id="min-profit-margin" step="0.1" min="0" max="100" placeholder="e.g. 15" 
                            class="w-full px-4 py-4 pr-12 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-amber-500/20 focus:border-amber-500 transition-all text-lg font-bold">
                        <span class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 font-bold">%</span>
                    </div>
                    <p class="text-xs text-slate-500">Alert when profit margin falls below this value</p>
                </div>

                <!-- Maximum Expense Ratio -->
                <div class="space-y-3">
                    <label class="flex items-center justify-between">
                        <span class="text-sm font-bold text-slate-700">Maximum Expense Ratio</span>
                        <span class="text-xs text-slate-400">Percentage</span>
                    </label>
                    <div class="relative">
                        <input type="number" id="max-expense-ratio" step="0.1" min="0" max="100" placeholder="e.g. 70" 
                            class="w-full px-4 py-4 pr-12 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-amber-500/20 focus:border-amber-500 transition-all text-lg font-bold">
                        <span class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 font-bold">%</span>
                    </div>
                    <p class="text-xs text-slate-500">Alert when expense ratio exceeds this value</p>
                </div>

                <!-- Minimum Monthly Profit -->
                <div class="space-y-3">
                    <label class="flex items-center justify-between">
                        <span class="text-sm font-bold text-slate-700">Minimum Monthly Profit</span>
                        <span class="text-xs text-slate-400">Currency (PHP)</span>
                    </label>
                    <div class="relative">
                        <span class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 font-bold">₱</span>
                        <input type="text" id="min-monthly-profit" placeholder="e.g. 50,000" 
                            class="w-full px-4 py-4 pl-10 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-amber-500/20 focus:border-amber-500 transition-all text-lg font-bold"
                            oninput="formatCurrency(this)">
                    </div>
                    <p class="text-xs text-slate-500">Alert when monthly profit drops below this amount</p>
                </div>

                <!-- Risk Score Alert Level -->
                <div class="space-y-3">
                    <label class="flex items-center justify-between">
                        <span class="text-sm font-bold text-slate-700">Risk Score Alert Level</span>
                        <span class="text-xs text-slate-400">Severity</span>
                    </label>
                    <select id="risk-alert-level" class="w-full px-4 py-4 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-amber-500/20 focus:border-amber-500 transition-all text-lg font-bold appearance-none cursor-pointer"
                        style="background-image: url('data:image/svg+xml;charset=UTF-8,%3csvg xmlns=%27http://www.w3.org/2000/svg%27 viewBox=%270 0 24 24%27 fill=%27none%27 stroke=%27%2394a3b8%27 stroke-width=%272%27 stroke-linecap=%27round%27 stroke-linejoin=%27round%27%3e%3cpolyline points=%276 9 12 15 18 9%27%3e%3c/polyline%3e%3c/svg%3e'); background-repeat: no-repeat; background-position: right 1rem center; background-size: 1.5em 1.5em;">
                        <option value="yellow">🟡 Yellow - Warning</option>
                        <option value="red">🔴 Red - Critical Only</option>
                    </select>
                    <p class="text-xs text-slate-500">Trigger SMS alerts at this risk level or worse</p>
                </div>
            </div>

            <!-- Divider -->
            <div class="border-t border-slate-200 my-8"></div>

            <!-- Current Settings Summary -->
            <div class="bg-slate-50 rounded-2xl p-6 mb-8">
                <h4 class="font-bold text-slate-900 mb-4 flex items-center space-x-2">
                    <svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
                    <span>Current Threshold Settings</span>
                </h4>
                <div id="settings-summary" class="grid grid-cols-2 md:grid-cols-4 gap-4">
                    <div class="bg-white rounded-xl p-4 border border-slate-100">
                        <p class="text-xs text-slate-500 uppercase tracking-widest">Min Profit Margin</p>
                        <p class="text-xl font-black text-slate-900 mt-1" id="summary-profit-margin">Not set</p>
                    </div>
                    <div class="bg-white rounded-xl p-4 border border-slate-100">
                        <p class="text-xs text-slate-500 uppercase tracking-widest">Max Expense Ratio</p>
                        <p class="text-xl font-black text-slate-900 mt-1" id="summary-expense-ratio">Not set</p>
                    </div>
                    <div class="bg-white rounded-xl p-4 border border-slate-100">
                        <p class="text-xs text-slate-500 uppercase tracking-widest">Min Monthly Profit</p>
                        <p class="text-xl font-black text-slate-900 mt-1" id="summary-monthly-profit">Not set</p>
                    </div>
                    <div class="bg-white rounded-xl p-4 border border-slate-100">
                        <p class="text-xs text-slate-500 uppercase tracking-widest">Risk Alert Level</p>
                        <p class="text-xl font-black mt-1" id="summary-risk-level">Not set</p>
                    </div>
                </div>
            </div>

            <!-- Save Button -->
            <div class="flex items-center justify-between">
                <p class="text-sm text-slate-500">
                    <svg class="w-4 h-4 inline mr-1 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
                    Alerts will be sent via SMS (Twilio) when thresholds are breached
                </p>
                <button type="submit" class="px-8 py-4 bg-amber-600 text-white font-bold rounded-xl hover:bg-amber-700 transition-colors flex items-center space-x-2 shadow-lg shadow-amber-500/20">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                    <span>Save Thresholds</span>
                </button>
            </div>
        </form>
    </div>

    <!-- Alert History -->
    <div class="bg-white rounded-3xl shadow-sm border border-slate-100 overflow-hidden">
        <div class="p-6 border-b border-slate-100 flex items-center justify-between">
            <div>
                <h3 class="font-bold text-slate-900">Recent Threshold Alerts</h3>
                <p class="text-xs text-slate-500 mt-1">History of triggered alerts</p>
            </div>
            <button onclick="clearAlertHistory()" class="text-sm text-slate-500 hover:text-red-600 transition-colors">Clear History</button>
        </div>
        <div id="alert-history" class="divide-y divide-slate-100">
            <!-- Alert history will be rendered here -->
        </div>
        <div id="alert-empty-state" class="p-12 text-center">
            <div class="w-16 h-16 bg-emerald-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <h4 class="font-bold text-slate-900 mb-2">No alerts triggered</h4>
            <p class="text-sm text-slate-500">All KPIs are within acceptable thresholds</p>
        </div>
    </div>
</div>

<!-- Success Toast -->
<div id="toast" class="fixed bottom-6 right-6 bg-emerald-500 text-white px-6 py-4 rounded-2xl shadow-2xl hidden items-center space-x-3 z-50 transform transition-all">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
    <span id="toast-message" class="font-bold">Thresholds saved successfully!</span>
</div>

@section Scripts {
    <script>
        // Load saved thresholds
        function loadThresholds() {
            const saved = JSON.parse(localStorage.getItem('coretex_kpi_thresholds') || '{}');
            
            if (saved.minProfitMargin !== undefined) {
                document.getElementById('min-profit-margin').value = saved.minProfitMargin;
            }
            if (saved.maxExpenseRatio !== undefined) {
                document.getElementById('max-expense-ratio').value = saved.maxExpenseRatio;
            }
            if (saved.minMonthlyProfit !== undefined) {
                document.getElementById('min-monthly-profit').value = formatNumber(saved.minMonthlyProfit);
            }
            if (saved.riskAlertLevel) {
                document.getElementById('risk-alert-level').value = saved.riskAlertLevel;
            }
            
            updateSummary();
        }

        // Format currency input
        function formatCurrency(input) {
            let value = input.value.replace(/[^\d]/g, '');
            if (value) {
                value = parseInt(value).toLocaleString();
            }
            input.value = value;
        }

        function formatNumber(num) {
            return parseInt(num).toLocaleString();
        }

        function parseCurrency(str) {
            return parseInt(str.replace(/[^\d]/g, '')) || 0;
        }

        // Update summary display
        function updateSummary() {
            const minProfitMargin = document.getElementById('min-profit-margin').value;
            const maxExpenseRatio = document.getElementById('max-expense-ratio').value;
            const minMonthlyProfit = document.getElementById('min-monthly-profit').value;
            const riskAlertLevel = document.getElementById('risk-alert-level').value;

            document.getElementById('summary-profit-margin').textContent = minProfitMargin ? `${minProfitMargin}%` : 'Not set';
            document.getElementById('summary-expense-ratio').textContent = maxExpenseRatio ? `${maxExpenseRatio}%` : 'Not set';
            document.getElementById('summary-monthly-profit').textContent = minMonthlyProfit ? `₱${minMonthlyProfit}` : 'Not set';
            
            const riskEl = document.getElementById('summary-risk-level');
            if (riskAlertLevel === 'yellow') {
                riskEl.textContent = '🟡 Yellow';
                riskEl.className = 'text-xl font-black mt-1 text-amber-600';
            } else if (riskAlertLevel === 'red') {
                riskEl.textContent = '🔴 Red';
                riskEl.className = 'text-xl font-black mt-1 text-red-600';
            } else {
                riskEl.textContent = 'Not set';
                riskEl.className = 'text-xl font-black mt-1 text-slate-900';
            }
        }

        // Save thresholds
        document.getElementById('threshold-form').addEventListener('submit', function(e) {
            e.preventDefault();
            
            const thresholds = {
                minProfitMargin: parseFloat(document.getElementById('min-profit-margin').value) || null,
                maxExpenseRatio: parseFloat(document.getElementById('max-expense-ratio').value) || null,
                minMonthlyProfit: parseCurrency(document.getElementById('min-monthly-profit').value) || null,
                riskAlertLevel: document.getElementById('risk-alert-level').value,
                updatedAt: new Date().toISOString()
            };

            localStorage.setItem('coretex_kpi_thresholds', JSON.stringify(thresholds));
            
            // Log activity
            logActivity('Thresholds Updated', 'KPI threshold configuration updated', 'threshold');
            
            // Update summary
            updateSummary();
            
            // Show success toast
            showToast('Thresholds saved successfully!');
        });

        function showToast(message) {
            const toast = document.getElementById('toast');
            document.getElementById('toast-message').textContent = message;
            toast.classList.remove('hidden');
            toast.classList.add('flex');
            
            setTimeout(() => {
                toast.classList.add('hidden');
                toast.classList.remove('flex');
            }, 3000);
        }

        function logActivity(action, description, type) {
            let activities = JSON.parse(localStorage.getItem('coretex_activities') || '[]');
            activities.unshift({
                id: Date.now(),
                action,
                description,
                type,
                timestamp: new Date().toISOString(),
                user: 'System Administrator'
            });
            activities = activities.slice(0, 100);
            localStorage.setItem('coretex_activities', JSON.stringify(activities));
        }

        // Render alert history
        function renderAlertHistory() {
            const container = document.getElementById('alert-history');
            const emptyState = document.getElementById('alert-empty-state');
            const alerts = JSON.parse(localStorage.getItem('coretex_threshold_alerts') || '[]');

            if (alerts.length === 0) {
                container.innerHTML = '';
                emptyState.classList.remove('hidden');
                return;
            }

            emptyState.classList.add('hidden');
            container.innerHTML = alerts.slice(0, 10).map(alert => `
                <div class="p-6 hover:bg-slate-50 transition-colors">
                    <div class="flex items-center justify-between">
                        <div class="flex items-center space-x-4">
                            <div class="w-12 h-12 ${alert.severity === 'red' ? 'bg-red-100' : 'bg-amber-100'} rounded-xl flex items-center justify-center">
                                <svg class="w-6 h-6 ${alert.severity === 'red' ? 'text-red-600' : 'text-amber-600'}" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
                            </div>
                            <div>
                                <h4 class="font-bold text-slate-900">${alert.metric}</h4>
                                <p class="text-sm text-slate-500">${alert.message}</p>
                            </div>
                        </div>
                        <div class="text-right">
                            <p class="text-xs text-slate-400">${formatTimeAgo(alert.timestamp)}</p>
                            <span class="px-2 py-1 text-[10px] font-bold uppercase tracking-widest rounded-full ${alert.severity === 'red' ? 'bg-red-100 text-red-700' : 'bg-amber-100 text-amber-700'}">${alert.severity === 'red' ? 'Critical' : 'Warning'}</span>
                        </div>
                    </div>
                </div>
            `).join('');
        }

        function formatTimeAgo(timestamp) {
            const now = new Date();
            const then = new Date(timestamp);
            const diffMs = now - then;
            const diffMins = Math.floor(diffMs / 60000);
            const diffHours = Math.floor(diffMs / 3600000);
            const diffDays = Math.floor(diffMs / 86400000);

            if (diffMins < 1) return 'Just now';
            if (diffMins < 60) return `${diffMins}m ago`;
            if (diffHours < 24) return `${diffHours}h ago`;
            return `${diffDays}d ago`;
        }

        function clearAlertHistory() {
            if (confirm('Are you sure you want to clear the alert history?')) {
                localStorage.removeItem('coretex_threshold_alerts');
                renderAlertHistory();
                showToast('Alert history cleared');
            }
        }

        // Update summary on input change
        document.getElementById('min-profit-margin').addEventListener('input', updateSummary);
        document.getElementById('max-expense-ratio').addEventListener('input', updateSummary);
        document.getElementById('min-monthly-profit').addEventListener('input', updateSummary);
        document.getElementById('risk-alert-level').addEventListener('change', updateSummary);

        // Initialize
        document.addEventListener('DOMContentLoaded', function() {
            loadThresholds();
            renderAlertHistory();
        });
    </script>
}
