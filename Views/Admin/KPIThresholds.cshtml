@using Microsoft.AspNetCore.Identity
@inject UserManager<AppUser> UserManager
@{
    ViewData["Title"] = "KPI Thresholds";
    Layout = "_AdminLayout";
    var currentUser = await UserManager.GetUserAsync(User);
    var isCEO = User.IsInRole("CEO");
    var isManager = User.IsInRole("BRANCH_ADMIN");
    var canEdit = isCEO; // Only the CEO has the keys to the business strategy
}

<div class="space-y-8 pb-20">
    <!-- Premium Header -->
    <div class="relative overflow-hidden bg-slate-900 rounded-[2.5rem] p-10 text-white shadow-2xl">
        <div class="relative z-10 flex items-center justify-between">
            <div>
                <div class="flex items-center space-x-3 mb-4">
                    <a href="/Admin" class="w-8 h-8 flex items-center justify-center bg-white/10 hover:bg-white/20 rounded-full transition-all">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M15 19l-7-7 7-7"/></svg>
                    </a>
                    <span class="px-3 py-1 bg-amber-500/20 text-amber-300 font-black text-[10px] uppercase tracking-widest rounded-full border border-amber-500/30">Intelligence Guard</span>
                </div>
                <h2 class="text-4xl font-black tracking-tight">Performance Thresholds</h2>
                <p class="text-slate-400 mt-2 text-sm font-medium">
                    @(isCEO ? "Executive control panel for global operational safety limits." : $"Monitoring thresholds for {currentUser?.Branch?.Name ?? "Davao HQ"}.")
                </p>
            </div>
            @if (!canEdit) {
                <div class="px-6 py-3 bg-amber-500/10 border border-amber-500/30 rounded-2xl flex items-center space-x-3">
                    <div class="w-2 h-2 rounded-full bg-amber-500 animate-pulse"></div>
                    <span class="text-[10px] font-black text-amber-500 uppercase tracking-widest">Executive Read-Only</span>
                </div>
            }
        </div>
        <!-- Decorative Background Elements -->
        <div class="absolute top-0 right-0 -mr-20 -mt-20 w-80 h-80 bg-amber-500/10 rounded-full blur-3xl"></div>
    </div>

    <!-- Info Banner (Only for CEO) -->
    @if (isCEO) {
        <div class="bg-gradient-to-r from-indigo-500 to-indigo-700 rounded-[2rem] p-8 text-white shadow-xl">
            <div class="flex items-start space-x-6">
                <div class="w-14 h-14 bg-white/10 rounded-2xl flex items-center justify-center flex-shrink-0 backdrop-blur-sm border border-white/20">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z"/></svg>
                </div>
                <div>
                    <h4 class="text-xl font-black uppercase tracking-tight">Executive Dashboard Control</h4>
                    <p class="text-indigo-100 mt-1 font-medium">As the **Chief Executive Officer**, your thresholds here define the "Red Zone." If breached, secure SMS alerts will be routed to your device.</p>
                </div>
            </div>
        </div>
    }

    <!-- Threshold Configuration Grid -->
    <div class="bg-white rounded-[2.5rem] border border-slate-100 shadow-sm overflow-hidden @(!canEdit ? "opacity-75" : "")">
        <div class="p-10 border-b border-slate-50 bg-slate-50/30">
            <h3 class="text-xl font-black text-slate-900 tracking-tight">Threshold Definition</h3>
            <p class="text-xs text-slate-400 font-bold uppercase mt-1 tracking-widest">@(!canEdit ? "Executive Safety Targets" : "Configure intelligence triggers")</p>
        </div>
        
        <form id="threshold-form" class="p-10">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
                <!-- Minimum Profit Margin -->
                <div class="space-y-4">
                    <label class="flex items-center justify-between">
                        <span class="text-xs font-black text-slate-400 uppercase tracking-widest">Min Profit Margin</span>
                        <span class="px-2 py-1 bg-slate-100 text-[10px] font-black text-slate-500 rounded-lg">PERCENTAGE</span>
                    </label>
                    <div class="relative group">
                        <input type="number" id="min-profit-margin" step="0.1" min="0" max="100" placeholder="e.g. 15" @(!canEdit ? "disabled" : "")
                            class="w-full px-6 py-5 pr-14 bg-slate-50 border border-slate-200 rounded-2xl focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 transition-all text-2xl font-black text-slate-900 @(!canEdit ? "cursor-not-allowed" : "")">
                        <span class="absolute right-6 top-1/2 -translate-y-1/2 text-slate-300 font-black text-xl">%</span>
                    </div>
                    <p class="text-[10px] text-slate-400 font-bold uppercase tracking-tight">Alert CEO if margin falls below this level</p>
                </div>

                <!-- Maximum Expense Ratio -->
                <div class="space-y-4">
                    <label class="flex items-center justify-between">
                        <span class="text-xs font-black text-slate-400 uppercase tracking-widest">Max Expense Ratio</span>
                        <span class="px-2 py-1 bg-slate-100 text-[10px] font-black text-slate-500 rounded-lg">PERCENTAGE</span>
                    </label>
                    <div class="relative group">
                        <input type="number" id="max-expense-ratio" step="0.1" min="0" max="100" placeholder="e.g. 70" @(!canEdit ? "disabled" : "")
                            class="w-full px-6 py-5 pr-14 bg-slate-50 border border-slate-200 rounded-2xl focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 transition-all text-2xl font-black text-slate-900 @(!canEdit ? "cursor-not-allowed" : "")">
                        <span class="absolute right-6 top-1/2 -translate-y-1/2 text-slate-300 font-black text-xl">%</span>
                    </div>
                    <p class="text-[10px] text-slate-400 font-bold uppercase tracking-tight">Alert CEO if expenses exceed this ratio</p>
                </div>

                <!-- Minimum Monthly Profit -->
                <div class="space-y-4">
                    <label class="flex items-center justify-between">
                        <span class="text-xs font-black text-slate-400 uppercase tracking-widest">Min Monthly Profit</span>
                        <span class="px-2 py-1 bg-slate-100 text-[10px] font-black text-slate-500 rounded-lg">PHP CURRENCY</span>
                    </label>
                    <div class="relative group">
                        <span class="absolute left-6 top-1/2 -translate-y-1/2 text-slate-300 font-black text-xl">₱</span>
                        <input type="text" id="min-monthly-profit" placeholder="e.g. 50,000" @(!canEdit ? "disabled" : "")
                            class="w-full px-6 py-5 pl-12 bg-slate-50 border border-slate-200 rounded-2xl focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 transition-all text-2xl font-black text-slate-900 @(!canEdit ? "cursor-not-allowed" : "")"
                            oninput="formatCurrency(this)">
                    </div>
                    <p class="text-[10px] text-slate-400 font-bold uppercase tracking-tight">Critical warning if net profit is below this amount</p>
                </div>

                <!-- Risk Score Alert Level -->
                <div class="space-y-4">
                    <label class="flex items-center justify-between">
                        <span class="text-xs font-black text-slate-400 uppercase tracking-widest">Intelligence Alert Level</span>
                        <span class="px-2 py-1 bg-slate-100 text-[10px] font-black text-slate-500 rounded-lg">SEVERITY</span>
                    </label>
                    <select id="risk-alert-level" @(!canEdit ? "disabled" : "")
                        class="w-full px-6 py-5 bg-slate-50 border border-slate-200 rounded-2xl focus:ring-4 focus:ring-indigo-500/10 focus:border-indigo-500 transition-all text-xl font-black text-slate-900 appearance-none @(!canEdit ? "cursor-not-allowed" : "")">
                        <option value="yellow">🟡 Low Threshold Warning</option>
                        <option value="red">🔴 High Priority Critical Only</option>
                    </select>
                </div>
            </div>

            @if (canEdit) {
                <div class="mt-12 pt-10 border-t border-slate-100 flex items-center justify-between">
                    <p class="text-xs font-bold text-slate-400 uppercase tracking-widest flex items-center">
                        <svg class="w-4 h-4 mr-2 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        Encryption enabled for automated SMS triggers
                    </p>
                    <button type="submit" class="px-10 py-5 bg-slate-900 text-white font-black text-sm uppercase tracking-widest rounded-2xl hover:bg-slate-800 transition-all shadow-2xl shadow-slate-900/20 flex items-center space-x-3">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                        <span>Commit Thresholds</span>
                    </button>
                </div>
            }
        </form>
    </div>

    <!-- Alert History -->
    <div class="bg-white rounded-3xl shadow-sm border border-slate-100 overflow-hidden">
        <div class="p-6 border-b border-slate-100 flex items-center justify-between">
            <div>
                <h3 class="font-bold text-slate-900">Recent Threshold Alerts</h3>
                <p class="text-xs text-slate-500 mt-1">History of triggered alerts</p>
            </div>
            <button onclick="clearAlertHistory()" class="text-sm text-slate-500 hover:text-red-600 transition-colors">Clear History</button>
        </div>
        <div id="alert-history" class="divide-y divide-slate-100">
            <!-- Alert history will be rendered here -->
        </div>
        <div id="alert-empty-state" class="p-12 text-center">
            <div class="w-16 h-16 bg-emerald-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <h4 class="font-bold text-slate-900 mb-2">No alerts triggered</h4>
            <p class="text-sm text-slate-500">All KPIs are within acceptable thresholds</p>
        </div>
    </div>
</div>

<!-- Success Toast -->
<div id="toast" class="fixed bottom-6 right-6 bg-emerald-500 text-white px-6 py-4 rounded-2xl shadow-2xl hidden items-center space-x-3 z-50 transform transition-all">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
    <span id="toast-message" class="font-bold">Thresholds saved successfully!</span>
</div>

@section Scripts {
    <script>
        // Load saved thresholds
        function loadThresholds() {
            const saved = JSON.parse(localStorage.getItem('coretex_kpi_thresholds') || '{}');
            
            if (saved.minProfitMargin !== undefined) {
                document.getElementById('min-profit-margin').value = saved.minProfitMargin;
            }
            if (saved.maxExpenseRatio !== undefined) {
                document.getElementById('max-expense-ratio').value = saved.maxExpenseRatio;
            }
            if (saved.minMonthlyProfit !== undefined) {
                document.getElementById('min-monthly-profit').value = formatNumber(saved.minMonthlyProfit);
            }
            if (saved.riskAlertLevel) {
                document.getElementById('risk-alert-level').value = saved.riskAlertLevel;
            }
            
            updateSummary();
        }

        // Format currency input
        function formatCurrency(input) {
            let value = input.value.replace(/[^\d]/g, '');
            if (value) {
                value = parseInt(value).toLocaleString();
            }
            input.value = value;
        }

        function formatNumber(num) {
            return parseInt(num).toLocaleString();
        }

        function parseCurrency(str) {
            return parseInt(str.replace(/[^\d]/g, '')) || 0;
        }

        // Update summary display
        function updateSummary() {
            const minProfitMargin = document.getElementById('min-profit-margin').value;
            const maxExpenseRatio = document.getElementById('max-expense-ratio').value;
            const minMonthlyProfit = document.getElementById('min-monthly-profit').value;
            const riskAlertLevel = document.getElementById('risk-alert-level').value;

            document.getElementById('summary-profit-margin').textContent = minProfitMargin ? `${minProfitMargin}%` : 'Not set';
            document.getElementById('summary-expense-ratio').textContent = maxExpenseRatio ? `${maxExpenseRatio}%` : 'Not set';
            document.getElementById('summary-monthly-profit').textContent = minMonthlyProfit ? `₱${minMonthlyProfit}` : 'Not set';
            
            const riskEl = document.getElementById('summary-risk-level');
            if (riskAlertLevel === 'yellow') {
                riskEl.textContent = '🟡 Yellow';
                riskEl.className = 'text-xl font-black mt-1 text-amber-600';
            } else if (riskAlertLevel === 'red') {
                riskEl.textContent = '🔴 Red';
                riskEl.className = 'text-xl font-black mt-1 text-red-600';
            } else {
                riskEl.textContent = 'Not set';
                riskEl.className = 'text-xl font-black mt-1 text-slate-900';
            }
        }

        // Save thresholds
        document.getElementById('threshold-form').addEventListener('submit', function(e) {
            e.preventDefault();
            
            const thresholds = {
                minProfitMargin: parseFloat(document.getElementById('min-profit-margin').value) || null,
                maxExpenseRatio: parseFloat(document.getElementById('max-expense-ratio').value) || null,
                minMonthlyProfit: parseCurrency(document.getElementById('min-monthly-profit').value) || null,
                riskAlertLevel: document.getElementById('risk-alert-level').value,
                updatedAt: new Date().toISOString()
            };

            localStorage.setItem('coretex_kpi_thresholds', JSON.stringify(thresholds));
            
            // Log activity
            logActivity('Thresholds Updated', 'KPI threshold configuration updated', 'threshold');
            
            // Update summary
            updateSummary();
            
            // Show success toast
            showToast('Thresholds saved successfully!');
        });

        function showToast(message) {
            const toast = document.getElementById('toast');
            document.getElementById('toast-message').textContent = message;
            toast.classList.remove('hidden');
            toast.classList.add('flex');
            
            setTimeout(() => {
                toast.classList.add('hidden');
                toast.classList.remove('flex');
            }, 3000);
        }

        function logActivity(action, description, type) {
            let activities = JSON.parse(localStorage.getItem('coretex_activities') || '[]');
            activities.unshift({
                id: Date.now(),
                action,
                description,
                type,
                timestamp: new Date().toISOString(),
                user: 'System Administrator'
            });
            activities = activities.slice(0, 100);
            localStorage.setItem('coretex_activities', JSON.stringify(activities));
        }

        // Render alert history
        function renderAlertHistory() {
            const container = document.getElementById('alert-history');
            const emptyState = document.getElementById('alert-empty-state');
            const alerts = JSON.parse(localStorage.getItem('coretex_threshold_alerts') || '[]');

            if (alerts.length === 0) {
                container.innerHTML = '';
                emptyState.classList.remove('hidden');
                return;
            }

            emptyState.classList.add('hidden');
            container.innerHTML = alerts.slice(0, 10).map(alert => `
                <div class="p-6 hover:bg-slate-50 transition-colors">
                    <div class="flex items-center justify-between">
                        <div class="flex items-center space-x-4">
                            <div class="w-12 h-12 ${alert.severity === 'red' ? 'bg-red-100' : 'bg-amber-100'} rounded-xl flex items-center justify-center">
                                <svg class="w-6 h-6 ${alert.severity === 'red' ? 'text-red-600' : 'text-amber-600'}" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
                            </div>
                            <div>
                                <h4 class="font-bold text-slate-900">${alert.metric}</h4>
                                <p class="text-sm text-slate-500">${alert.message}</p>
                            </div>
                        </div>
                        <div class="text-right">
                            <p class="text-xs text-slate-400">${formatTimeAgo(alert.timestamp)}</p>
                            <span class="px-2 py-1 text-[10px] font-bold uppercase tracking-widest rounded-full ${alert.severity === 'red' ? 'bg-red-100 text-red-700' : 'bg-amber-100 text-amber-700'}">${alert.severity === 'red' ? 'Critical' : 'Warning'}</span>
                        </div>
                    </div>
                </div>
            `).join('');
        }

        function formatTimeAgo(timestamp) {
            const now = new Date();
            const then = new Date(timestamp);
            const diffMs = now - then;
            const diffMins = Math.floor(diffMs / 60000);
            const diffHours = Math.floor(diffMs / 3600000);
            const diffDays = Math.floor(diffMs / 86400000);

            if (diffMins < 1) return 'Just now';
            if (diffMins < 60) return `${diffMins}m ago`;
            if (diffHours < 24) return `${diffHours}h ago`;
            return `${diffDays}d ago`;
        }

        function clearAlertHistory() {
            if (confirm('Are you sure you want to clear the alert history?')) {
                localStorage.removeItem('coretex_threshold_alerts');
                renderAlertHistory();
                showToast('Alert history cleared');
            }
        }

        // Update summary on input change
        document.getElementById('min-profit-margin').addEventListener('input', updateSummary);
        document.getElementById('max-expense-ratio').addEventListener('input', updateSummary);
        document.getElementById('min-monthly-profit').addEventListener('input', updateSummary);
        document.getElementById('risk-alert-level').addEventListener('change', updateSummary);

        // Initialize
        document.addEventListener('DOMContentLoaded', function() {
            loadThresholds();
            renderAlertHistory();
        });
    </script>
}
