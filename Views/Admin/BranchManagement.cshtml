@model IEnumerable<coretex_finalproj.Models.Branch>
@{
    ViewData["Title"] = "Branch Management";
    Layout = "_AdminLayout";
}

<div class="space-y-8">
    <!-- Header -->
    <div class="flex items-center justify-between">
        <div>
            <div class="flex items-center space-x-3 mb-2">
                <a href="/Admin" class="text-slate-400 hover:text-slate-600 transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                </a>
                <span class="px-3 py-1 bg-indigo-100 text-indigo-700 font-black text-[10px] uppercase tracking-widest rounded-full">System Configuration</span>
            </div>
            <h2 class="text-3xl font-black text-slate-900 tracking-tight">Branch Management</h2>
            <p class="text-sm text-slate-500 mt-1">Real-time control center for @Model.Count() branches</p>
        </div>
        <button onclick="openAddModal()" class="px-6 py-3 bg-indigo-600 text-white font-bold text-sm rounded-xl hover:bg-indigo-700 hover:scale-105 transition-all flex items-center space-x-2 shadow-lg shadow-indigo-100">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            <span>Add New Branch</span>
        </button>
    </div>

    <!-- Branch Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        @foreach (var branch in Model)
        {
            <div class="bg-white rounded-3xl p-6 shadow-sm border border-slate-100 border-b-4 @(branch.IsActive ? "border-b-emerald-400" : "border-b-slate-300") hover:shadow-xl transition-all group">
                <div class="flex items-start justify-between mb-4">
                    <div class="w-12 h-12 @(branch.IsActive ? "bg-indigo-50 text-indigo-600" : "bg-slate-50 text-slate-400") rounded-2xl flex items-center justify-center font-black text-lg group-hover:scale-110 transition-transform">
                        @branch.BranchCode.Substring(0, Math.Min(2, branch.BranchCode.Length)).ToUpper()
                    </div>
                    <div class="flex gap-2">
                         <form asp-action="ToggleBranchStatus" asp-route-id="@branch.Id" method="post" class="inline">
                            <button type="submit" class="w-8 h-8 rounded-lg @(branch.IsActive ? "bg-emerald-50 text-emerald-600" : "bg-amber-50 text-amber-600") flex items-center justify-center hover:scale-110 transition-all" title="Toggle Active">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                            </button>
                        </form>
                        <form asp-action="ArchiveBranch" asp-route-id="@branch.Id" method="post" class="inline">
                            <button type="submit" class="w-8 h-8 bg-slate-100 text-slate-600 rounded-lg flex items-center justify-center hover:bg-slate-200 hover:scale-110 transition-all" title="Archive Branch">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" /></svg>
                            </button>
                        </form>
                    </div>
                </div>
                <h4 class="text-xl font-black text-slate-900 group-hover:text-indigo-600 transition-colors">@branch.Name</h4>
                <div class="mt-3 space-y-2">
                    <p class="text-xs text-slate-500 flex items-center gap-2 font-bold tracking-tight">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                        @branch.Address
                    </p>
                    <p class="text-[10px] font-black uppercase tracking-widest text-slate-400">Code: @branch.BranchCode</p>
                </div>
            </div>
        }
    </div>
</div>

<!-- Simple Add Modal -->
<div id="add-modal" class="fixed inset-0 bg-white/60 backdrop-blur-2xl z-50 hidden flex items-center justify-center p-4 transition-all duration-500">
    <div class="bg-white rounded-[3.5rem] p-12 w-full max-w-md shadow-[0_32px_80px_-15px_rgba(0,0,0,0.2)] transform transition-all duration-500 scale-95 opacity-0" id="add-modal-card">
        <h3 class="text-2xl font-black text-slate-900 mb-6">Create Branch</h3>
        <form asp-action="CreateBranch" method="post" class="space-y-4">
            <div>
                <label class="block text-xs font-black uppercase tracking-widest text-slate-500 mb-2">Name</label>
                <input name="Name" required class="w-full px-5 py-3 bg-slate-50 border border-slate-200 rounded-2xl focus:ring-4 focus:ring-indigo-100 outline-none transition-all" placeholder="e.g. Davao Main" />
            </div>
            <div>
                <label class="block text-xs font-black uppercase tracking-widest text-slate-500 mb-2">Branch Code</label>
                <input name="BranchCode" required maxlength="10" class="w-full px-5 py-3 bg-slate-50 border border-slate-200 rounded-2xl focus:ring-4 focus:ring-indigo-100 outline-none transition-all" placeholder="e.g. DVO-01" />
            </div>
            <div>
                <label class="block text-xs font-black uppercase tracking-widest text-slate-500 mb-2">Address</label>
                <input name="Address" required class="w-full px-5 py-3 bg-slate-50 border border-slate-200 rounded-2xl focus:ring-4 focus:ring-indigo-100 outline-none transition-all" placeholder="City, Region" />
            </div>
            <div class="flex gap-3 pt-4">
                <button type="button" onclick="closeAddModal()" class="flex-1 py-3 bg-slate-100 text-slate-600 font-bold rounded-xl">Cancel</button>
                <button type="submit" class="flex-1 py-3 bg-indigo-600 text-white font-bold rounded-xl shadow-lg shadow-indigo-100 hover:bg-indigo-700 transition-all">Create Now</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function openAddModal() { 
            const m = document.getElementById('add-modal');
            const c = document.getElementById('add-modal-card');
            m.classList.remove('hidden'); 
            setTimeout(() => { c.classList.remove('scale-95', 'opacity-0'); c.classList.add('scale-100', 'opacity-100'); }, 10);
        }
        function closeAddModal() { 
            const m = document.getElementById('add-modal');
            const c = document.getElementById('add-modal-card');
            c.classList.remove('scale-100', 'opacity-100'); c.classList.add('scale-95', 'opacity-0');
            setTimeout(() => { m.classList.add('hidden'); }, 500);
        }
    </script>
}
