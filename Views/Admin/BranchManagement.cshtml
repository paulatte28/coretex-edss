@model IEnumerable<coretex_finalproj.Models.Branch>
@{
    ViewData["Title"] = "Branch Management";
    Layout = "_AdminLayout";
}

<div class="space-y-8">
    <!-- Header & Search -->
    <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-6">
        <div>
            <div class="flex items-center space-x-3 mb-2">
                <a href="/Admin" class="text-slate-400 hover:text-slate-600 transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                </a>
                <span class="px-3 py-1 bg-indigo-100 text-indigo-700 font-black text-[10px] uppercase tracking-widest rounded-full">HQ Control Center</span>
            </div>
            <h2 class="text-3xl font-black text-slate-900 tracking-tight">Organization Map</h2>
            <p class="text-sm text-slate-500 mt-1">Operational control for your entire infrastructure</p>
        </div>
        
        <div class="flex flex-col md:flex-row items-center gap-4">
            <div class="relative group w-full md:w-64">
                <input type="text" id="branchSearch" onkeyup="searchBranches()" placeholder="Find a location..." 
                    class="w-full pl-10 pr-4 py-3 bg-white border border-slate-200 rounded-2xl text-sm focus:ring-4 focus:ring-indigo-100 outline-none transition-all" />
                <svg class="w-4 h-4 absolute left-4 top-3.5 text-slate-400 group-hover:text-indigo-600 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
            </div>
            <button onclick="openAddModal()" class="w-full md:w-auto px-6 py-3 bg-indigo-600 text-white font-bold text-sm rounded-2xl hover:bg-indigo-700 hover:scale-105 transition-all flex items-center justify-center space-x-2 shadow-lg shadow-indigo-100">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                <span>Provision New Branch</span>
            </button>
        </div>
    </div>

    <!-- HQ / Main Branch (Fixed Section) -->
    <div class="mb-12">
        <h3 class="text-xs font-black text-slate-400 uppercase tracking-[0.3em] mb-6 flex items-center gap-4">
            <span>Primary Infrastructure</span>
            <div class="h-px flex-1 bg-slate-100"></div>
        </h3>
        
        <div class="branch-card relative bg-slate-900 rounded-[3rem] p-10 text-white shadow-2xl shadow-slate-200 group overflow-hidden cursor-pointer" 
             onclick="openEditModal('HQ', 'Main Branch / HQ', 'CORETEX-HQ', 'Company Headquarters')">
            <div class="absolute -right-16 -top-16 w-64 h-64 bg-indigo-500/20 rounded-full blur-3xl group-hover:scale-150 transition-transform duration-1000"></div>
            <div class="relative z-10 flex flex-col md:flex-row md:items-center justify-between gap-8">
                <div class="flex items-center gap-6">
                    <div class="w-20 h-20 bg-white/10 rounded-[2rem] backdrop-blur-xl border border-white/10 flex items-center justify-center">
                        <svg class="w-10 h-10 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
                    </div>
                    <div>
                        <div class="flex items-center gap-3 mb-2">
                            <span class="px-3 py-1 bg-indigo-500 text-white text-[10px] font-black uppercase tracking-widest rounded-full">Global Headquarters</span>
                            <div class="w-2 h-2 bg-emerald-400 rounded-full animate-ping"></div>
                        </div>
                        <h4 class="text-3xl font-black tracking-tight mb-1">Main Branch / HQ</h4>
                        <p class="text-slate-400 font-bold flex items-center gap-2">
                             <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                             Davao City, PH (Global Operations)
                        </p>
                    </div>
                </div>
                <div class="text-right">
                    <p class="text-4xl font-black text-white mb-1">CORETEX-HQ</p>
                    <p class="text-xs font-black text-slate-500 uppercase tracking-widest">Primary System Node</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Active Branches Grid -->
    <div class="space-y-6">
        <h3 class="text-xs font-black text-slate-400 uppercase tracking-[0.3em] mb-6 flex items-center gap-4">
            <span>Satellite Locations</span>
            <div class="h-px flex-1 bg-slate-100"></div>
        </h3>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="branchGrid">
            @foreach (var branch in Model)
            {
                <div class="branch-card relative bg-white rounded-[2.5rem] p-8 border border-slate-100 shadow-sm hover:shadow-2xl hover:-translate-y-2 transition-all duration-500 group overflow-hidden @(branch.IsActive ? "" : "opacity-75 grayscale-[0.5]")">
                    <div class="flex items-start justify-between mb-8">
                        <div class="w-14 h-14 @(branch.IsActive ? "bg-slate-100 text-slate-900 shadow-xl shadow-slate-100" : "bg-slate-200 text-slate-500") rounded-2xl flex items-center justify-center font-black text-xl group-hover:bg-indigo-600 group-hover:text-white transition-all">
                            @branch.BranchCode.Substring(0, Math.Min(2, branch.BranchCode.Length)).ToUpper()
                        </div>
                        
                        <div class="flex gap-2 relative z-20">
                            <form asp-action="ToggleBranchStatus" asp-route-id="@branch.Id" method="post" class="inline">
                                <button type="submit" class="w-10 h-10 rounded-xl @(branch.IsActive ? "bg-emerald-50 text-emerald-600" : "bg-amber-50 text-amber-600") flex items-center justify-center hover:scale-110 transition-all border border-transparent hover:border-current/20" title="Toggle Maintenance Mode">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
                                </button>
                            </form>
                            <form asp-action="ArchiveBranch" asp-route-id="@branch.Id" method="post" class="inline" onsubmit="return confirm('Archive this branch?')">
                                <button type="submit" class="w-10 h-10 bg-slate-50 text-slate-400 rounded-xl flex items-center justify-center hover:bg-rose-50 hover:text-rose-600 transition-all border border-transparent hover:border-rose-100" title="Archive Branch">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                                </button>
                            </form>
                        </div>
                    </div>

                    <div class="space-y-4 cursor-pointer" onclick="openEditModal('@branch.Id', '@branch.Name', '@branch.BranchCode', '@branch.Address')">
                        <div class="flex items-center gap-2">
                            <span class="px-2 py-0.5 @(branch.IsActive ? "bg-emerald-100 text-emerald-700" : "bg-slate-200 text-slate-600") text-[9px] font-black uppercase tracking-widest rounded-md">
                                @(branch.IsActive ? "Operational" : "Maintenance")
                            </span>
                        </div>
                        <h4 class="text-2xl font-black text-slate-900 group-hover:text-indigo-600 transition-colors tracking-tight">@branch.Name</h4>
                        <p class="text-sm text-slate-400 font-bold flex items-center gap-2">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                            @branch.Address
                        </p>
                    </div>

                    <div class="mt-8 pt-6 border-t border-slate-50 flex items-center justify-between">
                        <div class="flex items-center gap-2 text-indigo-600">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
                            <span class="text-xs font-black">Branch Node</span>
                        </div>
                        <p class="text-[10px] font-black uppercase tracking-widest text-slate-400">@branch.BranchCode</p>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
</div>

<!-- Add Modal -->
<div id="add-modal" class="fixed inset-0 bg-slate-900/40 backdrop-blur-md z-50 hidden flex items-center justify-center p-4 transition-all duration-500">
    <div class="bg-white rounded-[3.5rem] p-12 w-full max-w-md shadow-2xl transform transition-all duration-500 scale-95 opacity-0" id="add-modal-card">
        <h3 class="text-3xl font-black text-slate-900 mb-2">New Branch</h3>
        <p class="text-sm text-slate-500 mb-8 font-bold">Register a new physical location</p>
        <form asp-action="CreateBranch" method="post" class="space-y-5">
            <div>
                <label class="block text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 mb-2">Location Name</label>
                <input name="Name" required class="w-full px-6 py-4 bg-slate-50 border border-slate-100 rounded-2xl focus:ring-4 focus:ring-indigo-100 outline-none transition-all font-bold" placeholder="e.g. Davao Central" />
            </div>
            <div>
                <label class="block text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 mb-2">Internal Code</label>
                <input name="BranchCode" required maxlength="10" class="w-full px-6 py-4 bg-slate-50 border border-slate-100 rounded-2xl focus:ring-4 focus:ring-indigo-100 outline-none transition-all font-bold" placeholder="e.g. DVO-01" />
            </div>
            <div>
                <label class="block text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 mb-2">Physical Address</label>
                <input name="Address" required class="w-full px-6 py-4 bg-slate-50 border border-slate-100 rounded-2xl focus:ring-4 focus:ring-indigo-100 outline-none transition-all font-bold" placeholder="City, Region" />
            </div>
            <div class="flex gap-4 pt-6">
                <button type="button" onclick="closeAddModal()" class="flex-1 py-4 bg-slate-100 text-slate-600 font-black text-xs uppercase tracking-widest rounded-2xl transition-all hover:bg-slate-200">Cancel</button>
                <button type="submit" class="flex-1 py-4 bg-indigo-600 text-white font-black text-xs uppercase tracking-widest rounded-2xl shadow-lg shadow-indigo-200 hover:bg-indigo-700 transition-all">Provision</button>
            </div>
        </form>
    </div>
</div>

<!-- Edit Modal -->
<div id="edit-modal" class="fixed inset-0 bg-slate-900/40 backdrop-blur-md z-50 hidden flex items-center justify-center p-4 transition-all duration-500">
    <div class="bg-white rounded-[3.5rem] p-12 w-full max-w-md shadow-2xl transform transition-all duration-500 scale-95 opacity-0" id="edit-modal-card">
        <h3 class="text-3xl font-black text-slate-900 mb-2">Edit Branch</h3>
        <p id="edit-branch-display" class="text-sm text-indigo-600 mb-8 font-black uppercase tracking-widest"></p>
        <form asp-action="UpdateBranch" method="post" class="space-y-5">
            <input type="hidden" name="Id" id="edit-id" />
            <div>
                <label class="block text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 mb-2">Update Name</label>
                <input name="Name" id="edit-name" required class="w-full px-6 py-4 bg-slate-50 border border-slate-100 rounded-2xl focus:ring-4 focus:ring-indigo-100 outline-none transition-all font-bold" />
            </div>
            <div>
                <label class="block text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 mb-2">Internal Code</label>
                <input name="BranchCode" id="edit-code" required maxlength="10" class="w-full px-6 py-4 bg-slate-50 border border-slate-100 rounded-2xl focus:ring-4 focus:ring-indigo-100 outline-none transition-all font-bold" />
            </div>
            <div>
                <label class="block text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 mb-2">Physical Address</label>
                <input name="Address" id="edit-address" required class="w-full px-6 py-4 bg-slate-50 border border-slate-100 rounded-2xl focus:ring-4 focus:ring-indigo-100 outline-none transition-all font-bold" />
            </div>
            <div class="flex gap-4 pt-6">
                <button type="button" onclick="closeEditModal()" class="flex-1 py-4 bg-slate-100 text-slate-600 font-black text-xs uppercase tracking-widest rounded-2xl transition-all hover:bg-slate-200">Discard</button>
                <button type="submit" class="flex-1 py-4 bg-slate-900 text-white font-black text-xs uppercase tracking-widest rounded-2xl shadow-lg shadow-slate-200 hover:bg-black transition-all">Save Changes</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function searchBranches() {
            let input = document.getElementById('branchSearch').value.toLowerCase();
            let cards = document.getElementsByClassName('branch-card');
            
            for (let card of cards) {
                let text = card.innerText.toLowerCase();
                if (text.includes(input)) {
                    card.style.display = "";
                } else {
                    card.style.display = "none";
                }
            }
        }

        function openAddModal() { 
            const m = document.getElementById('add-modal');
            const c = document.getElementById('add-modal-card');
            m.classList.remove('hidden'); 
            setTimeout(() => { c.classList.remove('scale-95', 'opacity-0'); c.classList.add('scale-100', 'opacity-100'); }, 10);
        }
        function closeAddModal() { 
            const m = document.getElementById('add-modal');
            const c = document.getElementById('add-modal-card');
            c.classList.remove('scale-100', 'opacity-100'); c.classList.add('scale-95', 'opacity-0');
            setTimeout(() => { m.classList.add('hidden'); }, 500);
        }

        function openEditModal(id, name, code, address) {
            document.getElementById('edit-id').value = id;
            document.getElementById('edit-name').value = name;
            document.getElementById('edit-code').value = code;
            document.getElementById('edit-address').value = address;
            document.getElementById('edit-branch-display').textContent = "Configuring: " + code;

            const m = document.getElementById('edit-modal');
            const c = document.getElementById('edit-modal-card');
            m.classList.remove('hidden'); 
            setTimeout(() => { c.classList.remove('scale-95', 'opacity-0'); c.classList.add('scale-100', 'opacity-100'); }, 10);
        }
        function closeEditModal() { 
            const m = document.getElementById('edit-modal');
            const c = document.getElementById('edit-modal-card');
            c.classList.remove('scale-100', 'opacity-100'); c.classList.add('scale-95', 'opacity-0');
            setTimeout(() => { m.classList.add('hidden'); }, 500);
        }
    </script>
}
