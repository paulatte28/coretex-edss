@{
    ViewData["Title"] = "Branch Management";
    Layout = "_AdminLayout";
}

<div class="space-y-8">
    <!-- Header -->
    <div class="flex items-center justify-between">
        <div>
            <div class="flex items-center space-x-3 mb-2">
                <a href="/Admin" class="text-slate-400 hover:text-slate-600 transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                </a>
                <span class="px-3 py-1 bg-blue-100 text-blue-700 font-black text-[10px] uppercase tracking-widest rounded-full">Branch Setup</span>
            </div>
            <h2 class="text-3xl font-black text-slate-900 tracking-tight">Branch Management</h2>
            <p class="text-sm text-slate-500 mt-1">Create and manage company branches (Davao, Tagum, Digos, etc.)</p>
        </div>
        <button onclick="openModal()" class="px-6 py-3 bg-blue-600 text-white font-bold text-sm rounded-xl hover:bg-blue-700 transition-colors flex items-center space-x-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            <span>Add Branch</span>
        </button>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-xs text-slate-500 uppercase tracking-widest">Total Branches</p>
                    <p class="text-3xl font-black text-slate-900 mt-1" id="total-branches">0</p>
                </div>
                <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center">
                    <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
                </div>
            </div>
        </div>
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-xs text-slate-500 uppercase tracking-widest">Active Branches</p>
                    <p class="text-3xl font-black text-emerald-600 mt-1" id="active-branches">0</p>
                </div>
                <div class="w-12 h-12 bg-emerald-100 rounded-xl flex items-center justify-center">
                    <svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
            </div>
        </div>
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-xs text-slate-500 uppercase tracking-widest">Inactive Branches</p>
                    <p class="text-3xl font-black text-slate-400 mt-1" id="inactive-branches">0</p>
                </div>
                <div class="w-12 h-12 bg-slate-100 rounded-xl flex items-center justify-center">
                    <svg class="w-6 h-6 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/></svg>
                </div>
            </div>
        </div>
    </div>

    <!-- Branch List -->
    <div class="bg-white rounded-3xl shadow-sm border border-slate-100 overflow-hidden">
        <div class="p-6 border-b border-slate-100">
            <div class="flex items-center justify-between">
                <h3 class="font-bold text-slate-900">All Branches</h3>
                <div class="flex items-center space-x-3">
                    <div class="relative">
                        <input type="text" id="search-branches" placeholder="Search branches..." class="pl-10 pr-4 py-2 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none w-64">
                        <svg class="w-4 h-4 text-slate-400 absolute left-3 top-1/2 -translate-y-1/2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                    </div>
                </div>
            </div>
        </div>
        
        <div id="branch-list" class="divide-y divide-slate-100">
            <!-- Branch items will be rendered here -->
        </div>

        <div id="empty-state" class="hidden p-12 text-center">
            <div class="w-16 h-16 bg-slate-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
            </div>
            <h4 class="font-bold text-slate-900 mb-2">No branches yet</h4>
            <p class="text-sm text-slate-500 mb-4">Get started by adding your first branch.</p>
            <button onclick="openModal()" class="px-4 py-2 bg-blue-600 text-white font-bold text-sm rounded-xl hover:bg-blue-700 transition-colors">Add First Branch</button>
        </div>
    </div>
</div>

<!-- Add/Edit Branch Modal -->
<div id="branch-modal" class="fixed inset-0 bg-black/50 z-50 hidden flex items-center justify-center p-4">
    <div class="bg-white rounded-3xl w-full max-w-lg shadow-2xl transform transition-all">
        <div class="p-6 border-b border-slate-100">
            <div class="flex items-center justify-between">
                <h3 class="text-xl font-black text-slate-900" id="modal-title">Add New Branch</h3>
                <button onclick="closeModal()" class="w-10 h-10 bg-slate-100 rounded-xl flex items-center justify-center hover:bg-slate-200 transition-colors">
                    <svg class="w-5 h-5 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
            </div>
        </div>
        <form id="branch-form" class="p-6 space-y-5">
            <input type="hidden" id="branch-id">
            
            <div>
                <label class="block text-sm font-bold text-slate-700 mb-2">Branch Name <span class="text-red-500">*</span></label>
                <input type="text" id="branch-name" required placeholder="e.g., Davao Main Branch" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none">
            </div>

            <div>
                <label class="block text-sm font-bold text-slate-700 mb-2">Branch Code <span class="text-red-500">*</span></label>
                <input type="text" id="branch-code" required placeholder="e.g., DVO" maxlength="10" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none uppercase">
                <p class="text-xs text-slate-400 mt-1">Short code for reports and identification (max 10 chars)</p>
            </div>

            <div>
                <label class="block text-sm font-bold text-slate-700 mb-2">Location / Address</label>
                <input type="text" id="branch-location" placeholder="e.g., 123 Main St, Davao City" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none">
            </div>

            <div>
                <label class="block text-sm font-bold text-slate-700 mb-2">Contact Number</label>
                <input type="tel" id="branch-contact" placeholder="e.g., +63 82 123 4567" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none">
            </div>

            <div>
                <label class="block text-sm font-bold text-slate-700 mb-2">Status</label>
                <select id="branch-status" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none">
                    <option value="active">Active</option>
                    <option value="inactive">Inactive</option>
                </select>
            </div>

            <div class="flex space-x-3 pt-4">
                <button type="button" onclick="closeModal()" class="flex-1 px-4 py-3 border border-slate-200 text-slate-700 font-bold rounded-xl hover:bg-slate-50 transition-colors">Cancel</button>
                <button type="submit" class="flex-1 px-4 py-3 bg-blue-600 text-white font-bold rounded-xl hover:bg-blue-700 transition-colors">Save Branch</button>
            </div>
        </form>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div id="delete-modal" class="fixed inset-0 bg-black/50 z-50 hidden flex items-center justify-center p-4">
    <div class="bg-white rounded-3xl w-full max-w-md shadow-2xl p-6">
        <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
        </div>
        <h3 class="text-xl font-black text-center text-slate-900 mb-2">Delete Branch?</h3>
        <p class="text-sm text-slate-500 text-center mb-6">This action cannot be undone. All associated data will be removed.</p>
        <input type="hidden" id="delete-branch-id">
        <div class="flex space-x-3">
            <button onclick="closeDeleteModal()" class="flex-1 px-4 py-3 border border-slate-200 text-slate-700 font-bold rounded-xl hover:bg-slate-50 transition-colors">Cancel</button>
            <button onclick="confirmDelete()" class="flex-1 px-4 py-3 bg-red-600 text-white font-bold rounded-xl hover:bg-red-700 transition-colors">Delete</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let branches = JSON.parse(localStorage.getItem('coretex_branches') || '[]');

        function renderBranches() {
            const container = document.getElementById('branch-list');
            const emptyState = document.getElementById('empty-state');
            const searchTerm = document.getElementById('search-branches').value.toLowerCase();

            const filteredBranches = branches.filter(b => 
                b.name.toLowerCase().includes(searchTerm) || 
                b.code.toLowerCase().includes(searchTerm) ||
                (b.location && b.location.toLowerCase().includes(searchTerm))
            );

            // Update stats
            document.getElementById('total-branches').textContent = branches.length;
            document.getElementById('active-branches').textContent = branches.filter(b => b.status === 'active').length;
            document.getElementById('inactive-branches').textContent = branches.filter(b => b.status === 'inactive').length;

            if (filteredBranches.length === 0) {
                container.innerHTML = '';
                emptyState.classList.remove('hidden');
                return;
            }

            emptyState.classList.add('hidden');
            container.innerHTML = filteredBranches.map(branch => `
                <div class="p-6 hover:bg-slate-50 transition-colors">
                    <div class="flex items-center justify-between">
                        <div class="flex items-center space-x-4">
                            <div class="w-12 h-12 ${branch.status === 'active' ? 'bg-blue-100' : 'bg-slate-100'} rounded-xl flex items-center justify-center">
                                <span class="text-lg font-black ${branch.status === 'active' ? 'text-blue-600' : 'text-slate-400'}">${branch.code.substring(0, 2).toUpperCase()}</span>
                            </div>
                            <div>
                                <div class="flex items-center space-x-2">
                                    <h4 class="font-bold text-slate-900">${branch.name}</h4>
                                    <span class="px-2 py-0.5 text-[10px] font-bold uppercase tracking-widest rounded-full ${branch.status === 'active' ? 'bg-emerald-100 text-emerald-700' : 'bg-slate-100 text-slate-500'}">${branch.status}</span>
                                </div>
                                <div class="flex items-center space-x-4 mt-1">
                                    <span class="text-xs text-slate-500 flex items-center space-x-1">
                                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 20l4-16m2 16l4-16M6 9h14M4 15h14"/></svg>
                                        <span>${branch.code}</span>
                                    </span>
                                    ${branch.location ? `
                                        <span class="text-xs text-slate-500 flex items-center space-x-1">
                                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/></svg>
                                            <span>${branch.location}</span>
                                        </span>
                                    ` : ''}
                                    ${branch.contact ? `
                                        <span class="text-xs text-slate-500 flex items-center space-x-1">
                                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                                            <span>${branch.contact}</span>
                                        </span>
                                    ` : ''}
                                </div>
                            </div>
                        </div>
                        <div class="flex items-center space-x-2">
                            <button onclick="editBranch('${branch.id}')" class="w-10 h-10 bg-slate-100 rounded-xl flex items-center justify-center hover:bg-blue-100 hover:text-blue-600 transition-colors">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                            </button>
                            <button onclick="deleteBranch('${branch.id}')" class="w-10 h-10 bg-slate-100 rounded-xl flex items-center justify-center hover:bg-red-100 hover:text-red-600 transition-colors">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                            </button>
                        </div>
                    </div>
                </div>
            `).join('');
        }

        function openModal(branchId = null) {
            const modal = document.getElementById('branch-modal');
            const title = document.getElementById('modal-title');
            const form = document.getElementById('branch-form');
            
            form.reset();
            document.getElementById('branch-id').value = '';

            if (branchId) {
                const branch = branches.find(b => b.id === branchId);
                if (branch) {
                    title.textContent = 'Edit Branch';
                    document.getElementById('branch-id').value = branch.id;
                    document.getElementById('branch-name').value = branch.name;
                    document.getElementById('branch-code').value = branch.code;
                    document.getElementById('branch-location').value = branch.location || '';
                    document.getElementById('branch-contact').value = branch.contact || '';
                    document.getElementById('branch-status').value = branch.status;
                }
            } else {
                title.textContent = 'Add New Branch';
            }

            modal.classList.remove('hidden');
        }

        function closeModal() {
            document.getElementById('branch-modal').classList.add('hidden');
        }

        function editBranch(id) {
            openModal(id);
        }

        function deleteBranch(id) {
            document.getElementById('delete-branch-id').value = id;
            document.getElementById('delete-modal').classList.remove('hidden');
        }

        function closeDeleteModal() {
            document.getElementById('delete-modal').classList.add('hidden');
        }

        function confirmDelete() {
            const id = document.getElementById('delete-branch-id').value;
            const branch = branches.find(b => b.id === id);
            branches = branches.filter(b => b.id !== id);
            localStorage.setItem('coretex_branches', JSON.stringify(branches));
            closeDeleteModal();
            renderBranches();
            
            // Log activity
            if (typeof window.parent.logActivity === 'function') {
                window.parent.logActivity('Branch Deleted', `Removed branch: ${branch?.name}`, 'branch');
            }
            logLocalActivity('Branch Deleted', `Removed branch: ${branch?.name}`, 'branch');
        }

        function logLocalActivity(action, description, type) {
            let activities = JSON.parse(localStorage.getItem('coretex_activities') || '[]');
            activities.unshift({
                id: Date.now(),
                action,
                description,
                type,
                timestamp: new Date().toISOString(),
                user: 'System Administrator'
            });
            activities = activities.slice(0, 100);
            localStorage.setItem('coretex_activities', JSON.stringify(activities));
        }

        document.getElementById('branch-form').addEventListener('submit', function(e) {
            e.preventDefault();
            
            const id = document.getElementById('branch-id').value;
            const branchData = {
                id: id || 'branch_' + Date.now(),
                name: document.getElementById('branch-name').value,
                code: document.getElementById('branch-code').value.toUpperCase(),
                location: document.getElementById('branch-location').value,
                contact: document.getElementById('branch-contact').value,
                status: document.getElementById('branch-status').value,
                createdAt: id ? branches.find(b => b.id === id)?.createdAt : new Date().toISOString(),
                updatedAt: new Date().toISOString()
            };

            if (id) {
                // Update existing
                const index = branches.findIndex(b => b.id === id);
                branches[index] = branchData;
                logLocalActivity('Branch Updated', `Updated branch: ${branchData.name}`, 'branch');
            } else {
                // Add new
                branches.push(branchData);
                logLocalActivity('Branch Created', `Added new branch: ${branchData.name}`, 'branch');
            }

            localStorage.setItem('coretex_branches', JSON.stringify(branches));
            closeModal();
            renderBranches();
        });

        document.getElementById('search-branches').addEventListener('input', renderBranches);

        // Initialize
        document.addEventListener('DOMContentLoaded', renderBranches);
    </script>
}
