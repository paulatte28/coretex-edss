@model coretex_finalproj.Models.AppUser
@{
    ViewData["Title"] = "Account Settings";
    Layout = "_AdminLayout"; // Using Admin layout for consistent look
}

<div class="max-w-4xl mx-auto py-10 px-4">
    <div class="mb-8">
        <h1 class="text-3xl font-black text-slate-900">Account Settings</h1>
        <p class="text-slate-500">Manage your profile information and security</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Profile Picture Section -->
        <div class="md:col-span-1">
            <div class="bg-white p-6 rounded-3xl border border-slate-100 shadow-sm text-center">
                <div class="relative inline-block mb-4">
                    @if (!string.IsNullOrEmpty(Model.ProfilePicturePath))
                    {
                        <img src="@Model.ProfilePicturePath" class="w-32 h-32 rounded-full object-cover border-4 border-slate-50 shadow-md" />
                    }
                    else
                    {
                        <div class="w-32 h-32 rounded-full bg-slate-100 flex items-center justify-center border-4 border-slate-50 shadow-md">
                            <span class="text-4xl">👤</span>
                        </div>
                    }
                </div>
                
                <form asp-action="UploadAvatar" method="post" enctype="multipart/form-data" class="mt-4">
                    <label class="block mb-2 text-sm font-bold text-slate-700">Change Avatar</label>
                    <input type="file" name="avatar" class="block w-full text-xs text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-xs file:font-black file:bg-slate-100 file:text-slate-700 hover:file:bg-slate-200 cursor-pointer mb-4" />
                    <button type="submit" class="w-full py-2 bg-indigo-600 text-white rounded-full font-black text-xs hover:bg-indigo-700 transition-all shadow-lg shadow-indigo-100">Upload Now</button>
                </form>
            </div>
        </div>

        <!-- Security Section -->
        <div class="md:col-span-2">
            <div class="bg-white p-8 rounded-3xl border border-slate-100 shadow-sm">
                <h3 class="text-lg font-bold text-slate-900 mb-6">Security & Password</h3>
                
                @if (TempData["Success"] != null)
                {
                    <div class="mb-6 p-4 bg-emerald-50 text-emerald-700 rounded-2xl text-sm font-bold">
                        @TempData["Success"]
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="mb-6 p-4 bg-rose-50 text-rose-700 rounded-2xl text-sm font-bold">
                        @TempData["Error"]
                    </div>
                }

                <form asp-action="ChangePassword" method="post" class="space-y-4">
                    <div>
                        <label class="block text-xs font-black text-slate-500 uppercase tracking-widest mb-2">Current Password</label>
                        <input type="password" name="currentPassword" class="w-full px-4 py-3 bg-slate-50 border border-slate-100 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none" required />
                    </div>
                    <div>
                        <label class="block text-xs font-black text-slate-500 uppercase tracking-widest mb-2">New Password</label>
                        <input type="password" name="newPassword" class="w-full px-4 py-3 bg-slate-50 border border-slate-100 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none" required />
                    </div>
                    <div class="pt-4">
                        <button type="submit" class="px-8 py-3 bg-slate-900 text-white rounded-xl font-black text-sm hover:scale-105 transition-all shadow-xl">Update Security</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
