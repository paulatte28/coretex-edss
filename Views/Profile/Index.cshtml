@model coretex_finalproj.Models.AppUser
@{
    ViewData["Title"] = "Security Command Center";
    Layout = "_AdminLayout";
}

<div class="space-y-8 py-6">
    <!-- Premium Identity Header -->
    <div class="bg-slate-900 rounded-[3.5rem] p-10 text-white shadow-2xl relative overflow-hidden">
        <div class="absolute right-0 top-0 w-96 h-96 bg-indigo-500/10 rounded-full -mr-32 -mt-32 blur-3xl"></div>
        
        <div class="flex flex-col md:flex-row items-center gap-8 relative z-10">
            <div class="relative">
                <div class="w-32 h-32 rounded-[2.5rem] bg-indigo-600 p-1 shadow-2xl shadow-indigo-500/20">
                    @if (!string.IsNullOrEmpty(Model.ProfilePicturePath))
                    {
                        <img src="@Model.ProfilePicturePath" class="w-full h-full rounded-[2.2rem] object-cover" />
                    }
                    else
                    {
                        <div class="w-full h-full rounded-[2.2rem] bg-gradient-to-br from-indigo-600 to-slate-800 flex items-center justify-center text-4xl font-black text-white shadow-inner">
                            @(Model.FullName?.Substring(0, 1) ?? "U")
                        </div>
                    }
                </div>
                <div class="absolute -bottom-2 -right-2 w-8 h-8 bg-emerald-500 rounded-xl border-4 border-slate-900 flex items-center justify-center animate-pulse">
                    <div class="w-2 h-2 bg-white rounded-full"></div>
                </div>
            </div>

            <div class="text-center md:text-left flex-1">
                <div class="flex items-center justify-center md:justify-start gap-3 mb-2">
                    <span class="px-3 py-1 bg-indigo-500/20 text-indigo-400 text-[9px] font-black uppercase tracking-[0.2em] rounded-lg border border-indigo-500/30">@(Model.Role == "CEO" ? "Strategic Owner" : Model.Role == "BRANCH_ADMIN" ? "Node Authority" : "Service Specialist")</span>
                    <span class="px-3 py-1 bg-white/5 text-white/40 text-[9px] font-black uppercase tracking-[0.2em] rounded-lg border border-white/10">@(Model.Role == "CEO" ? "Global Terminal" : "Local Terminal")</span>
                </div>
                <h2 class="text-4xl font-black tracking-tight">@Model.FullName</h2>
                <p class="text-slate-400 font-medium mt-1">@Model.Email</p>
            </div>

            <div class="flex gap-4">
                <div class="text-center px-6 py-4 bg-white/5 border border-white/10 rounded-3xl">
                    <p class="text-[9px] font-black text-slate-500 uppercase tracking-widest mb-1">Assigned Branch</p>
                    <p class="font-black text-sm text-white uppercase">@(Model.Branch?.Name ?? "Global Admin")</p>
                </div>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Security & Session Data -->
        <div class="space-y-8">
            <div class="bg-white rounded-[2.5rem] p-8 border border-slate-100 shadow-sm">
                <h3 class="text-xs font-black text-slate-400 uppercase tracking-widest mb-6 flex items-center gap-2">
                    <svg class="w-4 h-4 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                    Session Integrity
                </h3>
                <div class="space-y-5">
                    <div class="flex justify-between items-center">
                        <span class="text-sm font-bold text-slate-500">Last Login</span>
                        <span class="text-sm font-black text-slate-900">Today, 02:14 PM</span>
                    </div>
                    <div class="flex justify-between items-center">
                        <span class="text-sm font-bold text-slate-500">Access Node</span>
                        <span class="text-sm font-black text-indigo-600">192.168.1.1 (Local)</span>
                    </div>
                    <div class="flex justify-between items-center">
                        <span class="text-sm font-bold text-slate-500">Account Strength</span>
                        <div class="flex gap-1">
                            <div class="w-3 h-1.5 bg-emerald-500 rounded-full"></div>
                            <div class="w-3 h-1.5 bg-emerald-500 rounded-full"></div>
                            <div class="w-3 h-1.5 bg-emerald-500 rounded-full"></div>
                            <div class="w-3 h-1.5 bg-slate-200 rounded-full"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="bg-indigo-600 rounded-[2.5rem] p-8 text-white relative overflow-hidden group">
                <div class="absolute -right-4 -bottom-4 w-24 h-24 bg-white/10 rounded-full group-hover:scale-150 transition-transform duration-700"></div>
                <h4 class="text-sm font-black uppercase tracking-widest mb-3">Avatar Upload</h4>
                <form asp-action="UploadAvatar" method="post" enctype="multipart/form-data">
                    <input type="file" name="avatar" class="text-[10px] text-indigo-200 file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-[10px] file:font-black file:bg-white/10 file:text-white mb-4 w-full" />
                    <button type="submit" class="w-full py-3 bg-white text-indigo-600 font-black text-[10px] uppercase tracking-widest rounded-xl hover:bg-indigo-50 transition-all">Synchronize Photo</button>
                </form>
            </div>
        </div>

        <!-- Password & Auth Control -->
        <div class="lg:col-span-2 space-y-8">
            <div class="bg-white rounded-[2.5rem] p-10 border border-slate-100 shadow-sm relative">
                <div class="flex items-center justify-between mb-8">
                    <div>
                        <h3 class="text-xl font-black text-slate-900 tracking-tight">Security Credentials</h3>
                        <p class="text-xs text-slate-400 font-bold uppercase tracking-widest mt-1">Update Authentication Keys</p>
                    </div>
                    <div class="w-12 h-12 bg-slate-50 rounded-2xl flex items-center justify-center text-slate-400">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/></svg>
                    </div>
                </div>

                @if (TempData["Success"] != null)
                {
                    <div class="mb-8 p-4 bg-emerald-50 text-emerald-700 rounded-2xl text-xs font-bold border border-emerald-100 flex items-center gap-3">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                        @TempData["Success"]
                    </div>
                }

                <form asp-action="ChangePassword" method="post" class="space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-3 ml-1">Current Password</label>
                            <input type="password" name="currentPassword" class="w-full px-4 py-3 bg-slate-50 border border-slate-100 rounded-2xl focus:ring-4 focus:ring-indigo-100 outline-none transition-all font-bold text-slate-900" required />
                        </div>
                        <div>
                            <label class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-3 ml-1">New Secure Password</label>
                            <input type="password" name="newPassword" id="newPassword" onkeyup="checkStrength(this.value)" class="w-full px-4 py-3 bg-slate-50 border border-slate-100 rounded-2xl focus:ring-4 focus:ring-indigo-100 outline-none transition-all font-bold text-slate-900" required />
                            
                            <!-- Tactical Strength Meter -->
                            <div class="mt-4 px-1">
                                <div class="flex gap-1.5 h-1.5 mb-2">
                                    <div id="bar-1" class="flex-1 rounded-full bg-slate-100 transition-all duration-500"></div>
                                    <div id="bar-2" class="flex-1 rounded-full bg-slate-100 transition-all duration-500"></div>
                                    <div id="bar-3" class="flex-1 rounded-full bg-slate-100 transition-all duration-500"></div>
                                    <div id="bar-4" class="flex-1 rounded-full bg-slate-100 transition-all duration-500"></div>
                                </div>
                                <div class="flex justify-between items-center">
                                    <p id="strength-text" class="text-[9px] font-black uppercase tracking-widest text-slate-400">Security Assessment: Pending</p>
                                    <p id="entropy-label" class="text-[9px] font-bold text-slate-300">0% Entropy</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="flex items-center justify-end gap-4 pt-4">
                        <span class="text-[10px] text-slate-400 font-bold italic">Requirement: 12+ Characters & Symbols</span>
                        <button type="submit" id="submitBtn" class="px-10 py-4 bg-slate-900 text-white rounded-2xl font-black text-xs uppercase tracking-widest hover:bg-slate-800 transition-all shadow-xl disabled:opacity-50" disabled>Update Credentials</button>
                    </div>
                </form>
            </div>

            <!-- Strength Meter Script -->
            <script>
                function checkStrength(password) {
                    const bars = [
                        document.getElementById('bar-1'),
                        document.getElementById('bar-2'),
                        document.getElementById('bar-3'),
                        document.getElementById('bar-4')
                    ];
                    const text = document.getElementById('strength-text');
                    const entropy = document.getElementById('entropy-label');
                    const btn = document.getElementById('submitBtn');

                    let score = 0;
                    if (!password) {
                        updateUI(0, "Pending", "text-slate-400", "bg-slate-100");
                        btn.disabled = true;
                        return;
                    }

                    // Scoring Criteria
                    if (password.length >= 8) score++;
                    if (password.length >= 12) score++;
                    if (/[A-Z]/.test(password) && /[a-z]/.test(password)) score++;
                    if (/[0-9]/.test(password) && /[^A-Za-z0-9]/.test(password)) score++;

                    let status = "Weak";
                    let color = "text-rose-500";
                    let barColor = "bg-rose-500";

                    if (score === 2) { status = "Medium"; color = "text-orange-500"; barColor = "bg-orange-500"; }
                    if (score === 3) { status = "Strong"; color = "text-yellow-500"; barColor = "bg-yellow-500"; }
                    if (score === 4) { status = "Tactical Grade"; color = "text-emerald-500"; barColor = "bg-emerald-500"; }

                    updateUI(score, status, color, barColor);
                    
                    // Enable button ONLY if it's at least strong (NIST compliance)
                    btn.disabled = score < 2;
                    entropy.textContent = (score * 25) + "% Entropy";
                }

                function updateUI(score, status, colorClass, barColorClass) {
                    const bars = [1, 2, 3, 4].map(i => document.getElementById('bar-' + i));
                    const text = document.getElementById('strength-text');

                    text.textContent = "Security Assessment: " + status;
                    text.className = "text-[9px] font-black uppercase tracking-widest " + colorClass;

                    bars.forEach((bar, i) => {
                        if (i < score) {
                            bar.className = "flex-1 rounded-full transition-all duration-500 " + barColorClass;
                        } else {
                            bar.className = "flex-1 rounded-full transition-all duration-500 bg-slate-100";
                        }
                    });
                }
            </script>

            <div class="bg-white rounded-[2.5rem] p-10 border border-slate-100 shadow-sm">
                <div class="flex items-center gap-3 mb-8">
                    <div class="w-1.5 h-6 bg-indigo-500 rounded-full"></div>
                    <h3 class="text-xs font-black text-slate-400 uppercase tracking-widest">Recent Administrative Footprint</h3>
                </div>
                <div class="space-y-6">
                    @if (ViewBag.RecentActivity != null && ((IEnumerable<coretex_finalproj.Models.ActivityLogEntry>)ViewBag.RecentActivity).Any())
                    {
                        foreach (var log in (IEnumerable<coretex_finalproj.Models.ActivityLogEntry>)ViewBag.RecentActivity)
                        {
                            <div class="flex items-center justify-between group">
                                <div class="flex items-center gap-4">
                                    <div class="w-10 h-10 bg-slate-50 text-slate-400 rounded-xl flex items-center justify-center font-bold text-[9px] uppercase">
                                        @(log.ActionType.Length > 3 ? log.ActionType.Substring(0, 3) : log.ActionType)
                                    </div>
                                    <div>
                                        <p class="text-sm font-bold text-slate-900">@log.Description</p>
                                        <p class="text-[10px] text-slate-400 font-bold uppercase mt-0.5">@log.CreatedAt.ToString("MMM dd • hh:mm tt")</p>
                                    </div>
                                </div>
                                <svg class="w-4 h-4 text-slate-200 group-hover:text-indigo-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="py-10 text-center">
                            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">No recent administrative activity</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

