<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Coretex EDSS</title>
    
    <!-- Tailwind CSS Play CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#001A4D', // Deep Navy
                        secondary: '#006D68', // Teal
                        accent: '#FFF0AD', // Light Yellow
                        bg: '#F8FAFC'
                    },
                    fontFamily: {
                        sans: ['Inter', 'ui-sans-serif', 'system-ui'],
                    },
                }
            }
        }
    </script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        
        /* Premium Mesh Gradient for Sidebar */
        .sidebar-mesh {
            background-color: #001A4D;
            background-image: 
                radial-gradient(at 0% 0%, hsla(210,100%,15%,1) 0, transparent 50%), 
                radial-gradient(at 50% 0%, hsla(180,100%,10%,1) 0, transparent 50%);
        }

        /* Glassmorphism Header */
        .glass-header {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
        }

        /* Active Menu Glow */
        .active-glow {
            position: relative;
            box-shadow: 0 0 20px rgba(0, 109, 104, 0.4);
        }
        .active-glow::after {
            content: '';
            position: absolute;
            right: 0;
            top: 25%;
            height: 50%;
            width: 4px;
            background: #006D68;
            border-radius: 4px 0 0 4px;
        }

        /* Slide In Animation */
        @@keyframes slideIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate-slide-in {
            animation: slideIn 0.5s ease-out forwards;
        }

        /* Smooth Sidebar Transition */
        .sidebar-transition {
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        /* Custom Hover Scrollbar */
        .custom-scrollbar::-webkit-scrollbar {
            width: 4px;
        }
        .custom-scrollbar::-webkit-scrollbar-track {
            background: transparent;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.1);
            border-radius: 10px;
        }
        .custom-scrollbar:hover::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.2);
        }
    </style>
</head>
<body class="bg-gray-100 text-slate-800">
    <div class="flex h-screen overflow-hidden">
        <!-- Sidebar -->
        <aside class="hidden md:flex flex-col w-72 sidebar-mesh text-white sidebar-transition border-r border-white/5">
            <div class="p-8 flex items-center space-x-4">
                <div class="w-12 h-12 bg-white rounded-2xl flex items-center justify-center shadow-xl shadow-blue-900/40 transform rotate-3">
                   <img src="/images/logo.png" alt="Logo" class="rounded-lg" /> 
                </div>
                <div>
                    <h1 class="text-2xl font-black tracking-tighter">CORETEX</h1>
                    <p class="text-[10px] text-blue-300 font-bold tracking-[0.2em] uppercase">Executive EDSS</p>
                </div>
            </div>
            
            <nav class="flex-1 px-6 py-8 space-y-3 overflow-y-auto custom-scrollbar">
                <a href="/Dashboard" class="flex items-center space-x-3 p-4 @(Context.Request.Path == "/Dashboard" || Context.Request.Path == "/" ? "bg-secondary active-glow" : "text-slate-400 hover:bg-white/5 hover:text-white") rounded-2xl transition-all duration-300 transform @(Context.Request.Path == "/Dashboard" || Context.Request.Path == "/" ? "scale-[1.02]" : "")">
                    <svg class="w-5 h-5 @(Context.Request.Path == "/Dashboard" || Context.Request.Path == "/" ? "text-white" : "group-hover:text-secondary transition-colors")" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
                    <span class="font-bold tracking-tight text-sm">KPI Dashboard</span>
                </a>
                
                <a href="/Dashboard/TrendAnalysis" class="group flex items-center space-x-3 p-4 @(Context.Request.Path == "/Dashboard/TrendAnalysis" ? "bg-secondary active-glow" : "text-slate-400 hover:bg-white/5 hover:text-white") rounded-2xl transition-all duration-300 transform @(Context.Request.Path == "/Dashboard/TrendAnalysis" ? "scale-[1.02]" : "")">
                    <svg class="w-5 h-5 @(Context.Request.Path == "/Dashboard/TrendAnalysis" ? "text-white" : "group-hover:text-secondary transition-colors")" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
                    <span class="font-semibold tracking-tight text-sm">Predictive Trend</span>
                </a>
                
                <a href="/Dashboard/ExecutiveReporting" class="group flex items-center space-x-3 p-4 @(Context.Request.Path == "/Dashboard/ExecutiveReporting" ? "bg-secondary active-glow" : "text-slate-400 hover:bg-white/5 hover:text-white") rounded-2xl transition-all duration-300 transform @(Context.Request.Path == "/Dashboard/ExecutiveReporting" ? "scale-[1.02]" : "")">
                    <svg class="w-5 h-5 @(Context.Request.Path == "/Dashboard/ExecutiveReporting" ? "text-white" : "group-hover:text-secondary transition-colors")" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 2v-6m10 10V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2z"/></svg>
                    <span class="font-semibold tracking-tight text-sm">Exec Reporting</span>
                </a>

                <a href="/Dashboard/DataVisualization" class="group flex items-center space-x-3 p-4 @(Context.Request.Path == "/Dashboard/DataVisualization" ? "bg-secondary active-glow" : "text-slate-400 hover:bg-white/5 hover:text-white") rounded-2xl transition-all duration-300 transform @(Context.Request.Path == "/Dashboard/DataVisualization" ? "scale-[1.02]" : "")">
                    <svg class="w-5 h-5 @(Context.Request.Path == "/Dashboard/DataVisualization" ? "text-white" : "group-hover:text-secondary transition-colors")" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z"/></svg>
                    <span class="font-semibold tracking-tight text-sm">Data Viz & Insights</span>
                </a>

                <a href="/Dashboard/DecisionSupport" class="group flex items-center space-x-3 p-4 @(Context.Request.Path == "/Dashboard/DecisionSupport" ? "bg-secondary active-glow" : "text-slate-400 hover:bg-white/5 hover:text-white") rounded-2xl transition-all duration-300 transform @(Context.Request.Path == "/Dashboard/DecisionSupport" ? "scale-[1.02]" : "")">
                    <svg class="w-5 h-5 @(Context.Request.Path == "/Dashboard/DecisionSupport" ? "text-white" : "group-hover:text-secondary transition-colors")" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                    <span class="font-semibold tracking-tight text-sm">Decision Analytics</span>
                </a>

                <a href="/DataEntry" class="group flex items-center space-x-3 p-4 @(Context.Request.Path == "/DataEntry" ? "bg-secondary active-glow" : "text-slate-400 hover:bg-white/5 hover:text-white") rounded-2xl transition-all duration-300 transform @(Context.Request.Path == "/DataEntry" ? "scale-[1.02]" : "")">
                    <svg class="w-5 h-5 @(Context.Request.Path == "/DataEntry" ? "text-white" : "group-hover:text-secondary transition-colors")" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                    <span class="font-semibold tracking-tight text-sm">Record Business Data</span>
                </a>

                <div class="pt-8">
                    <p class="px-4 text-[10px] font-bold uppercase tracking-[0.2em] text-blue-400/60 pb-2">Platform Administration</p>
                    <a href="/Dashboard/TenantManagement" class="group flex items-center space-x-3 p-4 @(Context.Request.Path == "/Dashboard/TenantManagement" ? "bg-secondary active-glow" : "text-slate-400 hover:bg-white/5 hover:text-white") rounded-2xl transition-all duration-300 transform @(Context.Request.Path == "/Dashboard/TenantManagement" ? "scale-[1.02]" : "")">
                        <svg class="w-5 h-5 @(Context.Request.Path == "/Dashboard/TenantManagement" ? "text-white" : "group-hover:text-secondary transition-colors")" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
                        <span class="font-semibold tracking-tight text-sm">Tenant Management</span>
                    </a>
                    
                    <a href="/Dashboard/Subscription" class="group flex items-center space-x-3 p-4 @(Context.Request.Path == "/Dashboard/Subscription" ? "bg-secondary active-glow" : "text-slate-400 hover:bg-white/5 hover:text-white") rounded-2xl transition-all duration-300 transform @(Context.Request.Path == "/Dashboard/Subscription" ? "scale-[1.02]" : "")">
                        <svg class="w-5 h-5 @(Context.Request.Path == "/Dashboard/Subscription" ? "text-white" : "group-hover:text-secondary transition-colors")" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
                        <span class="font-semibold tracking-tight text-sm">Subscription Plans</span>
                    </a>
                </div>

                <div class="pt-8 mb-10">
                    <p class="px-4 text-[10px] font-bold uppercase tracking-[0.2em] text-blue-400/60 pb-2">System Administrator Setup</p>
                    <a href="/Admin/UserManagement" class="group flex items-center space-x-3 p-4 @(Context.Request.Path == "/Admin/UserManagement" ? "bg-secondary active-glow" : "text-slate-400 hover:bg-white/5 hover:text-white") rounded-2xl transition-all duration-300 transform @(Context.Request.Path == "/Admin/UserManagement" ? "scale-[1.02]" : "")">
                        <svg class="w-5 h-5 @(Context.Request.Path == "/Admin/UserManagement" ? "text-white" : "group-hover:text-secondary transition-colors")" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
                        <span class="font-semibold tracking-tight text-sm">Team Provisioning</span>
                    </a>
                    <a href="/Admin/SystemSetup" class="group flex items-center space-x-3 p-4 @(Context.Request.Path == "/Admin/SystemSetup" ? "bg-secondary active-glow" : "text-slate-400 hover:bg-white/5 hover:text-white") rounded-2xl transition-all duration-300 transform @(Context.Request.Path == "/Admin/SystemSetup" ? "scale-[1.02]" : "")">
                        <svg class="w-5 h-5 @(Context.Request.Path == "/Admin/SystemSetup" ? "text-white" : "group-hover:text-secondary transition-colors")" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                        <span class="font-semibold tracking-tight text-sm">Intelligence Setup</span>
                    </a>
                    <a href="/Admin/ActivityLog" class="group flex items-center space-x-3 p-4 @(Context.Request.Path == "/Admin/ActivityLog" ? "bg-secondary active-glow" : "text-slate-400 hover:bg-white/5 hover:text-white") rounded-2xl transition-all duration-300 transform @(Context.Request.Path == "/Admin/ActivityLog" ? "scale-[1.02]" : "")">
                        <svg class="w-5 h-5 @(Context.Request.Path == "/Admin/ActivityLog" ? "text-white" : "group-hover:text-secondary transition-colors")" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                        <span class="font-semibold tracking-tight text-sm">Security Audit</span>
                    </a>
                </div>
            </nav>
            
            <div class="p-6">
                <div class="bg-white/5 border border-white/10 rounded-[2rem] p-5 backdrop-blur-md">
                    <div class="flex items-center space-x-3">
                        <div class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse"></div>
                        <p class="text-[10px] text-emerald-400 font-bold uppercase tracking-widest">System Active</p>
                    </div>
                    <p class="font-bold text-white mt-1 text-sm">CEO Terminal</p>
                </div>
            </div>
        </aside>

        <!-- Main Content Area -->
        <div class="flex-1 flex flex-col overflow-hidden">
            <!-- Header -->
            <header class="h-20 glass-header flex items-center justify-between px-10 z-20 sticky top-0 border-b border-slate-200/50">
                <div class="flex items-center space-x-4">
                     <span class="text-slate-400 text-xs font-bold uppercase tracking-widest">EDSS Dashboard</span>
                     <span class="text-slate-300 text-lg">/</span>
                     <span class="font-black text-slate-900 tracking-tight">EXECUTIVE OVERVIEW</span>
                </div>
                
                <div class="flex items-center space-x-8">
                    <div class="relative group">
                        <input type="text" placeholder="Search insights..." class="bg-slate-100/50 border-none rounded-2xl py-2 pl-10 pr-4 text-sm focus:ring-2 focus:ring-secondary/20 transition-all w-64" />
                        <svg class="w-4 h-4 absolute left-4 top-1/2 -translate-y-1/2 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                    </div>
                    <button class="relative text-slate-400 hover:text-secondary transition-colors">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
                        <span class="absolute top-0 right-0 w-2 h-2 bg-red-500 rounded-full border-2 border-white"></span>
                    </button>
                    <div class="flex items-center space-x-3 cursor-pointer group">
                        <div class="text-right">
                            <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Admin</p>
                            <p class="text-sm font-black text-slate-800 group-hover:text-secondary transition-colors">Core Dynamic</p>
                        </div>
                        <div class="h-12 w-12 bg-primary rounded-2xl flex items-center justify-center text-white text-xs font-bold shadow-lg shadow-blue-900/40 transform hover:rotate-6 transition-all">
                            CD
                        </div>
                    </div>
                </div>
            </header>

            <!-- Scrollable Page Content -->
            <main class="flex-1 overflow-y-auto px-10 py-10 bg-slate-50">
                <div class="max-w-7xl mx-auto animate-slide-in">
                    @RenderBody()
                </div>
            </main>
        </div>
    </div>

    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
