<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Coretex EDSS</title>
    
    <!-- Tailwind CSS Play CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#001A4D', // Deep Navy
                        secondary: '#006D68', // Teal
                        accent: '#FFF0AD', // Light Yellow
                        bg: '#F8FAFC'
                    },
                    fontFamily: {
                        sans: ['Inter', 'ui-sans-serif', 'system-ui'],
                    },
                }
            }
        }
    </script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        
        /* Premium Mesh Gradient for Sidebar */
        .sidebar-mesh {
            background-color: #001A4D;
            background-image: 
                radial-gradient(at 0% 0%, hsla(210,100%,15%,1) 0, transparent 50%), 
                radial-gradient(at 50% 0%, hsla(180,100%,10%,1) 0, transparent 50%);
        }

        /* Glassmorphism Header - Now Solid & Clean */
        .glass-header {
            background: #FFFFFF;
            border-bottom: 1px solid rgba(0,0,0,0.05);
        }

        /* Active Menu Glow */
        .active-glow {
            position: relative;
            box-shadow: 0 0 20px rgba(0, 109, 104, 0.4);
        }
        .active-glow::after {
            content: '';
            position: absolute;
            right: 0;
            top: 25%;
            height: 50%;
            width: 4px;
            background: #006D68;
            border-radius: 4px 0 0 4px;
        }

        /* Slide In Animation */
        @@keyframes slideIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate-slide-in {
            animation: slideIn 0.5s ease-out forwards;
        }

        /* Smooth Sidebar Transition */
        .sidebar-transition {
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        /* Custom Hover Scrollbar */
        .custom-scrollbar::-webkit-scrollbar {
            width: 4px;
        }
        .custom-scrollbar::-webkit-scrollbar-track {
            background: transparent;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.1);
            border-radius: 10px;
        }
        .custom-scrollbar:hover::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.2);
        }
    </style>
</head>
<body class="bg-gray-100 text-slate-800">
    <div class="flex h-screen overflow-hidden">
        <!-- Sidebar -->
        <aside class="hidden md:flex flex-col w-72 sidebar-mesh text-white sidebar-transition border-r border-white/5">
            <div class="p-8 flex items-center space-x-4">
                <div class="w-12 h-12 bg-white rounded-2xl flex items-center justify-center shadow-xl shadow-blue-900/40 transition-transform hover:scale-105">
                   <img src="/images/logo.png" alt="Logo" class="rounded-lg" /> 
                </div>
                <div>
                    <h1 class="text-2xl font-black tracking-tighter">CORETEX</h1>
                    <p class="text-[10px] text-blue-300 font-bold tracking-[0.2em] uppercase">Executive EDSS</p>
                </div>
            </div>
            
            <nav class="flex-1 px-6 py-8 space-y-3 overflow-y-auto custom-scrollbar">
                @if (User.IsInRole("CEO"))
                {
                    <a href="/ceo/dashboard" class="flex items-center space-x-3 p-4 @(Context.Request.Path == "/ceo/dashboard" || Context.Request.Path == "/ceo" ? "bg-secondary active-glow" : "text-slate-400 hover:bg-white/5 hover:text-white") rounded-2xl transition-all duration-300 transform @(Context.Request.Path == "/ceo/dashboard" || Context.Request.Path == "/ceo" ? "scale-[1.02]" : "")">
                        <svg class="w-5 h-5 @(Context.Request.Path == "/ceo/dashboard" || Context.Request.Path == "/ceo" ? "text-white" : "group-hover:text-secondary transition-colors")" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
                        <span class="font-bold tracking-tight text-sm">KPI Dashboard</span>
                    </a>
                    
                    <a href="/ceo/analytics/predictive" class="group flex items-center space-x-3 p-4 @(Context.Request.Path == "/ceo/analytics/predictive" ? "bg-secondary active-glow" : "text-slate-400 hover:bg-white/5 hover:text-white") rounded-2xl transition-all duration-300 transform @(Context.Request.Path == "/ceo/analytics/predictive" ? "scale-[1.02]" : "")">
                        <svg class="w-5 h-5 @(Context.Request.Path == "/ceo/analytics/predictive" ? "text-white" : "group-hover:text-secondary transition-colors")" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
                        <span class="font-semibold tracking-tight text-sm">Predictive Trend</span>
                    </a>
                    
                    <a href="/ceo/reports" class="group flex items-center space-x-3 p-4 @(Context.Request.Path == "/ceo/reports" ? "bg-secondary active-glow" : "text-slate-400 hover:bg-white/5 hover:text-white") rounded-2xl transition-all duration-300 transform @(Context.Request.Path == "/ceo/reports" ? "scale-[1.02]" : "")">
                        <svg class="w-5 h-5 @(Context.Request.Path == "/ceo/reports" ? "text-white" : "group-hover:text-secondary transition-colors")" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 2v-6m10 10V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2z"/></svg>
                        <span class="font-semibold tracking-tight text-sm">Exec Reporting</span>
                    </a>

                    <a href="/ceo/charts" class="group flex items-center space-x-3 p-4 @(Context.Request.Path == "/ceo/charts" ? "bg-secondary active-glow" : "text-slate-400 hover:bg-white/5 hover:text-white") rounded-2xl transition-all duration-300 transform @(Context.Request.Path == "/ceo/charts" ? "scale-[1.02]" : "")">
                        <svg class="w-5 h-5 @(Context.Request.Path == "/ceo/charts" ? "text-white" : "group-hover:text-secondary transition-colors")" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z"/></svg>
                        <span class="font-semibold tracking-tight text-sm">Data Viz & Insights</span>
                    </a>

                    <a href="/ceo/analytics/health-summary" class="group flex items-center space-x-3 p-4 @(Context.Request.Path == "/ceo/analytics/health-summary" ? "bg-secondary active-glow" : "text-slate-400 hover:bg-white/5 hover:text-white") rounded-2xl transition-all duration-300 transform @(Context.Request.Path == "/ceo/analytics/health-summary" ? "scale-[1.02]" : "")">
                        <svg class="w-5 h-5 @(Context.Request.Path == "/ceo/analytics/health-summary" ? "text-white" : "group-hover:text-secondary transition-colors")" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477-4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                        <span class="font-semibold tracking-tight text-sm">Decision Analytics</span>
                    </a>
                }

                @if (User.IsInRole("FINANCE"))
                {
                    <a href="/finance/dashboard" class="group flex items-center space-x-3 p-4 @(Context.Request.Path.StartsWithSegments("/finance") ? "bg-secondary active-glow" : "text-slate-400 hover:bg-white/5 hover:text-white") rounded-2xl transition-all duration-300 transform @(Context.Request.Path.StartsWithSegments("/finance") ? "scale-[1.02]" : "")">
                        <svg class="w-5 h-5 @(Context.Request.Path.StartsWithSegments("/finance") ? "text-white" : "group-hover:text-secondary transition-colors")" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                        <span class="font-semibold tracking-tight text-sm">Record Business Data</span>
                    </a>
                }

                @if (User.IsInRole("CASHIER"))
                {
                    <a href="/cashier/pos" class="group flex items-center space-x-3 p-4 @(Context.Request.Path.StartsWithSegments("/cashier") ? "bg-secondary active-glow" : "text-slate-400 hover:bg-white/5 hover:text-white") rounded-2xl transition-all duration-300 transform @(Context.Request.Path.StartsWithSegments("/cashier") ? "scale-[1.02]" : "")">
                        <svg class="w-5 h-5 @(Context.Request.Path.StartsWithSegments("/cashier") ? "text-white" : "group-hover:text-secondary transition-colors")" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
                        <span class="font-semibold tracking-tight text-sm">POS Transactions</span>
                    </a>
                }

                @if (User.IsInRole("ADMIN"))
                {
                    <div class="pt-8">
                        <p class="px-4 text-[10px] font-bold uppercase tracking-[0.2em] text-blue-400/60 pb-2">System Administration</p>
                    
                    <a href="/Admin" class="group flex items-center space-x-3 p-4 @(Context.Request.Path == "/Admin" ? "bg-secondary active-glow" : "text-slate-400 hover:bg-white/5 hover:text-white") rounded-2xl transition-all duration-300 transform @(Context.Request.Path == "/Admin" ? "scale-[1.02]" : "")">
                        <svg class="w-5 h-5 @(Context.Request.Path == "/Admin" ? "text-white" : "group-hover:text-secondary transition-colors")" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z" /></svg>
                        <span class="font-semibold tracking-tight text-sm">Admin Dashboard</span>
                    </a>

                    <a href="/Admin/BranchManagement" class="group flex items-center space-x-3 p-4 @(Context.Request.Path == "/Admin/BranchManagement" ? "bg-secondary active-glow" : "text-slate-400 hover:bg-white/5 hover:text-white") rounded-2xl transition-all duration-300 transform @(Context.Request.Path == "/Admin/BranchManagement" ? "scale-[1.02]" : "")">
                        <svg class="w-5 h-5 @(Context.Request.Path == "/Admin/BranchManagement" ? "text-white" : "group-hover:text-secondary transition-colors")" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
                        <span class="font-semibold tracking-tight text-sm">Branch Management</span>
                    </a>

                    <a href="/Admin/UserManagement" class="group flex items-center space-x-3 p-4 @(Context.Request.Path == "/Admin/UserManagement" ? "bg-secondary active-glow" : "text-slate-400 hover:bg-white/5 hover:text-white") rounded-2xl transition-all duration-300 transform @(Context.Request.Path == "/Admin/UserManagement" ? "scale-[1.02]" : "")">
                        <svg class="w-5 h-5 @(Context.Request.Path == "/Admin/UserManagement" ? "text-white" : "group-hover:text-secondary transition-colors")" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
                        <span class="font-semibold tracking-tight text-sm">User Management</span>
                    </a>

                    <a href="/Admin/ActivityLog" class="group flex items-center space-x-3 p-4 @(Context.Request.Path == "/Admin/ActivityLog" ? "bg-secondary active-glow" : "text-slate-400 hover:bg-white/5 hover:text-white") rounded-2xl transition-all duration-300 transform @(Context.Request.Path == "/Admin/ActivityLog" ? "scale-[1.02]" : "")">
                        <svg class="w-5 h-5 @(Context.Request.Path == "/Admin/ActivityLog" ? "text-white" : "group-hover:text-secondary transition-colors")" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                        <span class="font-semibold tracking-tight text-sm">Activity Log</span>
                    </a>

                    <a href="/Admin/BranchSubmissions" class="group flex items-center space-x-3 p-4 @(Context.Request.Path == "/Admin/BranchSubmissions" ? "bg-secondary active-glow" : "text-slate-400 hover:bg-white/5 hover:text-white") rounded-2xl transition-all duration-300 transform @(Context.Request.Path == "/Admin/BranchSubmissions" ? "scale-[1.02]" : "")">
                        <svg class="w-5 h-5 @(Context.Request.Path == "/Admin/BranchSubmissions" ? "text-white" : "group-hover:text-secondary transition-colors")" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        <span class="font-semibold tracking-tight text-sm">Branch Submissions</span>
                    </a>

                    <a href="/Admin/AuditTrail" class="group flex items-center space-x-3 p-4 @(Context.Request.Path == "/Admin/AuditTrail" ? "bg-secondary active-glow" : "text-slate-400 hover:bg-white/5 hover:text-white") rounded-2xl transition-all duration-300 transform @(Context.Request.Path == "/Admin/AuditTrail" ? "scale-[1.02]" : "")">
                        <svg class="w-5 h-5 @(Context.Request.Path == "/Admin/AuditTrail" ? "text-white" : "group-hover:text-secondary transition-colors")" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/></svg>
                        <span class="font-semibold tracking-tight text-sm">Audit Trail</span>
                    </a>
                </div>

                <div class="pt-8 mb-10">
                    <p class="px-4 text-[10px] font-bold uppercase tracking-[0.2em] text-blue-400/60 pb-2">Configuration</p>

                    <a href="/Admin/KPIThresholds" class="group flex items-center space-x-3 p-4 @(Context.Request.Path == "/Admin/KPIThresholds" ? "bg-secondary active-glow" : "text-slate-400 hover:bg-white/5 hover:text-white") rounded-2xl transition-all duration-300 transform @(Context.Request.Path == "/Admin/KPIThresholds" ? "scale-[1.02]" : "")">
                        <svg class="w-5 h-5 @(Context.Request.Path == "/Admin/KPIThresholds" ? "text-white" : "group-hover:text-secondary transition-colors")" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                        <span class="font-semibold tracking-tight text-sm">KPI Thresholds</span>
                    </a>

                    <a href="/Admin/GoalsTargets" class="group flex items-center space-x-3 p-4 @(Context.Request.Path == "/Admin/GoalsTargets" ? "bg-secondary active-glow" : "text-slate-400 hover:bg-white/5 hover:text-white") rounded-2xl transition-all duration-300 transform @(Context.Request.Path == "/Admin/GoalsTargets" ? "scale-[1.02]" : "")">
                        <svg class="w-5 h-5 @(Context.Request.Path == "/Admin/GoalsTargets" ? "text-white" : "group-hover:text-secondary transition-colors")" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        <span class="font-semibold tracking-tight text-sm">Goals & Targets</span>
                    </a>

                    <a href="/Admin/ReportSchedule" class="group flex items-center space-x-3 p-4 @(Context.Request.Path == "/Admin/ReportSchedule" ? "bg-secondary active-glow" : "text-slate-400 hover:bg-white/5 hover:text-white") rounded-2xl transition-all duration-300 transform @(Context.Request.Path == "/Admin/ReportSchedule" ? "scale-[1.02]" : "")">
                        <svg class="w-5 h-5 @(Context.Request.Path == "/Admin/ReportSchedule" ? "text-white" : "group-hover:text-secondary transition-colors")" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                        <span class="font-semibold tracking-tight text-sm">Report Schedules</span>
                    </a>
                </div>
                }

                <!-- Shared Links -->
                <div class="pt-4 pb-10 border-t border-white/5">
                    <a href="/Profile" class="group flex items-center space-x-3 p-4 @(Context.Request.Path == "/Profile" ? "bg-secondary active-glow" : "text-slate-400 hover:bg-white/5 hover:text-white") rounded-2xl transition-all duration-300">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
                        <span class="font-bold tracking-tight text-sm">My Profile</span>
                    </a>
                </div>
            </nav>
            
            <div class="p-6">
                <div class="bg-white/5 border border-white/10 rounded-[2rem] p-5 backdrop-blur-md">
                    <div class="flex items-center space-x-3">
                        <div class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse"></div>
                        <p class="text-[10px] text-emerald-400 font-bold uppercase tracking-widest">System Active</p>
                    </div>
                    <p class="font-bold text-white mt-1 text-sm">@(User.IsInRole("CEO") ? "CEO Terminal" : User.IsInRole("ADMIN") ? "Admin Terminal" : User.IsInRole("FINANCE") ? "Finance Terminal" : "Cashier Terminal")</p>
                </div>
            </div>
        </aside>

        <!-- Main Content Area -->
        <div class="flex-1 flex flex-col overflow-hidden">
            <!-- Header -->
            <header class="h-20 glass-header flex items-center justify-between px-10 z-20 sticky top-0 border-b border-slate-200/50">
                <div class="flex items-center space-x-4">
                     <span id="role-badge" class="px-3 py-1 bg-primary text-white text-[9px] font-black uppercase tracking-widest rounded-lg">@(User.IsInRole("CEO") ? "CEO Mode" : User.IsInRole("ADMIN") ? "Admin Mode" : User.IsInRole("FINANCE") ? "Finance Mode" : "Staff Mode")</span>
                     <span class="text-slate-300 text-lg">/</span>
                     <span id="page-crumb" class="font-black text-slate-900 tracking-tight uppercase">Dashboard Overview</span>
                </div>
                
                <div class="flex items-center space-x-8">
                    <div class="relative group">
                        <input type="text" placeholder="Search insights..." class="bg-slate-100/50 border-none rounded-2xl py-2 pl-10 pr-4 text-sm focus:ring-2 focus:ring-secondary/20 transition-all w-64" />
                        <svg class="w-4 h-4 absolute left-4 top-1/2 -translate-y-1/2 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                    </div>

                    <!-- Notification Toggle -->
                    <div class="relative">
                        <button onclick="toggleNotifications()" class="relative text-slate-400 hover:text-secondary transition-colors">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
                            <span id="notif-dot" class="absolute top-0 right-0 w-2 h-2 bg-red-500 rounded-full border-2 border-white"></span>
                        </button>
                        <!-- Notif Dropdown -->
                        <div id="notif-dropdown" class="hidden absolute right-0 mt-4 w-80 bg-white border border-slate-100 shadow-2xl rounded-[2rem] p-6 text-left animate-in fade-in slide-in-from-top-2">
                            <h4 class="font-black text-slate-800 text-sm mb-4">Command Center Alerts</h4>
                            <div class="space-y-4" id="notif-list">
                                <div class="flex items-start space-x-3 p-3 bg-red-50 rounded-2xl border border-red-100">
                                    <div class="w-2 h-2 bg-red-500 rounded-full mt-1.5 animate-pulse"></div>
                                    <div>
                                        <p class="text-[11px] font-bold text-red-900 leading-tight">Strategic Risk Detected: High operational expense ratio in South Branch.</p>
                                        <p class="text-[9px] text-red-500 font-black uppercase mt-1">2 mins ago</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="flex items-center space-x-6">
                        <div class="text-right">
                            <p id="user-role-label" class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">@(User.IsInRole("CEO") ? "CEO" : User.IsInRole("ADMIN") ? "Admin" : User.IsInRole("FINANCE") ? "Finance" : "Staff")</p>
                            <p id="user-name-label" class="text-sm font-black text-slate-800">@(User.Identity?.Name ?? "Guest")</p>
                        </div>
                        
                        <form asp-controller="Home" asp-action="Logout" method="post" id="logoutForm" class="inline">
                            <button type="submit" class="group relative">
                                <div id="user-avatar" class="h-12 w-12 bg-primary rounded-2xl flex items-center justify-center text-white text-xs font-bold shadow-lg shadow-blue-900/40 transition-all hover:scale-105 group-hover:rotate-6 overflow-hidden">
                                     <img src="https://ui-avatars.com/api/?name=@(User.Identity?.Name)&background=random" class="w-full h-full object-cover" alt="Avatar" />
                                </div>
                                <div class="absolute -top-1 -right-1 w-5 h-5 bg-red-500 rounded-full border-2 border-white flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                                    <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
                                </div>
                            </button>
                        </form>
                    </div>
                </div>
            </header>

            <!-- Scrollable Page Content -->
            <main class="flex-1 overflow-y-auto px-10 py-10 bg-slate-50">
                <div class="max-w-7xl mx-auto animate-slide-in">
                    @RenderBody()
                </div>
            </main>
        </div>
    </div>

    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        function toggleNotifications() {
            const dropdown = document.getElementById('notif-dropdown');
            dropdown.classList.toggle('hidden');
            document.getElementById('notif-dot').classList.add('hidden');
        }
    </script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
