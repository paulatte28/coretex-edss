<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - coretex_finalproj</title>
    <!-- Tailwind CSS Play CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#001A4D', // Deep Navy
                        secondary: '#006D68', // Teal
                        accent: '#FFF0AD', // Light Yellow
                        bg: '#F8FAFC'
                    },
                    fontFamily: {
                        sans: ['Inter', 'ui-sans-serif', 'system-ui'],
                    },
                }
            }
        }
    </script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        body { 
            font-family: 'Inter', sans-serif; 
            background-color: #f8fafc;
            overflow-x: hidden;
        }

        /* Mesh Gradient Background */
        .mesh-bg {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
            background-color: #f8fafc;
            background-image: 
                radial-gradient(at 0% 0%, hsla(210,100%,95%,1) 0, transparent 50%), 
                radial-gradient(at 100% 0%, hsla(180,100%,95%,1) 0, transparent 50%),
                radial-gradient(at 100% 100%, hsla(210,100%,95%,1) 0, transparent 50%),
                radial-gradient(at 0% 100%, hsla(180,100%,95%,1) 0, transparent 50%);
            filter: blur(100px);
            opacity: 0.8;
        }

        /* Glassmorphism Navigation */
        .glass-nav {
            background: rgba(255, 255, 255, 0.6);
            backdrop-filter: blur(20px) saturate(180%);
            -webkit-backdrop-filter: blur(20px) saturate(180%);
            border-bottom: 1px solid rgba(255, 255, 255, 0.3);
        }

        .nav-link-premium {
            position: relative;
            font-weight: 700;
            font-size: 0.85rem;
            letter-spacing: -0.01em;
            padding: 0.5rem 1rem;
            color: #475569; /* Slate-600 */
            transition: all 0.3s ease;
        }

        .nav-link-premium:hover {
            color: #0f172a; /* Slate-900 */
        }

        .nav-link-premium.active {
            color: #006D68;
        }
        
        /* Premium Buttons */
        .btn-glow {
            box-shadow: 0 0 20px rgba(0, 109, 104, 0.1);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .btn-glow:hover {
            box-shadow: 0 10px 30px rgba(0, 109, 104, 0.2);
            transform: translateY(-2px);
        }
    </style>
</head>
<body class="selection:bg-secondary/20 selection:text-secondary">
    <div class="mesh-bg"></div>
    
    <header class="fixed top-0 left-0 w-full z-50">
        <nav class="glass-nav h-20 md:h-24">
            <div class="max-w-7xl mx-auto h-full px-6 flex items-center justify-between">
                <!-- Logo -->
                <a href="/" class="flex items-center space-x-3 group">
                    <div class="w-12 h-12 bg-white rounded-2xl flex items-center justify-center shadow-xl shadow-slate-200 group-hover:rotate-6 transition-transform overflow-hidden p-1">
                        <img src="/images/logo.png" alt="Coretex Logo" class="w-full h-full object-contain" />
                    </div>
                    <div class="hidden sm:block">
                        <span class="text-xl font-black text-slate-900 tracking-tighter">CORETEX</span>
                        <p class="text-[8px] font-black text-slate-500 uppercase tracking-[0.3em] -mt-1 leading-none">Decision Engine</p>
                    </div>
                </a>

                <!-- Links -->
                <div class="flex items-center space-x-2 md:space-x-4">
                    <a href="/" class="nav-link-premium @(Context.Request.Path == "/" ? "active" : "")">Home</a>
                    <a href="/Home/Privacy" class="nav-link-premium @(Context.Request.Path == "/Home/Privacy" ? "active" : "")">Privacy</a>
                    <a href="/ceo/dashboard" class="nav-link-premium @(Context.Request.Path == "/ceo/dashboard" ? "active" : "")">Dashboard</a>
                    <a href="/Admin" class="nav-link-premium">Admin</a>
                    <a href="/Home/Login" class="ml-4 px-6 py-3 bg-slate-900 text-white text-xs font-black rounded-xl hover:bg-slate-800 transition-all shadow-xl shadow-slate-900/10">
                        Sign In
                    </a>
                </div>
            </div>
        </nav>
    </header>

    <main id="main-content" class="pt-24 md:pt-32">
        @RenderBody()
    </main>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - coretex_finalproj - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
