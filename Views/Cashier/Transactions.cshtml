@model IEnumerable<coretex_finalproj.Models.Sale>
@{
    ViewData["Title"] = "Transaction History";
    Layout = "_AdminLayout";
}

<div class="space-y-8">
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
        <div>
            <h2 class="text-3xl font-black text-slate-900 tracking-tight">Transaction History</h2>
            <p class="text-xs text-slate-400 font-bold uppercase tracking-widest mt-1">Real-time database records</p>
        </div>
        <div class="flex items-center gap-3">
            <form method="get" class="flex items-center gap-2">
                <input type="text" name="search" value="@ViewBag.SearchTerm" placeholder="Order ID or Customer..." class="px-4 py-2 bg-white border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-indigo-500 outline-none w-64" />
                <button type="submit" class="px-4 py-2 bg-indigo-600 text-white text-xs font-black rounded-xl hover:bg-indigo-700 transition-all">Search</button>
                @if (!string.IsNullOrEmpty(ViewBag.SearchTerm))
                {
                    <a href="/Cashier/Transactions" class="text-xs text-slate-400 hover:text-slate-600 font-bold">Clear</a>
                }
            </form>
        </div>
    </div>

    <div class="bg-white rounded-3xl shadow-sm border border-slate-100 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead class="bg-slate-50">
                    <tr>
                        <th class="px-6 py-4 text-left text-[10px] font-black text-slate-500 uppercase tracking-widest">Date</th>
                        <th class="px-6 py-4 text-left text-[10px] font-black text-slate-500 uppercase tracking-widest">Order ID</th>
                        <th class="px-6 py-4 text-left text-[10px] font-black text-slate-500 uppercase tracking-widest">Customer</th>
                        <th class="px-6 py-4 text-right text-[10px] font-black text-slate-500 uppercase tracking-widest">Amount</th>
                        <th class="px-6 py-4 text-center text-[10px] font-black text-slate-500 uppercase tracking-widest">Status</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="px-6 py-12 text-center text-slate-400 text-sm italic">No records found matching your search.</td>
                        </tr>
                    }
                    @foreach (var sale in Model)
                    {
                        <tr class="hover:bg-slate-50 transition-colors">
                            <td class="px-6 py-4 text-sm text-slate-600">@sale.Date.ToString("MMM dd, yyyy HH:mm")</td>
                            <td class="px-6 py-4 text-sm font-black text-slate-900">#@sale.OrderId</td>
                            <td class="px-6 py-4 text-sm text-slate-600">@sale.CustomerName</td>
                            <td class="px-6 py-4 text-sm font-black text-slate-900 text-right">@sale.Amount.ToString("C")</td>
                            <td class="px-6 py-4 text-center">
                                <span class="px-3 py-1 bg-emerald-100 text-emerald-700 text-[10px] font-black uppercase rounded-full">@sale.Status</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>