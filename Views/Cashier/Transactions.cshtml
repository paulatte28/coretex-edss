@model List<coretex_finalproj.Models.Sale>
@{
    ViewData["Title"] = "Transaction Repository";
    Layout = "_AdminLayout";
}

<div class="space-y-10 pb-10">
    <!-- Header Area -->
    <div class="relative bg-slate-900 rounded-[3rem] p-12 overflow-hidden shadow-2xl animate-slide-in">
        <div class="relative z-10 flex flex-col md:flex-row md:items-center justify-between gap-8">
            <div>
                <div class="flex items-center space-x-3 mb-4">
                    <span class="px-3 py-1 bg-indigo-500/20 text-indigo-300 font-black text-[10px] uppercase tracking-widest rounded-full border border-indigo-500/30">Transactional Core</span>
                </div>
                <h1 class="text-4xl font-black text-white tracking-tighter uppercase">Transaction <span class="text-indigo-400">Ledger</span></h1>
                <p class="text-slate-400 mt-2 text-sm font-medium">Reviewing the absolute audit trail of branch-level retail operations.</p>
            </div>
            <div class="flex items-center space-x-4">
                <div class="text-right hidden md:block">
                    <p class="text-[10px] font-black text-slate-500 uppercase tracking-widest">Total Volume</p>
                    <p class="text-2xl font-black text-white tracking-tighter">₱@Model.Sum(x => (decimal)x.Amount).ToString("N0")</p>
                </div>
                <div class="w-16 h-16 bg-white/5 rounded-3xl flex items-center justify-center border border-white/10 backdrop-blur-md">
                    <svg class="w-8 h-8 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/></svg>
                </div>
            </div>
        </div>
        <div class="absolute top-0 right-0 -mr-20 -mt-20 w-80 h-80 bg-indigo-500/10 rounded-full blur-3xl"></div>
    </div>

    <!-- Hifi Table Container -->
    <div class="bg-white rounded-[3rem] border border-slate-100 shadow-sm overflow-hidden animate-slide-in" style="animation-delay: 0.1s">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="border-b border-slate-50">
                        <th class="px-10 py-6 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">Temporal Context</th>
                        <th class="px-10 py-6 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">Transaction ID</th>
                        <th class="px-10 py-6 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">Customer Entity</th>
                        <th class="px-10 py-6 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">Settlement Amount</th>
                        <th class="px-10 py-6 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">Status</th>
                        <th class="px-10 py-6 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50">
                    @{
                        var groupedSales = Model.GroupBy(s => s.OrderId)
                                               .OrderByDescending(g => g.First().Date);
                    }
                    @foreach (var group in groupedSales)
                    {
                        var first = group.First();
                        var totalAmount = group.Sum(s => s.Amount);
                        var itemCount = group.Count();
                        var itemsJson = System.Text.Json.JsonSerializer.Serialize(group.Select(i => new { i.ProductName, i.Quantity, i.UnitPrice, i.Amount }));

                        <tr class="group hover:bg-slate-50/50 transition-all duration-300">
                            <td class="px-10 py-8">
                                <div class="flex flex-col">
                                    <span class="text-sm font-black text-slate-900 tracking-tight">@first.Date.ToString("MMM dd, yyyy")</span>
                                    <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">@first.Date.ToString("HH:mm:ss")</span>
                                </div>
                            </td>
                            <td class="px-10 py-8">
                                <div class="flex items-center space-x-2">
                                    <div class="w-6 h-6 rounded-lg bg-slate-900 flex items-center justify-center text-[10px] text-white font-black shadow-lg">#</div>
                                    <span class="text-xs font-mono font-bold text-slate-700 tracking-tight">@first.OrderId</span>
                                </div>
                            </td>
                            <td class="px-10 py-8">
                                <div class="flex flex-col">
                                    <span class="text-sm font-bold text-slate-600">@first.CustomerName</span>
                                    <span class="text-[9px] font-black text-indigo-500 uppercase mt-1">@itemCount Item(s)</span>
                                </div>
                            </td>
                            <td class="px-10 py-8">
                                <span class="text-lg font-black text-slate-900 tracking-tighter">₱@totalAmount.ToString("N0")</span>
                            </td>
                            <td class="px-10 py-8">
                                <div class="flex items-center space-x-2">
                                    <div class="w-1.5 h-1.5 rounded-full bg-emerald-500"></div>
                                    <span class="text-[10px] font-black text-emerald-600 uppercase tracking-widest">Authenticated</span>
                                </div>
                            </td>
                            <td class="px-10 py-8 text-right">
                                <button onclick="viewReceipt('@first.OrderId', '@first.Date.ToString("MMM dd, yyyy HH:mm")', '@first.CustomerName', @itemsJson, @totalAmount)" 
                                        class="w-10 h-10 bg-slate-100 text-slate-400 rounded-xl flex items-center justify-center hover:bg-indigo-600 hover:text-white transition-all shadow-sm">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Modals {
    <!-- DIGITAL RECEIPT MODAL -->
    <div id="receipt-modal" onclick="if(event.target === this) closeReceipt()" class="fixed inset-0 z-[9999] flex items-center justify-center bg-slate-900/60 backdrop-blur-[40px] opacity-0 pointer-events-none transition-all duration-500">
        <div class="bg-white w-full max-w-md rounded-[3rem] shadow-[0_32px_64px_-15px_rgba(0,0,0,0.5)] overflow-hidden transform scale-95 transition-all duration-300 relative" id="receipt-content">
            <!-- Close Button -->
            <button onclick="closeReceipt()" class="absolute top-6 right-6 w-10 h-10 bg-slate-50 text-slate-400 rounded-2xl flex items-center justify-center hover:bg-rose-50 hover:text-rose-600 transition-all z-[110] group">
                <svg class="w-5 h-5 transition-transform group-hover:rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>

            <div class="p-8 border-b border-slate-100 text-center relative">
                <div class="w-16 h-16 bg-indigo-600 rounded-3xl flex items-center justify-center mx-auto mb-4 shadow-xl shadow-indigo-200">
                    <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" /></svg>
                </div>
                <h3 class="text-xl font-black text-slate-900 uppercase tracking-tighter">Transaction Authenticated</h3>
                <p class="text-[10px] font-black text-indigo-500 uppercase tracking-[0.3em] mt-1">Coretex Secure Repository</p>
            </div>
            
            <div class="p-10 space-y-8 bg-slate-50/50 max-h-[400px] overflow-y-auto">
                <div class="grid grid-cols-2 gap-6">
                    <div>
                        <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest mb-1">Order ID</p>
                        <p id="r-order-id" class="text-sm font-mono font-black text-slate-900 tracking-tighter"></p>
                    </div>
                    <div class="text-right">
                        <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest mb-1">Timestamp</p>
                        <p id="r-date" class="text-xs font-bold text-slate-600"></p>
                    </div>
                </div>

                <div class="p-4 bg-white rounded-2xl border border-slate-100">
                    <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest mb-1">Customer Identifier</p>
                    <p id="r-customer" class="text-sm font-black text-slate-900"></p>
                </div>

                <div class="space-y-4">
                    <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest border-b border-slate-100 pb-2">Manifest Summary</p>
                    <div id="r-items-list" class="space-y-4">
                        <!-- Items injected here -->
                    </div>
                </div>
            </div>

            <div class="p-8 bg-white border-t border-slate-100">
                <div class="flex justify-between items-center mb-6">
                    <p class="text-sm font-black text-slate-900 uppercase tracking-tighter">Grand Total</p>
                    <p id="r-total" class="text-2xl font-black text-indigo-600 tracking-tighter"></p>
                </div>
                <button onclick="window.print()" class="w-full py-5 bg-slate-900 text-white rounded-2xl font-black text-[10px] uppercase tracking-widest hover:bg-slate-800 transition-all flex items-center justify-center space-x-3 shadow-xl shadow-slate-200">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/></svg>
                    <span>Print Transaction Record</span>
                </button>
            </div>
        </div>
    </div>
}

<script>
    function viewReceipt(id, date, customer, items, total) {
        document.getElementById('r-order-id').innerText = '#' + id;
        document.getElementById('r-date').innerText = date;
        document.getElementById('r-customer').innerText = customer;
        document.getElementById('r-total').innerText = '₱' + total.toLocaleString();

        const list = document.getElementById('r-items-list');
        list.innerHTML = items.map(i => `
            <div class="flex justify-between items-start">
                <div>
                    <p class="text-xs font-black text-slate-900">${i.ProductName}</p>
                    <p class="text-[10px] text-slate-400 font-bold mt-1">${i.Quantity} Unit(s) x ₱${i.UnitPrice.toLocaleString()}</p>
                </div>
                <p class="text-xs font-black text-slate-900">₱${i.Amount.toLocaleString()}</p>
            </div>
        `).join('');

        const modal = document.getElementById('receipt-modal');
        const content = document.getElementById('receipt-content');
        modal.classList.remove('opacity-0', 'pointer-events-none');
        content.classList.remove('scale-95');
    }

    function closeReceipt() {
        const modal = document.getElementById('receipt-modal');
        const content = document.getElementById('receipt-content');
        modal.classList.add('opacity-0', 'pointer-events-none');
        content.classList.add('scale-95');
    }
</script>