@{
    ViewData["Title"] = "Executive Retail Node";
    Layout = "_AdminLayout";
}

<style>
    .pos-grid-bg {
        background-color: #f8fafc;
        background-image: radial-gradient(#e2e8f0 1px, transparent 1px);
        background-size: 20px 20px;
    }
    .product-card:hover .product-icon {
        transform: scale(1.1) rotate(5deg);
    }
    .data-flow-pulse {
        box-shadow: 0 0 0 0 rgba(99, 102, 241, 0.4);
        animation: pulse-indigo 2s infinite;
    }
    @@keyframes pulse-indigo {
        0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(99, 102, 241, 0.7); }
        70% { transform: scale(1); box-shadow: 0 0 0 10px rgba(99, 102, 241, 0); }
        100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(99, 102, 241, 0); }
    }
</style>

<div class="space-y-6 pb-20 animate-slide-in">
    <!-- NEW: CEO DIRECTIVE BANNER (Real-time Command Receiver) -->
    <div id="ceo-directive-banner" class="hidden transform transition-all duration-700 -translate-y-10 opacity-0 mb-6">
        <div class="bg-indigo-600 rounded-3xl p-6 text-white shadow-2xl border-4 border-indigo-400 flex items-center justify-between relative overflow-hidden">
            <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.png')] opacity-20"></div>
            <div class="relative z-10 flex items-center space-x-6">
                <div class="w-14 h-14 bg-white/20 rounded-2xl flex items-center justify-center animate-pulse">
                    <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                </div>
                <div>
                    <p class="text-[10px] font-black text-indigo-200 uppercase tracking-[0.4em] mb-1">Executive Directive Active</p>
                    <h3 class="text-xl font-black tracking-tight">CEO ORDER: MANDATORY PRICING FLOOR</h3>
                    <p class="text-xs text-indigo-100 mt-1 font-bold">Manual discounts are disabled. Minimum 20% markup enforced on all transactions.</p>
                </div>
            </div>
            <div class="relative z-10 hidden md:block">
                <div class="px-4 py-2 bg-white/10 rounded-xl border border-white/20">
                    <span class="text-[10px] font-black uppercase tracking-widest text-indigo-100">Status: ENFORCED</span>
                </div>
            </div>
        </div>
    </div>

    <!-- NEW: MARKETING BLITZ BANNER (Real-time Growth Receiver) -->
    <div id="marketing-blitz-banner" class="hidden transform transition-all duration-700 -translate-y-10 opacity-0 mb-6">
        <div class="bg-emerald-500 rounded-3xl p-6 text-white shadow-2xl border-4 border-emerald-300 flex items-center justify-between relative overflow-hidden">
            <div class="relative z-10 flex items-center space-x-6">
                <div class="w-14 h-14 bg-white/20 rounded-2xl flex items-center justify-center animate-bounce">
                    <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
                </div>
                <div>
                    <p class="text-[10px] font-black text-emerald-100 uppercase tracking-[0.4em] mb-1">Growth Protocol Active</p>
                    <h3 class="text-xl font-black tracking-tight">🚀 MARKETING BLITZ: PROMOTION LIVE</h3>
                    <p class="text-xs text-emerald-50 mt-1 font-bold">Offer exclusive 'Coretex Bundles' to all customers to maximize revenue lift!</p>
                </div>
            </div>
            <div class="relative z-10 hidden md:block">
                <div class="px-4 py-2 bg-white/10 rounded-xl border border-white/20">
                    <span class="text-[10px] font-black uppercase tracking-widest text-emerald-100">Status: ACCELERATING</span>
                </div>
            </div>
        </div>
    </div>

    <!-- EXECUTIVE STATUS BAR -->
    <div class="bg-slate-900 rounded-[2.5rem] p-8 text-white shadow-2xl relative overflow-hidden">
        <div class="absolute top-0 right-0 w-64 h-64 bg-indigo-500/10 rounded-full blur-3xl -mr-32 -mt-32"></div>
        <div class="relative z-10 flex flex-col md:flex-row md:items-center justify-between gap-6">
            <div>
                <div class="flex items-center space-x-3 mb-2">
                    <span class="px-3 py-1 bg-indigo-500/20 text-indigo-300 font-black text-[10px] uppercase tracking-widest rounded-full border border-indigo-500/30">Node Active</span>
                    <span class="text-[10px] text-slate-500 font-bold uppercase tracking-widest">Branch: <span class="text-white">@(ViewBag.BranchName ?? "Davao HQ")</span></span>
                </div>
                <h2 class="text-4xl font-black tracking-tight">Executive Retail Terminal</h2>
                <p class="text-slate-400 mt-1 text-sm font-medium">Capture daily operations and commit transactional data to the enterprise core.</p>
            </div>
            <div class="flex items-center space-x-6">
                <div class="text-right">
                    <p class="text-[10px] font-black text-slate-500 uppercase tracking-widest mb-1">SQL Link Status</p>
                    <div class="flex items-center space-x-2 bg-emerald-500/10 border border-emerald-500/20 px-4 py-2 rounded-2xl">
                        <div class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></div>
                        <span class="text-xs font-black text-emerald-500 uppercase tracking-widest">Synchronized</span>
                    </div>
                </div>
                <div class="w-16 h-16 bg-white/5 rounded-3xl flex items-center justify-center border border-white/10 backdrop-blur-md">
                    <svg class="w-8 h-8 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"/></svg>
                </div>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
        <!-- PRODUCT DISCOVERY ENGINE -->
        <div class="lg:col-span-8 space-y-6">
            <div class="bg-white rounded-[3rem] border border-slate-100 shadow-sm p-10 flex flex-col h-[800px]">
                <div class="flex items-center justify-between mb-8">
                    <div>
                        <h3 class="text-xl font-black text-slate-900 tracking-tight">Available Inventory</h3>
                        <p class="text-xs text-slate-400 font-bold uppercase mt-1 tracking-widest">Live from SQL Warehouse</p>
                    </div>
                    <div class="flex bg-slate-100 p-1.5 rounded-2xl space-x-1">
                        <button onclick="filterCategory('All')" class="category-btn px-4 py-2 text-[10px] font-black uppercase tracking-widest rounded-xl bg-white shadow-sm transition-all" data-cat="All">All Items</button>
                        <button onclick="filterCategory('Laptops')" class="category-btn px-4 py-2 text-[10px] font-black uppercase tracking-widest rounded-xl text-slate-400 hover:text-slate-600 transition-all" data-cat="Laptops">Laptops</button>
                        <button onclick="filterCategory('Components')" class="category-btn px-4 py-2 text-[10px] font-black uppercase tracking-widest rounded-xl text-slate-400 hover:text-slate-600 transition-all" data-cat="Components">Parts</button>
                        <button onclick="filterCategory('Infrastructure')" class="category-btn px-4 py-2 text-[10px] font-black uppercase tracking-widest rounded-xl text-slate-400 hover:text-slate-600 transition-all" data-cat="Infrastructure">Infrastructure</button>
                        <button onclick="filterCategory('Software')" class="category-btn px-4 py-2 text-[10px] font-black uppercase tracking-widest rounded-xl text-slate-400 hover:text-slate-600 transition-all" data-cat="Software">Software</button>
                    </div>
                </div>

                <div class="flex-grow overflow-y-auto pr-4 custom-scrollbar pos-grid-bg rounded-[2rem] p-6 border border-slate-50">
                    <!-- SEARCH BAR -->
                    <div class="mb-6 relative">
                        <input type="text" id="pos-search" onkeyup="filterProducts()" placeholder="Search Inventory (e.g. ZenBook, RTX, ERP...)" class="w-full py-4 pl-12 pr-4 bg-white border border-slate-200 rounded-2xl text-xs font-bold focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all outline-none shadow-sm">
                        <svg class="w-4 h-4 text-slate-400 absolute left-4 top-1/2 -translate-y-1/2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                    </div>

                    <div class="grid grid-cols-2 xl:grid-cols-3 gap-6" id="product-grid">
                        @if (ViewBag.Products != null)
                        {
                            foreach (var p in (IEnumerable<coretex_finalproj.Models.Product>)ViewBag.Products)
                            {
                                <button onclick="addToCart('@p.Id', '@p.Name', @p.Price)" 
                                        data-category="@p.Category"
                                        data-name="@p.Name.ToLower()"
                                        class="product-card p-6 bg-white rounded-3xl border border-slate-100 shadow-sm hover:shadow-xl hover:border-indigo-500 hover:-translate-y-1 transition-all text-left flex flex-col group">
                                    <div class="w-12 h-12 bg-slate-50 rounded-2xl flex items-center justify-center mb-4 product-icon transition-transform">
                                        <svg class="w-6 h-6 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                                    </div>
                                    <div class="flex items-center justify-between mb-1">
                                        <span class="text-[8px] font-black text-indigo-400 uppercase tracking-[0.2em]">@p.Category</span>
                                        @if (p.StockQuantity <= p.LowStockThreshold) {
                                            <span class="px-2 py-0.5 bg-rose-50 text-rose-500 text-[7px] font-black uppercase rounded-full border border-rose-100">Low Stock</span>
                                        } else {
                                            <span class="px-2 py-0.5 bg-emerald-50 text-emerald-500 text-[7px] font-black uppercase rounded-full border border-emerald-100">In Stock</span>
                                        }
                                    </div>
                                    <h4 class="text-sm font-black text-slate-900 leading-tight mb-2 truncate">@p.Name</h4>
                                    <div class="mt-auto pt-4 flex items-center justify-between border-t border-slate-50">
                                        <p class="text-lg font-black text-slate-900">₱@p.Price.ToString("N0")</p>
                                        <div class="w-8 h-8 bg-indigo-50 rounded-full flex items-center justify-center text-indigo-600 group-hover:bg-indigo-600 group-hover:text-white transition-colors">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M12 4v16m8-8H4"/></svg>
                                        </div>
                                    </div>
                                </button>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- TRANSACTION ENGINE -->
        <div class="lg:col-span-4 space-y-8">
            <div class="bg-white rounded-[3rem] border border-slate-100 shadow-sm p-8 h-[800px] flex flex-col">
                <div class="flex items-center justify-between mb-8">
                    <h3 class="text-[10px] font-black text-slate-400 uppercase tracking-[0.3em]">Transaction Cart</h3>
                    <div class="flex items-center space-x-2">
                        <span class="w-2 h-2 rounded-full bg-indigo-500 animate-pulse"></span>
                        <span class="text-[10px] font-black text-indigo-500 uppercase tracking-widest">Active Session</span>
                    </div>
                </div>

                <div id="cart-items" class="flex-grow overflow-y-auto pr-2 space-y-4 custom-scrollbar">
                    <div class="flex flex-col items-center justify-center h-full text-slate-200">
                        <div class="w-20 h-20 bg-slate-50 rounded-[2.5rem] flex items-center justify-center mb-4">
                            <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 11-8 0v4M5 9h14l1 12H4L5 9z" /></svg>
                        </div>
                        <p class="text-[10px] font-black uppercase tracking-[0.2em]">Awaiting input...</p>
                    </div>
                </div>

                    <div class="mt-8 pt-8 border-t border-slate-100 space-y-6">
                        <div id="margin-guard-row" class="hidden flex justify-between items-center p-3 bg-indigo-50 rounded-xl border border-indigo-100 animate-pulse">
                            <p class="text-[10px] font-black text-indigo-600 uppercase tracking-widest">Margin Protection (CEO)</p>
                            <p id="margin-guard-amt" class="text-sm font-bold text-indigo-700">+₱0.00</p>
                        </div>
                        <div id="marketing-blitz-row" class="hidden flex justify-between items-center p-3 bg-emerald-50 rounded-xl border border-emerald-100 animate-pulse">
                            <p class="text-[10px] font-black text-emerald-600 uppercase tracking-widest">Marketing Rebate (CEO)</p>
                            <p id="marketing-blitz-amt" class="text-sm font-bold text-emerald-700">-₱0.00</p>
                        </div>
                        <div class="space-y-3">
                            <div class="flex justify-between items-center">
                                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Operational Tax</p>
                                <p class="text-sm font-bold text-slate-900">₱0.00</p>
                            </div>
                            <div class="flex justify-between items-center">
                                <p class="text-xs font-black text-slate-900 uppercase tracking-widest">Grand Total</p>
                                <p id="cart-total" class="text-3xl font-black tracking-tighter text-indigo-600">₱0.00</p>
                            </div>
                        </div>
                    
                    <button id="checkout-btn" onclick="processCheckout()" disabled class="w-full py-6 bg-slate-900 disabled:bg-slate-100 disabled:text-slate-400 text-white rounded-3xl font-black text-sm uppercase tracking-widest shadow-2xl shadow-slate-900/20 hover:bg-slate-800 transition-all flex items-center justify-center space-x-3">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" /></svg>
                        <span>Finalize Commitment</span>
                    </button>
                    
                    <div class="flex items-center justify-center space-x-4">
                         <div class="flex items-center space-x-1.5 opacity-50">
                            <svg class="w-3 h-3 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                            <span class="text-[8px] font-black uppercase tracking-widest text-slate-500">AES-256 Commit</span>
                         </div>
                         <div class="flex items-center space-x-1.5 opacity-50">
                            <svg class="w-3 h-3 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/></svg>
                            <span class="text-[8px] font-black uppercase tracking-widest text-slate-500">Cloud Link Ready</span>
                         </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- DATA COMMIT OVERLAY (The "Proof") -->
<div id="success-overlay" class="fixed inset-0 bg-slate-900/95 z-[100] flex items-center justify-center opacity-0 pointer-events-none transition-all duration-500">
    <div class="text-center space-y-8">
        <div class="relative inline-block">
             <div class="w-32 h-32 bg-indigo-500 rounded-[3rem] flex items-center justify-center mx-auto scale-50 transition-all duration-700 data-flow-pulse" id="success-icon">
                <svg class="w-16 h-16 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" /></svg>
            </div>
        </div>
        <div class="space-y-3">
            <h2 class="text-white text-5xl font-black tracking-tight uppercase" id="success-title">Committing to SQL...</h2>
            <div class="flex items-center justify-center space-x-3 text-indigo-400 font-black text-xs uppercase tracking-[0.5em]">
                <span id="success-step">Initializing Secure Pipeline</span>
                <span class="animate-bounce">...</span>
            </div>
        </div>
        <div class="pt-10 grid grid-cols-3 gap-8 max-w-lg mx-auto border-t border-white/10 opacity-50">
            <div><p class="text-[9px] text-slate-500 font-bold uppercase mb-1">Source</p><p class="text-xs text-white font-black">Node-01</p></div>
            <div><p class="text-[9px] text-slate-500 font-bold uppercase mb-1">Target</p><p class="text-xs text-white font-black">Core_DB</p></div>
            <div><p class="text-[9px] text-slate-500 font-bold uppercase mb-1">ID</p><p class="text-xs text-white font-black" id="success-order-id">#PENDING</p></div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            renderCart();
            filterCategory('All');
               // EXECUTIVE DIRECTIVE LISTENER (Real-time bridge for the demo)
            setInterval(() => {
                const isEnforced = localStorage.getItem('coretex_pricing_floor');
                const isBlitz = localStorage.getItem('coretex_marketing_blitz');
                
                // Pricing Floor Banner Logic
                const banner = document.getElementById('ceo-directive-banner');
                if (isEnforced === 'true') {
                    if (banner.classList.contains('hidden')) {
                        banner.classList.remove('hidden');
                        setTimeout(() => banner.classList.remove('-translate-y-10', 'opacity-0'), 50);
                        renderCart();
                    }
                } else {
                    if (!banner.classList.contains('hidden')) {
                        banner.classList.add('-translate-y-10', 'opacity-0');
                        setTimeout(() => { banner.classList.add('hidden'); renderCart(); }, 700);
                    }
                }

                // Marketing Blitz Banner Logic
                const blitzBanner = document.getElementById('marketing-blitz-banner');
                if (isBlitz === 'true') {
                    if (blitzBanner.classList.contains('hidden')) {
                        blitzBanner.classList.remove('hidden');
                        setTimeout(() => blitzBanner.classList.remove('-translate-y-10', 'opacity-0'), 50);
                    }
                } else {
                    if (!blitzBanner.classList.contains('hidden')) {
                        blitzBanner.classList.add('-translate-y-10', 'opacity-0');
                        setTimeout(() => blitzBanner.classList.add('hidden'), 700);
                    }
                }
            }, 1000);
        });

        let cart = [];

        function filterProducts() {
            const query = document.getElementById('pos-search').value.toLowerCase();
            const cards = document.querySelectorAll('.product-card');
            const activeCat = document.querySelector('.category-btn.bg-white').dataset.cat;

            cards.forEach(c => {
                const name = c.dataset.name;
                const cat = c.dataset.category;
                const matchesSearch = name.includes(query);
                const matchesCat = activeCat === 'All' || cat === activeCat;

                if (matchesSearch && matchesCat) {
                    c.classList.remove('hidden');
                } else {
                    c.classList.add('hidden');
                }
            });
        }

        function filterCategory(cat) {
            const btns = document.querySelectorAll('.category-btn');
            btns.forEach(b => {
                if (b.dataset.cat === cat) {
                    b.classList.remove('text-slate-400', 'hover:text-slate-600');
                    b.classList.add('bg-white', 'shadow-sm', 'text-slate-900');
                } else {
                    b.classList.add('text-slate-400', 'hover:text-slate-600');
                    b.classList.remove('bg-white', 'shadow-sm', 'text-slate-900');
                }
            });

            const cards = document.querySelectorAll('.product-card');
            cards.forEach(c => {
                if (cat === 'All' || c.dataset.category === cat) {
                    c.classList.remove('hidden');
                } else {
                    c.classList.add('hidden');
                }
            });
        }

        function addToCart(id, name, price) {
            const existing = cart.find(i => i.id === id);
            if (existing) {
                existing.qty++;
            } else {
                cart.push({ id, name, price, qty: 1 });
            }
            renderCart();
        }

        function renderCart() {
            const container = document.getElementById('cart-items');
            const totalEl = document.getElementById('cart-total');
            const btn = document.getElementById('checkout-btn');

            if (cart.length === 0) {
                container.innerHTML = `
                    <div class="flex flex-col items-center justify-center h-full text-slate-200">
                        <div class="w-20 h-20 bg-slate-50 rounded-[2.5rem] flex items-center justify-center mb-4">
                            <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 11-8 0v4M5 9h14l1 12H4L5 9z" /></svg>
                        </div>
                        <p class="text-[10px] font-black uppercase tracking-[0.2em]">Awaiting input...</p>
                    </div>`;
                totalEl.textContent = "₱0";
                btn.disabled = true;
                return;
            }

            let total = 0;
            container.innerHTML = cart.map((item, index) => {
                const lineTotal = item.price * item.qty;
                total += lineTotal;
                return `
                    <div class="p-6 bg-slate-50 border border-slate-100 rounded-[2rem] space-y-4 group transition-all hover:bg-white hover:shadow-lg">
                        <div class="flex items-center justify-between">
                            <div class="flex-grow">
                                <h4 class="text-xs font-black text-slate-900 uppercase tracking-tight truncate">${item.name}</h4>
                                <p class="text-[9px] text-slate-400 font-bold mt-0.5">₱${item.price.toLocaleString()} unit cost</p>
                            </div>
                            <button onclick="removeItem(${index})" class="w-8 h-8 rounded-full flex items-center justify-center text-slate-300 hover:bg-red-50 hover:text-red-500 transition-colors">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                            </button>
                        </div>
                        <div class="flex items-center justify-between pt-4 border-t border-slate-100">
                            <div class="flex items-center space-x-4 bg-white px-3 py-1.5 rounded-xl border border-slate-200">
                                <button onclick="updateQty(${index}, -1)" class="text-slate-400 hover:text-indigo-600 font-black">-</button>
                                <span class="text-xs font-black text-slate-900 min-w-[20px] text-center">${item.qty}</span>
                                <button onclick="updateQty(${index}, 1)" class="text-slate-400 hover:text-indigo-600 font-black">+</button>
                            </div>
                            <p class="text-sm font-black text-slate-900">₱${lineTotal.toLocaleString()}</p>
                        </div>
                    </div>`;
            }).join('');

            // CEO DIRECTIVE: MARGIN PROTECTION SURCHARGE (5%)
            const isEnforced = localStorage.getItem('coretex_pricing_floor') === 'true';
            const mgRow = document.getElementById('margin-guard-row');
            const mgAmtEl = document.getElementById('margin-guard-amt');
            
            if (isEnforced) {
                const surcharge = total * 0.05;
                total += surcharge;
                mgRow.classList.remove('hidden');
                mgAmtEl.textContent = `+₱${surcharge.toLocaleString(undefined, {minimumFractionDigits: 2})}`;
            } else {
                mgRow.classList.add('hidden');
            }

            // CEO DIRECTIVE: MARKETING BLITZ REBATE (10%)
            const isBlitz = localStorage.getItem('coretex_marketing_blitz') === 'true';
            const blitzRow = document.getElementById('marketing-blitz-row');
            const blitzAmtEl = document.getElementById('marketing-blitz-amt');

            if (isBlitz) {
                const rebate = total * 0.10;
                total -= rebate;
                blitzRow.classList.remove('hidden');
                blitzAmtEl.textContent = `-₱${rebate.toLocaleString(undefined, {minimumFractionDigits: 2})}`;
            } else {
                blitzRow.classList.add('hidden');
            }

            totalEl.textContent = `₱${total.toLocaleString(undefined, {minimumFractionDigits: 2})}`;
            btn.disabled = false;
        }

        function updateQty(idx, delta) {
            cart[idx].qty += delta;
            if (cart[idx].qty < 1) cart.splice(idx, 1);
            renderCart();
        }

        function removeItem(idx) {
            cart.splice(idx, 1);
            renderCart();
        }

        async function postToDb(item) {
            const isEnforced = localStorage.getItem('coretex_pricing_floor') === 'true';
            let finalAmount = item.qty * item.price;
            if (isEnforced) finalAmount += (finalAmount * 0.05);

            const response = await fetch('/Cashier/CreateSale', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ 
                    productName: item.name, 
                    quantity: item.qty, 
                    unitPrice: item.price, 
                    amount: finalAmount,
                    customerName: "Executive Demo Walk-in" 
                })
            });

            if (!response.ok) {
                const errorData = await response.text();
                throw new Error(errorData || "Server rejected the commitment.");
            }

            return await response.json();
        }

        async function processCheckout() {
            const btn = document.getElementById('checkout-btn');
            btn.disabled = true;
            
            showStep('Establishing SQL Handshake...', 0);
            
            try {
                let orderId = "";
                for (const item of cart) {
                    const res = await postToDb(item);
                    orderId = res.orderId;
                }
                
                document.getElementById('success-order-id').textContent = orderId;
                showStep('Committing Secure Record...', 1000);
                setTimeout(() => finalizeSuccess(), 2000);
            } catch (err) {
                alert("Database commit failed: " + err.message);
                btn.disabled = false;
                hideOverlay();
            }
        }

        function showStep(text, delay) {
            setTimeout(() => {
                const overlay = document.getElementById('success-overlay');
                overlay.classList.remove('opacity-0', 'pointer-events-none');
                document.getElementById('success-step').textContent = text.toUpperCase();
            }, delay);
        }

        function finalizeSuccess() {
            const title = document.getElementById('success-title');
            const step = document.getElementById('success-step');
            const icon = document.getElementById('success-icon');
            
            title.textContent = "TRANSACTION AUTHENTICATED";
            step.textContent = "DATA SECURED IN REPOSITORY";
            icon.classList.remove('scale-50');
            icon.classList.add('bg-emerald-500');
            
            setTimeout(() => {
                hideOverlay();
                cart = [];
                renderCart();
                setTimeout(() => {
                    title.textContent = "Committing to SQL...";
                    icon.classList.add('scale-50');
                    icon.classList.remove('bg-emerald-500');
                }, 500);
            }, 3000);
        }

        function hideOverlay() {
            document.getElementById('success-overlay').classList.add('opacity-0', 'pointer-events-none');
        }
    </script>
}