@{
    ViewData["Title"] = "Executive Retail Terminal";
    Layout = "_AdminLayout";
}

<div class="space-y-6 pb-20">
    <!-- POS HEADER -->
    <div class="bg-white rounded-[2rem] border border-slate-100 shadow-sm p-6">
        <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-4">
            <div>
                <h2 class="text-2xl font-black text-slate-900 tracking-tight">Coretex Retail Node</h2>
                <p class="text-[10px] text-slate-400 font-bold uppercase tracking-[0.2em] mt-1">Status: <span class="text-emerald-500">Operational</span> | SQL Link: <span class="text-indigo-600">Active</span></p>
            </div>
            <div class="flex items-center gap-4">
                <div class="text-right">
                    <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest">System Date</p>
                    <p id="current-date" class="text-xs font-black text-slate-800">--</p>
                </div>
                <div class="h-10 w-10 bg-slate-900 rounded-xl flex items-center justify-center text-white">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                </div>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 items-start">
        
        <!-- COLUMN 1: PRODUCT GALLERY (FROM DB) -->
        <div class="lg:col-span-4 space-y-4">
            <div class="bg-white rounded-[2rem] border border-slate-100 shadow-sm p-6 h-[700px] overflow-hidden flex flex-col">
                <h3 class="text-[10px] font-black text-slate-400 uppercase tracking-[0.3em] mb-4">Inventory Gallery</h3>
                <div class="grid grid-cols-2 gap-3 overflow-y-auto pr-2 custom-scrollbar">
                    @if (ViewBag.Products != null)
                    {
                        foreach (var p in (IEnumerable<coretex_finalproj.Models.Product>)ViewBag.Products)
                        {
                            <button onclick="addToCart('@p.Id', '@p.Name', @p.Price)" class="p-4 bg-slate-50 rounded-2xl border border-slate-100 hover:border-indigo-500 hover:bg-indigo-50/30 transition-all text-left group">
                                <p class="text-[11px] font-black text-slate-800 group-hover:text-indigo-700 truncate">@p.Name</p>
                                <p class="text-[10px] text-slate-400 font-bold mt-1">₱@p.Price.ToString("N2")</p>
                            </button>
                        }
                    }
                    else
                    {
                        <p class="text-[10px] text-slate-400 italic text-center col-span-2 py-10">No products found in database.</p>
                    }
                </div>
                <div class="mt-4 pt-4 border-t border-slate-50">
                    <p class="text-[9px] text-slate-400 font-bold italic">Note: These items are pulled directly from your Company SQL Database.</p>
                </div>
            </div>
        </div>

        <!-- COLUMN 2: ACTIVE CART -->
        <div class="lg:col-span-4 space-y-4">
            <div class="bg-white rounded-[2rem] border border-slate-100 shadow-sm p-6 h-[700px] flex flex-col">
                <div class="flex items-center justify-between mb-6">
                    <h3 class="text-[10px] font-black text-slate-400 uppercase tracking-[0.3em]">Customer Cart</h3>
                    <button onclick="clearCart()" class="text-[10px] font-black text-rose-500 uppercase tracking-widest hover:underline">Clear All</button>
                </div>
                
                <div id="cart-items" class="flex-grow overflow-y-auto pr-2 space-y-3 custom-scrollbar">
                    <!-- Dynamic Cart Items -->
                    <div class="flex flex-col items-center justify-center h-full text-slate-300 opacity-50">
                        <svg class="w-12 h-12 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 11-8 0v4M5 9h14l1 12H4L5 9z" /></svg>
                        <p class="text-xs font-bold uppercase tracking-widest">Cart Empty</p>
                    </div>
                </div>

                <div class="mt-6 space-y-4">
                    <div class="p-5 bg-slate-900 rounded-2xl text-white">
                        <div class="flex justify-between items-center mb-1">
                            <p class="text-[10px] font-bold text-slate-400 uppercase">Subtotal</p>
                            <p id="cart-subtotal" class="text-xs font-black">₱0.00</p>
                        </div>
                        <div class="flex justify-between items-center pt-2 border-t border-white/10 mt-2">
                            <p class="text-xs font-black uppercase text-indigo-400">Total Bill</p>
                            <p id="cart-total" class="text-2xl font-black tracking-tight text-white">₱0.00</p>
                        </div>
                    </div>
                    <button id="checkout-btn" onclick="processCheckout()" disabled class="w-full py-5 bg-indigo-600 disabled:bg-slate-200 disabled:cursor-not-allowed text-white rounded-2xl font-black text-xs uppercase tracking-[0.2em] shadow-lg shadow-indigo-100 hover:scale-[1.02] active:scale-95 transition-all">
                        Finalize Checkout
                    </button>
                </div>
            </div>
        </div>

        <!-- COLUMN 3: DAILY PULSE -->
        <div class="lg:col-span-4 space-y-6">
            <div class="bg-indigo-900 rounded-[2rem] p-8 text-white shadow-xl relative overflow-hidden">
                <div class="absolute -top-10 -right-10 w-40 h-40 bg-indigo-800 rounded-full blur-3xl opacity-50"></div>
                <h3 class="text-[10px] font-black text-indigo-300 uppercase tracking-[0.3em] mb-6">Daily Operational Pulse</h3>
                <div class="space-y-1">
                    <p id="daily-total" class="text-4xl font-black tracking-tighter">₱0.00</p>
                    <p class="text-[10px] text-indigo-300 font-bold uppercase tracking-widest">Revenue Today</p>
                </div>
                <div class="mt-8 flex items-center justify-between">
                    <div>
                        <p id="daily-count" class="text-xl font-black">0</p>
                        <p class="text-[8px] text-indigo-400 font-black uppercase tracking-widest">Transactions</p>
                    </div>
                    <div class="text-right">
                        <p id="daily-avg" class="text-xl font-black">₱0.00</p>
                        <p class="text-[8px] text-indigo-400 font-black uppercase tracking-widest">Avg Ticket</p>
                    </div>
                </div>
            </div>

            <div class="bg-white rounded-[2rem] border border-slate-100 shadow-sm p-6">
                <h3 class="text-[10px] font-black text-slate-400 uppercase tracking-[0.3em] mb-4">Live Transaction Feed</h3>
                <div id="history-feed" class="space-y-3 max-h-[350px] overflow-y-auto pr-1">
                    <p class="text-[10px] text-slate-400 italic text-center py-10">Waiting for first transaction...</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- SUCCESS OVERLAY -->
<div id="success-overlay" class="fixed inset-0 bg-slate-900/90 z-50 flex items-center justify-center opacity-0 pointer-events-none transition-all duration-500">
    <div class="text-center">
        <div class="w-24 h-24 bg-emerald-500 rounded-full flex items-center justify-center mx-auto mb-6 scale-50 transition-all duration-500" id="success-icon">
            <svg class="w-12 h-12 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" /></svg>
        </div>
        <h2 class="text-white text-3xl font-black mb-2 uppercase tracking-tight">Order Authenticated</h2>
        <p class="text-slate-400 font-bold uppercase text-[10px] tracking-[0.3em]">Data Committed to SQL Database</p>
    </div>
</div>

@section Scripts {
    <script>
        let cart = [];
        let dailyTotal = 0;

        document.addEventListener('DOMContentLoaded', () => {
            renderDate();
            loadDailySummary();
        });

        function renderDate() {
            const now = new Date();
            document.getElementById('current-date').textContent = now.toLocaleDateString('en-PH', { weekday: 'short', month: 'short', day: 'numeric', year: 'numeric' });
        }

        function addToCart(id, name, price) {
            const existing = cart.find(item => item.id === id);
            if (existing) {
                existing.qty++;
            } else {
                cart.push({ id, name, price, qty: 1 });
            }
            renderCart();
        }

        function removeFromCart(index) {
            cart.splice(index, 1);
            renderCart();
        }

        function updateQty(index, delta) {
            cart[index].qty += delta;
            if (cart[index].qty < 1) cart.splice(index, 1);
            renderCart();
        }

        function clearCart() {
            cart = [];
            renderCart();
        }

        function renderCart() {
            const container = document.getElementById('cart-items');
            const totalEl = document.getElementById('cart-total');
            const subtotalEl = document.getElementById('cart-subtotal');
            const btn = document.getElementById('checkout-btn');

            if (cart.length === 0) {
                container.innerHTML = `
                    <div class="flex flex-col items-center justify-center h-full text-slate-300 opacity-50">
                        <svg class="w-12 h-12 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 11-8 0v4M5 9h14l1 12H4L5 9z" /></svg>
                        <p class="text-xs font-bold uppercase tracking-widest">Cart Empty</p>
                    </div>`;
                totalEl.textContent = "₱0.00";
                subtotalEl.textContent = "₱0.00";
                btn.disabled = true;
                return;
            }

            let total = 0;
            container.innerHTML = cart.map((item, index) => {
                const lineTotal = item.price * item.qty;
                total += lineTotal;
                return `
                    <div class="p-4 bg-slate-50 border border-slate-100 rounded-2xl flex items-center justify-between group">
                        <div class="flex-grow">
                            <p class="text-xs font-black text-slate-800 uppercase tracking-tight">${item.name}</p>
                            <p class="text-[9px] text-slate-400 font-bold mt-0.5">${formatCurrency(item.price)} per unit</p>
                        </div>
                        <div class="flex items-center gap-3">
                            <div class="flex items-center bg-white rounded-lg border border-slate-200 px-2 py-1 gap-3">
                                <button onclick="updateQty(${index}, -1)" class="text-slate-400 hover:text-rose-500 font-black">-</button>
                                <span class="text-xs font-black text-slate-700 min-w-[20px] text-center">${item.qty}</span>
                                <button onclick="updateQty(${index}, 1)" class="text-slate-400 hover:text-indigo-500 font-black">+</button>
                            </div>
                            <div class="text-right min-w-[80px]">
                                <p class="text-xs font-black text-slate-900">${formatCurrency(lineTotal)}</p>
                                <button onclick="removeFromCart(${index})" class="text-[8px] font-black text-rose-500 uppercase tracking-widest opacity-0 group-hover:opacity-100 transition-all">Remove</button>
                            </div>
                        </div>
                    </div>`;
            }).join('');

            totalEl.textContent = formatCurrency(total);
            subtotalEl.textContent = formatCurrency(total);
            btn.disabled = false;
        }

        async function processCheckout() {
            const btn = document.getElementById('checkout-btn');
            btn.disabled = true;
            btn.innerHTML = '<span class="animate-spin inline-block w-4 h-4 border-2 border-white border-t-transparent rounded-full"></span> COMMITTING TO SQL...';

            try {
                // Loop through cart and save each item as a transaction
                const promises = cart.map(item => fetch('/Cashier/CreateSale', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ 
                        productName: item.name, 
                        quantity: item.qty, 
                        unitPrice: item.price, 
                        amount: item.qty * item.price, 
                        customerName: "Walk-in" 
                    })
                }));

                await Promise.all(promises);
                showSuccess();
                clearCart();
                loadDailySummary();
            } catch (error) {
                alert("SQL Sync Failed. Verify database connection.");
            } finally {
                btn.disabled = false;
                btn.textContent = "Finalize Checkout";
            }
        }

        async function loadDailySummary() {
            const response = await fetch(`/Cashier/GetDailySummary?date=${new Date().toISOString().split('T')[0]}`);
            const data = await response.json();
            
            animateValue("daily-total", dailyTotal, data.totalSales, 1000);
            dailyTotal = data.totalSales;
            document.getElementById('daily-count').textContent = data.totalTransactions;
            document.getElementById('daily-avg').textContent = formatCurrency(data.totalTransactions > 0 ? data.totalSales / data.totalTransactions : 0);

            const feed = document.getElementById('history-feed');
            if (data.transactions.length === 0) {
                feed.innerHTML = '<p class="text-[10px] text-slate-400 italic text-center py-10">Waiting for first transaction...</p>';
                return;
            }

            feed.innerHTML = data.transactions.slice(0, 10).map(t => `
                <div class="p-3 bg-slate-50 border-l-2 border-indigo-500 rounded-r-xl flex items-center justify-between">
                    <div>
                        <p class="text-[10px] font-black text-slate-800 uppercase">${t.productName}</p>
                        <p class="text-[8px] text-slate-400 font-bold">${t.quantity} Units | ${new Date(t.timestamp).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}</p>
                    </div>
                    <p class="text-[10px] font-black text-slate-900">${formatCurrency(t.lineTotal)}</p>
                </div>
            `).join('');
        }

        function formatCurrency(v) { return "₱" + Number(v).toLocaleString('en-PH', { minimumFractionDigits: 2 }); }

        function animateValue(id, start, end, duration) {
            const obj = document.getElementById(id);
            let startTimestamp = null;
            const step = (timestamp) => {
                if (!startTimestamp) startTimestamp = timestamp;
                const progress = Math.min((timestamp - startTimestamp) / duration, 1);
                obj.innerHTML = formatCurrency(Math.floor(progress * (end - start) + start));
                if (progress < 1) { window.requestAnimationFrame(step); }
            };
            window.requestAnimationFrame(step);
        }

        function showSuccess() {
            const overlay = document.getElementById('success-overlay');
            const icon = document.getElementById('success-icon');
            overlay.classList.remove('opacity-0', 'pointer-events-none');
            setTimeout(() => icon.classList.remove('scale-50'), 10);
            setTimeout(() => {
                overlay.classList.add('opacity-0', 'pointer-events-none');
                icon.classList.add('scale-50');
            }, 2500);
        }
    </script>
}