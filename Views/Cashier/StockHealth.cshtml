@model List<coretex_finalproj.Models.Product>
@{
    ViewData["Title"] = "Inventory Surveillance";
    Layout = "_AdminLayout";
    var criticalItems = ViewBag.CriticalItems as List<coretex_finalproj.Models.Product> ?? new List<coretex_finalproj.Models.Product>();
    var healthyItems = ViewBag.HealthyItems as List<coretex_finalproj.Models.Product> ?? new List<coretex_finalproj.Models.Product>();
}

<div class="space-y-8 py-6">
    <!-- Streamlined Header -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 border-b border-slate-100 pb-8">
        <div>
            <div class="flex items-center gap-2 mb-2">
                <div class="w-1.5 h-1.5 bg-indigo-500 rounded-full animate-pulse"></div>
                <span class="text-[10px] font-black text-indigo-500 uppercase tracking-[0.3em]">Coretex Surveillance Node</span>
            </div>
            <h2 class="text-3xl font-black text-slate-900 tracking-tighter uppercase">Inventory <span class="text-indigo-600">Health</span></h2>
        </div>
        
        <div class="flex gap-4">
            <div class="px-5 py-3 bg-rose-50 border border-rose-100 rounded-2xl flex items-center gap-3">
                <span class="text-[9px] font-black text-rose-400 uppercase tracking-widest">Critical</span>
                <span class="text-xl font-black text-rose-600">@criticalItems.Count</span>
            </div>
            <div class="px-5 py-3 bg-emerald-50 border border-emerald-100 rounded-2xl flex items-center gap-3">
                <span class="text-[9px] font-black text-emerald-400 uppercase tracking-widest">Healthy</span>
                <span class="text-xl font-black text-emerald-600">@healthyItems.Count</span>
            </div>
        </div>
    </div>

    @if (criticalItems.Any())
    {
        <!-- Critical Alert Section -->
        <div class="bg-red-50 border border-red-100 rounded-[2.5rem] p-8">
            <div class="flex items-center gap-3 mb-6">
                <div class="w-2 h-6 bg-red-500 rounded-full"></div>
                <h3 class="text-lg font-black text-red-900 tracking-tight">Replenishment Required</h3>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                @foreach (var item in criticalItems)
                {
                    <div class="bg-white rounded-[2rem] p-6 shadow-sm border border-red-100 group hover:shadow-md transition-all">
                        <div class="flex justify-between items-start mb-4">
                            <div class="w-12 h-12 bg-red-50 rounded-2xl flex items-center justify-center text-red-500">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
                            </div>
                            <span class="text-[10px] font-black text-red-500 uppercase tracking-widest px-2 py-1 bg-red-50 rounded-lg">Low Stock</span>
                        </div>
                        <h4 class="text-lg font-black text-slate-900 mb-1">@item.Name</h4>
                        <p class="text-xs text-slate-400 font-bold uppercase tracking-widest mb-4">@item.Category</p>
                        
                        <div class="flex items-center justify-between p-3 bg-slate-50 rounded-2xl mb-6">
                            <div>
                                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Current Stock</p>
                                <p class="text-lg font-black text-red-600">@item.StockQuantity</p>
                            </div>
                            <div class="text-right">
                                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Threshold</p>
                                <p class="text-sm font-black text-slate-600">@item.LowStockThreshold</p>
                            </div>
                        </div>

                        <button onclick="requestRestock('@item.Id', '@item.Name')" class="w-full py-4 bg-slate-900 text-white rounded-2xl font-black text-[10px] uppercase tracking-widest hover:bg-slate-800 transition-all flex items-center justify-center gap-2">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                            Request Restock
                        </button>
                    </div>
                }
            </div>
        </div>
    }

    <!-- Healthy Stock Section -->
    <div class="bg-white rounded-[2.5rem] p-10 border border-slate-100 shadow-sm">
        <div class="flex items-center justify-between mb-8">
            <div class="flex items-center gap-3">
                <div class="w-2 h-6 bg-emerald-500 rounded-full"></div>
                <h3 class="text-xl font-black text-slate-900 tracking-tight">Warehouse Snapshot</h3>
            </div>
            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Total Healthy SKUs: @healthyItems.Count</p>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full">
                <thead>
                    <tr class="text-left border-b border-slate-50">
                        <th class="pb-4 text-[10px] font-black text-slate-400 uppercase tracking-widest">Product</th>
                        <th class="pb-4 text-[10px] font-black text-slate-400 uppercase tracking-widest">Category</th>
                        <th class="pb-4 text-[10px] font-black text-slate-400 uppercase tracking-widest text-center">In Stock</th>
                        <th class="pb-4 text-[10px] font-black text-slate-400 uppercase tracking-widest">Status</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50">
                    @foreach (var item in healthyItems)
                    {
                        <tr class="group hover:bg-slate-50 transition-colors">
                            <td class="py-4">
                                <p class="text-sm font-black text-slate-800">@item.Name</p>
                            </td>
                            <td class="py-4 text-xs font-bold text-slate-500">@item.Category</td>
                            <td class="py-4 text-center">
                                <span class="text-sm font-black text-slate-900">@item.StockQuantity</span>
                            </td>
                            <td class="py-4">
                                <div class="flex items-center gap-2">
                                    <div class="w-1.5 h-1.5 bg-emerald-500 rounded-full"></div>
                                    <span class="text-[10px] font-black text-emerald-600 uppercase tracking-widest">Optimal</span>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function requestRestock(id, name) {
            Swal.fire({
                title: 'Transmit Request?',
                text: `Trigger an urgent restock alert for ${name} to management?`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#0f172a',
                cancelButtonColor: '#f1f5f9',
                confirmButtonText: 'Yes, Transmit',
                cancelButtonText: 'Cancel',
                customClass: {
                    popup: 'rounded-[2rem]',
                    confirmButton: 'rounded-xl font-black uppercase text-[10px] tracking-widest py-4 px-8',
                    cancelButton: 'rounded-xl font-black uppercase text-[10px] tracking-widest py-4 px-8 text-slate-600'
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    fetch('/Cashier/RequestRestock', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                        },
                        body: `productId=${id}`
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            Swal.fire({
                                title: 'Transmitted',
                                text: data.message,
                                icon: 'success',
                                confirmButtonColor: '#0f172a',
                                customClass: {
                                    popup: 'rounded-[2rem]',
                                    confirmButton: 'rounded-xl font-black uppercase text-[10px] tracking-widest py-4 px-8'
                                }
                            });
                        }
                    });
                }
            })
        }
    </script>
}
