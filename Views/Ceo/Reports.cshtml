@model IEnumerable<coretex_finalproj.Models.BranchSubmission>
@{
    ViewData["Title"] = "Executive Reporting Hub";
    Layout = "_AdminLayout";
}

<div class="space-y-8">
    <!-- Header -->
    <div class="bg-white rounded-3xl border border-slate-100 shadow-sm p-8">
        <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6">
            <div>
                <h2 class="text-3xl font-black text-slate-900 tracking-tight">Executive Reporting Hub</h2>
                <p class="text-xs text-slate-500 font-bold uppercase tracking-[0.2em] mt-2">Verified Business Submissions & Strategic Summaries</p>
            </div>
            <div class="flex gap-3">
                <a asp-action="ReportsGenerate" class="px-6 py-3 bg-slate-900 text-white rounded-2xl font-black text-xs uppercase tracking-widest hover:bg-indigo-600 transition-all shadow-lg hover:shadow-indigo-200">
                    Generate New Summary
                </a>
            </div>
        </div>
        <div id="ceo-nav" class="mt-8 flex flex-wrap gap-2"></div>
    </div>

    <!-- Submissions Table -->
    <div class="bg-white rounded-3xl border border-slate-100 shadow-sm overflow-hidden">
        <div class="p-6 border-b border-slate-100 flex items-center justify-between bg-slate-50/50">
            <div>
                <h3 class="text-base font-black text-slate-900">Recent Branch Intelligence</h3>
                <p class="text-[10px] text-slate-500 font-bold uppercase mt-1">Direct field data submitted by branch managers</p>
            </div>
            <div class="px-3 py-1 bg-emerald-100 rounded-full">
                <p class="text-[10px] font-black text-emerald-700 uppercase">Live Sync Active</p>
            </div>
        </div>
        
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="border-b border-slate-100">
                        <th class="px-6 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest">Submission Date</th>
                        <th class="px-6 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest">Branch Source</th>
                        <th class="px-6 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest">Revenue reported</th>
                        <th class="px-6 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest">Expenses reported</th>
                        <th class="px-6 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest text-center">Verification</th>
                        <th class="px-6 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50">
                    @foreach (var item in Model)
                    {
                        <tr class="hover:bg-slate-50/80 transition-colors group">
                            <td class="px-6 py-4">
                                <p class="text-sm font-bold text-slate-900">@item.SubmittedAt.ToString("MMM dd, yyyy")</p>
                                <p class="text-[10px] text-slate-400 font-medium">@item.SubmittedAt.ToString("hh:mm tt")</p>
                            </td>
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-2">
                                    <div class="w-2 h-2 rounded-full bg-indigo-500"></div>
                                    <p class="text-sm font-black text-slate-700">@item.Branch?.Name</p>
                                </div>
                            </td>
                            <td class="px-6 py-4">
                                <p class="text-sm font-black text-slate-900">@item.SalesRevenue.ToString("C0")</p>
                            </td>
                            <td class="px-6 py-4">
                                <p class="text-sm font-bold text-slate-500">@item.Expenses.ToString("C0")</p>
                            </td>
                            <td class="px-6 py-4 text-center">
                                <span class="px-2 py-1 bg-emerald-50 text-emerald-600 text-[10px] font-black rounded-md border border-emerald-100 uppercase">Verified</span>
                            </td>
                            <td class="px-6 py-4 text-right">
                                <button onclick="openSubmissionDetails('@item.Id', '@item.Branch?.Name', '@item.SubmissionMonth', '@item.SubmissionYear')" class="p-2 text-slate-400 hover:text-indigo-600 transition-colors">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        
        @if (!Model.Any())
        {
            <div class="p-20 text-center">
                <div class="w-16 h-16 bg-slate-50 rounded-full flex items-center justify-center mx-auto mb-4">
                    <svg class="w-8 h-8 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                </div>
                <h3 class="text-sm font-black text-slate-900">No Intelligence Submissions Found</h3>
                <p class="text-xs text-slate-500 mt-1">Branch managers have not submitted any data for review yet.</p>
            </div>
        }
    <!-- STRATEGIC DIRECTIVE HISTORY -->
    <div class="bg-slate-900 rounded-[2.5rem] p-8 text-white">
        <div class="flex items-center justify-between mb-8">
            <div>
                <h3 class="text-sm font-black uppercase tracking-[0.3em] text-indigo-400">Strategic Directive History</h3>
                <p class="text-[10px] text-slate-400 mt-1 uppercase font-bold tracking-widest">Active & Past Executive Decisions</p>
            </div>
            <div class="w-10 h-10 bg-white/5 rounded-2xl flex items-center justify-center">
                <svg class="w-5 h-5 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
            </div>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead>
                    <tr class="border-b border-white/5">
                        <th class="px-4 py-4 text-[9px] font-black text-slate-500 uppercase tracking-widest">Decision Date</th>
                        <th class="px-4 py-4 text-[9px] font-black text-slate-500 uppercase tracking-widest">Strategy applied</th>
                        <th class="px-4 py-4 text-[9px] font-black text-slate-500 uppercase tracking-widest">Status</th>
                        <th class="px-4 py-4 text-[9px] font-black text-slate-500 uppercase tracking-widest text-right">Audit</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-white/5">
                    @{
                        var genReports = ViewBag.GeneratedReports as IEnumerable<coretex_finalproj.Models.GeneratedReport>;
                    }
                    @if (genReports != null && genReports.Any())
                    {
                        foreach (var report in genReports.OrderByDescending(r => r.GeneratedAt))
                        {
                            <tr class="hover:bg-white/5 transition-colors group">
                                <td class="px-4 py-6">
                                    <p class="text-xs font-bold text-white">@report.GeneratedAt.ToString("MMM dd, yyyy")</p>
                                    <p class="text-[9px] text-slate-500 font-bold uppercase">@report.GeneratedAt.ToString("HH:mm") Server Time</p>
                                </td>
                                <td class="px-4 py-6">
                                    <p class="text-xs font-black text-indigo-300 uppercase tracking-tight">@report.Title</p>
                                    <p class="text-[9px] text-slate-500 font-medium">@report.SummaryData</p>
                                </td>
                                <td class="px-4 py-6">
                                    <div class="inline-flex items-center gap-2 px-2 py-1 bg-emerald-500/10 text-emerald-400 rounded-md border border-emerald-500/20">
                                        <div class="w-1 h-1 bg-emerald-400 rounded-full"></div>
                                        <span class="text-[9px] font-black uppercase">Active</span>
                                    </div>
                                </td>
                                <td class="px-4 py-6 text-right">
                                    <button class="text-[9px] font-black text-slate-400 hover:text-white uppercase tracking-widest transition-colors">View Memo</button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="px-4 py-20 text-center">
                                <p class="text-[10px] font-black text-slate-600 uppercase tracking-[0.2em]">No Strategic Decisions Logged</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Modals {
    <!-- Finance Detail Modal (CEO Audit View) -->
    <div id="details-modal" class="fixed inset-0 bg-white/90 backdrop-blur-[40px] z-[9999] hidden items-center justify-center p-4 transition-all duration-500">
        <div class="bg-white rounded-[2.5rem] shadow-[0_32px_64px_-15px_rgba(0,0,0,0.5)] w-full max-w-2xl overflow-hidden transform scale-95 opacity-0 transition-all duration-300" id="details-modal-content">
            <div class="p-6 border-b border-slate-100 flex items-center justify-between">
                <div>
                    <h3 class="text-xl font-black text-slate-900">Branch Intelligence Details</h3>
                    <p id="modal-branch-name" class="text-xs font-bold text-indigo-600 uppercase tracking-widest mt-1">BRANCH NAME</p>
                </div>
                <button onclick="closeDetailsModal()" class="w-10 h-10 bg-slate-100 text-slate-400 rounded-xl flex items-center justify-center hover:bg-rose-50 hover:text-rose-600 transition-all">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
            </div>
            <div class="p-8 grid grid-cols-2 gap-6">
                <div class="space-y-4">
                    <div class="p-4 bg-slate-50 rounded-2xl border border-slate-100">
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Total Revenue</p>
                        <p id="detail-revenue" class="text-lg font-black text-slate-900">P0.00</p>
                    </div>
                    <div class="p-4 bg-slate-50 rounded-2xl border border-slate-100">
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Total Expenses</p>
                        <p id="detail-expenses" class="text-lg font-black text-slate-900">P0.00</p>
                    </div>
                </div>
                <div class="space-y-4">
                    <div class="p-4 bg-slate-900 rounded-2xl border border-slate-800">
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1 text-white/50">Operating Net Profit</p>
                        <p id="detail-profit" class="text-lg font-black text-white">P0.00</p>
                    </div>
                    <div class="p-4 bg-white border-2 border-slate-100 rounded-2xl">
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">EDSS Status</p>
                        <p class="text-sm font-black text-emerald-600 uppercase tracking-widest flex items-center gap-2">
                            <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full"></span>
                            Verified Data
                        </p>
                        <p id="detail-period" class="text-[10px] text-slate-400 mt-1 uppercase tracking-widest">Period: --</p>
                    </div>
                </div>
            </div>
            <div id="detail-remarks-wrap" class="px-8 pb-8">
                <div class="p-4 bg-amber-50 rounded-2xl border border-amber-100">
                    <p class="text-[10px] font-black text-amber-700 uppercase tracking-widest mb-1">Finance Officer Remarks</p>
                    <p id="detail-remarks" class="text-xs text-amber-800 leading-relaxed italic">No specific remarks provided for this period.</p>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script src="~/js/ceo-flow.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const ceo = window.CoretexCeo;
            ceo.initialize().then(() => {
                ceo.renderNav('reports', 'ceo-nav');
            });
        });

        async function openSubmissionDetails(id, branchName, month, year) {
            const modal = document.getElementById('details-modal');
            const content = document.getElementById('details-modal-content');
            
            // In a real app, we'd fetch the specific submission details via API.
            // For now, we'll scrape the row we're on or use dummy data.
            document.getElementById('modal-branch-name').textContent = branchName;
            document.getElementById('detail-period').textContent = `Period: ${month} / ${year}`;
            
            // Scrape data from the row
            const row = event.target.closest('tr');
            if (row) {
                document.getElementById('detail-revenue').textContent = row.cells[2].textContent.trim();
                document.getElementById('detail-expenses').textContent = row.cells[3].textContent.trim();
                
                // Calculate profit from the numbers
                const rev = parseFloat(row.cells[2].textContent.replace(/[^\d.-]/g, ''));
                const exp = parseFloat(row.cells[3].textContent.replace(/[^\d.-]/g, ''));
                document.getElementById('detail-profit').textContent = new Intl.NumberFormat('en-PH', { style: 'currency', currency: 'PHP' }).format(rev - exp);
            }

            modal.classList.remove('hidden');
            modal.classList.add('flex');
            
            requestAnimationFrame(() => {
                content.classList.remove('scale-95', 'opacity-0');
                content.classList.add('scale-100', 'opacity-100');
            });
        }

        function closeDetailsModal() {
            const modal = document.getElementById('details-modal');
            const content = document.getElementById('details-modal-content');
            
            content.classList.add('scale-95', 'opacity-0');
            content.classList.remove('scale-100', 'opacity-100');
            
            setTimeout(() => {
                modal.classList.add('hidden');
                modal.classList.remove('flex');
            }, 300);
        }
    </script>
}
