@{
    ViewData["Title"] = "Expense Ratio KPI";
    Layout = "_AdminLayout";
}

<div class="space-y-8">
    <div class="bg-white rounded-[2.5rem] border border-slate-100 shadow-sm p-8">
        <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-6">
            <div>
                <h1 class="text-3xl font-black text-slate-900 tracking-tight">Intelligence: Expense Ratio</h1>
                <p class="text-xs text-slate-500 font-bold uppercase tracking-widest mt-2">Current ratio, category donut, and 12-month trend line</p>
            </div>
            
            <div class="flex flex-wrap items-center gap-4">
                <form id="filter-form" method="get" action="/ceo/kpi/expense-ratio" class="flex items-center gap-3">
                    <!-- BRANCH FILTER -->
                    <div class="relative">
                        <select name="branchId" onchange="submitFilters()" class="appearance-none bg-slate-900 text-white text-[10px] font-black uppercase tracking-[0.2em] rounded-xl py-3 pl-5 pr-10 focus:ring-4 focus:ring-indigo-500/20 cursor-pointer transition-all">
                            <option value="">Global Network (HQ)</option>
                            @foreach(var b in (List<coretex_finalproj.Models.Branch>)ViewBag.Branches)
                            {
                                <option value="@b.Id" selected="@(ViewBag.SelectedBranchId == b.Id)">@b.Name</option>
                            }
                        </select>
                        <div class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-white/50">
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                        </div>
                    </div>

                    <!-- PERIOD FILTER -->
                    <div class="relative">
                        <select name="period" onchange="submitFilters()" class="appearance-none bg-white text-slate-900 text-[10px] font-black uppercase tracking-[0.2em] border border-slate-200 rounded-xl py-3 pl-5 pr-10 focus:ring-4 focus:ring-indigo-500/10 cursor-pointer transition-all">
                            <option value="all" selected="@(ViewBag.SelectedMonth == null)">Overall Archive</option>
                            @{
                                var now = DateTime.Now;
                                for (int i = 0; i < 6; i++)
                                {
                                    var d = now.AddMonths(-i);
                                    var val = $"{d.Month}-{d.Year}";
                                    var label = d.ToString("MMMM yyyy");
                                    if (i == 0) label += " (LIVE)";
                                    <option value="@val" selected="@(ViewBag.SelectedMonth == d.Month && ViewBag.SelectedYear == d.Year)">@label</option>
                                }
                            }
                        </select>
                        <div class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-slate-400">
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                        </div>
                    </div>
                </form>

                <script>
                    function submitFilters() {
                        const form = document.getElementById('filter-form');
                        const period = form.period.value;
                        const branchId = form.branchId.value;
                        
                        let url = `/ceo/kpi/expense-ratio?branchId=${branchId}`;
                        if (period !== 'all') {
                            const [m, y] = period.split('-');
                            url += `&month=${m}&year=${y}`;
                        }
                        window.location.href = url;
                    }
                </script>
            </div>
        </div>
        <div id="ceo-nav" class="mt-8 flex flex-wrap gap-2"></div>
    </div>

    <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-6">
        <p class="text-xs text-slate-500 uppercase tracking-widest font-black">Current Expense Ratio</p>
        <p id="current-ratio" class="text-5xl font-black text-slate-900 mt-2">0.0%</p>
        <p class="text-xs text-slate-500 mt-2">Formula: Total Expenses / Total Revenue</p>
    </div>

    <div class="grid grid-cols-1 xl:grid-cols-2 gap-8">
        <div class="bg-white rounded-3xl border border-slate-100 shadow-sm p-6">
            <h3 class="text-base font-black text-slate-900">Expense Breakdown Donut</h3>
            <div class="mt-4 h-80"><canvas id="chart-donut"></canvas></div>
        </div>
        <div class="bg-white rounded-3xl border border-slate-100 shadow-sm p-6">
            <h3 class="text-base font-black text-slate-900">12-Month Expense Ratio Trend</h3>
            <div class="mt-4 h-80"><canvas id="chart-trend"></canvas></div>
        </div>
    </div>

    <!-- STRATEGIC INTERVENTION: COST CUTTING -->
    <div class="bg-slate-900 rounded-[2.5rem] p-8 text-white relative overflow-hidden">
        <div class="absolute top-0 right-0 p-8 opacity-10">
            <svg class="w-32 h-32" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/></svg>
        </div>
        <div class="relative z-10">
            <div class="flex items-center justify-between mb-8">
                <div>
                    <h3 class="text-[10px] font-black text-slate-500 uppercase tracking-[0.3em] mb-2">Prescriptive Intervention</h3>
                    <p class="text-xl font-black text-white">Emergency Cost-Cutting Protocol</p>
                </div>
                <div class="px-4 py-1 bg-white/10 rounded-full border border-white/20">
                    <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Ratio Target: < 35%</span>
                </div>
            </div>
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                <div class="lg:col-span-2">
                    <p class="text-sm text-slate-400 leading-relaxed mb-6">If the overhead-to-revenue ratio exceeds the safe limit, you can trigger a **Company-Wide Expenditure Audit**. This requires all branch finance officers to submit a digital "Justification Report" for any non-inventory expense exceeding ₱5,000.</p>
                    <div class="flex flex-wrap gap-4">
                        <button id="btn-cost-audit" onclick="initiateAudit()" class="px-8 py-4 bg-white text-slate-900 rounded-2xl font-black text-xs uppercase tracking-widest hover:bg-slate-50 transition-all shadow-xl shadow-white/10">Initiate Overhead Audit</button>
                        <button class="px-8 py-4 bg-slate-800 text-white rounded-2xl font-black text-xs uppercase tracking-widest border border-slate-700">Set Ratio Limit</button>
                    </div>
                </div>
                <div class="p-6 bg-white/5 rounded-3xl border border-white/10 flex flex-col justify-center">
                    <p class="text-[10px] font-black text-slate-500 uppercase tracking-widest mb-4">Estimated Monthly Savings</p>
                    <p class="text-3xl font-black text-emerald-400">₱142,500</p>
                    <p class="text-[10px] text-slate-500 mt-2">Calculated based on 15% reduction in operating waste.</p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/ceo-flow.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const ceo = window.CoretexCeo;
            ceo.renderNav('expense-ratio', 'ceo-nav');
            ceo.mountNotifications('notif-btn', 'notif-badge', 'notif-dropdown');

            const snapshot = @Html.Raw(Json.Serialize(ViewBag.Snapshot));
            const monthlyData = @Html.Raw(Json.Serialize(ViewBag.MonthlyData));
            const expenseData = @Html.Raw(Json.Serialize(ViewBag.ExpenseData));

            if (snapshot) {
                const ratio = snapshot.totalRevenue > 0 ? (snapshot.totalExpenses / snapshot.totalRevenue * 100) : 0;
                document.getElementById('current-ratio').textContent = ceo.pct(ratio);
            }

            if (expenseData && expenseData.length > 0) {
                ceo.makeChart('chart-donut', {
                    type: 'doughnut',
                    data: {
                        labels: expenseData.map(x => x.category),
                        datasets: [{
                            data: expenseData.map(x => x.amount),
                            backgroundColor: ['#f97316', '#3b82f6', '#10b981', '#8b5cf6', '#ec4899', '#6366f1']
                        }]
                    },
                    options: { responsive: true, maintainAspectRatio: false }
                });
            }

            if (monthlyData && monthlyData.length > 0) {
                ceo.makeChart('chart-trend', {
                    type: 'line',
                    data: {
                        labels: monthlyData.map(x => x.month),
                        datasets: [{
                            label: 'Expense Ratio',
                            data: monthlyData.map(x => x.sales > 0 ? (x.expenses / x.sales * 100) : 0),
                            borderColor: 'rgba(59,130,246,1)',
                            backgroundColor: 'rgba(59,130,246,0.15)',
                            fill: true,
                            tension: 0.35
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: { y: { ticks: { callback: value => `${value}%` } } }
                    }
                });
            }
        });

        async function initiateAudit() {
            const isBlitz = localStorage.getItem('coretex_marketing_blitz') === 'true';
            const isFreeze = localStorage.getItem('coretex_capital_freeze') === 'true';
            
            let msg = "Initiate Mandatory Overhead Audit?";
            if (isBlitz || isFreeze) {
                msg = "⚠️ STRATEGIC OVERRIDE\nYou are currently in Growth or Emergency Lockdown mode. Starting an Audit will override those protocols. Proceed?";
            }

            if (!confirm(msg)) return;

            const btn = document.getElementById('btn-cost-audit');
            const originalText = btn.textContent;
            
            btn.disabled = true;
            btn.innerHTML = '<svg class="w-4 h-4 animate-spin inline mr-2" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> INITIALIZING...';

            const report = {
                Title: "Strategic Audit Protocol Initiated",
                PeriodLabel: "Fiscal Discipline Phase",
                ReportHtml: "<h3>Executive Order: Overhead Audit Active</h3><p>CEO has initiated a company-wide audit of all operational overhead. Justification is now mandatory for all expense submissions.</p>",
                SummaryData: "Audit Status: ENFORCED"
            };

            try {
                const response = await fetch('/ceo/SaveReport', {
                    method: 'POST',
                    body: JSON.stringify(report),
                    headers: { 'Content-Type': 'application/json' }
                });
                const data = await response.json();
                
                if (data.success) {
                    btn.textContent = "AUDIT IN PROGRESS";
                    btn.className = "px-8 py-4 bg-emerald-500 text-white rounded-2xl font-black text-xs uppercase tracking-widest cursor-default shadow-xl shadow-emerald-500/20";
                    
                    // CONFLICT RESOLUTION
                    localStorage.removeItem('coretex_marketing_blitz');
                    localStorage.removeItem('coretex_capital_freeze');
                    
                    // SIGNAL TO FINANCE
                    localStorage.setItem('coretex_overhead_audit', 'true');
                    
                    alert("Strategic Directive Issued: Overhead audit is now active across all financial modules.");
                }
            } catch (error) {
                btn.disabled = false;
                btn.textContent = originalText;
                alert("Communication Error: Could not dispatch directive.");
            }
        }

        // SELF-HEALING STRATEGY MONITOR
        setInterval(() => {
            const isAudit = localStorage.getItem('coretex_overhead_audit') === 'true';
            
            // Get live ratio from the snapshot (refetched via element text to be safe if no full refresh)
            const ratioText = document.getElementById('current-ratio').textContent.replace('%', '');
            const ratio = parseFloat(ratioText);

            // Autonomous recovery: If ratio drops below 10%, auto-heal
            if (isAudit && ratio < 10 && ratio > 0) {
                localStorage.removeItem('coretex_overhead_audit');
                alert("🚀 AUTONOMOUS RECOVERY: System has detected that Expense Ratio has improved to " + ratio.toFixed(1) + "%. The Strategic Audit Protocol has been automatically deactivated.");
                window.location.reload();
            }
        }, 5000);
    </script>
}
