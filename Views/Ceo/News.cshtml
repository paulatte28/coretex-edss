@{
    ViewData["Title"] = "Live News Feed";
    Layout = "_AdminLayout";
}

<div class="space-y-8">
    <div class="bg-white rounded-3xl border border-slate-100 shadow-sm p-6">
        <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
            <div>
                <h2 class="text-3xl font-black text-slate-900 tracking-tight">View Live News Feed</h2>
                <p class="text-xs text-slate-500 font-bold uppercase tracking-widest mt-1">Business and industry headlines with category filtering</p>
            </div>
            <div class="relative">
                <button id="notif-btn" class="relative px-4 py-2 bg-slate-100 rounded-xl text-slate-700 hover:bg-slate-200 transition-colors font-bold text-xs">
                    Alerts
                    <span id="notif-badge" class="hidden absolute -top-2 -right-2 min-w-[20px] h-5 px-1 bg-red-600 text-white text-[10px] font-black rounded-full flex items-center justify-center">0</span>
                </button>
                <div id="notif-dropdown" class="hidden absolute right-0 mt-2 w-80 bg-white rounded-2xl border border-slate-100 shadow-xl p-3 z-20"></div>
            </div>
        </div>
        <div id="ceo-nav" class="mt-5 flex flex-wrap gap-2"></div>
    </div>

    <!-- STRATEGIC INTERVENTION: MARKET RESPONSE -->
    <div class="bg-indigo-900 rounded-[2.5rem] p-8 border border-indigo-700 relative overflow-hidden shadow-2xl">
        <div class="absolute top-0 right-0 p-8 opacity-10">
            <svg class="w-32 h-32 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M20 2H4c-1.1 0-1.99.9-1.99 2L2 22l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-2 12H6v-2h12v2zm0-3H6V9h12v2zm0-3H6V6h12v2z"/></svg>
        </div>
        <div class="relative z-10">
            <h3 class="text-[10px] font-black text-indigo-300 uppercase tracking-[0.3em] mb-2">Prescriptive Intervention</h3>
            <p class="text-xl font-black text-white mb-6">Issue Market Counter-Strategy</p>
            
            <div class="max-w-2xl">
                <p class="text-sm text-indigo-100/60 leading-relaxed mb-6">If external news signals a threat (Inflation, Competitor Moves, etc.), issue an executive bulletin to align all staff. This message will appear on the **Company Login Portal** for all employees.</p>
                
                <div class="flex flex-col sm:flex-row gap-4">
                    <input type="text" id="strategy-input" maxlength="100" placeholder="Type 1-sentence executive response..." class="flex-1 px-6 py-4 bg-white/10 border border-white/20 rounded-2xl text-white placeholder-white/30 focus:outline-none focus:border-white/50" />
                    <button onclick="broadcastStrategy()" class="px-8 py-4 bg-white text-indigo-900 rounded-2xl font-black text-xs uppercase tracking-widest hover:bg-indigo-50 transition-all">Broadcast to Company</button>
                </div>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-6">
        <div class="flex flex-wrap items-end gap-4">
            <div>
                <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">Category</label>
                <select id="news-category" class="px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl text-sm font-semibold">
                    <option value="business">Electronics Market</option>
                    <option value="technology">Gadgets & Tech</option>
                    <option value="economy">Hardware Supply</option>
                </select>
            </div>
            <button id="refresh-news" class="px-4 py-2.5 bg-slate-900 text-white text-xs font-black rounded-xl hover:bg-slate-800 transition-colors">Refresh</button>
            <p id="news-source" class="text-xs text-slate-500 font-semibold"></p>
        </div>
    </div>

    <div id="news-grid" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6"></div>
</div>

@section Scripts {
    <script src="~/js/ceo-flow.js" asp-append-version="true"></script>
    <script>
        async function renderNews() {
            const ceo = window.CoretexCeo;
            const category = document.getElementById('news-category').value;
            
            // Show loading state
            const grid = document.getElementById('news-grid');
            grid.innerHTML = Array(6).fill(0).map(() => `
                <div class="animate-pulse bg-white rounded-[2rem] h-80 border border-slate-100"></div>
            `).join('');

            const result = await ceo.fetchNews(category);

            document.getElementById('news-source').innerHTML = result.source === 'newsapi'
                ? '<span class="flex items-center gap-2"><span class="w-2 h-2 bg-emerald-500 rounded-full animate-pulse"></span> Live Intelligence Feed</span>'
                : '<span class="flex items-center gap-2"><span class="w-2 h-2 bg-amber-500 rounded-full"></span> Simulator Mode (Check API Key)</span>';

            grid.innerHTML = result.articles.map(article => {
                const imageUrl = article.image || 'https://images.unsplash.com/photo-1590283603385-17ffb3a7f29f?q=80&w=1000&auto=format&fit=crop';
                return `
                    <article class="group bg-white rounded-[2rem] border border-slate-100 shadow-sm hover:shadow-2xl transition-all duration-500 flex flex-col overflow-hidden h-full">
                        <div class="relative h-48 overflow-hidden">
                            <img src="${imageUrl}" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" onerror="this.src='https://images.unsplash.com/photo-1590283603385-17ffb3a7f29f?q=80&w=1000&auto=format&fit=crop'" />
                            <div class="absolute inset-0 bg-gradient-to-t from-slate-900/60 to-transparent"></div>
                            <div class="absolute bottom-4 left-4">
                                <span class="px-2 py-1 bg-white/20 backdrop-blur-md border border-white/30 text-[9px] font-black text-white uppercase tracking-widest rounded-lg">
                                    ${article.source || 'Intelligence'}
                                </span>
                            </div>
                        </div>
                        <div class="p-6 flex-1 flex flex-col">
                            <div class="flex items-center justify-between mb-3">
                                <p class="text-[9px] font-black text-indigo-500 uppercase tracking-widest">${new Date(article.publishedAt || Date.now()).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}</p>
                                <span class="w-1.5 h-1.5 bg-slate-200 rounded-full"></span>
                                <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest">${category}</p>
                            </div>
                            <h3 class="text-lg font-black text-slate-900 leading-tight group-hover:text-indigo-600 transition-colors line-clamp-2">${article.title || 'Untitled headline'}</h3>
                            <p class="text-xs text-slate-500 mt-3 line-clamp-3 font-medium leading-relaxed">${article.description || 'Access full intelligence report for market impact analysis.'}</p>
                            <div class="mt-auto pt-6 flex items-center justify-between">
                                <a href="${article.url || '#'}" target="_blank" class="text-[10px] font-black text-slate-900 uppercase tracking-widest flex items-center gap-2 group/link">
                                    Analyze Report 
                                    <svg class="w-3 h-3 group-hover/link:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                                </a>
                            </div>
                        </div>
                    </article>
                `;
            }).join('');
        }

        async function broadcastStrategy() {
            const input = document.getElementById('strategy-input');
            const msg = input.value.trim();
            if (!msg) return alert("Please type a response before broadcasting.");

            // SAVE TO EXECUTIVE BUS
            localStorage.setItem('coretex_market_response', JSON.stringify({
                message: msg,
                timestamp: new Date().toISOString()
            }));

            input.value = "";
            alert("🚀 STRATEGIC BROADCAST SUCCESSFUL: Your response has been pushed to the Company Login Portal and all operational nodes.");
        }

        document.addEventListener('DOMContentLoaded', function () {
            const ceo = window.CoretexCeo;
            ceo.renderNav('news', 'ceo-nav');
            ceo.mountNotifications('notif-btn', 'notif-badge', 'notif-dropdown');

            document.getElementById('refresh-news').addEventListener('click', renderNews);
            document.getElementById('news-category').addEventListener('change', renderNews);
            renderNews();
        });
    </script>
}
