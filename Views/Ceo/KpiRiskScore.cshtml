@{
    ViewData["Title"] = "Risk Score KPI";
    Layout = "_AdminLayout";
}

<div class="space-y-8">
    <div class="bg-white rounded-[2.5rem] border border-slate-100 shadow-sm p-8">
        <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-6">
            <div>
                <h1 class="text-3xl font-black text-slate-900 tracking-tight">Intelligence: Risk Score</h1>
                <p class="text-xs text-slate-500 font-bold uppercase tracking-widest mt-2">Current score, contributing factors, and historical trend</p>
            </div>
            
            <div class="flex flex-wrap items-center gap-4">
                <form id="filter-form" method="get" action="/ceo/kpi/risk-score" class="flex items-center gap-3">
                    <!-- BRANCH FILTER -->
                    <div class="relative">
                        <select name="branchId" onchange="submitFilters()" class="appearance-none bg-slate-900 text-white text-[10px] font-black uppercase tracking-[0.2em] rounded-xl py-3 pl-5 pr-10 focus:ring-4 focus:ring-indigo-500/20 cursor-pointer transition-all">
                            <option value="">Global Network (HQ)</option>
                            @foreach(var b in (List<coretex_finalproj.Models.Branch>)ViewBag.Branches)
                            {
                                <option value="@b.Id" selected="@(ViewBag.SelectedBranchId == b.Id)">@b.Name</option>
                            }
                        </select>
                        <div class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-white/50">
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                        </div>
                    </div>

                    <!-- PERIOD FILTER -->
                    <div class="relative">
                        <select name="period" onchange="submitFilters()" class="appearance-none bg-white text-slate-900 text-[10px] font-black uppercase tracking-[0.2em] border border-slate-200 rounded-xl py-3 pl-5 pr-10 focus:ring-4 focus:ring-indigo-500/10 cursor-pointer transition-all">
                            <option value="all" selected="@(ViewBag.SelectedMonth == null)">Overall Archive</option>
                            @{
                                var now = DateTime.Now;
                                for (int i = 0; i < 6; i++)
                                {
                                    var d = now.AddMonths(-i);
                                    var val = $"{d.Month}-{d.Year}";
                                    var label = d.ToString("MMMM yyyy");
                                    if (i == 0) label += " (LIVE)";
                                    <option value="@val" selected="@(ViewBag.SelectedMonth == d.Month && ViewBag.SelectedYear == d.Year)">@label</option>
                                }
                            }
                        </select>
                        <div class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-slate-400">
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                        </div>
                    </div>
                </form>

                <script>
                    function submitFilters() {
                        const form = document.getElementById('filter-form');
                        const period = form.period.value;
                        const branchId = form.branchId.value;
                        
                        let url = `/ceo/kpi/risk-score?branchId=${branchId}`;
                        if (period !== 'all') {
                            const [m, y] = period.split('-');
                            url += `&month=${m}&year=${y}`;
                        }
                        window.location.href = url;
                    }
                </script>
            </div>
        </div>
        <div id="ceo-nav" class="mt-8 flex flex-wrap gap-2"></div>
    </div>

    <div id="risk-card" class="bg-emerald-50 border border-emerald-200 rounded-3xl p-8">
        <p id="risk-main" class="text-5xl font-black text-emerald-700">🟢 GREEN</p>
        <p id="risk-sub" class="text-sm font-bold text-emerald-700 mt-2">Business Health: Healthy</p>
    </div>

    <!-- STRATEGIC INTERVENTION: RISK MITIGATION -->
    <div class="bg-rose-950 rounded-[2.5rem] p-8 text-white relative overflow-hidden border border-rose-900/50">
        <div class="absolute top-0 right-0 p-8 opacity-20">
            <svg class="w-32 h-32 text-rose-500" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L1 21h22L12 2zm1 14h-2v-2h2v2zm0-4h-2V8h2v4z"/></svg>
        </div>
        <div class="relative z-10">
            <div class="flex items-center justify-between mb-8">
                <div>
                    <h3 class="text-[10px] font-black text-rose-400 uppercase tracking-[0.3em] mb-2">Prescriptive Intervention</h3>
                    <p class="text-xl font-black text-white">Emergency Capital Expenditure Freeze</p>
                </div>
                <div class="px-4 py-1 bg-rose-500/20 rounded-full border border-rose-500/30">
                    <span class="text-[10px] font-black text-rose-300 uppercase tracking-widest animate-pulse">Monitoring Threats</span>
                </div>
            </div>
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                <div class="lg:col-span-2">
                    <p class="text-sm text-rose-200/70 leading-relaxed mb-6">If the Risk Score enters the **YELLOW** or **RED** zones, you can execute a **Global Capital Freeze**. This officially revokes the autonomous procurement authority of all branch managers, requiring CEO approval for any expense over ₱1,000.</p>
                    <div class="flex flex-wrap gap-4">
                        <button id="btn-risk-freeze" onclick="executeCapitalFreeze()" class="px-8 py-4 bg-rose-600 text-white rounded-2xl font-black text-xs uppercase tracking-widest hover:bg-rose-500 transition-all shadow-xl shadow-rose-950/40">Execute Budget Freeze</button>
                        <button class="px-8 py-4 bg-rose-900/40 text-rose-300 rounded-2xl font-black text-xs uppercase tracking-widest border border-rose-800/50">Risk Thresholds</button>
                    </div>
                </div>
                <div class="p-6 bg-white/5 rounded-3xl border border-white/10 flex flex-col justify-center">
                    <p class="text-[10px] font-black text-rose-400 uppercase tracking-widest mb-4">Risk Mitigation Impact</p>
                    <p class="text-3xl font-black text-white">-18%</p>
                    <p class="text-[10px] text-rose-400 mt-2">Predicted reduction in liquidity risk within 30 days.</p>
                </div>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-3xl border border-slate-100 shadow-sm p-6">
        <h3 class="text-base font-black text-slate-900">Factors Contributing to Score</h3>
        <div id="factor-list" class="mt-4 space-y-2"></div>
    </div>

    <div class="bg-white rounded-3xl border border-slate-100 shadow-sm p-6">
        <h3 class="text-base font-black text-slate-900">Historical Risk Score Trend</h3>
        <div class="mt-4 h-80"><canvas id="chart-risk"></canvas></div>
    </div>
</div>

@section Scripts {
    <script src="~/js/ceo-flow.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const ceo = window.CoretexCeo;
            ceo.renderNav('risk-score', 'ceo-nav');
            ceo.mountNotifications('notif-btn', 'notif-badge', 'notif-dropdown');

            const selectedBranchId = '@(ViewBag.SelectedBranchId ?? "")';
            const selectedMonth = '@(ViewBag.SelectedMonth ?? "")';
            const selectedYear = '@(ViewBag.SelectedYear ?? "")';

            ceo.initialize(selectedBranchId, selectedMonth, selectedYear).then(() => {
                const risk = ceo.getRiskSummary();
                document.getElementById('risk-main').textContent = `${risk.icon} ${risk.code}`;
                document.getElementById('risk-sub').textContent = risk.detail;

                const card = document.getElementById('risk-card');
                if (risk.code === 'RED') {
                    card.className = 'bg-red-50 border border-red-200 rounded-3xl p-8';
                    document.getElementById('risk-main').className = 'text-5xl font-black text-red-700';
                    document.getElementById('risk-sub').className = 'text-sm font-bold text-red-700 mt-2';
                } else if (risk.code === 'YELLOW') {
                    card.className = 'bg-amber-50 border border-amber-200 rounded-3xl p-8';
                    document.getElementById('risk-main').className = 'text-5xl font-black text-amber-700';
                    document.getElementById('risk-sub').className = 'text-sm font-bold text-amber-700 mt-2';
                }

                const factors = [
                    '✅ Profit Margin above threshold',
                    '✅ Expense Ratio within limit',
                    '⚠️ Branch performance tracking'
                ];
                document.getElementById('factor-list').innerHTML = factors.map(f => `<p class="text-sm text-slate-700">${f}</p>`).join('');

                const trend = ceo.getExpenseRatioTrend();
                const scoreValues = trend.map(item => {
                    if (item.ratio > 75) return 3;
                    if (item.ratio > 65) return 2;
                    return 1;
                });

                ceo.makeChart('chart-risk', {
                    type: 'line',
                    data: {
                        labels: trend.map(x => x.month),
                        datasets: [{
                            label: 'Risk Score (1=Green,2=Yellow,3=Red)',
                            data: scoreValues,
                            borderColor: 'rgba(59,130,246,1)',
                            backgroundColor: 'rgba(59,130,246,0.15)',
                            fill: true,
                            tension: 0.35
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: {
                            y: {
                                min: 1,
                                max: 3,
                                ticks: {
                                    stepSize: 1,
                                    callback: value => value === 1 ? 'Green' : value === 2 ? 'Yellow' : 'Red'
                                }
                            }
                        }
                    }
                });
                
                // SELF-HEALING STRATEGY MONITOR
                setInterval(() => {
                    const isFreeze = localStorage.getItem('coretex_capital_freeze') === 'true';
                    if (isFreeze && risk.code === 'GREEN') {
                        localStorage.removeItem('coretex_capital_freeze');
                        alert("🚀 AUTONOMOUS RECOVERY: System has detected that Risk Score has returned to GREEN levels. The Capital Freeze has been automatically deactivated to restore full procurement authority.");
                        window.location.reload();
                    }
                }, 3000);
            });
        });

        async function executeCapitalFreeze() {
            const isBlitz = localStorage.getItem('coretex_marketing_blitz') === 'true';
            const isFloor = localStorage.getItem('coretex_pricing_floor') === 'true';
            
            let msg = "Execute Global Capital Expenditure Freeze?";
            if (isBlitz || isFloor) {
                msg = "⚠️ STRATEGIC OVERRIDE\nYou are currently running Growth or Defense protocols. Executing this Freeze will automatically cancel those strategies. Proceed?";
            }

            if (!confirm(msg)) return;

            const btn = document.getElementById('btn-risk-freeze');
            const originalText = btn.textContent;
            
            btn.disabled = true;
            btn.innerHTML = '<svg class="w-4 h-4 animate-spin inline mr-2" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> LOCKING TREASURY...';

            const report = {
                Title: "Directive: Global Capital Expenditure Freeze",
                PeriodLabel: "High-Risk Status",
                ReportHtml: "<h3>Emergency Budget Freeze Activated</h3><p>CEO has revoked autonomous procurement authority for all branches. All expenses > ₱1,000 now require direct CEO signature via the Executive Terminal.</p>",
                SummaryData: "Budget Lock: ACTIVE"
            };

            try {
                const response = await fetch('/ceo/SaveReport', {
                    method: 'POST',
                    body: JSON.stringify(report),
                    headers: { 'Content-Type': 'application/json' }
                });
                const data = await response.json();
                
                if (data.success) {
                    btn.textContent = "BUDGET LOCKED";
                    btn.className = "px-8 py-4 bg-rose-500 text-white rounded-2xl font-black text-xs uppercase tracking-widest cursor-default shadow-xl shadow-rose-500/20";
                    
                    // TRIPLE CONFLICT RESOLUTION: Clear everything else
                    localStorage.removeItem('coretex_pricing_floor');
                    localStorage.removeItem('coretex_marketing_blitz');
                    
                    // SIGNAL TO ALL SYSTEMS (Lockdown Mode)
                    localStorage.setItem('coretex_capital_freeze', 'true');
                    
                    alert("EMERGENCY PROTOCOL ACTIVE: All other directives have been suspended. The system is now in Global Capital Lockdown.");
                }
            } catch (error) {
                btn.disabled = false;
                btn.textContent = originalText;
                alert("Communication Error: Could not dispatch directive.");
            }
        }
    </script>
}
