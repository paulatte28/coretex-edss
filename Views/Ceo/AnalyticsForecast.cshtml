@{
    ViewData["Title"] = "Revenue Forecast";
    Layout = "_AdminLayout";
}

<div class="space-y-8">
    <div class="bg-white rounded-[2.5rem] border border-slate-100 shadow-sm p-8">
        <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-6">
            <div>
                <h1 class="text-3xl font-black text-slate-900 tracking-tight">Intelligence: Revenue Forecast</h1>
                <p class="text-xs text-slate-500 font-bold uppercase tracking-widest mt-2">Historical revenue with projected next 3 months</p>
            </div>
            
            <div class="flex flex-wrap items-center gap-4">
                <form id="filter-form" method="get" action="/ceo/analytics/forecast" class="flex items-center gap-3">
                    <!-- BRANCH FILTER -->
                    <div class="relative">
                        <select name="branchId" onchange="submitFilters()" class="appearance-none bg-slate-900 text-white text-[10px] font-black uppercase tracking-[0.2em] rounded-xl py-3 pl-5 pr-10 focus:ring-4 focus:ring-indigo-500/20 cursor-pointer transition-all">
                            <option value="">Global Network (HQ)</option>
                            @foreach(var b in (List<coretex_finalproj.Models.Branch>)ViewBag.Branches)
                            {
                                <option value="@b.Id" selected="@(ViewBag.SelectedBranchId == b.Id)">@b.Name</option>
                            }
                        </select>
                        <div class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-white/50">
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                        </div>
                    </div>

                    <!-- PERIOD FILTER -->
                    <div class="relative">
                        <select name="period" onchange="submitFilters()" class="appearance-none bg-white text-slate-900 text-[10px] font-black uppercase tracking-[0.2em] border border-slate-200 rounded-xl py-3 pl-5 pr-10 focus:ring-4 focus:ring-indigo-500/10 cursor-pointer transition-all">
                            <option value="all" selected="@(ViewBag.SelectedMonth == null)">Overall Archive</option>
                            @{
                                var now = DateTime.Now;
                                for (int i = 0; i < 6; i++)
                                {
                                    var d = now.AddMonths(-i);
                                    var val = $"{d.Month}-{d.Year}";
                                    var label = d.ToString("MMMM yyyy");
                                    if (i == 0) label += " (LIVE)";
                                    <option value="@val" selected="@(ViewBag.SelectedMonth == d.Month && ViewBag.SelectedYear == d.Year)">@label</option>
                                }
                            }
                        </select>
                        <div class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-slate-400">
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                        </div>
                    </div>
                </form>

                <script>
                    function submitFilters() {
                        const form = document.getElementById('filter-form');
                        const period = form.period.value;
                        const branchId = form.branchId.value;
                        
                        let url = `/ceo/analytics/forecast?branchId=${branchId}`;
                        if (period !== 'all') {
                            const [m, y] = period.split('-');
                            url += `&month=${m}&year=${y}`;
                        }
                        window.location.href = url;
                    }
                </script>
            </div>
        </div>
        <div id="ceo-nav" class="mt-8 flex flex-wrap gap-2"></div>
    </div>

    <div class="bg-white rounded-3xl border border-slate-100 shadow-sm p-6">
        <h3 class="text-base font-black text-slate-900">Historical + Forecast Revenue</h3>
        <div class="mt-4 h-80"><canvas id="chart-forecast"></canvas></div>
    </div>

    <!-- STRATEGIC INTERVENTION: GROWTH CATALYST -->
    <div class="bg-emerald-900 rounded-[2.5rem] p-8 text-white relative overflow-hidden border border-emerald-800">
        <div class="absolute top-0 right-0 p-8 opacity-10">
            <svg class="w-32 h-32" fill="currentColor" viewBox="0 0 24 24"><path d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
        </div>
        <div class="relative z-10">
            <div class="flex items-center justify-between mb-8">
                <div>
                    <h3 class="text-[10px] font-black text-emerald-300 uppercase tracking-[0.3em] mb-2">Prescriptive Intervention</h3>
                    <p class="text-xl font-black text-white">Strategic Revenue Acceleration</p>
                </div>
                <div class="px-4 py-1 bg-white/10 rounded-full border border-white/20">
                    <span class="text-[10px] font-black text-emerald-200 uppercase tracking-widest">Growth Opportunity Detected</span>
                </div>
            </div>
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                <div class="lg:col-span-2">
                    <p class="text-sm text-emerald-100/70 leading-relaxed mb-6">If the forecast shows a stagnation in revenue, you can authorize a **Strategic Marketing Blitz**. This allocates a temporary ₱50,000 budget for targeted digital ads and branch-specific promotional events to capture the "Upper Confidence" sales potential.</p>
                    <div class="flex flex-wrap gap-4">
                        <button id="btn-growth-blitz" onclick="authorizeMarketingBlitz()" class="px-8 py-4 bg-white text-emerald-900 rounded-2xl font-black text-xs uppercase tracking-widest hover:bg-emerald-50 transition-all shadow-xl shadow-emerald-950/40">Authorize Marketing Blitz</button>
                        <button class="px-8 py-4 bg-emerald-800 text-white rounded-2xl font-black text-xs uppercase tracking-widest border border-emerald-700">View Campaign Brief</button>
                    </div>
                </div>
                <div class="p-6 bg-white/5 rounded-3xl border border-white/10 flex flex-col justify-center text-center">
                    <p class="text-[10px] font-black text-emerald-300 uppercase tracking-widest mb-4">Upside Potential</p>
                    <p class="text-3xl font-black text-white">+12.5%</p>
                    <p class="text-[10px] text-emerald-400 mt-2">Predicted revenue lift in Q4.</p>
                </div>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-3xl border border-slate-100 shadow-sm overflow-hidden">
        <div class="p-6 border-b border-slate-100">
            <h3 class="text-base font-black text-slate-900">Forecast Table</h3>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead class="bg-slate-50">
                    <tr>
                        <th class="px-6 py-4 text-left text-[10px] font-black text-slate-500 uppercase tracking-widest">Month</th>
                        <th class="px-6 py-4 text-right text-[10px] font-black text-slate-500 uppercase tracking-widest">Projected Revenue</th>
                        <th class="px-6 py-4 text-center text-[10px] font-black text-slate-500 uppercase tracking-widest">Confidence</th>
                    </tr>
                </thead>
                <tbody id="forecast-table" class="divide-y divide-slate-100"></tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/ceo-flow.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const ceo = window.CoretexCeo;
            ceo.renderNav('forecast', 'ceo-nav');
            ceo.mountNotifications('notif-btn', 'notif-badge', 'notif-dropdown');

            const monthlyData = @Html.Raw(Json.Serialize(ViewBag.MonthlyData));
            const forecastAmt = @(ViewBag.ForecastAmount ?? 0);

            if (monthlyData && monthlyData.length > 0) {
                const history = monthlyData.map(x => ({ month: x.month, revenue: x.sales }));
                
                // Construct 3-month simple projection based on the AI amount
                // STRATEGIC LIFT: If Marketing Blitz is active, boost forecast by 15%
                const isBlitzActive = localStorage.getItem('coretex_marketing_blitz') === 'true';
                const lift = isBlitzActive ? 1.15 : 1.0;
                const boostedAmt = forecastAmt * lift;

                // Construct 3-month simple projection based on the AI amount
                const lastMonthStr = history[history.length - 1].month;
                const forecast = [
                    { month: "Next Month", projectedRevenue: boostedAmt, confidence: 85 },
                    { month: "Month +2", projectedRevenue: boostedAmt * 1.05, confidence: 70 },
                    { month: "Month +3", projectedRevenue: boostedAmt * 1.10, confidence: 55 }
                ];

                const labels = history.map(h => h.month).concat(forecast.map(f => f.month));
                const historicalValues = history.map(h => h.revenue).concat(forecast.map(() => null));
                const projectedValues = history.map(() => null).concat(forecast.map(f => f.projectedRevenue));

                // Bridge the gap for visualization
                if (historicalValues.length > 0 && projectedValues.length > history.length) {
                    projectedValues[history.length - 1] = historicalValues[history.length - 1];
                }

                ceo.makeChart('chart-forecast', {
                    type: 'line',
                    data: {
                        labels,
                        datasets: [
                            {
                                label: 'Historical Revenue',
                                data: historicalValues,
                                borderColor: 'rgba(59,130,246,1)',
                                backgroundColor: 'rgba(59,130,246,0.15)',
                                tension: 0.3,
                                borderWidth: 4,
                                fill: true,
                                spanGaps: true
                            },
                            {
                                label: 'Projected Revenue',
                                data: projectedValues,
                                borderColor: 'rgba(16,185,129,1)',
                                borderDash: [6, 6],
                                tension: 0.3,
                                borderWidth: 4,
                                fill: false,
                                spanGaps: true
                            }
                        ]
                    },
                    options: { responsive: true, maintainAspectRatio: false }
                });

                document.getElementById('forecast-table').innerHTML = forecast.map(row => `
                    <tr class="hover:bg-slate-50 transition-colors">
                        <td class="px-6 py-4 text-sm font-semibold text-slate-900">${row.month}</td>
                        <td class="px-6 py-4 text-sm font-black text-slate-900 text-right">${ceo.money(row.projectedRevenue)}</td>
                        <td class="px-6 py-4 text-center"><span class="px-3 py-1 bg-slate-100 text-slate-700 text-xs font-black rounded-full">${row.confidence}%</span></td>
                    </tr>
                `).join('');
            }
        });

        async function authorizeMarketingBlitz() {
            const isFreeze = localStorage.getItem('coretex_capital_freeze') === 'true';
            const isFloor = localStorage.getItem('coretex_pricing_floor') === 'true';
            
            let msg = "Authorize Strategic Marketing Blitz (₱50,000 Budget)?";
            if (isFreeze || isFloor) {
                msg = "⚠️ STRATEGIC OVERRIDE\nYou are currently in a Capital Lockdown or Pricing Defense mode. Starting this Blitz will lift those restrictions to allow growth spending. Proceed?";
            }

            if (!confirm(msg)) return;

            const btn = document.getElementById('btn-growth-blitz');
            const originalText = btn.textContent;
            
            btn.disabled = true;
            btn.innerHTML = '<svg class="w-4 h-4 animate-spin inline mr-2" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> ALLOCATING BUDGET...';

            const report = {
                Title: "Directive: Authorize Marketing Blitz",
                PeriodLabel: "Growth Phase",
                ReportHtml: "<h3>Strategic Growth Catalyst Activated</h3><p>CEO has authorized an emergency ₱50,000 marketing budget for Q4 revenue acceleration. Campaign focuses on social media conversion and branch 'Holiday Specials'.</p>",
                SummaryData: "Budget Authorized: ₱50,000"
            };

            try {
                const response = await fetch('/ceo/SaveReport', {
                    method: 'POST',
                    body: JSON.stringify(report),
                    headers: { 'Content-Type': 'application/json' }
                });
                const data = await response.json();
                
                if (data.success) {
                    btn.textContent = "CAMPAIGN LIVE";
                    btn.className = "px-8 py-4 bg-emerald-500 text-white rounded-2xl font-black text-xs uppercase tracking-widest cursor-default shadow-xl shadow-emerald-500/20";
                    
                    // TRIPLE CONFLICT RESOLUTION: Clear everything else
                    localStorage.removeItem('coretex_pricing_floor');
                    localStorage.removeItem('coretex_capital_freeze');
                    
                    // SIGNAL TO THE RETAIL TERMINAL
                    localStorage.setItem('coretex_marketing_blitz', 'true');
                    
                    alert("Strategic Directive Issued: Marketing budget released. (All crisis lockdowns and pricing mandates have been lifted).");
                }
            } catch (error) {
                btn.disabled = false;
                btn.textContent = originalText;
                alert("Communication Error: Could not dispatch directive.");
            }
        }
        // SELF-HEALING STRATEGY MONITOR
        setInterval(() => {
            const isBlitz = localStorage.getItem('coretex_marketing_blitz') === 'true';
            // SUCCESS THRESHOLD: If forecast goes above 1M, target reached, auto-heal
            // This prevents over-spending on marketing once the branch is healthy
            if (isBlitz && (forecastAmt * 1.15) > 1000000) {
                localStorage.removeItem('coretex_marketing_blitz');
                alert("🚀 AUTONOMOUS STRATEGY RECOVERY\n\nSystem has detected that Projected Revenue targets have been exceeded (>₱1.0M).\n\nThe Strategic Marketing Blitz has been automatically deactivated to preserve operational budget.");
                window.location.reload();
            }
        }, 5000);
    </script>
}
