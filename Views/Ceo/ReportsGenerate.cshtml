@model coretex_finalproj.Models.BusinessSummaryViewModel
@{
    ViewData["Title"] = "Strategic Summary Generator";
    Layout = "_AdminLayout";
}

<div class="max-w-5xl mx-auto space-y-8">
    <!-- Header -->
    <div class="bg-white rounded-3xl border border-slate-100 shadow-sm p-8">
        <div class="flex items-center justify-between">
            <div>
                <h2 class="text-3xl font-black text-slate-900 tracking-tight">Strategic Summary</h2>
                <p class="text-xs text-slate-500 font-bold uppercase tracking-[0.2em] mt-2">Executive Overview & Performance Synthesis</p>
            </div>
            <a asp-action="Reports" class="p-3 bg-slate-50 text-slate-400 rounded-2xl hover:text-slate-900 transition-all">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </a>
        </div>
    </div>

    <!-- Summary Content -->
    <div id="summary-print-area" class="bg-white rounded-[2.5rem] border border-slate-100 shadow-2xl overflow-hidden">
        <!-- Header Strip -->
        <div class="bg-slate-900 p-10 text-white flex justify-between items-center">
            <div>
                <p class="text-xs font-black uppercase tracking-[0.3em] text-indigo-400 mb-2">Internal Executive Memo</p>
                <h1 class="text-4xl font-black tracking-tighter">CORETEX BUSINESS INTELLIGENCE</h1>
                <p class="text-sm font-medium text-slate-400 mt-2">Generated on @DateTime.Now.ToString("MMMM dd, yyyy")</p>
            </div>
            <div class="text-right">
                <p class="text-xs font-bold text-slate-500 uppercase">Clearance Level</p>
                <p class="text-lg font-black text-indigo-300">EXECUTIVE-ONLY</p>
            </div>
        </div>

        <div class="p-10 space-y-10">
            <!-- Top Line Stats -->
            <div class="grid grid-cols-3 gap-8">
                <div class="p-6 bg-slate-50 rounded-2xl border border-slate-100">
                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Aggregate Revenue</p>
                    <p class="text-3xl font-black text-slate-900 mt-1">@Model.TotalRevenue.ToString("C0")</p>
                </div>
                <div class="p-6 bg-slate-50 rounded-2xl border border-slate-100">
                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Aggregate Expenses</p>
                    <p class="text-3xl font-black text-slate-900 mt-1">@Model.TotalExpenses.ToString("C0")</p>
                </div>
                <div class="p-6 bg-indigo-50 rounded-2xl border border-indigo-100">
                    <p class="text-[10px] font-black text-indigo-400 uppercase tracking-widest">Net Intelligence Profit</p>
                    <p class="text-3xl font-black text-indigo-700 mt-1">@Model.NetProfit.ToString("C0")</p>
                </div>
            </div>

            <!-- Detailed Breakdown -->
            <div class="space-y-6">
                <h4 class="text-sm font-black text-slate-900 uppercase tracking-widest flex items-center gap-3">
                    <span class="w-8 h-[2px] bg-indigo-500"></span>
                    Operational Synthesis
                </h4>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
                    <div class="space-y-4">
                        <p class="text-xs font-bold text-slate-500 leading-relaxed italic">
                            "The system has analyzed the financial footprint across @Model.ActiveBranches active nodes. 
                            The current profit margin of @((Model.TotalRevenue > 0 ? (Model.NetProfit / Model.TotalRevenue * 100) : 0).ToString("F1"))% 
                            indicates a stable operational environment."
                        </p>
                        <div class="p-4 bg-emerald-50 rounded-xl border border-emerald-100">
                            <p class="text-[10px] font-black text-emerald-700 uppercase">Growth Trajectory</p>
                            <p class="text-xs text-emerald-600 mt-1">Revenue generation is currently outpacing operational expenditures by a factor of @((Model.TotalExpenses > 0 ? (Model.TotalRevenue / Model.TotalExpenses) : 0).ToString("F2"))x.</p>
                        </div>
                    </div>
                    <div class="space-y-4">
                        <div class="p-5 border border-slate-100 rounded-2xl">
                            <h5 class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Strategic Recommendation</h5>
                            <ul class="mt-4 space-y-3">
                                <li class="flex items-start gap-2">
                                    <div class="w-1.5 h-1.5 rounded-full bg-indigo-500 mt-1"></div>
                                    <p class="text-xs text-slate-700">Optimize supply chain logistics for high-performing branches.</p>
                                </li>
                                <li class="flex items-start gap-2">
                                    <div class="w-1.5 h-1.5 rounded-full bg-indigo-500 mt-1"></div>
                                    <p class="text-xs text-slate-700">Reinvest @( (Model.NetProfit * 0.15m).ToString("C0") ) (15% of profit) into digital transformation.</p>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Footer Seal -->
            <div class="pt-10 border-t border-slate-100 flex justify-between items-end">
                <div>
                    <div class="w-12 h-12 bg-slate-900 rounded-full flex items-center justify-center text-white font-black text-xs">CTX</div>
                    <p class="text-[10px] font-bold text-slate-400 mt-3 uppercase tracking-tighter">Verified by Coretex EDSS Kernel v1.4</p>
                </div>
                <div class="text-right">
                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Authorization Signature</p>
                    <div class="w-48 h-[1px] bg-slate-200 ml-auto"></div>
                    <p class="text-sm font-serif italic text-slate-900 mt-2">Executive Lead: @(User.Identity?.Name ?? "Executive Authorized")</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Actions -->
    <div class="flex justify-center gap-4">
        <button onclick="window.print()" class="px-8 py-4 bg-white border border-slate-200 text-slate-900 rounded-2xl font-black text-xs uppercase tracking-widest hover:bg-slate-50 transition-all flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/></svg>
            Export to PDF
        </button>
    </div>
</div>

@section Scripts {
    <script src="~/js/ceo-flow.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const ceo = window.CoretexCeo;
            ceo.renderNav('reports', 'ceo-nav');
            ceo.mountNotifications('notif-btn', 'notif-badge', 'notif-dropdown');
        });
    </script>
    
    <style>
        @@media print {
            .no-print, nav, aside, button, a { display: none !important; }
            body { background: white !important; }
            #summary-print-area { border: none !important; shadow: none !important; margin: 0 !important; width: 100% !important; }
        }
    </style>
}
