@{
    ViewData["Title"] = "Profit Margin KPI";
    Layout = "_AdminLayout";
}

<div class="space-y-8">
    <div class="bg-white rounded-3xl border border-slate-100 shadow-sm p-6">
        <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
            <div>
                <h2 class="text-3xl font-black text-slate-900 tracking-tight">View Profit Margin</h2>
                <p class="text-xs text-slate-500 font-bold uppercase tracking-widest mt-1">Current month KPI, 12-month trend, threshold line, and branch breakdown</p>
            </div>
            <div class="relative">
                <button id="notif-btn" class="relative px-4 py-2 bg-slate-100 rounded-xl text-slate-700 hover:bg-slate-200 transition-colors font-bold text-xs">
                    Alerts
                    <span id="notif-badge" class="hidden absolute -top-2 -right-2 min-w-[20px] h-5 px-1 bg-red-600 text-white text-[10px] font-black rounded-full flex items-center justify-center">0</span>
                </button>
                <div id="notif-dropdown" class="hidden absolute right-0 mt-2 w-80 bg-white rounded-2xl border border-slate-100 shadow-xl p-3 z-20"></div>
            </div>
        </div>
        <div id="ceo-nav" class="mt-5 flex flex-wrap gap-2"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-6">
            <p class="text-xs text-slate-500 uppercase tracking-widest font-black">Current Month Profit Margin</p>
            <p id="current-margin" class="text-5xl font-black text-slate-900 mt-2">0.0%</p>
            <p id="threshold-text" class="text-xs text-slate-500 mt-2">Threshold: 15.0%</p>
        </div>
        <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-6">
            <p class="text-xs text-slate-500 uppercase tracking-widest font-black">Status</p>
            <p id="margin-status" class="text-2xl font-black text-emerald-700 mt-2">🟢 Above Threshold</p>
            <p class="text-xs text-slate-500 mt-2">Threshold is set by System Admin in KPI Thresholds.</p>
        </div>
    </div>

    <div class="bg-white rounded-3xl border border-slate-100 shadow-sm p-6">
        <h3 class="text-base font-black text-slate-900">12-Month Profit Margin Trend</h3>
        <div class="mt-4 h-80"><canvas id="chart-margin"></canvas></div>
    </div>

    <!-- STRATEGIC INTERVENTION: MARGIN GUARD -->
    <div class="bg-indigo-900 rounded-[2.5rem] p-8 text-white">
        <div class="flex items-center justify-between mb-8">
            <div>
                <h3 class="text-[10px] font-black text-indigo-300 uppercase tracking-[0.3em] mb-2">Prescriptive Intervention</h3>
                <p class="text-xl font-black text-white">Profit Margin Guard System</p>
            </div>
            <div class="px-4 py-1 bg-white/10 rounded-full border border-white/20">
                <span class="text-[10px] font-black text-indigo-200 uppercase tracking-widest">System Status: Monitoring</span>
            </div>
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <div class="lg:col-span-2">
                <p class="text-sm text-indigo-100 leading-relaxed mb-6">If the overall profit margin falls below the 15% threshold, you can activate the **Pricing Floor Protocol**. This officially issues a directive to all branch managers to disable manual discounting and enforce a strict 20% markup on all new stock entries.</p>
                <div class="flex flex-wrap gap-4">
                    <button id="btn-margin-guard" onclick="activateMarginGuard()" class="px-8 py-4 bg-white text-indigo-900 rounded-2xl font-black text-xs uppercase tracking-widest hover:bg-indigo-50 transition-all shadow-xl shadow-indigo-900/20">Enforce Pricing Floor</button>
                    <button onclick="openPolicyDraft()" class="px-8 py-4 bg-indigo-800 text-white rounded-2xl font-black text-xs uppercase tracking-widest border border-indigo-700">View Policy Draft</button>
                </div>
            </div>
            <div class="p-6 bg-white/5 rounded-3xl border border-white/10">
                <p class="text-[10px] font-black text-indigo-300 uppercase tracking-widest mb-4">Predicted Impact</p>
                <div class="space-y-4">
                    <div class="flex items-center justify-between">
                        <span class="text-xs text-indigo-100">Recovery Time</span>
                        <span class="text-xs font-black text-emerald-400">45 Days</span>
                    </div>
                    <div class="flex items-center justify-between">
                        <span class="text-xs text-indigo-100">Margin Gain</span>
                        <span class="text-xs font-black text-emerald-400">+3.2%</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-3xl border border-slate-100 shadow-sm overflow-hidden">
        <div class="p-6 border-b border-slate-100">
            <h3 class="text-base font-black text-slate-900">Branch Breakdown</h3>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead class="bg-slate-50">
                    <tr>
                        <th class="px-6 py-4 text-left text-[10px] font-black text-slate-500 uppercase tracking-widest">Branch</th>
                        <th class="px-6 py-4 text-right text-[10px] font-black text-slate-500 uppercase tracking-widest">Revenue</th>
                        <th class="px-6 py-4 text-right text-[10px] font-black text-slate-500 uppercase tracking-widest">Expenses</th>
                        <th class="px-6 py-4 text-right text-[10px] font-black text-slate-500 uppercase tracking-widest">Margin</th>
                    </tr>
                </thead>
                <tbody id="branch-breakdown" class="divide-y divide-slate-100"></tbody>
            </table>
        </div>
    </div>
</div>

<!-- POLICY DRAFT MODAL -->
<div id="policy-modal" class="fixed inset-0 z-[100] hidden">
    <div class="absolute inset-0 bg-slate-900/60 backdrop-blur-sm" onclick="closePolicyModal()"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-lg p-4">
        <div class="bg-white rounded-[2.5rem] shadow-2xl overflow-hidden border border-slate-100">
            <div class="p-8 border-b border-slate-50 bg-slate-50/50">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-[10px] font-black text-indigo-600 uppercase tracking-widest mb-1">Confidential Draft</p>
                        <h3 class="text-xl font-black text-slate-900 tracking-tight">Executive Policy: #MG-2027-01</h3>
                    </div>
                    <button onclick="closePolicyModal()" class="w-10 h-10 bg-white border border-slate-100 rounded-full flex items-center justify-center text-slate-400 hover:text-slate-900 transition-colors">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                    </button>
                </div>
            </div>
            <div class="p-8 space-y-6">
                <div class="space-y-1">
                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Subject</p>
                    <p class="text-sm font-bold text-slate-900 italic">Mandatory Pricing Floor & Margin Protection Protocol</p>
                </div>
                <div class="p-5 bg-slate-50 rounded-2xl border border-slate-100">
                    <p class="text-xs text-slate-600 leading-relaxed font-medium">
                        Pursuant to the Q4 Fiscal Review, the Office of the CEO hereby mandates a **strict floor** on all retail margins. 
                        Effective immediately upon activation, manual price overrides at the POS terminal will be restricted. 
                        Minimum retail markup is set to **20% above landed cost (COGS)**. 
                        This directive aims to recover 3.2% in leaked margins over the next 45 operational days.
                    </p>
                </div>
                <button onclick="activateMarginGuard(); closePolicyModal();" class="w-full py-4 bg-indigo-600 text-white rounded-2xl font-black text-xs uppercase tracking-widest hover:bg-indigo-700 transition-all">Sign & Enforce Now</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/ceo-flow.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const ceo = window.CoretexCeo;
            ceo.renderNav('profit-margin', 'ceo-nav');
            ceo.mountNotifications('notif-btn', 'notif-badge', 'notif-dropdown');

            const monthlyData = @Html.Raw(Json.Serialize(ViewBag.MonthlyData));
            const branchData = @Html.Raw(Json.Serialize(ViewBag.BranchData));
            const threshold = @(ViewBag.Threshold ?? 15);

            if (monthlyData && monthlyData.length > 0) {
                const latest = monthlyData[monthlyData.length - 1];
                const profit = latest.sales - latest.expenses;
                const margin = latest.sales > 0 ? (profit / latest.sales * 100) : 0;
                
                document.getElementById('current-margin').textContent = ceo.pct(margin);
                document.getElementById('threshold-text').textContent = `Threshold: ${Number(threshold).toFixed(1)}%`;

                const above = margin >= threshold;
                document.getElementById('margin-status').textContent = above ? '🟢 Above Threshold' : '🔴 Below Threshold';
                document.getElementById('margin-status').className = `text-2xl font-black mt-2 ${above ? 'text-emerald-700' : 'text-red-700'}`;

                ceo.makeChart('chart-margin', {
                    type: 'line',
                    data: {
                        labels: monthlyData.map(x => x.month),
                        datasets: [
                            {
                                label: 'Profit Margin',
                                data: monthlyData.map(x => x.sales > 0 ? (x.sales - x.expenses)/x.sales*100 : 0),
                                borderColor: 'rgba(16,185,129,1)',
                                backgroundColor: 'rgba(16,185,129,0.15)',
                                fill: true,
                                tension: 0.35
                            },
                            {
                                label: 'Threshold',
                                data: monthlyData.map(() => threshold),
                                borderColor: 'rgba(239,68,68,1)',
                                borderDash: [6, 6],
                                pointRadius: 0,
                                fill: false,
                                tension: 0
                            }
                        ]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: { y: { ticks: { callback: value => `${value}%` } } }
                    }
                });
            }

            if (branchData && branchData.length > 0) {
                document.getElementById('branch-breakdown').innerHTML = branchData.map(b => `
                    <tr class="hover:bg-slate-50 transition-colors">
                        <td class="px-6 py-4 text-sm font-semibold text-slate-900">${b.name}</td>
                        <td class="px-6 py-4 text-sm font-black text-slate-900 text-right">${ceo.money(b.totalSales)}</td>
                        <td class="px-6 py-4 text-sm font-black text-slate-900 text-right">${ceo.money(b.totalExpenses)}</td>
                        <td class="px-6 py-4 text-sm font-black text-slate-900 text-right">${ceo.pct(b.totalSales > 0 ? (b.totalSales - b.totalExpenses)/b.totalSales*100 : 0)}</td>
                    </tr>
                `).join('');
            }
        });

        async function activateMarginGuard() {
            const btn = document.getElementById('btn-margin-guard');
            const originalText = btn.textContent;
            
            btn.disabled = true;
            btn.innerHTML = '<svg class="w-4 h-4 animate-spin inline mr-2" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> ACTIVATING...';

            const report = {
                Title: "Directive: Mandatory Pricing Floor",
                PeriodLabel: "Active Intelligence",
                ReportHtml: "<h3>Strategic Margin Guard Activated</h3><p>CEO has enforced a mandatory pricing floor across all branches. Manual discounting is disabled. 20% minimum markup required on all stock entries.</p>",
                SummaryData: "Margin Threshold Locked: 15.0%"
            };

            try {
                const response = await fetch('/ceo/SaveReport', {
                    method: 'POST',
                    body: JSON.stringify(report),
                    headers: { 'Content-Type': 'application/json' }
                });
                const data = await response.json();
                
                if (data.success) {
                    btn.textContent = "GUARD ACTIVE";
                    btn.className = "px-8 py-4 bg-emerald-500 text-white rounded-2xl font-black text-xs uppercase tracking-widest cursor-default shadow-xl shadow-emerald-500/20";
                    
                    // SIGNAL TO THE POS SYSTEM
                    localStorage.setItem('coretex_pricing_floor', 'true');
                    
                    alert("Strategic Directive Issued: Pricing floor is now enforced across all operational nodes.");
                }
            } catch (error) {
                btn.disabled = false;
                btn.textContent = originalText;
                alert("Communication Error: Could not dispatch directive.");
            }
        }

        function openPolicyDraft() {
            document.getElementById('policy-modal').classList.remove('hidden');
        }

        function closePolicyModal() {
            document.getElementById('policy-modal').classList.add('hidden');
        }
    </script>
}
