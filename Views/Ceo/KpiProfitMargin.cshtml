@{
    ViewData["Title"] = "Profit Margin KPI";
    Layout = "_AdminLayout";
}

<div class="space-y-8">
    <div class="bg-white rounded-3xl border border-slate-100 shadow-sm p-6">
        <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
            <div>
                <h2 class="text-3xl font-black text-slate-900 tracking-tight">View Profit Margin</h2>
                <p class="text-xs text-slate-500 font-bold uppercase tracking-widest mt-1">Current month KPI, 12-month trend, threshold line, and branch breakdown</p>
            </div>
            <div class="relative">
                <button id="notif-btn" class="relative px-4 py-2 bg-slate-100 rounded-xl text-slate-700 hover:bg-slate-200 transition-colors font-bold text-xs">
                    Alerts
                    <span id="notif-badge" class="hidden absolute -top-2 -right-2 min-w-[20px] h-5 px-1 bg-red-600 text-white text-[10px] font-black rounded-full flex items-center justify-center">0</span>
                </button>
                <div id="notif-dropdown" class="hidden absolute right-0 mt-2 w-80 bg-white rounded-2xl border border-slate-100 shadow-xl p-3 z-20"></div>
            </div>
        </div>
        <div id="ceo-nav" class="mt-5 flex flex-wrap gap-2"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-6">
            <p class="text-xs text-slate-500 uppercase tracking-widest font-black">Current Month Profit Margin</p>
            <p id="current-margin" class="text-5xl font-black text-slate-900 mt-2">0.0%</p>
            <p id="threshold-text" class="text-xs text-slate-500 mt-2">Threshold: 15.0%</p>
        </div>
        <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-6">
            <p class="text-xs text-slate-500 uppercase tracking-widest font-black">Status</p>
            <p id="margin-status" class="text-2xl font-black text-emerald-700 mt-2">🟢 Above Threshold</p>
            <p class="text-xs text-slate-500 mt-2">Threshold is set by System Admin in KPI Thresholds.</p>
        </div>
    </div>

    <div class="bg-white rounded-3xl border border-slate-100 shadow-sm p-6">
        <h3 class="text-base font-black text-slate-900">12-Month Profit Margin Trend</h3>
        <div class="mt-4 h-80"><canvas id="chart-margin"></canvas></div>
    </div>

    <div class="bg-white rounded-3xl border border-slate-100 shadow-sm overflow-hidden">
        <div class="p-6 border-b border-slate-100">
            <h3 class="text-base font-black text-slate-900">Branch Breakdown</h3>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead class="bg-slate-50">
                    <tr>
                        <th class="px-6 py-4 text-left text-[10px] font-black text-slate-500 uppercase tracking-widest">Branch</th>
                        <th class="px-6 py-4 text-right text-[10px] font-black text-slate-500 uppercase tracking-widest">Revenue</th>
                        <th class="px-6 py-4 text-right text-[10px] font-black text-slate-500 uppercase tracking-widest">Expenses</th>
                        <th class="px-6 py-4 text-right text-[10px] font-black text-slate-500 uppercase tracking-widest">Margin</th>
                    </tr>
                </thead>
                <tbody id="branch-breakdown" class="divide-y divide-slate-100"></tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/ceo-flow.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const ceo = window.CoretexCeo;
            ceo.renderNav('profit-margin', 'ceo-nav');
            ceo.mountNotifications('notif-btn', 'notif-badge', 'notif-dropdown');

            const kpi = ceo.getKpiSnapshot();
            document.getElementById('current-margin').textContent = ceo.pct(kpi.profitMargin);

            const thresholds = JSON.parse(localStorage.getItem('coretex_kpi_thresholds') || '{}');
            const threshold = Number(thresholds.minProfitMargin || 15);
            document.getElementById('threshold-text').textContent = `Threshold: ${threshold.toFixed(1)}%`;

            const above = kpi.profitMargin >= threshold;
            document.getElementById('margin-status').textContent = above ? '🟢 Above Threshold' : '🔴 Below Threshold';
            document.getElementById('margin-status').className = `text-2xl font-black mt-2 ${above ? 'text-emerald-700' : 'text-red-700'}`;

            const trend = ceo.getProfitMarginTrend();
            ceo.makeChart('chart-margin', {
                type: 'line',
                data: {
                    labels: trend.map(x => x.month),
                    datasets: [
                        {
                            label: 'Profit Margin',
                            data: trend.map(x => x.margin),
                            borderColor: 'rgba(16,185,129,1)',
                            backgroundColor: 'rgba(16,185,129,0.15)',
                            fill: true,
                            tension: 0.35
                        },
                        {
                            label: 'Threshold',
                            data: trend.map(() => threshold),
                            borderColor: 'rgba(239,68,68,1)',
                            borderDash: [6, 6],
                            pointRadius: 0,
                            fill: false,
                            tension: 0
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: { y: { ticks: { callback: value => `${value}%` } } }
                }
            });

            const rows = ceo.getBranchComparisonRows();
            document.getElementById('branch-breakdown').innerHTML = rows.map(row => `
                <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-6 py-4 text-sm font-semibold text-slate-900">${row.branch}</td>
                    <td class="px-6 py-4 text-sm font-black text-slate-900 text-right">${ceo.money(row.revenue)}</td>
                    <td class="px-6 py-4 text-sm font-black text-slate-900 text-right">${ceo.money(row.expenses)}</td>
                    <td class="px-6 py-4 text-sm font-black text-slate-900 text-right">${ceo.pct(row.margin)}</td>
                </tr>
            `).join('');
        });
    </script>
}
