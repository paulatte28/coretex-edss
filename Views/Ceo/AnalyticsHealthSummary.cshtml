@{
    ViewData["Title"] = "Business Health Summary";
    Layout = "_AdminLayout";
}

<div class="space-y-8">
    <!-- SIMPLE HEADER -->
    <div class="bg-white rounded-[2.5rem] border border-slate-100 shadow-sm p-8">
        <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-6">
            <div>
                <h1 class="text-3xl font-black text-slate-900 tracking-tight">Business Health Summary</h1>
                <p class="text-xs text-slate-500 font-bold uppercase tracking-widest mt-2">Executive narrative and key performance indicators</p>
            </div>
            
            <div class="flex flex-wrap items-center gap-4">
                <form id="filter-form" method="get" action="/ceo/analytics/health-summary" class="flex items-center gap-3">
                    <div class="relative">
                        <select name="branchId" onchange="submitFilters()" class="appearance-none bg-slate-900 text-white text-[10px] font-black uppercase tracking-[0.2em] rounded-xl py-3 pl-5 pr-10 focus:ring-4 focus:ring-indigo-500/20 cursor-pointer transition-all">
                            <option value="">Global Network (HQ)</option>
                            @foreach(var b in (List<coretex_finalproj.Models.Branch>)ViewBag.Branches)
                            {
                                <option value="@b.Id" selected="@(ViewBag.SelectedBranchId == b.Id)">@b.Name</option>
                            }
                        </select>
                        <div class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-white/50">
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                        </div>
                    </div>


                    <!-- PERIOD FILTER -->
                    <div class="relative">
                        <select name="period" onchange="submitFilters()" class="appearance-none bg-white text-slate-900 text-[10px] font-black uppercase tracking-[0.2em] border border-slate-200 rounded-xl py-3 pl-5 pr-10 focus:ring-4 focus:ring-indigo-500/10 cursor-pointer transition-all">
                            <option value="all" selected="@(ViewBag.SelectedMonth == null)">Overall Archive</option>
                            @{
                                var now = DateTime.Now;
                                for (int i = 0; i < 6; i++)
                                {
                                    var d = now.AddMonths(-i);
                                    var val = $"{d.Month}-{d.Year}";
                                    var label = d.ToString("MMMM yyyy");
                                    if (i == 0) label += " (LIVE)";
                                    <option value="@val" selected="@(ViewBag.SelectedMonth == d.Month && ViewBag.SelectedYear == d.Year)">@label</option>
                                }
                            }
                        </select>
                        <div class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-slate-400">
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                        </div>
                    </div>
                </form>
            </div>

                <script>
                    function submitFilters() {
                        const form = document.getElementById('filter-form');
                        const period = form.period.value;
                        const branchId = form.branchId.value;
                        
                        let url = `/ceo/analytics/health-summary?branchId=${branchId}`;
                        if (period !== 'all') {
                            const [m, y] = period.split('-');
                            url += `&month=${m}&year=${y}`;
                        }
                        window.location.href = url;
                    }
                </script>
            </div>
        </div>
        <div id="ceo-nav" class="mt-8 flex flex-wrap gap-2"></div>
    </div>

    <!-- CLEAN METRICS TABLE -->
    <div class="bg-white rounded-[2.5rem] border border-slate-100 shadow-sm overflow-hidden">
        <div class="p-8 border-b border-slate-100 bg-slate-50/50">
            <h3 class="text-sm font-black text-slate-900 uppercase tracking-widest">Key Performance Indicators</h3>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead>
                    <tr class="border-b border-slate-100">
                        <th class="px-8 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest">Metric</th>
                        <th class="px-8 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest">Value</th>
                        <th class="px-8 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest text-right">Status</th>
                    </tr>
                </thead>
                <tbody id="metrics-table" class="divide-y divide-slate-50">
                    <!-- Data injected here -->
                </tbody>
            </table>
        </div>
    </div>

    <!-- SIMPLE RECOMMENDATIONS -->
    <div class="bg-white rounded-[2.5rem] border border-slate-100 shadow-sm p-8">
        <h3 class="text-sm font-black text-slate-900 uppercase tracking-widest mb-6">Strategic Recommendations</h3>
        <div id="recommendations" class="space-y-3">
            <!-- Recommendations injected here -->
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/ceo-flow.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const ceo = window.CoretexCeo;
            const selectedBranchId = '@(ViewBag.SelectedBranchId ?? "")';
            const selectedMonth = '@(ViewBag.SelectedMonth ?? "")';
            const selectedYear = '@(ViewBag.SelectedYear ?? "")';

            ceo.initialize(selectedBranchId, selectedMonth, selectedYear).then(() => {
                ceo.renderNav('health-summary', 'ceo-nav');

                const kpi = ceo.getKpiSnapshot();
                const margin = parseFloat(kpi.profitMargin || 0);

                const metrics = [
                    { name: 'Total Revenue', value: ceo.money(kpi.totalRevenue), status: 'Healthy' },
                    { name: 'Total Expenses', value: ceo.money(kpi.totalExpenses), status: 'Healthy' },
                    { name: 'Profit Margin', value: ceo.pct(kpi.profitMargin), status: margin < 15 ? 'Critical' : 'Healthy' },
                    { name: 'Risk Assessment', value: kpi.risk.label, status: kpi.risk.code === 'RED' ? 'Warning' : 'Healthy' }
                ];

                document.getElementById('metrics-table').innerHTML = metrics.map(m => `
                    <tr class="hover:bg-slate-50 transition-colors">
                        <td class="px-8 py-6 text-sm font-bold text-slate-700">${m.name}</td>
                        <td class="px-8 py-6 text-sm font-black text-slate-900">${m.value}</td>
                        <td class="px-8 py-6 text-right">
                            <span class="px-3 py-1 ${m.status === 'Healthy' ? 'bg-emerald-50 text-emerald-600' : 'bg-red-50 text-red-600'} text-[10px] font-black rounded-full uppercase tracking-widest">
                                ${m.status}
                            </span>
                        </td>
                    </tr>
                `).join('');

                const recs = [
                    'Perform financial audit on Branch 2 to identify expense leaks.',
                    'Maintain current revenue growth by scaling digital sales channels.',
                    'Optimize COGS by reviewing supplier contracts in Q3.'
                ];

                document.getElementById('recommendations').innerHTML = recs.map(r => `
                    <div class="flex items-center gap-3">
                        <div class="w-1.5 h-1.5 bg-indigo-500 rounded-full"></div>
                        <p class="text-sm text-slate-600 font-medium">${r}</p>
                    </div>
                `).join('');
            });
        });
    </script>
}
