@{
    ViewData["Title"] = "Compare Branch Performance";
    Layout = "_AdminLayout";
}

<div class="space-y-8">
    <div class="bg-white rounded-3xl border border-slate-100 shadow-sm p-6">
        <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
            <div>
                <h2 class="text-3xl font-black text-slate-900 tracking-tight">Compare Branch Performance</h2>
                <p class="text-xs text-slate-500 font-bold uppercase tracking-widest mt-1">Revenue chart with branch-level profitability and rank table</p>
            </div>
            <div class="relative">
                <button id="notif-btn" class="relative px-4 py-2 bg-slate-100 rounded-xl text-slate-700 hover:bg-slate-200 transition-colors font-bold text-xs">
                    Alerts
                    <span id="notif-badge" class="hidden absolute -top-2 -right-2 min-w-[20px] h-5 px-1 bg-red-600 text-white text-[10px] font-black rounded-full flex items-center justify-center">0</span>
                </button>
                <div id="notif-dropdown" class="hidden absolute right-0 mt-2 w-80 bg-white rounded-2xl border border-slate-100 shadow-xl p-3 z-20"></div>
            </div>
        </div>
        <div id="ceo-nav" class="mt-5 flex flex-wrap gap-2"></div>
    </div>

    <div class="bg-white rounded-3xl border border-slate-100 shadow-sm p-6">
        <h3 class="text-base font-black text-slate-900">Revenue by Branch</h3>
        <div class="mt-4 h-80"><canvas id="chart-branches"></canvas></div>
    </div>

    <!-- STRATEGIC INTERVENTION: PERFORMANCE REPLICATION -->
    <div class="bg-slate-50 rounded-[2.5rem] p-8 border-2 border-dashed border-slate-200 relative overflow-hidden">
        <div class="flex items-center justify-between mb-8">
            <div>
                <h3 class="text-[10px] font-black text-slate-400 uppercase tracking-[0.3em] mb-2">Prescriptive Intervention</h3>
                <p class="text-xl font-black text-slate-900">Strategic Performance Replication</p>
            </div>
            <div class="px-4 py-1 bg-indigo-50 rounded-full border border-indigo-100">
                <span class="text-[10px] font-black text-indigo-600 uppercase tracking-widest">Leadership Logic Active</span>
            </div>
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <div class="lg:col-span-2">
                <p class="text-sm text-slate-600 leading-relaxed mb-6">If there is a significant performance gap between branches, you can trigger the **Workflow Synchronization Protocol**. This officially designates the #1 ranked branch as the "Operational Benchmark" and orders all other branches to adopt their inventory rotation and staffing strategy for the next 30 days.</p>
                <div class="flex flex-wrap gap-4">
                    <button id="btn-sync-branches" onclick="replicateTopBranch()" class="px-8 py-4 bg-indigo-600 text-white rounded-2xl font-black text-xs uppercase tracking-widest hover:bg-indigo-700 transition-all shadow-xl shadow-indigo-600/20">Synchronize Branch Workflows</button>
                    <button class="px-8 py-4 bg-white text-slate-900 rounded-2xl font-black text-xs uppercase tracking-widest border border-slate-200">Set Benchmark KPIs</button>
                </div>
            </div>
            <div class="p-6 bg-white rounded-3xl border border-slate-100 flex flex-col justify-center text-center shadow-sm">
                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-4">Target Network Gain</p>
                <p class="text-3xl font-black text-indigo-600">+₱210,000</p>
                <p class="text-[10px] text-slate-400 mt-2">Estimated revenue lift if lower branches match top efficiency.</p>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-3xl border border-slate-100 shadow-sm overflow-hidden">
        <div class="p-6 border-b border-slate-100">
            <h3 class="text-base font-black text-slate-900">Branch Comparison Table</h3>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead class="bg-slate-50">
                    <tr>
                        <th class="px-6 py-4 text-left text-[10px] font-black text-slate-500 uppercase tracking-widest">Branch</th>
                        <th class="px-6 py-4 text-right text-[10px] font-black text-slate-500 uppercase tracking-widest">Revenue</th>
                        <th class="px-6 py-4 text-right text-[10px] font-black text-slate-500 uppercase tracking-widest">Expenses</th>
                        <th class="px-6 py-4 text-right text-[10px] font-black text-slate-500 uppercase tracking-widest">Profit</th>
                        <th class="px-6 py-4 text-right text-[10px] font-black text-slate-500 uppercase tracking-widest">Margin</th>
                        <th class="px-6 py-4 text-center text-[10px] font-black text-slate-500 uppercase tracking-widest">Rank</th>
                    </tr>
                </thead>
                <tbody id="branch-table" class="divide-y divide-slate-100"></tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/ceo-flow.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const ceo = window.CoretexCeo;
            ceo.renderNav('branches-compare', 'ceo-nav');
            ceo.mountNotifications('notif-btn', 'notif-badge', 'notif-dropdown');

            const rows = ceo.getBranchComparisonRows();
            ceo.makeChart('chart-branches', {
                type: 'bar',
                data: {
                    labels: rows.map(x => x.branch),
                    datasets: [{
                        label: 'Revenue',
                        data: rows.map(x => x.revenue),
                        backgroundColor: ['#10b981', '#3b82f6', '#8b5cf6']
                    }]
                },
                options: { responsive: true, maintainAspectRatio: false }
            });

            document.getElementById('branch-table').innerHTML = rows.map(row => `
                <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-6 py-4 text-sm font-semibold text-slate-900">${row.branch}</td>
                    <td class="px-6 py-4 text-sm font-black text-slate-900 text-right">${ceo.money(row.revenue)}</td>
                    <td class="px-6 py-4 text-sm font-black text-slate-900 text-right">${ceo.money(row.expenses)}</td>
                    <td class="px-6 py-4 text-sm font-black text-slate-900 text-right">${ceo.money(row.profit)}</td>
                    <td class="px-6 py-4 text-sm font-black text-slate-900 text-right">${ceo.pct(row.margin)}</td>
                    <td class="px-6 py-4 text-center text-lg">${row.rank}</td>
                </tr>
            `).join('');
        });

        async function replicateTopBranch() {
            const btn = document.getElementById('btn-sync-branches');
            const originalText = btn.textContent;
            
            btn.disabled = true;
            btn.innerHTML = '<svg class="w-4 h-4 animate-spin inline mr-2" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> SYNCHRONIZING...';

            const report = {
                Title: "Directive: Network-Wide Workflow Synchronization",
                PeriodLabel: "Operational Excellence",
                ReportHtml: "<h3>Operational Benchmark Directive Issued</h3><p>CEO has designated Branch #1 as the 'Operational Benchmark'. All branches are hereby ordered to adopt the benchmarked inventory rotation and staffing strategy immediately.</p>",
                SummaryData: "Benchmark: Branch Performance Sync"
            };

            try {
                const response = await fetch('/ceo/SaveReport', {
                    method: 'POST',
                    body: JSON.stringify(report),
                    headers: { 'Content-Type': 'application/json' }
                });
                const data = await response.json();
                
                if (data.success) {
                    btn.textContent = "WORKFLOWS SYNCED";
                    btn.className = "px-8 py-4 bg-emerald-500 text-white rounded-2xl font-black text-xs uppercase tracking-widest cursor-default shadow-xl shadow-emerald-500/20";
                    alert("Strategic Directive Issued: Benchmark workflows have been pushed to all operational nodes.");
                }
            } catch (error) {
                btn.disabled = false;
                btn.textContent = originalText;
                alert("Communication Error: Could not dispatch directive.");
            }
        }
    </script>
}
