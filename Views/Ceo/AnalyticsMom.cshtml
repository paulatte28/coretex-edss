@{
    ViewData["Title"] = "Month-over-Month Analysis";
    Layout = "_AdminLayout";
}

<div class="space-y-8">
    <div class="bg-white rounded-[2.5rem] border border-slate-100 shadow-sm p-8">
        <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-6">
            <div>
                <h1 class="text-3xl font-black text-slate-900 tracking-tight">Intelligence: MoM Analysis</h1>
                <p class="text-xs text-slate-500 font-bold uppercase tracking-widest mt-2">Compare performance across consecutive months with change indicators</p>
            </div>
            
            <div class="flex flex-wrap items-center gap-4">
                <form id="filter-form" method="get" action="/ceo/analytics/mom" class="flex items-center gap-3">
                    <div class="relative">
                        <select name="branchId" onchange="submitFilters()" class="appearance-none bg-slate-900 text-white text-[10px] font-black uppercase tracking-[0.2em] rounded-xl py-3 pl-5 pr-10 focus:ring-4 focus:ring-indigo-500/20 cursor-pointer transition-all">
                            <option value="">Global Network (HQ)</option>
                            @foreach(var b in (List<coretex_finalproj.Models.Branch>)ViewBag.Branches)
                            {
                                <option value="@b.Id" selected="@(ViewBag.SelectedBranchId == b.Id)">@b.Name</option>
                            }
                        </select>
                        <div class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-white/50">
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                        </div>
                    </div>

                    <!-- PERIOD FILTER -->
                    <div class="relative">
                        <select name="period" onchange="submitFilters()" class="appearance-none bg-white text-slate-900 text-[10px] font-black uppercase tracking-[0.2em] border border-slate-200 rounded-xl py-3 pl-5 pr-10 focus:ring-4 focus:ring-indigo-500/10 cursor-pointer transition-all">
                            <option value="all" selected="@(ViewBag.SelectedMonth == null)">Overall Archive</option>
                            @{
                                var now = DateTime.Now;
                                for (int i = 0; i < 6; i++)
                                {
                                    var d = now.AddMonths(-i);
                                    var val = $"{d.Month}-{d.Year}";
                                    var label = d.ToString("MMMM yyyy");
                                    if (i == 0) label += " (LIVE)";
                                    <option value="@val" selected="@(ViewBag.SelectedMonth == d.Month && ViewBag.SelectedYear == d.Year)">@label</option>
                                }
                            }
                        </select>
                        <div class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-slate-400">
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                        </div>
                    </div>
                </form>
            </div>

                <script>
                    function submitFilters() {
                        const form = document.getElementById('filter-form');
                        const period = form.period.value;
                        const branchId = form.branchId.value;
                        
                        let url = `/ceo/analytics/mom?branchId=${branchId}`;
                        if (period !== 'all') {
                            const [m, y] = period.split('-');
                            url += `&month=${m}&year=${y}`;
                        }
                        window.location.href = url;
                    }
                </script>
            </div>
        </div>
        <div id="ceo-nav" class="mt-8 flex flex-wrap gap-2"></div>
    </div>

    <div class="bg-white rounded-3xl border border-slate-100 shadow-sm overflow-hidden">
        <div class="p-6 border-b border-slate-100">
            <h3 class="text-base font-black text-slate-900">Comparison Table</h3>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead class="bg-slate-50">
                    <tr>
                        <th class="px-6 py-4 text-left text-[10px] font-black text-slate-500 uppercase tracking-widest">Metric</th>
                        <th id="prev-label" class="px-6 py-4 text-right text-[10px] font-black text-slate-500 uppercase tracking-widest">Mar 2026</th>
                        <th id="curr-label" class="px-6 py-4 text-right text-[10px] font-black text-slate-500 uppercase tracking-widest">Apr 2026</th>
                        <th class="px-6 py-4 text-right text-[10px] font-black text-slate-500 uppercase tracking-widest">Change</th>
                    </tr>
                </thead>
                <tbody id="mom-table" class="divide-y divide-slate-100"></tbody>
            </table>
        </div>
    </div>

    <div class="bg-white rounded-3xl border border-slate-100 shadow-sm p-6">
        <h3 class="text-base font-black text-slate-900">Line Chart Comparison</h3>
        <div class="mt-4 h-80"><canvas id="chart-mom"></canvas></div>
    </div>
</div>

@section Scripts {
    <script src="~/js/ceo-flow.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const ceo = window.CoretexCeo;
            ceo.renderNav('mom', 'ceo-nav');
            ceo.mountNotifications('notif-btn', 'notif-badge', 'notif-dropdown');

            const selectedBranchId = '@(ViewBag.SelectedBranchId ?? "")';
            const selectedMonth = '@(ViewBag.SelectedMonth ?? "")';
            const selectedYear = '@(ViewBag.SelectedYear ?? "")';

            ceo.initialize(selectedBranchId, selectedMonth, selectedYear).then(() => {
                const mom = ceo.getMomData();
                document.getElementById('prev-label').textContent = mom.previous.label;
                document.getElementById('curr-label').textContent = mom.current.label;

                const rows = [
                    ['Revenue', mom.previous.revenue, mom.current.revenue],
                    ['Expenses', mom.previous.expenses, mom.current.expenses],
                    ['Profit', mom.previous.profit, mom.current.profit]
                ];

                document.getElementById('mom-table').innerHTML = rows.map(([name, previous, current]) => {
                    const change = previous > 0 ? ((current - previous) / previous) * 100 : 0;
                    const sign = change >= 0 ? '↑' : '↓';
                    const color = change >= 0 ? 'text-emerald-600' : 'text-red-600';
                    return `
                        <tr class="hover:bg-slate-50 transition-colors">
                            <td class="px-6 py-4 text-sm font-semibold text-slate-900">${name}</td>
                            <td class="px-6 py-4 text-sm font-black text-slate-900 text-right">${ceo.money(previous)}</td>
                            <td class="px-6 py-4 text-sm font-black text-slate-900 text-right">${ceo.money(current)}</td>
                            <td class="px-6 py-4 text-sm font-black ${color} text-right">${sign} ${Math.abs(change).toFixed(1)}%</td>
                        </tr>
                    `;
                }).join('');

                ceo.makeChart('chart-mom', {
                    type: 'line',
                    data: {
                        labels: [mom.previous.label, mom.current.label],
                        datasets: [
                            { label: 'Revenue', data: [mom.previous.revenue, mom.current.revenue], borderColor: '#10b981', tension: 0.2 },
                            { label: 'Expenses', data: [mom.previous.expenses, mom.current.expenses], borderColor: '#f97316', tension: 0.2 },
                            { label: 'Profit', data: [mom.previous.profit, mom.current.profit], borderColor: '#3b82f6', tension: 0.2 }
                        ]
                    },
                    options: { responsive: true, maintainAspectRatio: false }
                });
            });
        });
    </script>
}
