@{
    ViewData["Title"] = "CEO Dashboard";
    Layout = "_AdminLayout";
}

<div class="space-y-6">
    
    <div class="bg-white/80 backdrop-blur-xl rounded-[2.5rem] p-8 border border-slate-100 shadow-sm flex flex-col lg:flex-row lg:items-center justify-between gap-6">
        <div>
            <div class="flex items-center gap-3">
                <h1 class="text-3xl font-black text-slate-900 tracking-tight">Intelligence Command</h1>
                <span class="px-3 py-1 bg-indigo-50 text-indigo-600 text-[10px] font-black uppercase tracking-widest rounded-lg border border-indigo-100 uppercase">Live Feedback</span>
            </div>
            <div class="flex flex-wrap items-center gap-4 mt-3">
                <!-- BRANCH FILTER -->
                <form id="filter-form" method="get" action="/ceo/dashboard" class="flex items-center gap-3">
                    <div class="relative">
                        <select name="branchId" onchange="submitFilters()" class="appearance-none bg-slate-900 text-white text-[10px] font-black uppercase tracking-[0.2em] rounded-xl py-3 pl-5 pr-10 focus:ring-4 focus:ring-indigo-500/20 cursor-pointer transition-all">
                            <option value="">Global Network (HQ)</option>
                            @foreach(var b in (List<coretex_finalproj.Models.Branch>)ViewBag.Branches)
                            {
                                <option value="@b.Id" selected="@(ViewBag.SelectedBranchId == b.Id)">@b.Name</option>
                            }
                        </select>
                        <div class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-white/50">
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                        </div>
                    </div>

                    <!-- PERIOD FILTER -->
                    <div class="relative">
                        <select name="period" onchange="submitFilters()" class="appearance-none bg-white text-slate-900 text-[10px] font-black uppercase tracking-[0.2em] border border-slate-200 rounded-xl py-3 pl-5 pr-10 focus:ring-4 focus:ring-indigo-500/10 cursor-pointer transition-all">
                            <option value="all" selected="@(ViewBag.SelectedMonth == null)">Overall Archive</option>
                            @{
                                var now = DateTime.Now;
                                for (int i = 0; i < 6; i++)
                                {
                                    var d = now.AddMonths(-i);
                                    var val = $"{d.Month}-{d.Year}";
                                    var label = d.ToString("MMMM yyyy");
                                    if (i == 0) label += " (LIVE)";
                                    <option value="@val" selected="@(ViewBag.SelectedMonth == d.Month && ViewBag.SelectedYear == d.Year)">@label</option>
                                }
                            }
                        </select>
                        <div class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-slate-400">
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                        </div>
                    </div>
                </form>

                <script>
                    function submitFilters() {
                        const form = document.getElementById('filter-form');
                        const period = form.period.value;
                        const branchId = form.branchId.value;
                        
                        let url = `/ceo/dashboard?branchId=${branchId}`;
                        if (period !== 'all') {
                            const [m, y] = period.split('-');
                            url += `&month=${m}&year=${y}`;
                        }
                        window.location.href = url;
                    }
                </script>

                <div class="h-4 w-px bg-slate-200"></div>
                <div class="flex items-center gap-2">
                    <div class="w-2 h-2 bg-emerald-500 rounded-full animate-pulse"></div>
                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">@DateTime.Now.ToString("HH:mm") PHT</p>
                </div>
            </div>
        </div>
        <div class="flex items-center gap-3">
            <a href="/Ceo/AuditTrail" class="p-4 bg-slate-50 text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-2xl transition-all group" title="System Audit Trail">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            </a>
            <button id="safe-test-btn" class="p-4 bg-slate-50 text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-2xl transition-all group" title="Verify Email Connection">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            </button>
            <div class="h-8 w-px bg-slate-100"></div>
            <a href="/ceo/reports" class="px-8 py-4 bg-indigo-600 text-white rounded-2xl font-black text-[10px] uppercase tracking-widest hover:bg-indigo-700 transition-all shadow-lg shadow-indigo-100">
                Exec Reports
            </a>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-6">
        <a href="/ceo/analytics/forecast" class="bg-white rounded-3xl p-6 border border-slate-100 shadow-sm transition-all hover:scale-[1.02] hover:border-indigo-200 group">
            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest group-hover:text-indigo-600 transition-colors">Revenue</p>
            <p id="kpi-revenue" class="text-2xl font-black text-slate-900 mt-2">P0.00</p>
        </a>
        <a href="/ceo/kpi/expense-ratio" class="bg-white rounded-3xl p-6 border border-slate-100 shadow-sm transition-all hover:scale-[1.02] hover:border-indigo-200 group">
            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest group-hover:text-rose-600 transition-colors">Expenses</p>
            <p id="kpi-expenses" class="text-2xl font-black text-slate-900 mt-2">P0.00</p>
        </a>
        <a href="/ceo/analytics/mom" class="bg-white rounded-3xl p-6 border border-slate-100 shadow-sm transition-all hover:scale-[1.02] hover:border-indigo-200 group">
            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest group-hover:text-emerald-600 transition-colors">Profit</p>
            <p id="kpi-profit" class="text-2xl font-black text-slate-900 mt-2">P0.00</p>
        </a>
        <a href="/ceo/kpi/profit-margin" class="bg-white rounded-3xl p-6 border border-slate-100 shadow-sm transition-all hover:scale-[1.02] hover:border-indigo-200 group">
            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest group-hover:text-indigo-600 transition-colors">Margin</p>
            <p id="kpi-margin" class="text-2xl font-black text-indigo-600 mt-2">0.0%</p>
        </a>
        <!-- REFINED RISK CARD -->
        <a href="/ceo/kpi/risk-score" id="risk-widget" class="bg-emerald-50 rounded-3xl p-6 border border-emerald-100 shadow-sm flex items-center justify-between transition-all hover:scale-[1.02] group">
            <div>
                <p class="text-[10px] font-black text-emerald-700/50 uppercase tracking-widest group-hover:text-emerald-700 transition-colors">Risk Score</p>
                <p id="risk-indicator" class="text-lg font-black text-emerald-700 mt-1 uppercase">Green</p>
            </div>
            <div class="w-10 h-10 bg-emerald-500 rounded-xl flex items-center justify-center text-white shadow-lg shadow-emerald-200 group-hover:rotate-12 transition-transform">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            </div>
        </a>
    </div>

    <div class="grid grid-cols-1 gap-8">
        <div class="bg-white rounded-[2.5rem] p-8 border border-slate-100 shadow-sm">
            <h3 class="text-sm font-black text-slate-900 uppercase tracking-widest">Financial Trajectory</h3>
            <div class="mt-6 h-80"><canvas id="chart-revenue-expenses"></canvas></div>
        </div>
    </div>

    <!-- OPERATION INTELLIGENCE ROW -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
        <div class="lg:col-span-8 bg-white rounded-[2.5rem] p-8 border border-slate-100 shadow-sm">
            <div class="flex items-center justify-between mb-8">
                <h3 class="text-sm font-black text-slate-900 uppercase tracking-widest">Branch Ranking</h3>
                <div class="flex items-center gap-4">
                    <span class="text-[10px] font-bold text-slate-400">Monthly Verification Summary</span>
                    <div class="w-px h-3 bg-slate-200"></div>
                    <a href="/Report/ExportReportCsv" class="text-[10px] font-black text-indigo-600 hover:text-indigo-700 uppercase tracking-widest flex items-center gap-1.5 transition-colors">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
                        Export CSV
                    </a>
                </div>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead>
                        <tr class="text-[9px] font-black text-slate-400 uppercase tracking-widest">
                            <th class="pb-4">Branch</th>
                            <th class="pb-4 text-right">Revenue</th>
                            <th class="pb-4 text-right">Profit</th>
                            <th class="pb-4 text-center">Rank</th>
                        </tr>
                    </thead>
                    <tbody id="branch-table" class="divide-y divide-slate-50"></tbody>
                </table>
            </div>
        </div>

        <div class="lg:col-span-4 bg-white rounded-[2.5rem] p-8 border border-slate-100 shadow-sm overflow-hidden">
            <h3 class="text-sm font-black text-slate-900 uppercase tracking-widest mb-8">System Alerts</h3>
            <div id="alerts-list" class="space-y-4">
                <div class="p-4 bg-slate-50 rounded-2xl flex items-center gap-3">
                    <div class="w-2 h-2 bg-emerald-400 rounded-full"></div>
                    <p class="text-[10px] font-bold text-slate-500">System initialization complete.</p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/ceo-flow.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const ceo = window.CoretexCeo;
            const selectedBranchId = '@(ViewBag.SelectedBranchId ?? "")';
            const selectedMonth = '@(ViewBag.SelectedMonth ?? "")';
            const selectedYear = '@(ViewBag.SelectedYear ?? "")';

            ceo.initialize(selectedBranchId, selectedMonth, selectedYear).then(() => {
                ceo.renderNav('dashboard', 'ceo-nav');
                const snapshot = @Html.Raw(Json.Serialize(ViewBag.Snapshot));
                const monthlyData = @Html.Raw(Json.Serialize(ViewBag.MonthlyData));
                const branchData = @Html.Raw(Json.Serialize(ViewBag.BranchData));

                // LINK TO GLOBAL LAYOUT NOTIFICATIONS
                const globalNotifBtn = document.querySelector('header button[onclick="toggleNotifications()"]');
                if (globalNotifBtn) {
                    ceo.mountNotifications(null, 'notif-dot', 'notif-dropdown');
                }

                document.getElementById('safe-test-btn').addEventListener('click', function() {
                    const ceoEmail = "@ViewBag.UserEmail";
                    if (confirm("Send system connectivity test to your email (" + ceoEmail + ")?")) {
                        const formData = new URLSearchParams({ emailAddress: ceoEmail, alertType: 'SIMPLE_TEST' });
                        fetch('/Report/TriggerAlertEmail', { method: 'POST', body: formData, headers: { 'Content-Type': 'application/x-www-form-urlencoded' } })
                        .then(r => r.json())
                        .then(data => {
                            alert(data.message);
                        })
                        .catch(err => alert('Communication Error: ' + err));
                    }
                });

                // TRUE REAL-TIME PULSE SYNC (Polls every 10 seconds)
                const syncNotifications = () => {
                    fetch('/Ceo/GetNotifications')
                        .then(r => r.json())
                        .then(notifs => {
                            // Update Top Bar Badge via the CoretexCeo global object
                            const badge = document.getElementById('notif-dot');
                            if (badge) {
                                const unreadCount = notifs.filter(n => !n.isRead).length;
                                badge.textContent = unreadCount;
                                badge.classList.toggle('hidden', unreadCount === 0);
                            }

                            // Update Dashboard Widget
                            const list = document.getElementById('alerts-list');
                            if (list && notifs && notifs.length > 0) {
                                const newHtml = notifs.slice(0, 5).map(n => {
                                    const color = n.severity === 'red' ? 'bg-red-500' : (n.severity === 'indigo' ? 'bg-indigo-500' : 'bg-emerald-500');
                                    const bg = n.severity === 'red' ? 'bg-red-50' : (n.severity === 'indigo' ? 'bg-indigo-50' : 'bg-emerald-50');
                                    return `
                                        <div class="p-4 ${bg} rounded-2xl flex items-center gap-3 animate-in fade-in slide-in-from-right-4">
                                            <div class="w-2 h-2 ${color} rounded-full animate-pulse"></div>
                                            <div>
                                                <p class="text-[10px] font-black text-slate-800 uppercase tracking-widest">${n.title}</p>
                                                <p class="text-[9px] font-bold text-slate-500 mt-0.5">${n.message}</p>
                                            </div>
                                        </div>
                                    `;
                                }).join('');

                                // Only update if content changed to prevent flickering
                                if (list.innerHTML !== newHtml) {
                                    list.innerHTML = newHtml;
                                }
                            }
                        });
                };

                // Initial sync and then every 10s
                syncNotifications();
                setInterval(syncNotifications, 10000);

                if (snapshot) {
                    const rev = snapshot.totalRevenue || snapshot.TotalRevenue || 0;
                    const exp = snapshot.totalExpenses || snapshot.TotalExpenses || 0;
                    const prof = snapshot.netProfit || snapshot.NetProfit || 0;
                    const risk = snapshot.riskLevel || snapshot.RiskLevel || 'Healthy';

                    document.getElementById('kpi-revenue').textContent = ceo.money(rev);
                    document.getElementById('kpi-expenses').textContent = ceo.money(exp);
                    document.getElementById('kpi-profit').textContent = ceo.money(prof);
                    document.getElementById('kpi-margin').textContent = ceo.pct(rev > 0 ? (prof / rev * 100) : 0);

                    const riskInd = document.getElementById('risk-indicator');
                    const riskW = document.getElementById('risk-widget');
                    riskInd.textContent = risk;
                    if (risk === 'Critical') {
                        riskW.className = 'bg-red-50 rounded-3xl p-6 border border-red-100 shadow-sm flex items-center justify-between transition-all hover:scale-[1.02] group';
                        riskInd.className = 'text-lg font-black text-red-700 mt-1 uppercase';
                    }

                }

                if (monthlyData && monthlyData.length > 0) {
                    const labels = monthlyData.map(x => x.month || x.Month);
                    ceo.makeChart('chart-revenue-expenses', {
                        type: 'line',
                        data: {
                            labels,
                            datasets: [
                                { label: 'Revenue', data: monthlyData.map(x => x.sales || x.Sales), borderColor: '#10b981', backgroundColor: 'rgba(16, 185, 129, 0.1)', fill: true, tension: 0.4, borderWidth: 3, pointRadius: 4 },
                                { label: 'Expenses', data: monthlyData.map(x => x.expenses || x.Expenses), borderColor: '#f43f5e', backgroundColor: 'rgba(244, 63, 94, 0.1)', fill: true, tension: 0.4, borderWidth: 3, pointRadius: 4 }
                            ]
                        },
                        options: { 
                            responsive: true, 
                            maintainAspectRatio: false, 
                            plugins: { legend: { display: false } },
                            scales: {
                                y: { grid: { display: false }, ticks: { display: false } },
                                x: { grid: { display: false } }
                            }
                        }
                    });
                }

                if (branchData && branchData.length > 0) {
                    document.getElementById('branch-table').innerHTML = branchData.map((b, i) => `
                        <tr class="hover:bg-indigo-50/50 transition-colors cursor-pointer group" onclick="window.location.href='/ceo/dashboard?branchId=${b.id || b.Id}'">
                            <td class="py-4"><p class="text-[11px] font-black text-slate-700 group-hover:text-indigo-600">${b.name || b.Name}</p></td>
                            <td class="py-4 text-right"><p class="text-[11px] font-bold text-slate-900">${ceo.money(b.revenue || b.Revenue)}</p></td>
                            <td class="py-4 text-right"><p class="text-[11px] font-bold text-slate-600">${ceo.money((b.revenue || b.Revenue) - (b.expenses || b.Expenses))}</p></td>
                            <td class="py-4 text-center"><span class="px-3 py-1 bg-slate-900 text-white text-[9px] font-black rounded-lg group-hover:bg-indigo-600 transition-colors">#${i+1}</span></td>
                        </tr>
                    `).join('');
                }
            });
        });
    </script>
}
