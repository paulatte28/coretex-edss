<div class="space-y-12">
    <div class="flex items-center justify-between">
        <div>
            <h2 class="text-4xl font-black text-slate-900 tracking-tighter uppercase">Intelligence Hub</h2>
            <p class="text-[10px] text-slate-400 font-black uppercase tracking-[0.3em] mt-2 italic">Global Market Parity & Multi-Vector Visualizations</p>
        </div>
        <div class="flex items-center space-x-4">
             <div class="bg-white border border-slate-200 rounded-2xl p-1 shadow-sm flex items-center">
                <span class="px-4 text-[9px] font-black uppercase text-slate-400 tracking-[0.2em] border-r border-slate-100">Global Basis</span>
                <select class="text-xs font-black bg-white border-none rounded-xl text-primary py-2.5 pl-4 pr-10 focus:ring-0 cursor-pointer uppercase tracking-widest">
                    <option value="USD">USD ($)</option>
                    <option value="EUR">EUR (€)</option>
                    <option value="CNY">CNY (¥)</option>
                    <option value="JPY">JPY (¥)</option>
                </select>
            </div>
        </div>
    </div>

    <!-- Live Conversion Banner -->
    <div class="bg-slate-900 border border-slate-800 rounded-[2.5rem] p-6 flex items-center justify-between shadow-2xl relative overflow-hidden group">
        <div class="absolute inset-0 bg-gradient-to-r from-blue-600/10 to-emerald-600/10 opacity-50"></div>
        <div class="flex items-center space-x-6 relative z-10">
            <div class="w-12 h-12 rounded-2xl bg-white/5 text-emerald-400 flex items-center justify-center border border-white/10 shadow-inner group-hover:scale-110 transition-transform">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
            </div>
            <div>
                <p class="text-[10px] font-black uppercase tracking-[0.3em] text-emerald-400">ExchangeRate API: Live Stream Active</p>
                <div class="flex items-center space-x-4 mt-1">
                    <span class="text-sm font-black text-white tracking-widest uppercase italic">1 USD = 56.45 PHP</span>
                    <span class="w-1.5 h-1.5 bg-slate-700 rounded-full"></span>
                    <span class="text-sm font-black text-slate-400 tracking-widest uppercase italic">1 CNY = 7.82 PHP</span>
                </div>
            </div>
        </div>
        <p class="text-[9px] text-slate-500 font-black uppercase tracking-widest relative z-10">Last Parity Update: 0.04s Ago</p>
    </div>

    <!-- Multi-Currency Conversion Widget (Phase 7) -->
    <div class="bg-white p-12 rounded-[3.5rem] shadow-xl shadow-slate-200/50 border border-slate-100 space-y-10 group relative overflow-hidden">
        <div class="absolute top-0 right-0 w-64 h-64 bg-indigo-50/50 rounded-full blur-3xl -mr-32 -mt-32"></div>
        <div class="flex items-center justify-between relative z-10">
            <div>
                <h3 class="font-black text-slate-900 text-3xl tracking-tighter uppercase italic">Cost Auditor</h3>
                <p class="text-[10px] text-slate-400 font-black uppercase tracking-[0.3em] mt-2 italic">Algorithmic PHP Normalization Engine</p>
            </div>
            <div class="w-16 h-16 bg-slate-50 text-slate-900 rounded-3xl flex items-center justify-center border border-slate-100 shadow-sm group-hover:bg-primary group-hover:text-white transition-all duration-500">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-10 relative z-10">
            <div class="space-y-4">
                <label class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] px-1">Imported Sum</label>
                <div class="relative group">
                    <input id="import-amount" type="number" placeholder="0.00" class="w-full bg-slate-50 border-slate-100 rounded-2xl py-5 pl-8 pr-16 text-lg font-black focus:ring-4 focus:ring-secondary/10 focus:bg-white transition-all border-2" />
                    <span id="target-currency-label" class="absolute right-8 top-1/2 -translate-y-1/2 text-slate-300 font-black text-sm uppercase italic">CNY</span>
                </div>
            </div>

            <div class="space-y-4">
                <label class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] px-1">Basis Currency</label>
                <div class="relative">
                    <select id="source-currency" class="w-full bg-slate-50 border-slate-100 border-2 rounded-2xl py-5 px-8 text-sm font-black focus:ring-4 focus:ring-secondary/10 focus:bg-white transition-all appearance-none cursor-pointer uppercase tracking-widest">
                        <option value="CNY">CNY • Chinese Yuan</option>
                        <option value="USD">USD • US Dollar</option>
                        <option value="EUR">EUR • Euro</option>
                        <option value="JPY">JPY • Japanese Yen</option>
                    </select>
                    <div class="absolute right-8 top-1/2 -translate-y-1/2 pointer-events-none text-slate-400">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7"/></svg>
                    </div>
                </div>
            </div>

            <div class="flex items-end">
                <button onclick="simulateConversion()" class="w-full py-5 bg-primary text-white font-black rounded-2xl hover:bg-slate-800 transition-all shadow-2xl shadow-blue-900/30 uppercase tracking-[0.3em] text-[11px] h-[64px]">
                    Analyze Parity
                </button>
            </div>
        </div>

        <div id="conversion-result" class="hidden animate-in fade-in slide-in-from-bottom-5 duration-500">
            <div class="p-10 bg-emerald-50 rounded-[3rem] border-2 border-emerald-100 flex items-center justify-between shadow-xl shadow-emerald-100/50">
                <div>
                    <p class="text-[10px] text-emerald-600 font-black uppercase tracking-[0.4em] italic mb-2">Audit-Normalized Value (PHP)</p>
                    <h4 id="converted-value" class="text-5xl font-black text-slate-900 tracking-tighter">₱0.00</h4>
                </div>
                <div class="text-right space-y-2">
                    <p class="text-[10px] text-emerald-600 font-black uppercase tracking-widest bg-white/50 px-3 py-1 rounded-lg border border-emerald-200 inline-block">Real-time Parity</p>
                    <p id="conversion-meta" class="text-sm font-black text-emerald-700 tracking-tight italic">--</p>
                </div>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
        <!-- Chart 1: Profit Trend -->
        <div class="bg-white p-12 rounded-[3.5rem] shadow-xl shadow-slate-200/50 border border-slate-100 group">
            <div class="flex justify-between items-center mb-10">
                <div>
                    <h3 class="font-black text-slate-900 text-2xl tracking-tighter uppercase italic">Margin Vector</h3>
                    <p class="text-[10px] text-slate-400 font-black uppercase tracking-[0.3em] mt-2 italic">Net Profit Performance Trend</p>
                </div>
                <div class="w-12 h-12 bg-emerald-50 text-emerald-600 rounded-2xl flex items-center justify-center font-black text-xs border border-emerald-100 italic transition-transform group-hover:scale-110">
                    6M
                </div>
            </div>
            
            <div class="h-80 relative z-10">
                <canvas id="profitChart"></canvas>
            </div>
        </div>

        <!-- Chart 2: Comparison -->
        <div class="bg-white p-12 rounded-[3.5rem] shadow-xl shadow-slate-200/50 border border-slate-100 group">
            <div class="flex justify-between items-center mb-10">
                <div>
                    <h3 class="font-black text-slate-900 text-2xl tracking-tighter uppercase italic">Resource Stack</h3>
                    <p class="text-[10px] text-slate-400 font-black uppercase tracking-[0.3em] mt-2 italic">Revenue vs Operational Outflow</p>
                </div>
                <div class="w-12 h-12 bg-indigo-50 text-indigo-600 rounded-2xl flex items-center justify-center font-black text-xs border border-indigo-100 italic transition-transform group-hover:scale-110 text-center">
                    COMP
                </div>
            </div>
            
            <div class="h-80 relative z-10">
                <canvas id="comparisonChart"></canvas>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function simulateConversion() {
            const amount = document.getElementById('import-amount').value;
            const source = document.getElementById('source-currency').value;
            const resultDiv = document.getElementById('conversion-result');
            const convertedVal = document.getElementById('converted-value');
            const meta = document.getElementById('conversion-meta');

            if (!amount || amount <= 0) {
                alert('Please enter a valid audit sum.');
                return;
            }

            const rates = { 'CNY': 7.82, 'USD': 56.45, 'EUR': 61.12, 'JPY': 0.37 };
            const rate = rates[source];
            const phpValue = amount * rate;

            convertedVal.innerText = `₱${phpValue.toLocaleString(undefined, {minimumFractionDigits: 2})}`;
            meta.innerText = `1 ${source} = ${rate} PHP [Parity Verified]`;
            
            resultDiv.classList.remove('hidden');
            resultDiv.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }

        document.addEventListener('DOMContentLoaded', function() {
            const sourceSelector = document.getElementById('source-currency');
            if (sourceSelector) {
                sourceSelector.addEventListener('change', (e) => {
                    const currency = e.target.value.split(' ')[0];
                    const label = document.getElementById('target-currency-label');
                    if (label) label.innerText = currency;
                });
            }

            const history = JSON.parse(localStorage.getItem('coretex_monthly_data') || '[]');
            
            let labels = ['JAN', 'FEB', 'MAR', 'APR', 'MAY', 'JUN'];
            let salesData = [12000000, 13500000, 12800000, 14500000, 16000000, 15500000];
            let expenseData = [9000000, 11000000, 10500000, 11500000, 13000000, 14000000];
            let profitData = salesData.map((s, i) => s - expenseData[i]);

            if (history.length > 0) {
                const last6 = history.slice(-6);
                labels = last6.map(h => h.month.toUpperCase());
                salesData = last6.map(h => (h.sales || 0));
                expenseData = last6.map(h => (h.expenses || 0));
                profitData = last6.map(h => h.profit || ((h.sales || 0) - (h.expenses || 0)));
            }

            // Global Chart Options
            const baseOptions = {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        backgroundColor: '#001A4D',
                        titleFont: { size: 14, weight: 'bold' },
                        bodyFont: { size: 13 },
                        padding: 15,
                        cornerRadius: 15,
                        displayColors: false
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        grid: { color: '#F8FAFC', drawBorder: false },
                        ticks: { 
                            font: { size: 11, weight: '600' },
                            color: '#94A3B8',
                            callback: function(value) { return '₱' + (value/1000).toLocaleString() + 'k'; } 
                        }
                    },
                    x: {
                        grid: { display: false },
                        ticks: { font: { size: 11, weight: 'bold' }, color: '#94A3B8' }
                    }
                }
            };

            // Chart 1: Margin Vector
            const profitCanvas = document.getElementById('profitChart');
            if (profitCanvas) {
                const ctxProfit = profitCanvas.getContext('2d');
                new Chart(ctxProfit, {
                    type: 'line',
                    data: {
                        labels: labels,
                        datasets: [{
                            data: profitData,
                            borderColor: '#006D68',
                            backgroundColor: 'rgba(0, 109, 104, 0.05)',
                            borderWidth: 5,
                            fill: true,
                            tension: 0.4,
                            pointRadius: 6,
                            pointBackgroundColor: '#006D68',
                            pointBorderColor: '#fff',
                            pointBorderWidth: 3
                        }]
                    },
                    options: baseOptions
                });
            }

            // Chart 2: Resource Stack
            const compCanvas = document.getElementById('comparisonChart');
            if (compCanvas) {
                const ctxComp = compCanvas.getContext('2d');
                new Chart(ctxComp, {
                    type: 'bar',
                    data: {
                        labels: labels,
                        datasets: [
                            { label: 'Revenue', data: salesData, backgroundColor: '#001A4D', borderRadius: 12, barThickness: 20 },
                            { label: 'Burn', data: expenseData, backgroundColor: '#E2E8F0', borderRadius: 12, barThickness: 20 }
                        ]
                    },
                    options: {
                        ...baseOptions,
                        plugins: {
                            ...baseOptions.plugins,
                            legend: { 
                                display: true, 
                                position: 'bottom', 
                                labels: { usePointStyle: true, padding: 25, font: { weight: 'black', size: 10 } } 
                            }
                        }
                    }
                });
            }
        });
    </script>
}
