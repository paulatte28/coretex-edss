@{
    ViewData["Title"] = "Data Visualization & Insights";
    Layout = "_AdminLayout";
}

<div class="space-y-10">
    <div class="flex items-center justify-between">
        <div>
            <h2 class="text-3xl font-black text-slate-900 tracking-tight">Data Viz & Insights</h2>
            <p class="text-xs text-slate-400 font-bold uppercase tracking-widest mt-2">Interactive Financial Tracking with ExchangeRate API</p>
        </div>
        <div class="flex items-center bg-white border border-slate-200 rounded-xl p-1 shadow-sm">
            <span class="px-3 text-[10px] font-black uppercase text-slate-400 tracking-widest">Base Currency</span>
            <select class="text-sm font-bold bg-slate-50 border-none rounded-lg text-slate-800 py-1.5 pl-3 pr-8 focus:ring-secondary/30 focus:border-secondary transition-all">
                <option value="USD">USD ($)</option>
                <option value="EUR">EUR (€)</option>
                <option value="GBP">GBP (£)</option>
                <option value="JPY">JPY (¥)</option>
            </select>
        </div>
    </div>

    <!-- Live Conversion Banner -->
    <div class="bg-gradient-to-r from-blue-50 to-indigo-50 border border-indigo-100 rounded-2xl p-4 flex items-center justify-between shadow-inner">
        <div class="flex items-center space-x-3">
            <div class="w-8 h-8 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center animate-pulse">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <div>
                <p class="text-[10px] font-black uppercase tracking-widest text-indigo-400">Live Exchange Rates Active</p>
                <p class="text-sm font-bold text-slate-700">1 USD = 0.92 EUR | 0.79 GBP</p>
            </div>
        </div>
        <p class="text-xs text-slate-400 font-medium italic">Last updated: 5 mins ago</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <!-- Chart 1: Profit Trend -->
        <div class="bg-white p-8 rounded-[2.5rem] shadow-sm border border-slate-100 relative overflow-hidden">
            <h3 class="font-black text-slate-800 text-lg mb-1">Net Profit Performance</h3>
            <p class="text-[10px] text-slate-400 font-bold uppercase tracking-[0.2em] mb-6">6-Month Trendline in PHP</p>
            
            <div class="h-64 relative z-10 flex justify-center">
                <canvas id="profitChart"></canvas>
            </div>
        </div>

        <!-- Chart 2: Sales vs Expenses comparison -->
        <div class="bg-white p-8 rounded-[2.5rem] shadow-sm border border-slate-100 relative overflow-hidden">
            <div class="flex justify-between items-center mb-6 z-10 relative">
                <div>
                    <h3 class="font-black text-slate-800 text-lg mb-1">Resource Utilization</h3>
                    <p class="text-[10px] text-slate-400 font-bold uppercase tracking-[0.2em] mb-6">Sales vs Total Expenses</p>
                </div>
            </div>
            
            <div class="h-64 relative z-10">
                <canvas id="comparisonChart"></canvas>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const history = JSON.parse(localStorage.getItem('coretex_monthly_data') || '[]');
            
            // Default mock data if history is empty
            let labels = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'];
            let salesData = [120000, 135000, 128000, 145000, 160000, 155000];
            let expenseData = [90000, 110000, 105000, 115000, 130000, 140000];
            let profitData = salesData.map((s, i) => s - expenseData[i]);

            if (history.length > 0) {
                // Get last 6 entries
                const last6 = history.slice(-6);
                labels = last6.map(h => h.month);
                salesData = last6.map(h => h.sales);
                expenseData = last6.map(h => h.expenses);
                profitData = last6.map(h => h.profit || (h.sales - h.expenses));
            }

            // Chart 1: Profit Trend (Line Chart)
            const ctxProfit = document.getElementById('profitChart').getContext('2d');
            new Chart(ctxProfit, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Net Profit',
                        data: profitData,
                        borderColor: '#006D68',
                        backgroundColor: 'rgba(0, 109, 104, 0.1)',
                        borderWidth: 4,
                        fill: true,
                        tension: 0.4,
                        pointRadius: 5,
                        pointBackgroundColor: '#006D68'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: { callbacks: { label: function(context) { return 'Profit: ₱' + context.parsed.y.toLocaleString(); } } }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: { color: '#F1F5F9' },
                            ticks: { font: {size: 10}, callback: function(value) { return '₱' + (value/1000) + 'k'; } }
                        },
                        x: {
                            grid: { display: false },
                            ticks: { font: {size: 10, weight: 'bold'} }
                        }
                    }
                }
            });

            // Chart 2: Sales vs Expenses (Bar Chart)
            const ctxComp = document.getElementById('comparisonChart').getContext('2d');
            new Chart(ctxComp, {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [
                        {
                            label: 'Sales Revenue',
                            data: salesData,
                            backgroundColor: '#001A4D',
                            borderRadius: 8
                        },
                        {
                            label: 'Total Expenses',
                            data: expenseData,
                            backgroundColor: '#E2E8F0',
                            borderRadius: 8
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'top', labels: { usePointStyle: true, font: { weight: 'bold', size: 10 } } }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: { color: '#F1F5F9' },
                            ticks: { font: {size: 10}, callback: function(value) { return '₱' + (value/1000) + 'k'; } }
                        },
                        x: {
                            grid: { display: false },
                            ticks: { font: {size: 10, weight: 'bold'} }
                        }
                    }
                }
            });
        });
    </script>
}
