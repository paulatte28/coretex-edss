@model coretex_finalproj.Models.DashboardViewModel
@{
    ViewData["Title"] = "Executive Dashboard";
    Layout = "_AdminLayout";
}

<!-- PHASE 5: IPGEOLOCATION LOGIN NOTIFICATION -->
<div id="login-geo-toast" class="fixed top-10 left-10 z-[100] transform -translate-x-[120%] transition-all duration-700 pointer-events-none">
    <div class="bg-white/80 backdrop-blur-xl p-5 rounded-[2rem] shadow-2xl border border-white flex items-center space-x-4">
        <div class="w-12 h-12 bg-emerald-50 text-emerald-600 rounded-2xl flex items-center justify-center animate-pulse">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        </div>
        <div>
            <p class="text-[10px] font-black uppercase text-slate-400 tracking-widest">Secure Login Detected</p>
            <p id="geo-text" class="text-xs font-bold text-slate-900 tracking-tight">Locating Business Owner...</p>
        </div>
    </div>
</div>

<div class="space-y-12">
    <!-- KPI Summary Section -->
    <section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-8">
        <!-- Revenue Card -->
        <div class="group bg-white p-10 rounded-[2.5rem] shadow-sm border border-slate-100 flex flex-col justify-between hover:shadow-2xl hover:-translate-y-2 transition-all duration-500 relative overflow-hidden">
            <div class="absolute top-0 left-0 w-full h-1.5 bg-gradient-to-r from-blue-400 to-secondary opacity-0 group-hover:opacity-100 transition-opacity"></div>
            <div class="flex items-center justify-between mb-8">
                <div class="p-4 bg-blue-50 text-blue-600 rounded-2xl group-hover:scale-110 transition-transform duration-500">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
                <div class="flex items-center space-x-1 text-emerald-500 font-black text-[10px] bg-emerald-50 px-3 py-1 rounded-full uppercase tracking-widest">
                    <svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 10l7-7m0 0l7 7m-7-7v18"/></svg>
                    <span>@Model.RevenueGrowth%</span>
                </div>
            </div>
            <div>
                <p class="text-slate-400 text-[10px] font-black uppercase tracking-[0.2em]">Cross-Revenue</p>
                <h3 class="text-4xl font-black text-slate-900 mt-2 tracking-tighter">₱@Model.TotalRevenue.ToString("N0")</h3>
            </div>
        </div>

        <!-- Orders Card -->
        <div class="group bg-white p-10 rounded-[2.5rem] shadow-sm border border-slate-100 flex flex-col justify-between hover:shadow-2xl hover:-translate-y-2 transition-all duration-500 relative overflow-hidden">
            <div class="absolute top-0 left-0 w-full h-1.5 bg-gradient-to-r from-indigo-400 to-primary opacity-0 group-hover:opacity-100 transition-opacity"></div>
            <div class="flex items-center justify-between mb-8">
                <div class="p-4 bg-indigo-50 text-indigo-600 rounded-2xl group-hover:scale-110 transition-transform duration-500">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
                </div>
                <div class="text-[10px] font-black text-indigo-400 uppercase tracking-widest bg-indigo-50 px-3 py-1 rounded-full text-center">Active Period</div>
            </div>
            <div>
                <p class="text-slate-400 text-[10px] font-black uppercase tracking-[0.2em]">Customer Volume</p>
                <h3 id="stat-orders" class="text-4xl font-black text-slate-900 mt-2 tracking-tighter">@Model.TotalOrders.ToString("N0")</h3>
            </div>
        </div>

        <!-- Risk Score Card -->
        <div class="group bg-white p-10 rounded-[2.5rem] shadow-sm border border-slate-100 flex flex-col justify-between hover:shadow-2xl hover:-translate-y-2 transition-all duration-500 relative overflow-hidden">
            <div id="risk-border" class="absolute top-0 left-0 w-full h-1.5 bg-slate-200 opacity-0 group-hover:opacity-100 transition-opacity"></div>
            <div class="flex items-center justify-between mb-8">
                <div id="risk-icon-bg" class="p-4 bg-slate-50 text-slate-400 rounded-2xl group-hover:scale-110 transition-transform duration-500">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.268 16c-.77 1.333.192 3 1.732 3z"/></svg>
                </div>
                <div id="risk-label" class="px-3 py-1 bg-slate-100 text-slate-600 font-black text-[10px] uppercase tracking-widest rounded-full">Auditing...</div>
            </div>
            <div>
                <p class="text-slate-400 text-[10px] font-black uppercase tracking-[0.2em]">Strategic Risk</p>
                <h3 id="stat-risk-score" class="text-4xl font-black text-slate-900 mt-2 tracking-tighter">--</h3>
            </div>
        </div>

        <!-- Inventory Card -->
        <div class="group bg-white p-10 rounded-[2.5rem] shadow-sm border border-slate-100 flex flex-col justify-between hover:shadow-2xl hover:-translate-y-2 transition-all duration-500 relative overflow-hidden">
            <div class="absolute top-0 left-0 w-full h-1.5 bg-gradient-to-r from-red-400 to-red-600 opacity-0 group-hover:opacity-100 transition-opacity"></div>
            <div class="flex items-center justify-between mb-8">
                <div class="p-4 bg-red-50 text-red-600 rounded-2xl group-hover:scale-110 transition-transform duration-500">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                </div>
                <div class="px-3 py-1 bg-red-500 text-white rounded-full text-[9px] font-black uppercase tracking-[0.2em] animate-pulse">Critical</div>
            </div>
            <div>
                <p class="text-slate-400 text-[10px] font-black uppercase tracking-[0.2em]">Supply Chain</p>
                <div class="flex items-baseline space-x-2 mt-2">
                    <h3 class="text-4xl font-black text-slate-900 tracking-tighter">@Model.LowStockItems</h3>
                    <span class="text-[10px] text-red-400 font-bold uppercase">Alerts Active</span>
                </div>
            </div>
        </div>

        <!-- Profit Card -->
        <div class="group bg-white p-10 rounded-[2.5rem] shadow-sm border border-slate-100 flex flex-col justify-between hover:shadow-2xl hover:-translate-y-2 transition-all duration-500 relative overflow-hidden">
            <div class="absolute top-0 left-0 w-full h-1.5 bg-gradient-to-r from-emerald-400 to-secondary opacity-0 group-hover:opacity-100 transition-opacity"></div>
            <div class="flex items-center justify-between mb-8">
                <div class="p-4 bg-emerald-50 text-emerald-600 rounded-2xl group-hover:scale-110 transition-transform duration-500">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
                </div>
                <div id="health-badge" class="px-3 py-1 bg-slate-900 text-white rounded-full text-[9px] font-black uppercase tracking-widest hidden">CORE: <span id="health-grade">-</span></div>
            </div>
            <div>
                <p class="text-slate-400 text-[10px] font-black uppercase tracking-[0.2em]">Net Efficiency</p>
                <h3 id="stat-profit-margin" class="text-4xl font-black text-slate-900 mt-2 tracking-tighter">@Model.ProfitMargin%</h3>
            </div>
        </div>
    </section>

    <section class="grid grid-cols-1 lg:grid-cols-3 gap-10">
        <!-- Sales & Analytics Chart -->
        <div class="lg:col-span-2 bg-white p-12 rounded-[3.5rem] shadow-xl shadow-slate-200/50 border border-slate-100 relative overflow-hidden">
            <div class="flex items-center justify-between mb-12 relative z-10">
                <div>
                    <h4 class="text-2xl font-black text-slate-900 tracking-tight">Performance Vectors</h4>
                    <p class="text-[10px] text-slate-400 font-bold uppercase tracking-[0.3em] mt-2">Live Revenue & Operational Flow</p>
                </div>
                <div class="flex bg-slate-100 p-1.5 rounded-2xl">
                    <button class="px-5 py-2 bg-white shadow-sm rounded-xl text-[10px] font-black text-slate-800 uppercase tracking-widest">Current YR</button>
                    <button class="px-5 py-2 text-[10px] font-black text-slate-400 hover:text-slate-600 transition uppercase tracking-widest">Historical</button>
                </div>
            </div>
            <div class="h-80 relative z-10">
                <canvas id="revenueChart"></canvas>
            </div>
            <div class="absolute -top-24 -right-24 w-48 h-48 bg-secondary/5 rounded-full blur-3xl"></div>
        </div>

        <!-- Predictive Trend Preview -->
        <div class="bg-primary text-white p-10 rounded-[3.5rem] shadow-2xl relative overflow-hidden flex flex-col justify-between">
            <div class="relative z-10">
                <div class="flex items-center space-x-3 mb-2">
                    <div class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse shadow-[0_0_10px_rgba(52,211,153,0.5)]"></div>
                    <h4 class="text-lg font-black tracking-tight">CORE Logic Engines</h4>
                </div>
                <p class="text-indigo-200 text-xs font-bold uppercase tracking-widest">Deep Predictive Synthesis</p>
                
                <div class="mt-12 space-y-8">
                    <div class="p-6 bg-white/5 rounded-[2rem] border border-white/10 backdrop-blur-md">
                        <p class="text-[10px] text-indigo-300 uppercase tracking-[0.2em] font-black mb-2">Aggregate Forecast</p>
                        <p id="dashboard-forecast-val" class="text-3xl font-black tracking-tighter">₱---</p>
                        <div class="flex items-center mt-3 space-x-2 text-emerald-400">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
                            <span class="text-[11px] font-black uppercase tracking-widest">+12.5% Projected</span>
                        </div>
                    </div>

                    <div class="space-y-5">
                        <p class="text-[10px] text-indigo-300 font-bold uppercase tracking-[0.3em]">Neural Insights</p>
                        <div class="flex items-start space-x-4">
                            <div class="w-1.5 h-1.5 bg-secondary rounded-full mt-2 ring-4 ring-secondary/20"></div>
                            <p class="text-sm text-indigo-100/80 font-medium leading-relaxed">High demand cluster detected for Smart Electronics in Q2 segment.</p>
                        </div>
                        <div class="flex items-start space-x-4">
                            <div class="w-1.5 h-1.5 bg-accent rounded-full mt-2 ring-4 ring-accent/20"></div>
                            <p class="text-sm text-indigo-100/80 font-medium leading-relaxed">Inventory redistribution could mitigate 15% latency in Cebu hub.</p>
                        </div>
                    </div>
                </div>
            </div>
            
            <button class="w-full py-5 bg-white text-primary font-black rounded-2xl hover:bg-emerald-400 hover:text-white transition-all shadow-xl text-[10px] uppercase tracking-[0.3em] mt-10">
                Open Strategy Deck
            </button>
            <div class="absolute -bottom-20 -right-20 w-64 h-64 bg-secondary/10 rounded-full animate-pulse"></div>
        </div>
    </section>

    <!-- Recent Transactions Section -->
    <section class="bg-white rounded-[3.5rem] shadow-xl shadow-slate-200/50 border border-slate-100 overflow-hidden">
        <div class="p-12 border-b border-slate-50 flex items-center justify-between bg-slate-50/20">
            <div>
                <h4 class="text-2xl font-black text-slate-900 tracking-tight">Audit Stream</h4>
                <p class="text-[10px] text-slate-400 font-black uppercase tracking-[0.3em] mt-2">Real-time Platform Transaction Ledger</p>
            </div>
            <div class="flex space-x-3">
                <button class="px-6 py-3 bg-white text-slate-700 text-[10px] font-black uppercase tracking-widest rounded-xl hover:bg-slate-50 transition-all border border-slate-200 shadow-sm">Filter</button>
                <button class="px-6 py-3 bg-slate-900 text-white text-[10px] font-black uppercase tracking-widest rounded-xl hover:bg-secondary transition-all shadow-xl shadow-slate-900/20">Export Ledger</button>
            </div>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead class="bg-white border-b border-slate-100">
                    <tr>
                        <th class="px-12 py-6 text-[10px] font-black text-slate-400 uppercase tracking-widest">Identifier</th>
                        <th class="px-12 py-6 text-[10px] font-black text-slate-400 uppercase tracking-widest">Counterparty</th>
                        <th class="px-12 py-6 text-[10px] font-black text-slate-400 uppercase tracking-widest">Timeline</th>
                        <th class="px-12 py-6 text-[10px] font-black text-slate-400 uppercase tracking-widest">Final Valuation</th>
                        <th class="px-12 py-6 text-[10px] font-black text-slate-400 uppercase tracking-widest">Security Status</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50">
                    @foreach (var item in Model.RecentTransactions)
                    {
                        <tr class="hover:bg-slate-50/50 transition-all duration-300 group">
                            <td class="px-12 py-8">
                                <span class="text-sm font-black text-slate-900 inline-block px-3 py-1 bg-slate-100 rounded-lg group-hover:bg-secondary group-hover:text-white transition-colors">@item.OrderId</span>
                            </td>
                            <td class="px-12 py-8">
                                <div class="flex items-center space-x-3">
                                    <div class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center font-black text-[10px] text-slate-400 italic">@item.CustomerName.Substring(0, 1)</div>
                                    <span class="text-sm font-black text-slate-700 tracking-tight">@item.CustomerName</span>
                                </div>
                            </td>
                            <td class="px-12 py-8 text-xs font-bold text-slate-400 uppercase tracking-tighter">@item.Date.ToString("MMM dd, yyyy")</td>
                            <td class="px-12 py-8">
                                <span class="text-sm font-black text-slate-900">₱@item.Amount.ToString("N2")</span>
                            </td>
                            <td class="px-12 py-8">
                                @if (item.Status == "Completed")
                                {
                                    <span class="inline-flex items-center px-4 py-1.5 bg-emerald-50 text-emerald-600 rounded-full text-[9px] font-black uppercase tracking-widest border border-emerald-100 shadow-sm shadow-emerald-100/50">@item.Status</span>
                                }
                                else if (item.Status == "Pending")
                                {
                                    <span class="inline-flex items-center px-4 py-1.5 bg-amber-50 text-amber-600 rounded-full text-[9px] font-black uppercase tracking-widest border border-amber-100">@item.Status</span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center px-4 py-1.5 bg-blue-50 text-blue-600 rounded-full text-[9px] font-black uppercase tracking-widest border border-blue-100">@item.Status</span>
                                }
                            </td>
                        </tr>
                    }
        </div>
    </section>
</div>

@section Scripts {
    <script>
        const ctx = document.getElementById('revenueChart').getContext('2d');
        
        // Custom Theme Colors
        const primaryColor = '#001A4D'; // Navy
        const secondaryColor = '#006D68'; // Teal
        const gridColor = '#F1F5F9';
        
        const mainChart = new Chart(ctx, {
            type: 'line',
            data: {
                labels: @Json.Serialize(Model.MonthlyLabels),
                datasets: [
                    {
                        label: 'Revenue',
                        data: @Json.Serialize(Model.RevenueData),
                        borderColor: secondaryColor,
                        backgroundColor: 'rgba(0, 109, 104, 0.1)',
                        borderWidth: 4,
                        fill: true,
                        tension: 0.4,
                        pointRadius: 4,
                        pointBackgroundColor: secondaryColor,
                        pointBorderColor: '#fff',
                        pointHoverRadius: 6
                    },
                    {
                        label: 'Expenses',
                        data: @Json.Serialize(Model.ExpenseData),
                        borderColor: '#E2E8F0',
                        borderWidth: 2,
                        borderDash: [5, 5],
                        fill: false,
                        tension: 0.4,
                        pointRadius: 0
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        display: false
                    },
                    tooltip: {
                        backgroundColor: primaryColor,
                        padding: 12,
                        titleFont: { size: 14, weight: 'bold' },
                        bodyFont: { size: 13 },
                        cornerRadius: 12,
                        displayColors: false
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        grid: {
                            color: gridColor,
                            drawBorder: false
                        },
                        ticks: {
                            color: '#94A3B8',
                            font: { size: 12, weight: '500' },
                            callback: function(value) { return '₱' + value.toLocaleString(); }
                        }
                    },
                    x: {
                        grid: {
                            display: false
                        },
                        ticks: {
                            color: '#94A3B8',
                            font: { size: 12, weight: '500' }
                        }
                    }
                }
            }
        });

        // PHASE 5: Business Owner Dynamic Data & Geolocation
        document.addEventListener('DOMContentLoaded', async () => {
            const history = JSON.parse(localStorage.getItem('coretex_monthly_data') || '[]');
            
            // 1. IPGeolocation Simulation
            const geoToast = document.getElementById('login-geo-toast');
            const geoText = document.getElementById('geo-text');
            setTimeout(async () => {
                geoToast.classList.remove('-translate-x-[120%]');
                try {
                    const res = await fetch('https://ipapi.co/json/');
                    const data = await res.json();
                    geoText.innerText = `${data.city}, ${data.country_name} (${data.ip})`;
                } catch (e) {
                    geoText.innerText = 'Quezon City, PH (Verified IP)';
                }
                setTimeout(() => geoToast.classList.add('-translate-x-[120%]'), 4000);
            }, 1000);

            // 2. Risk Score & Tile Logic
            const riskH3 = document.getElementById('stat-risk-score');
            const riskLabel = document.getElementById('risk-label');
            const riskBg = document.getElementById('risk-icon-bg');
            const riskBorder = document.getElementById('risk-border');

            const calculateRisk = (revenue, margin) => {
                let score = 25;
                if (margin < 20) score += 30; // High expense risk
                if (revenue < 50000) score += 15; // Low volume risk
                return score;
            };

            const updateRiskUI = (score) => {
                riskH3.innerText = score;
                if (score < 40) {
                    riskLabel.innerText = 'Low Risk';
                    riskLabel.classList.add('bg-emerald-100', 'text-emerald-700');
                    riskBg.classList.add('bg-emerald-50', 'text-emerald-500');
                    riskBorder.classList.add('bg-emerald-400');
                } else if (score < 70) {
                    riskLabel.innerText = 'Moderate';
                    riskLabel.classList.add('bg-amber-100', 'text-amber-700');
                    riskBg.classList.add('bg-amber-50', 'text-amber-500');
                    riskBorder.classList.add('bg-amber-400');
                } else {
                    riskLabel.innerText = 'High Risk';
                    riskLabel.classList.add('bg-red-100', 'text-red-700');
                    riskBg.classList.add('bg-red-50', 'text-red-500');
                    riskBorder.classList.add('bg-red-400');
                }
            };

            if (history.length > 0) {
                const latest = history[history.length - 1];
                
                // Update KPI Tiles
                if (latest.sales) {
                    const salesEls = document.querySelectorAll('h3.text-4xl.font-black.text-slate-900.tracking-tighter');
                    if (salesEls.length > 0) salesEls[0].innerText = `₱${latest.sales.toLocaleString()}`;
                }
                if (latest.customers) document.getElementById('stat-orders').innerText = latest.customers.toLocaleString();
                if (latest.profitMargin) document.getElementById('stat-profit-margin').innerText = `${latest.profitMargin}%`;
                
                // Risk Logic
                const score = calculateRisk(latest.sales, parseFloat(latest.profitMargin));
                updateRiskUI(score);

                // Update Forecast Preview
                if (latest.forecast) {
                    const forecastVal = document.getElementById('dashboard-forecast-val');
                    if (forecastVal) forecastVal.innerText = `₱${latest.forecast.toLocaleString()}`;
                }

                // Update Health Summary Grade
                const health = localStorage.getItem('coretex_business_health');
                if (health) {
                    const badge = document.getElementById('health-badge');
                    const grade = document.getElementById('health-grade');
                    badge.classList.remove('hidden');
                    grade.innerText = health;
                    if (health.startsWith('A')) {
                        badge.classList.add('bg-emerald-500');
                        badge.classList.remove('bg-slate-900');
                    }
                    if (health.startsWith('C')) {
                        badge.classList.add('bg-red-500');
                        badge.classList.remove('bg-slate-900');
                    }
                }
            } else {
                // Fallback to Model data for first load
                const score = calculateRisk(@Model.TotalRevenue, @Model.ProfitMargin);
                updateRiskUI(score);
            }
        });
    </script>
}
