<div class="space-y-12">
    <div class="flex items-center justify-between">
        <div>
            <h2 class="text-4xl font-black text-slate-900 tracking-tighter uppercase">Audit Hub</h2>
            <p class="text-[10px] text-slate-400 font-black uppercase tracking-[0.3em] mt-2">Verified Financial Records & Digital Asset Exports</p>
        </div>
        <div class="flex items-center space-x-3 text-[10px] font-black uppercase text-secondary tracking-widest bg-emerald-50 px-4 py-2 rounded-xl border border-emerald-100">
            <div class="w-2 h-2 bg-secondary rounded-full animate-pulse shadow-[0_0_10px_rgba(0,109,104,0.4)]"></div>
            <span>Audit Gateway Secure</span>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-10">
        <!-- Quick Actions Column -->
        <div class="space-y-6">
            <div class="bg-white p-8 rounded-[3rem] border border-slate-100 shadow-sm hover:shadow-2xl hover:-translate-y-2 transition-all duration-500 cursor-pointer group">
                <div class="w-14 h-14 bg-blue-50 text-blue-600 rounded-3xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                    <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 2v-6m10 10V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2z" /></svg>
                </div>
                <h4 class="font-black text-slate-900 text-lg tracking-tight">Period Summary</h4>
                <p class="text-[11px] text-slate-400 font-bold uppercase tracking-tight mt-2 italic">Revenue vs Op. Burn</p>
                <button class="mt-8 w-full py-4 bg-slate-900 text-white text-[10px] font-black uppercase tracking-[0.3em] rounded-2xl group-hover:bg-blue-600 transition-all shadow-xl">
                    Generate Sync
                </button>
            </div>

            <div class="bg-primary p-10 rounded-[3rem] text-white shadow-2xl relative overflow-hidden group">
                <div class="absolute top-0 right-0 w-32 h-32 bg-emerald-500/10 rounded-full blur-3xl group-hover:scale-150 transition-transform duration-1000"></div>
                <h4 class="font-black text-xl tracking-tight mb-4">Export PDF</h4>
                <p class="text-[11px] text-indigo-200/60 font-bold tracking-widest leading-relaxed mb-8 uppercase">Official Digital Asset for Stakeholder Review</p>
                
                <button id="export-pdf-btn" onclick="simulateExport()" class="w-full py-5 bg-white text-primary font-black rounded-2xl text-[10px] uppercase tracking-[0.3em] hover:bg-emerald-400 hover:text-white transition-all shadow-2xl relative z-10">
                    Verify & Finalize
                </button>
                
                <div id="export-toast" class="hidden mt-6 p-4 bg-white/5 border border-white/10 rounded-2xl flex items-center space-x-3 animate-pulse relative z-10">
                    <div class="w-2 h-2 bg-emerald-400 rounded-full ring-4 ring-emerald-400/20"></div>
                    <span class="text-[9px] font-black text-indigo-100 uppercase tracking-widest">Compiling Audit File...</span>
                </div>
            </div>
        </div>

        <!-- Financial Breakdown Table -->
        <div class="lg:col-span-3 bg-white border border-slate-100 rounded-[3.5rem] shadow-xl shadow-slate-200/50 overflow-hidden flex flex-col">
            <div class="p-12 border-b border-slate-50 flex justify-between items-center bg-slate-50/20">
                <div>
                    <h3 class="font-black text-slate-900 text-2xl tracking-tighter uppercase">Audit Ledger</h3>
                    <p class="text-[10px] text-slate-400 font-black uppercase tracking-[0.3em] mt-2 italic">PHP-Normalized Operational Parity</p>
                </div>
                <div class="flex items-center space-x-3">
                    <span class="px-4 py-2 bg-emerald-50 text-emerald-600 rounded-xl text-[10px] font-black uppercase tracking-widest shadow-sm">Verified by CORE Engine</span>
                </div>
            </div>

            <div class="flex-1 overflow-x-auto">
                <table class="w-full text-left">
                    <thead>
                        <tr class="bg-white border-b border-slate-100">
                            <th class="px-12 py-6 text-[10px] font-black text-slate-400 uppercase tracking-widest">Timeline</th>
                            <th class="px-12 py-6 text-[10px] font-black text-slate-400 uppercase tracking-widest text-right">Sales Revenue</th>
                            <th class="px-12 py-6 text-[10px] font-black text-slate-400 uppercase tracking-widest text-right">Burn Flow</th>
                            <th class="px-12 py-6 text-[10px] font-black text-slate-400 uppercase tracking-widest text-center">Imported Basis</th>
                            <th class="px-12 py-6 text-[10px] font-black text-slate-400 uppercase tracking-widest text-right">Audited Margin</th>
                        </tr>
                    </thead>
                    <tbody id="breakdown-body" class="divide-y divide-slate-50">
                        <!-- Dynamic content -->
                    </tbody>
                </table>
                <div id="no-data-msg" class="hidden p-32 text-center">
                    <div class="w-16 h-16 bg-slate-100 rounded-3xl flex items-center justify-center mx-auto mb-6 text-slate-300">
                        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" /></svg>
                    </div>
                    <p class="text-[10px] text-slate-400 font-black uppercase tracking-[0.4em]">Empty Ledger State</p>
                </div>
            </div>
            
            <div class="px-12 py-8 bg-slate-50/50 border-t border-slate-100 italic">
                <p class="text-[11px] text-slate-400 font-bold uppercase tracking-widest">
                    * ALL ENTRIES ARE AUTONOMOUSLY NORMALIZED TO PHP VIA EXCHANGERATE PARITY.
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function simulateExport() {
            const btn = document.getElementById('export-pdf-btn');
            const toast = document.getElementById('export-toast');
            
            if (btn.innerText === 'Download Again') {
                alert('Success! Financial_Audit_Final.pdf is being downloaded.');
                return;
            }

            btn.disabled = true;
            btn.innerText = 'Analyzing Data...';
            toast.classList.remove('hidden');

            setTimeout(() => {
                toast.innerHTML = `
                    <div class="w-2 h-2 bg-white rounded-full"></div>
                    <span class="text-[9px] font-black text-white uppercase tracking-widest">Success: Digest Exported!</span>
                `;
                toast.classList.remove('animate-pulse');
                toast.classList.add('bg-blue-600', 'border-blue-700');
                btn.innerText = 'Download Again';
                btn.disabled = false;
                alert('Success! Official Financial Audit has been compiled.');
            }, 3000);
        }

        document.addEventListener('DOMContentLoaded', () => {
            const history = JSON.parse(localStorage.getItem('coretex_monthly_data') || '[]');
            const tbody = document.getElementById('breakdown-body');
            const noData = document.getElementById('no-data-msg');

            if (history.length === 0) {
                noData.classList.remove('hidden');
                return;
            }

            history.forEach(item => {
                const row = document.createElement('tr');
                row.className = 'hover:bg-slate-50/50 transition-all duration-300 group';
                
                const sales = parseFloat(item.sales || 0);
                const expenses = parseFloat(item.expenses || 0);
                const imported = parseFloat(item.importedCostPHP || 0);
                const profit = parseFloat(item.profit || (sales - expenses));

                row.innerHTML = `
                    <td class="px-12 py-10">
                        <span class="font-black text-slate-900 text-sm tracking-tight inline-block px-4 py-2 bg-slate-50 rounded-xl group-hover:bg-primary group-hover:text-white transition-colors uppercase italic">${item.month}</span>
                    </td>
                    <td class="px-12 py-10 text-right">
                        <span class="text-sm font-black text-slate-900 tracking-tighter">₱${sales.toLocaleString()}</span>
                    </td>
                    <td class="px-12 py-10 text-right">
                        <span class="text-sm font-black text-red-500 tracking-tighter">₱${expenses.toLocaleString()}</span>
                    </td>
                    <td class="px-12 py-10 text-center">
                        <div class="flex flex-col items-center">
                            <span class="text-sm font-black text-slate-800 tracking-tight italic">₱${imported.toLocaleString()}</span>
                            <span class="text-[9px] font-black text-slate-400 uppercase tracking-widest mt-1">Audit: ${item.currency || 'USD'}</span>
                        </div>
                    </td>
                    <td class="px-12 py-10 text-right">
                        <span class="inline-flex items-center px-5 py-2 bg-emerald-50 text-emerald-600 rounded-full text-[11px] font-black uppercase tracking-widest border border-emerald-100 shadow-xl shadow-emerald-100/50">
                            ₱${profit.toLocaleString()}
                        </span>
                    </td>
                `;
                tbody.appendChild(row);
            });
        });
    </script>
}
