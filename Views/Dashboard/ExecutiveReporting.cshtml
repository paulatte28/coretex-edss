@{
    ViewData["Title"] = "Executive Reporting";
    Layout = "_AdminLayout";
}

<div class="space-y-8">
    <div class="flex items-center justify-between">
        <div>
            <h2 class="text-3xl font-black text-slate-900 tracking-tight">Executive Audit & Reporting</h2>
            <p class="text-xs text-slate-400 font-bold uppercase tracking-widest mt-2">Verified Financial Records & Official Document Exports</p>
        </div>
        <div class="flex items-center space-x-3 text-[10px] font-black uppercase text-slate-400 tracking-widest">
            <div class="w-2 h-2 bg-emerald-500 rounded-full animate-pulse"></div>
            <span>SendGrid API Connected</span>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
        <!-- Quick Actions Column -->
        <div class="space-y-4">
            <div class="bg-white p-6 rounded-3xl border border-slate-100 shadow-sm hover:shadow-md transition-shadow cursor-pointer group">
                <div class="w-12 h-12 bg-blue-50 text-blue-600 rounded-2xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 2v-6m10 10V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2z" /></svg>
                </div>
                <h4 class="font-bold text-slate-800">Financial Summary</h4>
                <p class="text-xs text-slate-400 mt-1">Monthly P&L, Revenue vs Expenses</p>
                <button class="mt-4 w-full py-2 bg-slate-50 text-slate-600 text-[10px] font-black uppercase tracking-widest rounded-lg group-hover:bg-blue-600 group-hover:text-white transition-colors">
                    Generate Now
                </button>
            </div>

            <div class="bg-slate-900 p-8 rounded-[2rem] text-white shadow-xl relative overflow-hidden group">
                <div class="absolute top-0 right-0 w-24 h-24 bg-emerald-500/10 rounded-full blur-2xl group-hover:scale-150 transition-transform"></div>
                <h4 class="font-bold text-sm mb-4">Export Official Report</h4>
                <p class="text-[10px] text-slate-400 leading-relaxed mb-6">Verified financial records aggregated into a secure PDF document for stakeholder review.</p>
                <button id="export-pdf-btn" onclick="simulateExport()" class="w-full py-4 bg-emerald-500 text-white font-black rounded-xl text-[10px] uppercase tracking-widest hover:bg-emerald-400 transition-all shadow-lg shadow-emerald-500/20">
                    Verify & Export PDF
                </button>
                <div id="export-toast" class="hidden mt-4 p-3 bg-emerald-500/20 border border-emerald-500/30 rounded-xl flex items-center space-x-2 animate-pulse">
                    <div class="w-2 h-2 bg-emerald-400 rounded-full"></div>
                    <span class="text-[9px] font-bold text-emerald-400 uppercase tracking-widest">Generating Digital Asset...</span>
                </div>
            </div>
        </div>

        <!-- Financial Breakdown Table -->
        <div class="lg:col-span-3 bg-white border border-slate-100 rounded-[2.5rem] shadow-sm overflow-hidden flex flex-col">
            <div class="p-8 border-b border-slate-50 flex justify-between items-center bg-slate-50/50">
                <div>
                    <h3 class="font-black text-slate-800 text-lg">Financial Audit Breakdown</h3>
                    <p class="text-[10px] text-slate-400 font-bold uppercase tracking-[0.2em] mt-1">Full verification of PHP-normalized records</p>
                </div>
                <div class="flex items-center space-x-2">
                    <div class="px-3 py-1 bg-emerald-50 text-emerald-600 rounded-lg text-[9px] font-black uppercase tracking-widest">Verified by CORE AI</div>
                </div>
            </div>

            <div class="flex-1 overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-white border-b border-slate-100">
                            <th class="px-8 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest">Timeline</th>
                            <th class="px-8 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest">Sales Revenue</th>
                            <th class="px-8 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest">Op. Expenses</th>
                            <th class="px-8 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest">Imported Costs</th>
                            <th class="px-8 py-4 text-[10px] font-black text-slate-400 uppercase tracking-widest">Net Profit</th>
                        </tr>
                    </thead>
                    <tbody id="breakdown-body" class="divide-y divide-slate-50">
                        <!-- Dynamic content via script -->
                    </tbody>
                </table>
                <div id="no-data-msg" class="hidden p-20 text-center">
                    <p class="text-xs text-slate-400 font-bold uppercase tracking-[0.3em]">No Financial Records Found</p>
                </div>
            </div>
            
            <div class="px-8 py-6 bg-slate-50/50 border-t border-slate-100">
                <p class="text-[10px] text-slate-400 font-medium italic">
                    * All values are automatically normalized to Philippine Peso (PHP) using real-time ExchangeRate API parity at the moment of entry.
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function simulateExport() {
            const btn = document.getElementById('export-pdf-btn');
            const toast = document.getElementById('export-toast');
            
            if (btn.innerText === 'Download Again') {
                alert('Success! Financial_Audit_Q2_2026.pdf is being downloaded again.');
                return;
            }

            btn.disabled = true;
            btn.innerText = 'Processing Audit...';
            toast.classList.remove('hidden');

            setTimeout(() => {
                toast.innerHTML = `
                    <div class="w-2 h-2 bg-white rounded-full"></div>
                    <span class="text-[9px] font-bold text-white uppercase tracking-widest">Success: Report Exported!</span>
                `;
                toast.classList.remove('animate-pulse');
                toast.classList.add('bg-blue-600', 'border-blue-700');
                btn.innerText = 'Download Again';
                btn.disabled = false;
                alert('Success! Financial_Audit_Q2_2026.pdf has been prepared for download.');
            }, 3000);
        }

        document.addEventListener('DOMContentLoaded', () => {
            const history = JSON.parse(localStorage.getItem('coretex_monthly_data') || '[]');
            const tbody = document.getElementById('breakdown-body');
            const noData = document.getElementById('no-data-msg');

            if (history.length === 0) {
                noData.classList.remove('hidden');
                return;
            }

            history.forEach(item => {
                const row = document.createElement('tr');
                row.className = 'hover:bg-slate-50/50 transition-colors group';
                
                const sales = parseFloat(item.sales || 0);
                const expenses = parseFloat(item.expenses || 0);
                const imported = parseFloat(item.importedCostPHP || 0);
                const profit = parseFloat(item.profit || (sales - expenses));

                row.innerHTML = `
                    <td class="px-8 py-6">
                        <span class="font-black text-slate-900 text-sm">${item.month}</span>
                    </td>
                    <td class="px-8 py-6">
                        <span class="text-xs font-bold text-slate-800 tracking-tight">₱${sales.toLocaleString()}</span>
                    </td>
                    <td class="px-8 py-6">
                        <span class="text-xs font-bold text-red-500 tracking-tight">₱${expenses.toLocaleString()}</span>
                    </td>
                    <td class="px-8 py-6">
                        <div class="flex flex-col">
                            <span class="text-xs font-bold text-slate-800 italic">₱${imported.toLocaleString()}</span>
                            <span class="text-[9px] font-black text-slate-400 uppercase tracking-tighter">via ${item.currency || 'USD'} Audit</span>
                        </div>
                    </td>
                    <td class="px-8 py-6">
                        <span class="inline-flex items-center px-4 py-1.5 bg-emerald-50 text-emerald-600 rounded-full text-[10px] font-black uppercase tracking-widest border border-emerald-100">
                            ₱${profit.toLocaleString()}
                        </span>
                    </td>
                `;
                tbody.appendChild(row);
            });
        });
    </script>
}
