@{
    ViewData["Title"] = "Subscription Plans";
    Layout = "_AdminLayout";
}

<div class="space-y-10">
    <!-- Header Section -->
    <div class="text-center max-w-3xl mx-auto mb-16 relative">
        <div class="absolute -top-10 left-1/2 -translate-x-1/2 w-64 h-64 bg-blue-500/20 blur-[100px] rounded-full pointer-events-none"></div>
        <h2 class="text-4xl lg:text-5xl font-black text-slate-900 tracking-tight leading-tight">Scale Your Decision Making</h2>
        <p class="text-slate-500 text-sm md:text-base mt-4 font-medium px-4">Choose a subscription tier that matches your company's operational needs. Upgrade anytime to unlock predictive capabilities.</p>
        
        <div class="flex justify-center items-center space-x-4 mt-8">
            <span class="text-sm font-bold text-slate-500">Monthly</span>
            <button class="relative w-14 h-7 bg-slate-200 rounded-full focus:outline-none transition-colors duration-300">
                <span class="absolute left-1 top-1 w-5 h-5 bg-white rounded-full shadow-sm transform translate-x-7 transition-transform duration-300"></span>
            </button>
            <span class="text-sm font-bold text-slate-900">Annually <span class="ml-1 text-[9px] uppercase tracking-widest bg-emerald-100 text-emerald-700 px-2 py-0.5 rounded-full font-black">Save 20%</span></span>
        </div>
    </div>

    <!-- Pricing Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-6xl mx-auto relative z-10">
        
        <!-- Basic Tier -->
        <div class="bg-white rounded-[2.5rem] p-10 border border-slate-100 shadow-xl shadow-slate-200/50 flex flex-col hover:-translate-y-2 transition-transform duration-300">
            <div class="mb-6">
                <span class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 bg-slate-50 px-3 py-1 rounded-full">Core</span>
                <h3 class="text-2xl font-black text-slate-800 tracking-tight mt-4">Starter Analytics</h3>
                <p class="text-xs text-slate-500 mt-2 font-medium">Perfect for small businesses making the transition to data.</p>
            </div>
            <div class="mb-8 flex items-baseline text-slate-900">
                <span class="text-4xl font-black tracking-tighter">$49</span>
                <span class="text-sm text-slate-400 ml-1 font-bold">/mo</span>
            </div>
            
            <ul class="space-y-4 mb-10 flex-1">
                <li class="flex items-center space-x-3 text-sm font-semibold text-slate-600">
                    <svg class="w-5 h-5 text-emerald-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                    <span>Basic KPI Dashboard</span>
                </li>
                <li class="flex items-center space-x-3 text-sm font-semibold text-slate-600">
                    <svg class="w-5 h-5 text-emerald-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                    <span>Up to 3 Users</span>
                </li>
                <li class="flex items-center space-x-3 text-sm font-semibold text-slate-600">
                    <svg class="w-5 h-5 text-emerald-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                    <span>Manual Data Entry</span>
                </li>
            </ul>
            <button onclick="window.location.href='/Home/Onboarding?plan=Starter'" class="w-full py-4 bg-slate-50 text-slate-700 font-bold rounded-2xl hover:bg-slate-100 transition-colors">Start Free Trial</button>
        </div>

        <!-- Premium Tier (Highlighted) -->
        <div class="bg-slate-900 rounded-[2.5rem] p-10 shadow-2xl shadow-blue-900/40 flex flex-col relative transform md:-translate-y-4 border border-white/10 overflow-hidden">
            <div class="absolute top-0 right-0 -mt-10 -mr-10 w-40 h-40 bg-blue-500 rounded-full blur-3xl opacity-30"></div>
            
            <div class="mb-6 relative z-10">
                <div class="flex items-center justify-between">
                    <span class="text-[10px] font-black uppercase tracking-[0.2em] text-blue-300 bg-blue-500/20 px-3 py-1 rounded-full">Pro</span>
                    <span class="text-[9px] font-black uppercase tracking-[0.1em] text-white bg-gradient-to-r from-emerald-400 to-emerald-500 px-3 py-1 rounded-full shadow-lg shadow-emerald-500/20">Most Popular</span>
                </div>
                <h3 class="text-2xl font-black text-white tracking-tight mt-4">Predictive Hub</h3>
                <p class="text-xs text-slate-400 mt-2 font-medium">Unlocks AI forecasting and automated reporting capabilities.</p>
            </div>
            <div class="mb-8 flex items-baseline text-white relative z-10">
                <span class="text-4xl font-black tracking-tighter">$149</span>
                <span class="text-sm text-slate-400 ml-1 font-bold">/mo</span>
            </div>
            
            <ul class="space-y-4 mb-10 flex-1 relative z-10">
                <li class="flex items-center space-x-3 text-sm font-semibold text-slate-300">
                    <svg class="w-5 h-5 text-emerald-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                    <span class="text-white">Everything in Core</span>
                </li>
                <li class="flex items-center space-x-3 text-sm font-semibold text-slate-300">
                    <svg class="w-5 h-5 text-emerald-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                    <span>Unlimited Users</span>
                </li>
                <li class="flex items-center space-x-3 text-sm font-semibold text-slate-300">
                    <svg class="w-5 h-5 text-emerald-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                    <span>Automated Email Reporting</span>
                </li>
                <li class="flex items-center space-x-3 text-sm font-semibold text-slate-300">
                    <svg class="w-5 h-5 text-emerald-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                    <span>Demand Forecasting AI</span>
                </li>
            </ul>
            <button onclick="window.location.href='/Home/Onboarding?plan=Pro'" class="relative z-10 w-full py-4 bg-white text-slate-900 font-black rounded-2xl hover:bg-slate-100 transition-colors shadow-lg shadow-white/10">Upgrade to Pro</button>
        </div>

        <!-- Enterprise Tier -->
        <div class="bg-white rounded-[2.5rem] p-10 border border-slate-100 shadow-xl shadow-slate-200/50 flex flex-col hover:-translate-y-2 transition-transform duration-300">
            <div class="mb-6">
                <span class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-400 bg-slate-50 px-3 py-1 rounded-full">Suite</span>
                <h3 class="text-2xl font-black text-slate-800 tracking-tight mt-4">Enterprise Grade</h3>
                <p class="text-xs text-slate-500 mt-2 font-medium">Custom tailored EDSS platform with multi-tenant data bridges.</p>
            </div>
            <div class="mb-8 flex items-baseline text-slate-900">
                <span class="text-4xl font-black tracking-tighter">Custom</span>
            </div>
            
            <ul class="space-y-4 mb-10 flex-1">
                <li class="flex items-center space-x-3 text-sm font-semibold text-slate-600">
                    <svg class="w-5 h-5 text-emerald-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                    <span class="font-bold text-slate-800">Everything in Pro</span>
                </li>
                <li class="flex items-center space-x-3 text-sm font-semibold text-slate-600">
                    <svg class="w-5 h-5 text-emerald-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                    <span>Custom API Integrations</span>
                </li>
                <li class="flex items-center space-x-3 text-sm font-semibold text-slate-600">
                    <svg class="w-5 h-5 text-emerald-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                    <span>SMS Alert Trigger Algorithms</span>
                </li>
                <li class="flex items-center space-x-3 text-sm font-semibold text-slate-600">
                    <svg class="w-5 h-5 text-emerald-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                    <span>Dedicated Support Lead</span>
                </li>
            </ul>
            <button onclick="window.location.href='/Home/Onboarding?plan=Enterprise'" class="w-full py-4 bg-slate-100 text-slate-600 font-bold rounded-2xl hover:bg-slate-200 transition-colors">Contact Sales</button>
        </div>

    </div>
</div>
