@model IEnumerable<coretex_finalproj.Models.Tenant>
@{
    ViewData["Title"] = "Tenant Management";
    Layout = "_AdminLayout";
}

<div class="space-y-10">
    <div class="flex items-center justify-between">
        <div>
            <div class="flex items-center space-x-3 mb-2">
                <span class="px-3 py-1 bg-blue-100 text-blue-700 font-black text-[10px] uppercase tracking-widest rounded-full">Super Admin Only</span>
                <span class="px-3 py-1 bg-slate-100 text-slate-500 font-bold text-[10px] uppercase tracking-widest rounded-full">Multi-Tenant Engine</span>
            </div>
            <h2 class="text-3xl font-black text-slate-900 tracking-tight">Tenant Management</h2>
            <p class="text-xs text-slate-400 font-bold uppercase tracking-widest mt-2">Manage registered electronics companies</p>
        </div>
        
        <button class="px-6 py-3 bg-slate-900 text-white font-bold rounded-xl text-sm hover:bg-slate-800 transition-all shadow-lg flex items-center space-x-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" /></svg>
            <span>Onboard New Client</span>
        </button>
    </div>

    <!-- Metrics Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white p-6 rounded-3xl border border-slate-100 shadow-sm flex items-center justify-between">
            <div>
                <p class="text-[10px] text-slate-400 font-bold uppercase tracking-[0.2em]">Active Tenants</p>
                <h3 class="text-3xl font-black text-slate-900 mt-1 tracking-tight">24</h3>
            </div>
            <div class="w-12 h-12 bg-emerald-50 text-emerald-600 rounded-2xl flex items-center justify-center">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            </div>
        </div>
        
        <div class="bg-white p-6 rounded-3xl border border-slate-100 shadow-sm flex items-center justify-between">
            <div>
                <p class="text-[10px] text-slate-400 font-bold uppercase tracking-[0.2em]">Pending Review</p>
                <h3 class="text-3xl font-black text-slate-900 mt-1 tracking-tight">3</h3>
            </div>
            <div class="w-12 h-12 bg-amber-50 text-amber-600 rounded-2xl flex items-center justify-center">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            </div>
        </div>
        
        <div class="bg-white p-6 rounded-3xl border border-slate-100 shadow-sm flex items-center justify-between">
            <div>
                <p class="text-[10px] text-slate-400 font-bold uppercase tracking-[0.2em]">Total MRR</p>
                <h3 class="text-3xl font-black text-slate-900 mt-1 tracking-tight">$8,450</h3>
            </div>
            <div class="w-12 h-12 bg-blue-50 text-blue-600 rounded-2xl flex items-center justify-center">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            </div>
        </div>
    </div>

    <!-- Companies List -->
    <div class="bg-white rounded-[3rem] shadow-xl shadow-slate-200/50 border border-slate-100 overflow-hidden">
        <div class="p-8 border-b border-slate-50 flex items-center justify-between">
            <div>
                <h4 class="text-xl font-black text-slate-900 tracking-tight">Registered Companies</h4>
                <p class="text-[10px] text-slate-400 font-bold uppercase tracking-[0.2em] mt-1">Status & Sandbox Management</p>
            </div>
            <div class="relative">
                <input type="text" placeholder="Search tenants..." class="bg-slate-50 border-none rounded-xl py-2 pl-10 pr-4 text-xs font-bold text-slate-600 w-64 focus:ring-2 focus:ring-secondary/30 transition-all">
                <svg class="w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
            </div>
        </div>
        
        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead class="bg-slate-50 border-b border-slate-100">
                    <tr>
                        <th class="px-10 py-5 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">Company / Owner</th>
                        <th class="px-10 py-5 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">Plan</th>
                        <th class="px-10 py-5 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">Joined</th>
                        <th class="px-10 py-5 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">Status</th>
                        <th class="px-10 py-5 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50">
                    @foreach (var tenant in Model)
                    {
                        var statusClass = tenant.Status == "Active" ? "bg-emerald-50 text-emerald-600 border-emerald-100" : "bg-slate-100 text-slate-500 border-slate-200";
                        var dotClass = tenant.Status == "Active" ? "bg-emerald-500" : "bg-slate-400";
                        var initials = string.Join("", tenant.CompanyName.Split(' ').Take(2).Select(s => s.Substring(0, 1))).ToUpper();
                    <tr class="hover:bg-slate-50 transition-all duration-300">
                        <td class="px-10 py-6">
                            <div class="flex items-center space-x-4">
                                <div class="w-10 h-10 bg-slate-100 rounded-xl flex items-center justify-center text-slate-500 font-black text-xs">
                                    @initials
                                </div>
                                <div>
                                    <p class="font-black text-slate-900 text-sm">@tenant.CompanyName</p>
                                </div>
                            </div>
                        </td>
                        <td class="px-10 py-6">
                            <span class="text-xs font-black text-slate-600 bg-slate-100 px-3 py-1 rounded-full">@tenant.PlanType</span>
                        </td>
                        <td class="px-10 py-6 text-xs text-slate-500 font-medium">@tenant.JoinedDate.ToString("MMM dd, yyyy")</td>
                        <td class="px-10 py-6">
                            <span class="inline-flex items-center space-x-1 px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest border @statusClass">
                                <span class="w-1.5 h-1.5 rounded-full @dotClass"></span>
                                <span>@tenant.Status</span>
                            </span>
                        </td>
                        <td class="px-10 py-6 text-right">
                            <div class="flex items-center justify-end space-x-2">
                                <button class="px-3 py-1.5 bg-white border border-slate-200 text-slate-600 font-bold rounded-lg text-xs hover:bg-slate-50 shadow-sm">View Details</button>
                                @if(tenant.Status == "Active") {
                                    <button class="px-3 py-1.5 bg-red-50 text-red-600 font-bold rounded-lg text-xs hover:bg-red-100 border border-red-100 transition-colors">Deactivate</button>
                                } else {
                                    <button class="px-3 py-1.5 bg-emerald-50 text-emerald-600 font-bold rounded-lg text-xs hover:bg-emerald-100 border border-emerald-100 transition-colors">Activate</button>
                                }
                            </div>
                        </td>
                    </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="px-10 py-8 text-center text-slate-400 font-bold text-xs uppercase tracking-widest">No tenants registered yet.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
