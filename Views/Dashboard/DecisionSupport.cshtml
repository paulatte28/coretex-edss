@{
    ViewData["Title"] = "Decision Support Analytics";
    Layout = "_AdminLayout";
}

<div class="space-y-10">
    <div>
        <h2 class="text-3xl font-black text-slate-900 tracking-tight">Decision Support Analytics</h2>
        <p class="text-xs text-slate-400 font-bold uppercase tracking-widest mt-2">Executive Strategy & Risk Evaluation</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <!-- Strategic Risk Scoring -->
        <div class="bg-white p-10 rounded-[3rem] shadow-sm border border-slate-100 space-y-8">
            <h3 class="font-black text-slate-800 text-xl">Strategic Risk Analysis</h3>
            
            <div class="flex items-center space-x-10 p-8 bg-slate-50 rounded-[2rem] border border-slate-100">
                <div class="relative w-32 h-32 flex items-center justify-center">
                    <svg class="w-full h-full transform -rotate-90" viewBox="0 0 36 36">
                        <circle cx="18" cy="18" r="16" fill="none" stroke="#f1f5f9" stroke-width="4"></circle>
                        <circle id="risk-circle" cx="18" cy="18" r="16" fill="none" stroke="#f59e0b" stroke-width="4" stroke-dasharray="0, 100" stroke-linecap="round" class="transition-all duration-1000"></circle>
                    </svg>
                    <div class="absolute text-center">
                        <span id="risk-score-text" class="text-3xl font-black text-slate-900">--</span>
                    </div>
                </div>
                
                <div class="space-y-2">
                    <p id="risk-level-badge" class="text-xs font-black px-3 py-1 bg-slate-200 text-slate-600 rounded-lg inline-block uppercase tracking-widest">Calculating...</p>
                    <p id="risk-explanation" class="text-xs text-slate-500 leading-relaxed font-medium">
                        Analyzing latest performance data against configured risk thresholds...
                    </p>
                </div>
            </div>

            <div class="space-y-4">
                <h4 class="text-[10px] font-black text-slate-400 uppercase tracking-widest">CORE AI Assessment</h4>
                <div id="health-assessment-box" class="p-6 bg-slate-900 text-white rounded-[2rem] space-y-3 relative overflow-hidden">
                    <div class="absolute top-0 right-0 w-24 h-24 bg-indigo-500/10 rounded-full blur-2xl"></div>
                    <p id="health-summary-text" class="text-sm font-medium leading-relaxed italic opacity-80">
                        "The current financial trajectory indicates stable growth, but expense scaling needs careful monitoring to maintain optimal profit margins."
                    </p>
                    <div class="flex items-center space-x-2">
                        <div class="w-2 h-2 bg-emerald-500 rounded-full animate-pulse"></div>
                        <span id="health-status-subtext" class="text-[9px] font-black uppercase text-indigo-300 tracking-[0.2em]">System Status: Optimal</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Branch Performance Comparison -->
        <div class="bg-white p-10 rounded-[3rem] shadow-sm border border-slate-100 space-y-8">
            <div class="flex items-center justify-between">
                <h3 class="font-black text-slate-800 text-xl">Branch Performance</h3>
                <span class="px-3 py-1 bg-indigo-50 text-indigo-600 text-[9px] font-black uppercase rounded-lg">Multi-Site Comparison</span>
            </div>

            <div class="space-y-6" id="branch-container">
                <!-- Branch 1 -->
                <div class="p-6 bg-slate-50 rounded-[2rem] border border-slate-100 flex items-center justify-between group hover:bg-white hover:shadow-xl transition-all duration-500">
                    <div class="flex items-center space-x-4">
                        <div class="w-12 h-12 bg-white rounded-2xl flex items-center justify-center text-slate-900 font-black text-xs shadow-sm ring-1 ring-slate-100">HQ</div>
                        <div>
                            <p class="text-sm font-black text-slate-900">Main Branch</p>
                            <p class="text-[10px] font-bold text-slate-400 uppercase">Primary Operations</p>
                        </div>
                    </div>
                    <div class="text-right">
                        <p id="branch-hq-val" class="text-lg font-black text-slate-900">--%</p>
                        <p class="text-[9px] font-black text-emerald-500 uppercase">Margin</p>
                    </div>
                </div>

                <!-- Branch 2 -->
                <div class="p-6 bg-slate-50 rounded-[2rem] border border-slate-100 flex items-center justify-between group hover:bg-white hover:shadow-xl transition-all duration-500">
                    <div class="flex items-center space-x-4">
                        <div class="w-12 h-12 bg-white rounded-2xl flex items-center justify-center text-slate-900 font-black text-xs shadow-sm ring-1 ring-slate-100">EST</div>
                        <div>
                            <p class="text-sm font-black text-slate-900">East Sector</p>
                            <p class="text-[10px] font-bold text-slate-400 uppercase">Regional Hub</p>
                        </div>
                    </div>
                    <div class="text-right">
                        <p id="branch-east-val" class="text-lg font-black text-slate-900">--%</p>
                        <p class="text-[9px] font-black text-amber-500 uppercase">Margin</p>
                    </div>
                </div>

                <!-- Branch 3 -->
                <div class="p-6 bg-slate-50 rounded-[2rem] border border-slate-100 flex items-center justify-between group hover:bg-white hover:shadow-xl transition-all duration-500">
                    <div class="flex items-center space-x-4">
                        <div class="w-12 h-12 bg-white rounded-2xl flex items-center justify-center text-slate-900 font-black text-xs shadow-sm ring-1 ring-slate-100">WST</div>
                        <div>
                            <p class="text-sm font-black text-slate-900">West Coast</p>
                            <p class="text-[10px] font-bold text-slate-400 uppercase">Expansion Point</p>
                        </div>
                    </div>
                    <div class="text-right">
                        <p id="branch-west-val" class="text-lg font-black text-slate-900">--%</p>
                        <p class="text-[9px] font-black text-emerald-500 uppercase">Margin</p>
                    </div>
                </div>
            </div>
            
            <p class="text-[10px] text-slate-400 font-medium italic text-center">Branch metrics are computed based on localized expense allocation.</p>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const history = JSON.parse(localStorage.getItem('coretex_monthly_data') || '[]');
            const health = localStorage.getItem('coretex_business_health') || 'B';
            const branchData = JSON.parse(localStorage.getItem('coretex_branch_latest') || '{"mainBranch": "24.5", "eastBranch": "21.2", "westBranch": "26.8"}');

            if (history.length > 0) {
                const latest = history[history.length - 1];
                
                // 1. Dynamic Risk Score Calculation
                let score = 25; 
                let explanation = "Optimal distribution. Revenue growth is outpacing expense scaling.";
                
                if (parseFloat(latest.expenseRatio) > 70) {
                    score += 35;
                    explanation = "Elevated expense ratio detected. High operational costs are compressing margins.";
                }
                if (latest.alerts && latest.alerts.length > 0) {
                    score += 25;
                    explanation = "Critical KPI breach detected. Multiple performance thresholds have been violated.";
                }

                // UI Update
                const circle = document.getElementById('risk-circle');
                const scoreText = document.getElementById('risk-score-text');
                const levelBadge = document.getElementById('risk-level-badge');
                const explanText = document.getElementById('risk-explanation');

                scoreText.innerText = score;
                circle.setAttribute('stroke-dasharray', `${score}, 100`);
                explanText.innerText = explanation;

                if (score < 40) {
                    circle.setAttribute('stroke', '#10b981');
                    levelBadge.innerText = 'Low Risk';
                    levelBadge.className = 'text-xs font-black px-3 py-1 bg-emerald-100 text-emerald-700 rounded-lg inline-block uppercase tracking-widest';
                } else if (score < 70) {
                    circle.setAttribute('stroke', '#f59e0b');
                    levelBadge.innerText = 'Moderate Risk';
                    levelBadge.className = 'text-xs font-black px-3 py-1 bg-amber-100 text-amber-700 rounded-lg inline-block uppercase tracking-widest';
                } else {
                    circle.setAttribute('stroke', '#ef4444');
                    levelBadge.innerText = 'High Risk';
                    levelBadge.className = 'text-xs font-black px-3 py-1 bg-red-100 text-red-700 rounded-lg inline-block uppercase tracking-widest';
                }

                // 2. AI Assessment
                const summaryText = document.getElementById('health-summary-text');
                const statusSub = document.getElementById('health-status-subtext');
                const healthBox = document.getElementById('health-assessment-box');

                if (health.startsWith('A')) {
                    summaryText.innerText = `"Elite financial vector. Your profit margin of ${latest.profitMargin}% is in the top 5% of your industry segment. Suggest scaling expansion."`;
                    statusSub.innerText = "System Status: Exceptional";
                    healthBox.classList.add('ring-2', 'ring-emerald-500/20');
                } else if (health.startsWith('C')) {
                    summaryText.innerText = `"Warning: Liquidity pressure detected. The current health grade of ${health} suggest immediate intervention in expense management."`;
                    statusSub.innerText = "System Status: Intervention Required";
                    statusSub.className = "text-[9px] font-black uppercase text-red-300 tracking-[0.2em]";
                    healthBox.classList.add('ring-2', 'ring-red-500/20');
                }
            }

            // 3. Branch Performance
            document.getElementById('branch-hq-val').innerText = `${branchData.mainBranch}%`;
            document.getElementById('branch-east-val').innerText = `${branchData.eastBranch}%`;
            document.getElementById('branch-west-val').innerText = `${branchData.westBranch}%`;
        });
    </script>
}
