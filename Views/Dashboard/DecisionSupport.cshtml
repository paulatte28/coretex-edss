@{
    ViewData["Title"] = "Decision Support Analytics";
    Layout = "_AdminLayout";
}

<div class="space-y-10">
    <div>
        <h2 class="text-3xl font-black text-slate-900 tracking-tight">Decision Support Analytics</h2>
        <p class="text-xs text-slate-400 font-bold uppercase tracking-widest mt-2">What-if Scenarios & Risk Evaluation</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <!-- What-If Scenario Builder -->
        <div class="bg-white p-8 rounded-[2.5rem] shadow-sm border border-slate-100 flex flex-col">
            <div class="mb-8 border-b border-slate-100 pb-4">
                <h3 class="font-black text-slate-800 text-xl font-sans">Scenario Engine</h3>
                <p class="text-xs text-slate-500 font-medium">Adjust parameters to see forecasted impact</p>
            </div>

            <div class="space-y-6 flex-1">
                <div>
                    <label class="flex justify-between text-xs font-bold text-slate-600 uppercase tracking-widest mb-3">
                        <span>Price Adjustment</span>
                        <span class="text-secondary font-black">+5.0%</span>
                    </label>
                    <input type="range" class="w-full h-2 bg-slate-100 rounded-lg appearance-none cursor-pointer accent-secondary" value="5" min="-20" max="20">
                </div>

                <div>
                    <label class="flex justify-between text-xs font-bold text-slate-600 uppercase tracking-widest mb-3">
                        <span>Marketing Spend (Monthly)</span>
                        <span class="text-secondary font-black">$12,500</span>
                    </label>
                    <input type="range" class="w-full h-2 bg-slate-100 rounded-lg appearance-none cursor-pointer accent-secondary" value="12500" min="5000" max="50000" step="500">
                </div>

                <div>
                    <label class="flex justify-between text-xs font-bold text-slate-600 uppercase tracking-widest mb-3">
                        <span>Supplier Cost Increase</span>
                        <span class="text-red-500 font-black">+2.0%</span>
                    </label>
                    <input type="range" class="w-full h-2 bg-slate-100 rounded-lg appearance-none cursor-pointer accent-red-500" value="2" min="0" max="15">
                </div>
            </div>

            <div class="mt-8 pt-6 border-t border-slate-100">
                <button class="w-full py-4 bg-primary text-white font-bold rounded-2xl hover:bg-blue-900 transition-colors shadow-lg shadow-blue-900/30">
                    Run Simulation
                </button>
            </div>
        </div>

        <!-- Simulation Results / Risk Score -->
        <div class="space-y-8">
            <div class="bg-gradient-to-br from-slate-900 to-[#1e293b] p-8 rounded-[2.5rem] shadow-xl text-white relative overflow-hidden">
                <div class="absolute top-0 right-0 w-48 h-48 bg-emerald-400/10 rounded-full blur-3xl"></div>
                
                <h3 class="font-black text-slate-100 text-lg relative z-10">Projected Outcomes</h3>
                <p class="text-[10px] text-slate-400 font-bold uppercase tracking-[0.2em] mb-6 relative z-10">Based on Scenario Engine</p>

                <div class="grid grid-cols-2 gap-4 relative z-10">
                    <div class="bg-white/5 border border-white/10 p-5 rounded-2xl backdrop-blur-sm">
                        <p class="text-[10px] text-slate-400 uppercase font-bold tracking-widest">Est. Revenue Shift</p>
                        <p class="text-2xl font-black mt-1 text-emerald-400">+$18,450</p>
                    </div>
                    <div class="bg-white/5 border border-white/10 p-5 rounded-2xl backdrop-blur-sm">
                        <p class="text-[10px] text-slate-400 uppercase font-bold tracking-widest">Margin Impact</p>
                        <p class="text-2xl font-black mt-1 text-red-400">-1.2%</p>
                    </div>
                </div>
            </div>

            <div class="bg-white p-8 rounded-[2.5rem] shadow-sm border border-slate-100">
                <h3 class="font-black text-slate-800 text-lg mb-4">Strategic Risk Scoring</h3>
                
                <div class="flex items-center space-x-6">
                    <div class="relative w-24 h-24 flex items-center justify-center">
                        <svg class="w-full h-full transform -rotate-90" viewBox="0 0 36 36">
                            <path class="text-slate-100" stroke-width="4" stroke="currentColor" fill="none" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                            <path class="text-amber-500" stroke-dasharray="65, 100" stroke-width="4" stroke-linecap="round" stroke="currentColor" fill="none" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                        </svg>
                        <div class="absolute text-center">
                            <span class="text-2xl font-black text-slate-800">65</span>
                        </div>
                    </div>
                    
                    <div>
                        <p class="text-sm font-bold text-amber-600 bg-amber-50 px-3 py-1 rounded-lg inline-block mb-2">Moderate Risk</p>
                        <p class="text-xs text-slate-500 leading-relaxed font-medium">
                            Price sensitivity among the target demographic might offset revenue gains. We recommend a phased price rollout.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
